{
  "App": {
    "BaseUrl": "https://studiob2b.ru"
  },
  "ConnectionStrings": {
    "MasterDb": ""
  },
  "MultiTenancy": {
    "MasterDomain": "studiob2b.ru",
    "TenantDbConnectionTemplate": ""
  },
  "Ozon": {
    "BaseAddress": "https://api-seller.ozon.ru/",
    "TimeoutSeconds": 30
  },
  "Encryption": {
    "Key": "REPLACE_WITH_BASE64_32_BYTE_KEY_HERE"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_AT_LEAST_32_CHAR_SECRET_KEY_HERE",
    "Issuer": "StudioB2B",
    "Audience": "StudioB2B",
    "ExpiresMinutes": 1440
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "StudioB2B.Infrastructure": "Debug",
        "StudioB2B.Web": "Debug",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341",
          "apiKey": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "Modules": {
    "Manufacturers": {
      "SqlDumpPath": "dumps/manufacturers.sql"
    }
  },

  "Backup": {
    "Endpoint": "minio:9000",
    "PublicEndpoint": "",
    "Bucket": "backups",
    "AccessKey": "REMOVED_MINIO_CRED",
    "SecretKey": "REMOVED_MINIO_CRED",
    "UseSSL": false,
    "DefaultRetentionDays": 30,
    "MysqldumpPath": "mysqldump",
    "MysqlPath": "mysql"
  },

  "TenantSeeds": {
    "interparts": {
      "MarketplaceClients": [
        { "ApiId": "482702", "Key": "REMOVED_OZON_KEY", "Name": "Interparts 482702" },
        { "ApiId": "1478853", "Key": "REMOVED_OZON_KEY", "Name": "Interparts 1478853" },
        { "ApiId": "1500963", "Key": "REMOVED_OZON_KEY", "Name": "Interparts 1500963" },
        { "ApiId": "370459", "Key": "REMOVED_OZON_KEY", "Name": "Interparts 370459" },
        { "ApiId": "1303860", "Key": "REMOVED_OZON_KEY", "Name": "Interparts 1303860" }
      ]
    }
  },

  "AllowedHosts": "*"
}
