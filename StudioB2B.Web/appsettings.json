{
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "MasterDb": ""
  },
  "MultiTenancy": {
    "MasterDomain": "",
    "TenantDbConnectionTemplate": "",
    "ReservedSubdomains": ["app", "www", "api", "admin", "master", "chat", "matrix", "seq", "dimension", "minio"]
  },
  "Ozon": {
    "BaseAddress": "https://api-seller.ozon.ru/",
    "TimeoutSeconds": 30
  },
  "Encryption": {
    "Key": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "",
    "Audience": "",
    "ExpiresMinutes": 1440
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "StudioB2B.Infrastructure": "Debug",
        "StudioB2B.Web": "Debug",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341",
          "apiKey": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Modules": {
    "Manufacturers": {
      "SqlDumpPath": "dumps/manufacturers.sql"
    }
  },
  "Backup": {
    "Endpoint": "",
    "PublicEndpoint": "",
    "Bucket": "",
    "AccessKey": "",
    "SecretKey": "",
    "UseSSL": false,
    "DefaultRetentionDays": 30,
    "MysqldumpPath": "",
    "MysqlPath": ""
  },
  "TenantSeeds": {},
  "Email": {
    "Host": "",
    "Port": 587,
    "User": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "",
    "EnableSsl": true
  }
}
