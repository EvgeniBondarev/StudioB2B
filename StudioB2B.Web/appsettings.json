{
  "ConnectionStrings": {
    "MasterDb": ""
  },
  "MultiTenancy": {
    "MasterDomain": "studiob2b.ru",
    "TenantDbConnectionTemplate": ""
  },
  "Ozon": {
    "BaseAddress": "https://api-seller.ozon.ru/",
    "TimeoutSeconds": 30
  },
  "Encryption": {
    "Key": "REPLACE_WITH_BASE64_32_BYTE_KEY_HERE"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_AT_LEAST_32_CHAR_SECRET_KEY_HERE",
    "Issuer": "StudioB2B",
    "Audience": "StudioB2B",
    "ExpiresMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "StudioB2B.Infrastructure": "Debug",
        "StudioB2B.Web": "Debug",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "Modules": {
    "Manufacturers": {
      "SqlDumpPath": "dumps/manufacturers.sql"
    }
  },

  "AllowedHosts": "*"
}
