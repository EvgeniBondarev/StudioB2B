{
  "ConnectionStrings": {
    "MasterDb": "Server=localhost;Database=StudioB2B_Master_Dev;User=root;Password=root;Allow User Variables=true;AllowPublicKeyRetrieval=True;"
  },
  "MultiTenancy": {
