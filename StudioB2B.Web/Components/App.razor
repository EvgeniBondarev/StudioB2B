<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="_content/Radzen.Blazor/css/material.css" rel="stylesheet" />
    <link href="_content/Radzen.Blazor/css/icon.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet/>
    <title>StudioB2B</title>
</head>

<body>
<!-- Показывается пока Blazor не установил SignalR-соединение (prerender отключён).
     Скрывается в Blazor.start().then(...) ниже. -->
<div id="app-initial-loading">
    <div class="app-initial-spinner"></div>
    <p class="app-initial-text">Загрузка...</p>
</div>

<Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))"/>

<div id="components-reconnect-modal" class="components-reconnect-hide">
    <div class="components-reconnect-dialog">
        <div class="components-rejoining-animation"><div></div><div></div></div>
        <p class="reconnect-message">Переподключение к серверу...</p>
        <button class="reconnect-retry" onclick="window.Blazor.reconnect()">Переподключить</button>
        <p class="reconnect-failed" style="display:none;">Не удалось подключиться к серверу. Перезагрузите страницу.</p>
        <button class="reconnect-reload" style="display:none;" onclick="location.reload()">Перезагрузить</button>
    </div>
</div>

<script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
<script>
    Blazor.start().then(() => {
        // Скрываем стартовый оверлей — Blazor подключился
        const loading = document.getElementById('app-initial-loading');
        if (loading) loading.style.display = 'none';

        const modal = document.getElementById('components-reconnect-modal');
        if (!modal) return;
        const msg = modal.querySelector('.reconnect-message');
        const retryBtn = modal.querySelector('.reconnect-retry');
        const failedMsg = modal.querySelector('.reconnect-failed');
        const reloadBtn = modal.querySelector('.reconnect-reload');
        const anim = modal.querySelector('.components-rejoining-animation');

        Blazor.addEventListener('enhancedload', () => {
            modal.classList.add('components-reconnect-hide');
        });

        const observer = new MutationObserver(() => {
            if (modal.classList.contains('components-reconnect-show')) {
                msg.textContent = 'Переподключение к серверу...';
                msg.style.display = '';
                anim.style.display = 'flex';
                retryBtn.style.display = '';
                failedMsg.style.display = 'none';
                reloadBtn.style.display = 'none';
            } else if (modal.classList.contains('components-reconnect-failed')) {
                msg.style.display = 'none';
                anim.style.display = 'none';
                retryBtn.style.display = 'none';
                failedMsg.style.display = '';
                reloadBtn.style.display = '';
            } else if (modal.classList.contains('components-reconnect-rejected')) {
                msg.style.display = 'none';
                anim.style.display = 'none';
                retryBtn.style.display = 'none';
                failedMsg.textContent = 'Соединение потеряно. Перезагрузите страницу.';
                failedMsg.style.display = '';
                reloadBtn.style.display = '';
            }
        });
        observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
    });
</script>
<script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
<script src="copy.js"></script>
<script src="transactionCanvas.js"></script>
<script>
    window.moveFormulaAnchor = function (x, y) {
        var el = document.getElementById('formula-anchor');
        if (el) { el.style.left = x + 'px'; el.style.top = y + 'px'; }
    };
</script>
<script>
    window.__registerChatEscape = function (dotNetRef) {
        if (window.__chatEscapeHandler) {
            document.removeEventListener('keydown', window.__chatEscapeHandler);
        }
        window.__chatEscapeHandler = function (e) {
            if (e.key === 'Escape') {
                dotNetRef.invokeMethodAsync('HandleKeyEscape');
            }
        };
        document.addEventListener('keydown', window.__chatEscapeHandler);
    };
</script>
</body>

</html>
