@inherits LayoutComponentBase
@using System.Text.Json
@using StudioB2B.Infrastructure.Interfaces
@inject ITenantProvider TenantProvider
@inject NavigationManager Navigation
@inject TabService TabService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime
@implements IDisposable

<RadzenLayout Style="min-height: 100vh;">

    <!--
        Sidebar width is controlled manually via Style.
        @bind-Expanded is intentionally omitted — Radzen collapses it to width:0 when Expanded=false,
        which hides icons too. Instead we use CSS class .sidebar-compact to show icon-only mode.
    -->
    <RadzenSidebar Style="@(_sidebarExpanded ? "width: 220px;" : "width: 64px; overflow: hidden;")">
        <div class="sidebar-inner @(_sidebarExpanded ? "" : "sidebar-compact")">

            <div class="sidebar-logo">
                <RadzenIcon Icon="business_center"
                            Style="color: var(--rz-primary-light); font-size: 1.4rem; flex-shrink: 0;" />

                @if (_sidebarExpanded)
                {
                    <RadzenText Text="StudioB2B"
                                TextStyle="TextStyle.H6"
                                Style="color: var(--rz-primary-light); margin:0; font-weight:700;" />
                }
            </div>

            <RadzenPanelMenu>
                <RadzenPanelMenuItem Text="Главная" Path="/" Icon="home" />

                @if (TenantProvider.IsResolved)
                {
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <RadzenPanelMenuItem Text="Пользователи" Path="/users" Icon="people" />
                            <RadzenPanelMenuItem Text="Маркетплейс" Path="/marketplace-clients" Icon="store" />
                            <RadzenPanelMenuItem Text="Заказы" Path="/orders" Icon="receipt_long" />
                            <RadzenPanelMenuItem Text="Загрузка" Path="/orders-sync" Icon="cloud_sync" />
                            <RadzenPanelMenuItem Text="Статусы" Path="/order-statuses" Icon="label" />
                            <RadzenPanelMenuItem Text="Типы цен" Path="/price-types" Icon="payments" />
                            <RadzenPanelMenuItem Text="Документы" Path="/transactions" Icon="swap_horiz" />
                            <RadzenPanelMenuItem Text="История проведений" Path="/transactions-history" Icon="schedule" />
                            <RadzenPanelMenuItem Text="Расчёты" Path="/calculation-rules" Icon="calculate" />
                            <RadzenPanelMenuItem Text="Чаты" Path="/chats" Icon="chat" />
                            <RadzenPanelMenuItem Text="Журнал" Path="/audit" Icon="history" />
                        </Authorized>
                    </AuthorizeView>

                    <RadzenPanelMenuItem Text="@TenantProvider.Subdomain" Icon="apartment" Disabled="true" />
                }
                else if (_masterAuthenticated)
                {
                    <RadzenPanelMenuItem Text="Роли" Path="/roles" Icon="security" />
                }
            </RadzenPanelMenu>

        </div>
    </RadzenSidebar>

    <RadzenHeader Style="padding: 0;  background: var(--rz-primary-light); border-bottom: 1px solid var(--rz-border-color);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Style="height: 56px; padding: 0 1rem; width: 100%;">

            <!-- Кнопка-бургер для сворачивания/разворачивания панели -->
            <RadzenButton Icon="menu" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                          Size="ButtonSize.Medium" Click="ToggleSidebar" />

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <AuthorizeView>
                    <Authorized>
                        <!-- Имя пользователя — того же цвета, что и кнопка "Выйти" -->
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Style="color: var(--rz-base-light); margin: 0; font-weight: 500;">
                            @context.User.Identity?.Name
                        </RadzenText>
                        <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                      Variant="Variant.Text" Size="ButtonSize.Small"
                                      Click="@(() => Navigation.NavigateTo("/account/logout", forceLoad: true))" />
                    </Authorized>
                </AuthorizeView>
            </RadzenStack>

        </RadzenStack>
    </RadzenHeader>

    <RadzenBody>
        <AppTabBar />
        @if (_isFullHeight)
        {
            <div class="body-full-height" style="padding: 1rem 1.5rem;">
                @Body
            </div>
        }
        else
        {
            <div style="padding: 1rem 1.5rem;">
                @Body
            </div>
        }
    </RadzenBody>

</RadzenLayout>

<RadzenNotification />
<RadzenDialog />
<RadzenContextMenu />

@code {
    private bool _sidebarExpanded = true;
    private bool _masterAuthenticated;
    private const string TabsStorageKey = "app-tabs";

    // Страницы где контент занимает весь экран без padding
    private static readonly HashSet<string> FullHeightPages = ["/chats"];

    private bool _isFullHeight =>
        FullHeightPages.Contains(new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant());

    protected override void OnInitialized()
    {
        TabService.TabsChanged += OnTabsChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _masterAuthenticated = await AuthStateProvider.IsMasterAuthenticatedAsync();
            await LoadTabsFromStorageAsync();
            OpenCurrentTab();
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        OpenCurrentTab();
    }

    private void OpenCurrentTab()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath;
        if (string.IsNullOrEmpty(path)) path = "/";
        TabService.EnsureOpen(path);
        // Fire-and-forget save
        _ = SaveTabsToStorageAsync();
    }

    private void OnTabsChanged()
    {
        _ = SaveTabsToStorageAsync();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadTabsFromStorageAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", TabsStorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                var entries = JsonSerializer.Deserialize<List<TabEntry>>(json);
                if (entries is { Count: > 0 })
                    TabService.Restore(entries);
            }
        }
        catch
        {
            // Ignore storage errors
        }
    }

    private async Task SaveTabsToStorageAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(TabService.Tabs.ToList());
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", TabsStorageKey, json);
        }
        catch
        {
            // Ignore storage errors
        }
    }

    private void ToggleSidebar() => _sidebarExpanded = !_sidebarExpanded;

    public void Dispose()
    {
        TabService.TabsChanged -= OnTabsChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
