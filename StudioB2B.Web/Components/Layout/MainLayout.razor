@inherits LayoutComponentBase
@using System.Text.Json
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@inject ITenantProvider TenantProvider
@inject NavigationManager Navigation
@inject TabService TabService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject MasterAuthStateService MasterAuthState
@inject IJSRuntime JsRuntime
@inject UserContext UserContext
@inject NavService NavService

@implements IDisposable

<RadzenLayout Style="min-height: 100vh;">

    <RadzenSidebar Style="@(_sidebarExpanded ? "width: 220px;" : "width: 0;")" class="sidebar-animated">
        <div class="sidebar-inner">

            <div class="sidebar-logo">
                <RadzenIcon Icon="business_center"
                            Style="color: var(--rz-primary-light); font-size: 1.4rem; flex-shrink: 0;" />

                <RadzenText Text="StudioB2B"
                            TextStyle="TextStyle.H6"
                            Style="color: var(--rz-primary-light); margin:0; font-weight:700;" />
            </div>


           <RadzenPanelMenu>
    @if (TenantProvider.IsResolved)
    {
        @foreach (var group in NavService.Groups)
        {
            @* Если в группе только 1 элемент *@
            @if (group.Items.Count == 1)
            {
                var item = group.Items.First();

                if (string.IsNullOrEmpty(item.Role))
                {
                    <RadzenPanelMenuItem Text="@group.Title"
                                         Path="@item.Path"
                                         Icon="@group.Icon" />

                }
                else
                {
                    <AuthorizeView Roles="@item.Role">
                        <Authorized>
                            <RadzenPanelMenuItem Text="@group.Title"
                                                 Path="@item.Path"
                                                 Icon="@group.Icon" />
                        </Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="CalculationRulesView">
                        <Authorized><RadzenPanelMenuItem Text="Расчёты" Path="/calculation-rules" Icon="calculate" /></Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="ChatsView">
                        <Authorized><RadzenPanelMenuItem Text="Коммуникации" Path="/communication" Icon="communication" /></Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="AuditView">
                        <Authorized><RadzenPanelMenuItem Text="Журнал" Path="/audit" Icon="history" /></Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="ModulesView">
                        <Authorized><RadzenPanelMenuItem Text="Модули" Path="/modules" Icon="extension" /></Authorized>
                    </AuthorizeView>
                    <AuthorizeView Roles="PermissionsView">
                        <Authorized><RadzenPanelMenuItem Text="Права доступа" Path="/permissions" Icon="shield" /></Authorized>
                    </AuthorizeView>

                    <RadzenPanelMenuItem Text="@TenantProvider.Subdomain" Icon="apartment" Disabled="true" />                }
            }
            else
            {
                @* Группа с подпунктами *@
                <RadzenPanelMenuItem Text="@group.Title" Icon="@group.Icon">
                    @foreach (var item in group.Items)
                    {
                        if (string.IsNullOrEmpty(item.Role))
                        {
                            <RadzenPanelMenuItem Text="@TabService.KnownPages[item.Path].Title"
                                                 Path="@item.Path"
                                                 Icon="@TabService.KnownPages[item.Path].Icon" />
                        }
                        else
                        {
                            <AuthorizeView Roles="@item.Role">
                                <Authorized>
                                    <RadzenPanelMenuItem Text="@TabService.KnownPages[item.Path].Title"
                                                         Path="@item.Path"
                                                         Icon="@TabService.KnownPages[item.Path].Icon" />
                                </Authorized>
                            </AuthorizeView>
                        }
                    }
                </RadzenPanelMenuItem>
            }
        }

        <RadzenPanelMenuItem Text="@TenantProvider.Subdomain" Icon="apartment" Disabled="true" />
    }
    else if (MasterAuthState.IsAuthenticated)
    {
        <RadzenPanelMenuItem Text="Рабочие пространства" Path="/my-tenants" Icon="domain" />
        @if (MasterAuthState.UserInfo?.IsAdmin == true)
        {
            <RadzenPanelMenuItem Text="Пользователи" Path="/master-users" Icon="manage_accounts" />
        }
    }
</RadzenPanelMenu>

        </div>
    </RadzenSidebar>

    <RadzenHeader Style="padding: 0; background: var(--rz-primary-light); border-bottom: 1px solid var(--rz-border-color);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Style="height: 56px; padding: 0 1rem; width: 100%;">

            <!-- Кнопка-бургер для сворачивания/разворачивания панели -->
            <RadzenButton Icon="menu" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                          Size="ButtonSize.Medium" Click="ToggleSidebar" />

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <AuthorizeView>
                    <Authorized>
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Style="color: var(--rz-base-light); margin: 0; font-weight: 500;">
                            @context.User.Identity?.Name
                        </RadzenText>
                        <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                      Variant="Variant.Text" Size="ButtonSize.Small"
                                      Click="HandleTenantLogout" />
                    </Authorized>
                </AuthorizeView>
                @if (MasterAuthState.IsAuthenticated && !TenantProvider.IsResolved)
                {
                    @if (MasterAuthState.UserInfo is not null)
                    {
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Style="color: var(--rz-base-light); margin: 0; font-weight: 500;">
                            @MasterAuthState.UserInfo.LastName @MasterAuthState.UserInfo.FirstName
                        </RadzenText>
                    }
                    <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Text" Size="ButtonSize.Small"
                                  Click="HandleMasterLogout" />
                }
            </RadzenStack>

        </RadzenStack>
    </RadzenHeader>

    <RadzenBody>
        <AppTabBar />
        @if (_isFullHeight)
        {
            <div class="body-full-height @(!_sidebarExpanded ? "sidebar-hidden" : "")" style="@BodyPadding">
                @Body
            </div>
        }
        else
        {
            <div class="body-content @(!_sidebarExpanded ? "sidebar-hidden" : "")" style="@BodyPadding">
                @Body
            </div>
        }
    </RadzenBody>
</RadzenLayout>

<RadzenNotification />
<RadzenDialog />
<RadzenContextMenu />

@code {
    private bool _sidebarExpanded = true;
    private const string TabsStorageKey = "app-tabs";
    private const string SidebarStorageKey = "sidebar-expanded";

    private string BodyPadding => _sidebarExpanded
        ? "padding: 1rem 1.5rem;"
        : "padding: 0.5rem 0;";

    private static readonly HashSet<string> FullHeightPages = ["/chats", "/questions"];

    private bool _isFullHeight => FullHeightPages.Contains(new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant());

    protected override void OnInitialized()
    {
        TabService.TabsChanged += OnTabsChanged;
        Navigation.LocationChanged += OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        MasterAuthState.OnChanged += OnMasterAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Инициализируем состояние из localStorage при первом рендере
            var isAuth = await AuthStateProvider.IsMasterAuthenticatedAsync();
            if (isAuth)
            {
                var userInfo = await AuthStateProvider.GetMasterUserInfoAsync();
                MasterAuthState.Set(true, userInfo);
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            UserContext.SetUser(authState.User);
            await LoadSidebarStateAsync();
            await LoadTabsFromStorageAsync();
            OpenCurrentTab();
            StateHasChanged();
        }
    }

    private void OnMasterAuthChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        _ = task.ContinueWith(t =>
        {
            if (t.IsCompletedSuccessfully)
                UserContext.SetUser(t.Result.User);
        }, TaskScheduler.Default);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        OpenCurrentTab();
    }

    private void OpenCurrentTab()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath;
        if (string.IsNullOrEmpty(path)) path = "/";
        TabService.EnsureOpen(path);
        _ = SaveTabsToStorageAsync();
    }

    private void OnTabsChanged()
    {
        _ = SaveTabsToStorageAsync();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadTabsFromStorageAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", TabsStorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                var entries = JsonSerializer.Deserialize<List<TabEntry>>(json);
                if (entries is { Count: > 0 })
                    TabService.Restore(entries);
            }
        }
        catch { }
    }

    private async Task SaveTabsToStorageAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(TabService.Tabs.ToList());
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", TabsStorageKey, json);
        }
        catch { }
    }

    private void ToggleSidebar()
    {
        _sidebarExpanded = !_sidebarExpanded;
        _ = SaveSidebarStateAsync();
    }

    private async Task LoadSidebarStateAsync()
    {
        try
        {
            var val = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", SidebarStorageKey);
            if (val is not null)
                _sidebarExpanded = val == "true";
        }
        catch { }
    }

    private async Task SaveSidebarStateAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", SidebarStorageKey, _sidebarExpanded ? "true" : "false");
        }
        catch { }
    }

    private async Task HandleTenantLogout()
    {
        await AuthStateProvider.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private async Task HandleMasterLogout()
    {
        await AuthStateProvider.MasterLogoutAsync();
        MasterAuthState.Clear();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        TabService.TabsChanged -= OnTabsChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        MasterAuthState.OnChanged -= OnMasterAuthChanged;
    }
}
