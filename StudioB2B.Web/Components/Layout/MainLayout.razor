@inherits LayoutComponentBase
@using StudioB2B.Application.Common.Interfaces
@inject ITenantProvider TenantProvider
@inject IJSRuntime Js
@implements IDisposable

<MudThemeProvider @ref="_mud" Theme="_isDark ? AppTheme.Dark : AppTheme.Light" IsDarkMode="_isDark" DefaultScrollbar="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6" Style="font-weight:700; letter-spacing:-0.5px;">
            StudioB2B
        </MudText>

        <MudSpacer />

        @if (TenantProvider.IsResolved)
        {
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <MudButton Href="/users" StartIcon="@Icons.Material.Outlined.People"
                               Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small" Class="mr-1">
                        Пользователи
                    </MudButton>
                </Authorized>
            </AuthorizeView>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mr-1">
                @TenantProvider.Subdomain
            </MudChip>
        }
        else
        {
            <MudButton Href="/roles" StartIcon="@Icons.Material.Outlined.ManageAccounts"
                       Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small" Class="mr-1">
                Роли
            </MudButton>
        }

        <MudIconButton
            Icon="@(_isDark ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
            Color="Color.Inherit"
            Size="Size.Small"
            Title="Переключить тему"
            OnClick="ToggleTheme" />

        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="ml-2 mr-1">@context.User.Identity?.Name</MudText>
                <MudIconButton Icon="@Icons.Material.Outlined.Logout" Color="Color.Inherit" Size="Size.Small" Href="/account/logout" Title="Выйти" />
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _mud = null!;
    private bool _isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var prefersAttr = await Js.InvokeAsync<string?>(
                "eval", "document.documentElement.getAttribute('data-prefers-dark')");

            if (prefersAttr == "1")
            {
                _isDark = true;
            }
            else
            {
                var stored = await Js.InvokeAsync<string?>("localStorage.getItem", "theme");
                _isDark = stored == "dark" || (stored == null && await _mud.GetSystemPreference());
            }

            await Js.InvokeVoidAsync(
                "eval", "document.body.classList.remove('theme-unresolved')");

            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await Js.InvokeVoidAsync("localStorage.setItem", "theme", _isDark ? "dark" : "light");
        await Js.InvokeVoidAsync(
            "eval",
            _isDark
                ? "document.documentElement.setAttribute('data-prefers-dark','1')"
                : "document.documentElement.removeAttribute('data-prefers-dark')");
    }

    public void Dispose() { }
}
