@inherits LayoutComponentBase
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject ITenantProvider TenantProvider
@inject NavigationManager Navigation
@inject PageRegistry PageRegistry
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject MasterAuthStateService MasterAuthState
@inject UserContext UserContext
@inject NavService NavService
@inject NotificationService NotificationService
@inject TaskBoardStateService BoardState

@implements IDisposable
@implements IAsyncDisposable

<div class="app-shell">
    <nav class="icon-rail">
        <div class="rail-brand">
            <i class="notranslate rzi" style="font-size:1.3rem;color:var(--rz-primary);">business_center</i>
        </div>

        <div class="rail-items">
            @if (TenantProvider.IsResolved)
            {
                @foreach (var group in NavService.Groups)
                {
                    var idx = NavService.Groups.IndexOf(group);
                    var firstPath = group.Items.FirstOrDefault()?.Path ?? "/";
                    var isGroupActive = IsGroupActive(group);

                    @if (group.Items.Count == 1)
                    {
                        var item = group.Items[0];
                        @if (string.IsNullOrEmpty(item.Role))
                        {
                            <div class="rail-item @(isGroupActive ? "active" : "")"
                                 @onclick="@(() => NavigateDirect(item.Path))" title="@group.Title">
                                <i class="notranslate rzi">@group.Icon</i>
                            </div>
                        }
                        else
                        {
                            <AuthorizeView Roles="@item.Role">
                                <Authorized>
                                    <div class="rail-item @(isGroupActive ? "active" : "")"
                                         @onclick="@(() => NavigateDirect(item.Path))" title="@group.Title">
                                        <i class="notranslate rzi">@group.Icon</i>
                                    </div>
                                </Authorized>
                            </AuthorizeView>
                        }
                    }
                    else
                    {
                        <div class="rail-group">
                            <div class="rail-item @(isGroupActive ? "active" : "")"
                                 @onclick="@(() => NavigateDirect(firstPath))" title="@group.Title">
                                <i class="notranslate rzi">@group.Icon</i>

                            </div>
                            <div class="rail-flyout" style="top: @(GetFlyoutTop(group))px;">
                                <div class="rail-flyout-title">@group.Title</div>
                                @foreach (var item in group.Items)
                                {
                                    var info = PageRegistry.Get(item.Path);
                                    var isItemActive = IsPathActive(item.Path);
                                    @if (string.IsNullOrEmpty(item.Role))
                                    {
                                        <div class="rail-flyout-item @(isItemActive ? "active" : "")"
                                             @onclick="@(() => NavigateFromFlyout(item.Path))">
                                            <i class="notranslate rzi">@info.Icon</i>
                                            <span>@info.Title</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <AuthorizeView Roles="@item.Role">
                                            <Authorized>
                                                <div class="rail-flyout-item @(isItemActive ? "active" : "")"
                                                     @onclick="@(() => NavigateFromFlyout(item.Path))">
                                                    <i class="notranslate rzi">@info.Icon</i>
                                                    <span>@info.Title</span>
                                                </div>
                                            </Authorized>
                                        </AuthorizeView>
                                    }
                                }
                            </div>
                        </div>
                    }
                }
            }
            else if (MasterAuthState.IsAuthenticated)
            {
                <div class="rail-item @(IsPathActive("/my-tenants") ? "active" : "")"
                     @onclick="@(() => NavigateDirect("/my-tenants"))" title="Рабочие пространства">
                    <i class="notranslate rzi">domain</i>
                    <span class="rail-label">Пространства</span>
                </div>
                @if (MasterAuthState.UserInfo?.IsAdmin == true)
                {
                    <div class="rail-item @(IsPathActive("/master-users") ? "active" : "")"
                         @onclick="@(() => NavigateDirect("/master-users"))" title="Пользователи">
                        <i class="notranslate rzi">manage_accounts</i>
                        <span class="rail-label">Пользователи</span>
                    </div>
                }
            }
        </div>

        @if (TenantProvider.IsResolved)
        {
            <div class="rail-tenant" title="@TenantProvider.Subdomain">
                <i class="notranslate rzi">apartment</i>
            </div>
        }
    </nav>

    <div class="app-main">
        <!-- Slim header -->
        <header class="app-header">
            <div class="app-header-left">
                <i class="notranslate rzi" style="font-size:1rem;color:var(--rz-text-secondary-color);">@_pageIcon</i>
                <span class="app-header-title">@_pageTitle</span>
            </div>
            <div class="app-header-right">
                <AuthorizeView>
                    <Authorized>
                        <span class="app-header-user">@context.User.Identity?.Name</span>
                        <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                      Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                      Click="HandleTenantLogout" />
                    </Authorized>
                </AuthorizeView>
                @if (MasterAuthState.IsAuthenticated && !TenantProvider.IsResolved)
                {
                    @if (MasterAuthState.UserInfo is not null)
                    {
                        <span class="app-header-user">
                            @MasterAuthState.UserInfo.LastName @MasterAuthState.UserInfo.FirstName
                        </span>
                    }
                    <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                  Click="HandleMasterLogout" />
                }
            </div>
        </header>

        <!-- Body -->
        @if (_isFullHeight)
        {
            <div class="body-full-height">
                @Body
            </div>
        }
        else
        {
            <div class="body-content" style="padding: 1rem 1.5rem;">
                @Body
            </div>
        }
    </div>
</div>

<RadzenNotification />
<RadzenDialog />
<RadzenContextMenu />

@code {
    private string _pageTitle = "StudioB2B";
    private string _pageIcon = "home";
    private HubConnection? _ozonPushHub;

    private static readonly HashSet<string> FullHeightPages = ["/chats", "/questions", "/communication"];

    private bool _isFullHeight => FullHeightPages.Contains(
        new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant());

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        MasterAuthState.OnChanged += OnMasterAuthChanged;
        UpdatePageInfo();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var isAuth = await AuthStateProvider.IsMasterAuthenticatedAsync();
            if (isAuth)
            {
                var userInfo = await AuthStateProvider.GetMasterUserInfoAsync();
                MasterAuthState.Set(true, userInfo);
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            UserContext.SetUser(authState.User);
            StateHasChanged();

            if (TenantProvider.IsResolved && TenantProvider.TenantId.HasValue)
                await ConnectOzonPushHubAsync(TenantProvider.TenantId.Value);
        }
    }

    private async Task ConnectOzonPushHubAsync(Guid tenantId)
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        _ozonPushHub = new HubConnectionBuilder()
            .WithUrl($"{baseUri}/hubs/ozon-push")
            .WithAutomaticReconnect()
            .Build();

        _ozonPushHub.On<OzonPushNotificationDto>("OzonPush", notification =>
        {
            var label = GetMessageTypeLabel(notification.MessageType);
            var isChatType = OzonPushMessageType.ChatTypes.Contains(notification.MessageType);

            string detail;
            if (isChatType && !string.IsNullOrWhiteSpace(notification.MessageText))
                detail = notification.MessageText;
            else if (isChatType)
                detail = notification.MarketplaceClientName ?? $"Seller {notification.SellerId}";
            else if (notification.PostingNumber is not null)
                detail = notification.PostingNumber;
            else
                detail = notification.MarketplaceClientName ?? $"Seller {notification.SellerId}";

            var msg = new NotificationMessage
            {
                Severity = NotificationSeverity.Info,
                Summary = $"Ozon: {label}",
                Detail = isChatType ? $"{detail} — нажмите, чтобы открыть" : detail,
                Duration = 8000
            };

            if (isChatType && !string.IsNullOrWhiteSpace(notification.ChatId))
            {
                var chatId = notification.ChatId;
                var clientId = notification.MarketplaceClientId;
                msg.Click = _ => InvokeAsync(() => OpenChatInBoard(chatId, clientId));
            }

            NotificationService.Notify(msg);
            InvokeAsync(StateHasChanged);
        });

        await _ozonPushHub.StartAsync();
        await _ozonPushHub.InvokeAsync("JoinTenantGroup", tenantId.ToString());
    }

    private void OpenChatInBoard(string chatId, Guid? clientId)
    {
        // Store the pending chat even when clientId is null — the board will search by chatId alone.
        BoardState.RequestChatOpen(chatId, clientId);

        // Only navigate if not already on /communication.
        // Same-page NavigateTo can cause the board to be recreated, which loses the
        // pending-chat data race between the old component's InvokeAsync and the new
        // component's OnInitializedAsync. When already on the page, the event alone
        // (PendingChatOpenChanged) is sufficient to open the chat.
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        if (!currentPath.TrimEnd('/').Equals("/communication", StringComparison.OrdinalIgnoreCase))
            Navigation.NavigateTo("/communication");
    }

    private static string GetMessageTypeLabel(string messageType) => messageType switch
    {
        OzonPushMessageType.NewPosting => "Новое отправление",
        OzonPushMessageType.PostingCancelled => "Отмена отправления",
        OzonPushMessageType.StateChanged => "Изменён статус",
        OzonPushMessageType.CutoffDateChanged => "Изменена дата отгрузки",
        OzonPushMessageType.DeliveryDateChanged => "Изменена дата доставки",
        OzonPushMessageType.CreateOrUpdateItem => "Создание/обновление товара",
        OzonPushMessageType.CreateItem => "Создание товара",
        OzonPushMessageType.UpdateItem => "Обновление товара",
        OzonPushMessageType.StocksChanged => "Изменение остатков",
        OzonPushMessageType.NewMessage => "Новое сообщение",
        OzonPushMessageType.UpdateMessage => "Изменение сообщения",
        OzonPushMessageType.MessageRead => "Сообщение прочитано",
        OzonPushMessageType.ChatClosed => "Чат закрыт",
        _ => messageType
    };

    private void OnMasterAuthChanged() => InvokeAsync(StateHasChanged);

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        _ = task.ContinueWith(t =>
        {
            if (t.IsCompletedSuccessfully) UserContext.SetUser(t.Result.User);
        }, TaskScheduler.Default);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePageInfo();
        InvokeAsync(StateHasChanged);
    }

    private void UpdatePageInfo()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath;
        var info = PageRegistry.Get(path);
        _pageTitle = info.Title;
        _pageIcon = info.Icon;
    }

    private bool IsGroupActive(NavGroup group)
    {
        var current = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        if (string.IsNullOrEmpty(current)) current = "/";
        return group.Items.Any(i => i.Path.TrimEnd('/').ToLowerInvariant() == current);
    }

    private bool IsPathActive(string path)
    {
        var current = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        if (string.IsNullOrEmpty(current)) current = "/";
        return path.TrimEnd('/').ToLowerInvariant() == current;
    }

    private void NavigateDirect(string path) => Navigation.NavigateTo(path);

    private void NavigateFromFlyout(string path) => Navigation.NavigateTo(path);

    private int GetFlyoutTop(NavGroup group)
    {
        var idx = NavService.Groups.IndexOf(group);
        return 56 + idx * 52;
    }

    private async Task HandleTenantLogout()
    {
        await AuthStateProvider.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private async Task HandleMasterLogout()
    {
        await AuthStateProvider.MasterLogoutAsync();
        MasterAuthState.Clear();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        MasterAuthState.OnChanged -= OnMasterAuthChanged;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();
        if (_ozonPushHub is not null)
            await _ozonPushHub.DisposeAsync();
    }
}
