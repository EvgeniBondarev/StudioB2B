@inherits LayoutComponentBase
@inject ITenantProvider TenantProvider
@inject NavigationManager Navigation

<RadzenLayout Style="min-height: 100vh;">

    <!--
        Sidebar width is controlled manually via Style.
        @bind-Expanded is intentionally omitted — Radzen collapses it to width:0 when Expanded=false,
        which hides icons too. Instead we use CSS class .sidebar-compact to show icon-only mode.
    -->
    <RadzenSidebar Style="@(_sidebarExpanded ? "width: 220px;" : "width: 64px; overflow: hidden;")">
        <div class="sidebar-inner @(_sidebarExpanded ? "" : "sidebar-compact")">

            <div class="sidebar-logo">
                <RadzenIcon Icon="business_center" Style="color: var(--rz-primary); font-size: 1.3rem; flex-shrink: 0;" />
                @if (_sidebarExpanded)
                {
                    <span>StudioB2B</span>
                }
            </div>

            <RadzenPanelMenu>
                <RadzenPanelMenuItem Text="Главная" Path="/" Icon="home" />

                @if (TenantProvider.IsResolved)
                {
                    <AuthorizeView Roles="Admin">
                        <Authorized>
                            <RadzenPanelMenuItem Text="Пользователи" Path="/users" Icon="people" />
                            <RadzenPanelMenuItem Text="Маркетплейс" Path="/marketplace-clients" Icon="store" />
                        </Authorized>
                    </AuthorizeView>

                    <RadzenPanelMenuItem Text="@TenantProvider.Subdomain" Icon="apartment" Disabled="true" />
                }
                else
                {
                    <RadzenPanelMenuItem Text="Роли" Path="/roles" Icon="security" />
                }
            </RadzenPanelMenu>

        </div>
    </RadzenSidebar>

    <RadzenHeader Style="padding: 0; border-bottom: 1px solid var(--rz-border-color);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Style="height: 56px; padding: 0 1rem; width: 100%;">

            <!-- Кнопка-бургер для сворачивания/разворачивания панели -->
            <RadzenButton Icon="menu" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                          Size="ButtonSize.Medium" Click="ToggleSidebar" />

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <AuthorizeView>
                    <Authorized>
                        <!-- Имя пользователя — того же цвета, что и кнопка "Выйти" -->
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Style="color: var(--rz-text-color); margin: 0; font-weight: 500;">
                            @context.User.Identity?.Name
                        </RadzenText>
                        <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Light"
                                      Variant="Variant.Text" Size="ButtonSize.Small"
                                      Click="@(() => Navigation.NavigateTo("/account/logout", forceLoad: true))" />
                    </Authorized>
                </AuthorizeView>
            </RadzenStack>

        </RadzenStack>
    </RadzenHeader>

    <RadzenBody>
        <div style="padding: 1.5rem 2rem;">
            @Body
        </div>
    </RadzenBody>

</RadzenLayout>

<RadzenNotification />
<RadzenDialog />
<RadzenContextMenu />

@code {
    private bool _sidebarExpanded = true;

    private void ToggleSidebar() => _sidebarExpanded = !_sidebarExpanded;
}
