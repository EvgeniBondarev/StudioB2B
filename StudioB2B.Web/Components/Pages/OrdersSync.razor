@page "/orders-sync"
@attribute [Authorize(Roles = "SyncView")]
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using StudioB2B.Domain.Entities
@using SyncJobStatus = StudioB2B.Domain.Constants.SyncJobStatusEnum
@using SyncJobType = StudioB2B.Domain.Constants.SyncJobTypeEnum
@using StudioB2B.Infrastructure.Helpers
@using StudioB2B.Infrastructure.Interfaces
@inject ITenantProvider TenantProvider
@inject IOrderSyncJobService JobService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<link rel="stylesheet" href="css/orders.css"/>

<PageTitle>Фоновые задачи</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри рабочего пространства (тенанта).
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Фоновые задачи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            @if (_canRunAny)
            {
                <RadzenButton Text="Запустить задачу" Icon="play_arrow"
                              ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Small"
                              Click="@OpenEnqueueDialogAsync" />
            }
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
        </RadzenStack>
    </RadzenStack>
    <!-- ══ Расписания ══ -->
    <RadzenStack Gap="0.75rem" Style="margin-bottom: 1.5rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween">
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600; margin:0;">Расписания</RadzenText>
            @if (_canManageSchedules)
            {
                <RadzenButton Text="Добавить расписание" Icon="add_alarm"
                              ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@OpenCreateScheduleDialogAsync" />
            }
        </RadzenStack>

        @if (_schedules.Count == 0)
        {
            <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color);">
                Нет активных расписаний. Нажмите «Добавить расписание», чтобы настроить автоматический запуск задач.
            </RadzenText>
        }
        else
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                @foreach (var s in _schedules)
                {
                    <RadzenCard Style="@($"min-width:260px; max-width:320px; border-left: 4px solid {(s.IsEnabled ? "var(--rz-success)" : "var(--rz-text-disabled-color)")};")">
                        <RadzenStack Gap="0.4rem">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                         JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenBadge BadgeStyle="@JobTypeBadgeStyle(s.JobType)"
                                             Text="@JobTypeLabel(s.JobType)" />
                                @if (_canManageSchedules)
                                {
                                    <RadzenToggleButton Value="@s.IsEnabled"
                                                        ButtonStyle="ButtonStyle.Light"
                                                        ToggleButtonStyle="ButtonStyle.Success"
                                                        Icon="@(s.IsEnabled ? "toggle_on" : "toggle_off")"
                                                        Size="ButtonSize.ExtraSmall"
                                                        title="@(s.IsEnabled ? "Отключить" : "Включить")"
                                                        Click="@(() => ToggleScheduleAsync(s))" />
                                }
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:600;">
                                @ScheduleCronBuilder.Describe(s)
                            </RadzenText>
                            @if (s.JobType == SyncJobType.Sync && !string.IsNullOrEmpty(s.SyncParams))
                            {
                                var daysBack = ParseDaysBack(s.SyncParams);
                                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                                    Период: последние @daysBack дн.
                                </RadzenText>
                            }
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                                Создал: @(s.CreatedByEmail ?? "—")
                            </RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem" JustifyContent="JustifyContent.End">
                                @if (CanRunJobType(s.JobType))
                                {
                                    <RadzenButton Icon="play_arrow" Size="ButtonSize.ExtraSmall"
                                                  ButtonStyle="ButtonStyle.Success" title="Запустить сейчас"
                                                  IsBusy="@_runningScheduleIds.Contains(s.Id)"
                                                  Disabled="@_runningScheduleIds.Contains(s.Id)"
                                                  Click="@(() => RunScheduleNowAsync(s))" />
                                }
                                @if (_canManageSchedules)
                                {
                                    <RadzenButton Icon="edit" Size="ButtonSize.ExtraSmall"
                                                  ButtonStyle="ButtonStyle.Light" title="Редактировать"
                                                  Click="@(() => OpenEditScheduleDialogAsync(s))" />
                                    <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall"
                                                  ButtonStyle="ButtonStyle.Light" title="Удалить"
                                                  IsBusy="@_deletingScheduleIds.Contains(s.Id)"
                                                  Disabled="@_deletingScheduleIds.Contains(s.Id)"
                                                  Click="@(() => DeleteScheduleAsync(s))" />
                                }
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                }
            </RadzenStack>
        }
    </RadzenStack>

    <!-- Тип + Статус: пилюли -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                 Style="padding: 0 0 0.6rem 0; flex-wrap: wrap;">
        @{ var allTypeActive = _filterType == null; }
        <span class="q-pill @(allTypeActive ? "active" : "")"
              style="background:@(allTypeActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allTypeActive ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(() => { _filterType = null; ApplyFilters(); })">
            Все типы
        </span>
        <span class="q-pill @(_filterType == SyncJobType.Sync ? "active" : "")"
              style="background:@(_filterType == SyncJobType.Sync ? "#3b82f6" : "#dbeafe"); color:@(_filterType == SyncJobType.Sync ? "#fff" : "#1e3a5f");"
              @onclick="@(() => { _filterType = _filterType == SyncJobType.Sync ? null : SyncJobType.Sync; ApplyFilters(); })">
            Загрузка заказов
            @if (_typeCountSync > 0) { <span class="q-pill-count">@_typeCountSync</span> }
        </span>
        <span class="q-pill @(_filterType == SyncJobType.Update ? "active" : "")"
              style="background:@(_filterType == SyncJobType.Update ? "#8b5cf6" : "#ede9fe"); color:@(_filterType == SyncJobType.Update ? "#fff" : "#4c1d95");"
              @onclick="@(() => { _filterType = _filterType == SyncJobType.Update ? null : SyncJobType.Update; ApplyFilters(); })">
            Обновление статусов
            @if (_typeCountUpdate > 0) { <span class="q-pill-count">@_typeCountUpdate</span> }
        </span>
        <span class="q-pill @(_filterType == SyncJobType.Returns ? "active" : "")"
              style="background:@(_filterType == SyncJobType.Returns ? "#06b6d4" : "#cffafe"); color:@(_filterType == SyncJobType.Returns ? "#fff" : "#164e63");"
              @onclick="@(() => { _filterType = _filterType == SyncJobType.Returns ? null : SyncJobType.Returns; ApplyFilters(); })">
            Загрузка возвратов
            @if (_typeCountReturns > 0) { <span class="q-pill-count">@_typeCountReturns</span> }
        </span>

        <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>

        @{ var allStatusActive = _filterStatus == null; }
        <span class="q-pill @(allStatusActive ? "active" : "")"
              style="background:@(allStatusActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allStatusActive ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(() => { _filterStatus = null; ApplyFilters(); })">
            Все статусы
        </span>
        <span class="q-pill @(_filterStatus == SyncJobStatus.Enqueued ? "active" : "")"
              style="background:@(_filterStatus == SyncJobStatus.Enqueued ? "#f59e0b" : "#fef3c7"); color:@(_filterStatus == SyncJobStatus.Enqueued ? "#fff" : "#78350f");"
              @onclick="@(() => { _filterStatus = _filterStatus == SyncJobStatus.Enqueued ? null : SyncJobStatus.Enqueued; ApplyFilters(); })">
            В очереди
            @if (_statusCountEnqueued > 0) { <span class="q-pill-count">@_statusCountEnqueued</span> }
        </span>
        <span class="q-pill @(_filterStatus == SyncJobStatus.Processing ? "active" : "")"
              style="background:@(_filterStatus == SyncJobStatus.Processing ? "#3b82f6" : "#dbeafe"); color:@(_filterStatus == SyncJobStatus.Processing ? "#fff" : "#1e3a5f");"
              @onclick="@(() => { _filterStatus = _filterStatus == SyncJobStatus.Processing ? null : SyncJobStatus.Processing; ApplyFilters(); })">
            Выполняется
            @if (_statusCountProcessing > 0) { <span class="q-pill-count">@_statusCountProcessing</span> }
        </span>
        <span class="q-pill @(_filterStatus == SyncJobStatus.Succeeded ? "active" : "")"
              style="background:@(_filterStatus == SyncJobStatus.Succeeded ? "#10b981" : "#d1fae5"); color:@(_filterStatus == SyncJobStatus.Succeeded ? "#fff" : "#065f46");"
              @onclick="@(() => { _filterStatus = _filterStatus == SyncJobStatus.Succeeded ? null : SyncJobStatus.Succeeded; ApplyFilters(); })">
            Завершена
            @if (_statusCountSucceeded > 0) { <span class="q-pill-count">@_statusCountSucceeded</span> }
        </span>
        <span class="q-pill @(_filterStatus == SyncJobStatus.Failed ? "active" : "")"
              style="background:@(_filterStatus == SyncJobStatus.Failed ? "#ef4444" : "#fee2e2"); color:@(_filterStatus == SyncJobStatus.Failed ? "#fff" : "#7f1d1d");"
              @onclick="@(() => { _filterStatus = _filterStatus == SyncJobStatus.Failed ? null : SyncJobStatus.Failed; ApplyFilters(); })">
            Ошибка
            @if (_statusCountFailed > 0) { <span class="q-pill-count">@_statusCountFailed</span> }
        </span>
        <span class="q-pill @(_filterStatus == SyncJobStatus.Cancelled ? "active" : "")"
              style="background:@(_filterStatus == SyncJobStatus.Cancelled ? "#6b7280" : "#f3f4f6"); color:@(_filterStatus == SyncJobStatus.Cancelled ? "#fff" : "#374151");"
              @onclick="@(() => { _filterStatus = _filterStatus == SyncJobStatus.Cancelled ? null : SyncJobStatus.Cancelled; ApplyFilters(); })">
            Отменена
            @if (_statusCountCancelled > 0) { <span class="q-pill-count">@_statusCountCancelled</span> }
        </span>
    </RadzenStack>

    @if (_hasActiveJobs)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false"
                           Style="width: 100%; height: 3px; margin-bottom: 4px;" />
    }

    <RadzenDataGrid class="orders-grid"
                    TItem="SyncJobHistory"
                    Data="@_filteredItems"
                    Density="@_density"
                    AllowPaging="true"
                    PageSize="20"
                    ShowPagingSummary="true"
                    AllowSorting="true"
                    AllowFiltering="true"
                    FilterMode="FilterMode.Advanced"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    PageSizeOptions="@(new int[]{10,20,50})"
                    IsLoading="@_isLoading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText"
                    Style="width: 100%;">
        <Columns>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="JobType" Title="Тип" Width="210px"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColType")">
                <Template Context="h">
                    <RadzenBadge BadgeStyle="@JobTypeBadgeStyle(h.JobType)"
                                 Text="@JobTypeLabel(h.JobType)" />
                </Template>
                <FilterTemplate Context="col">
                    <div class="filter-all-item @(_filterType == null ? "active" : "")"
                         @onclick="@(() => { _filterType = null; ApplyFilters(); })">Все</div>
                    <RadzenListBox TValue="SyncJobType?" @bind-Value="_filterType"
                                   Data="@_filterTypeOptions" TextProperty="Label" ValueProperty="Value"
                                   AllowClear="true" Style="width:100%;"
                                   Change="@(_ => ApplyFilters())" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="Status" Title="Статус" Width="200px"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColStatus")">
                <Template Context="h">
                    <div style="display:flex;flex-direction:column;gap:2px;">
                        <RadzenBadge BadgeStyle="@StatusBadgeStyle(h.Status)" Text="@StatusLabel(h.Status)" />
                        @if (_progressMessages.TryGetValue(h.Id, out var prog))
                        {
                            <span style="font-size:0.72rem;color:var(--rz-text-secondary-color);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;" title="@prog">@prog</span>
                        }
                    </div>
                </Template>
                <FilterTemplate Context="col">
                    <div class="filter-all-item @(_filterStatus == null ? "active" : "")"
                         @onclick="@(() => { _filterStatus = null; ApplyFilters(); })">Все</div>
                    <RadzenListBox TValue="SyncJobStatus?" @bind-Value="_filterStatus"
                                   Data="@_filterStatusOptions" TextProperty="Label" ValueProperty="Value"
                                   AllowClear="true" Style="width:100%;"
                                   Change="@(_ => ApplyFilters())" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="Параметры" Width="260px"
                                  Filterable="false" HeaderCssClass="half-painted-header" Visible="@Col("SyncColParams")">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2" Class="rz-text-truncate" title="@FormatParameters(h)">
                        @FormatParameters(h)
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="StartedAtUtc" Title="Запуск" Width="160px"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColStartedAt")">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2">@($"{h.StartedAtUtc.ToLocalTime():g}")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="FinishedAtUtc" Title="Завершено" Width="160px"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColFinishedAt")">
                <Template Context="h">
                    @if (h.FinishedAtUtc.HasValue)
                    { <RadzenText TextStyle="TextStyle.Body2">@($"{h.FinishedAtUtc.Value.ToLocalTime():g}")</RadzenText> }
                    else
                    { <span style="color:var(--rz-text-secondary-color)">—</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="Продолжительность" Width="240px"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColDuration")">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2">@FormatDuration(h)</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="InitiatedByEmail" Title="Запустил"
                                  HeaderCssClass="half-painted-header" Visible="@Col("SyncColInitiatedBy")">
                <Template Context="h">
                    @if (!string.IsNullOrEmpty(h.InitiatedByEmail))
                    { <RadzenText TextStyle="TextStyle.Body2" Class="rz-text-truncate" title="@h.InitiatedByEmail">@h.InitiatedByEmail</RadzenText> }
                    else
                    { <span style="color:var(--rz-text-secondary-color)">—</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="" Width="90px" Sortable="false" Filterable="false"
                                  TextAlign="TextAlign.Right" HeaderCssClass="half-painted-header"
                                  Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                <Template Context="h">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.End" Style="flex-wrap: nowrap;">
                        @if (h.Status is SyncJobStatus.Enqueued or SyncJobStatus.Processing)
                        {
                            <RadzenButton Icon="stop_circle" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Danger"
                                          IsBusy="@_cancellingIds.Contains(h.Id)"
                                          Disabled="@_cancellingIds.Contains(h.Id)"
                                          Click="@(() => CancelJobAsync(h))" title="Остановить" />
                        }
                        @if (!string.IsNullOrEmpty(h.ResultJson))
                        {
                            <RadzenButton Icon="info" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Light"
                                          Click="@(() => ShowResultDialogAsync(h))" title="Результат" />
                        }
                        else if (!string.IsNullOrEmpty(h.ErrorMessage))
                        {
                            <RadzenButton Icon="error" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Click="@(() => ShowErrorDialogAsync(h))" title="Ошибка" />
                        }
                        @if (h.Status is not (SyncJobStatus.Enqueued or SyncJobStatus.Processing))
                        {
                            <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Light"
                                          IsBusy="@_deletingIds.Contains(h.Id)"
                                          Disabled="@_deletingIds.Contains(h.Id)"
                                          Click="@(() => DeleteJobAsync(h))" title="Удалить запись" />
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private List<SyncJobHistory> _historyItems = new();
    private List<SyncJobHistory> _filteredItems = new();
    private bool _hasActiveJobs;
    private bool _isLoading;
    private Density _density = Density.Default;

    private bool _canRunOrders;
    private bool _canRunStatusUpdate;
    private bool _canRunReturns;
    private bool _canRunAny;
    private bool _canManageSchedules;
    private System.Security.Claims.ClaimsPrincipal? _syncUser;

    private bool Col(string role) => _syncUser?.IsInRole("Admin") == true || _syncUser?.IsInRole(role) == true;

    private SyncJobType? _filterType;
    private SyncJobStatus? _filterStatus;

    // Pill counts (computed from full history, not filtered)
    private int _typeCountSync;
    private int _typeCountUpdate;
    private int _typeCountReturns;
    private int _statusCountEnqueued;
    private int _statusCountProcessing;
    private int _statusCountSucceeded;
    private int _statusCountFailed;
    private int _statusCountCancelled;

    private record FilterOption<T>(string Label, T? Value);

    private readonly List<FilterOption<SyncJobType>> _filterTypeOptions = new()
    {
        new("Загрузка заказов", SyncJobType.Sync),
        new("Обновление статусов", SyncJobType.Update),
        new("Загрузка возвратов", SyncJobType.Returns),
    };

    private readonly List<FilterOption<SyncJobStatus>> _filterStatusOptions = new()
    {
        new("В очереди", SyncJobStatus.Enqueued),
        new("Выполняется", SyncJobStatus.Processing),
        new("Завершена", SyncJobStatus.Succeeded),
        new("Ошибка", SyncJobStatus.Failed),
        new("Отменена", SyncJobStatus.Cancelled),
    };

    private readonly HashSet<Guid> _cancellingIds = new();
    private readonly HashSet<Guid> _deletingIds = new();
    private readonly Dictionary<Guid, string> _progressMessages = new();

    private List<SyncJobSchedule>  _schedules = new();
    private readonly HashSet<Guid> _deletingScheduleIds = new();
    private readonly HashSet<Guid> _togglingScheduleIds = new();
    private readonly HashSet<Guid> _runningScheduleIds = new();

    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource _pollCts = new();

    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        var user = state.User;
        _syncUser = user;
        _canRunOrders = user.IsInRole("Admin") || user.IsInRole("SyncRunOrders");
        _canRunStatusUpdate = user.IsInRole("Admin") || user.IsInRole("SyncRunStatusUpdate");
        _canRunReturns = user.IsInRole("Admin") || user.IsInRole("SyncRunReturns");
        _canRunAny = _canRunOrders || _canRunStatusUpdate || _canRunReturns;
        _canManageSchedules = user.IsInRole("Admin") || user.IsInRole("SyncManageSchedules");

        if (!TenantProvider.IsResolved) return;

        await LoadHistoryAsync();
        await LoadSchedulesAsync();
        // Polling запускается всегда — чтобы видеть задачи запущенные по расписанию
        StartPollingIfNeeded();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantProvider.IsResolved) return;

        await ConnectSignalRAsync();
    }

    private async Task ConnectSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/sync"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<JobCompletedPayload>("JobStarted", async payload =>
        {
            await InvokeAsync(async () =>
            {
                await LoadHistoryAsync();
                StateHasChanged();
            });
        });

        _hubConnection.On<JobProgressPayload>("JobProgress", payload =>
        {
            InvokeAsync(() =>
            {
                _progressMessages[payload.HistoryId] = payload.Message;
                StateHasChanged();
            });
        });

        _hubConnection.On<JobCompletedPayload>("JobCompleted", async payload =>
        {
            await InvokeAsync(async () =>
            {
                _progressMessages.Remove(payload.HistoryId);
                await LoadHistoryAsync();
                var h = _historyItems.FirstOrDefault(x => x.Id == payload.HistoryId);
                if (h is not null)
                    NotifyJobResult(h, JobTypeLabel(h.JobType));
                StateHasChanged();
            });
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinTenantGroup", TenantProvider.TenantId!.Value.ToString());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SignalR] Connection failed, polling-only mode: {ex.Message}");
        }
    }

    private async Task OpenEnqueueDialogAsync()
    {
        var allowed = new List<SyncJobType>();
        if (_canRunOrders) allowed.Add(SyncJobType.Sync);
        if (_canRunStatusUpdate) allowed.Add(SyncJobType.Update);
        if (_canRunReturns) allowed.Add(SyncJobType.Returns);

        var result = await DialogService.OpenAsync(
            "Запустить фоновую задачу",
            _ => @<EnqueueJobDialog AllowedTypes="@allowed" />,
            new DialogOptions { Width = "700px", Resizable = true, Draggable = true });

        if (result is true)
        {
            NotificationService.Notify(NotificationSeverity.Info, "Задача поставлена в очередь",
                "Следите за прогрессом в таблице ниже.");
            await LoadHistoryAsync();
            StartPollingIfNeeded();
        }
    }

    private async Task CancelJobAsync(SyncJobHistory h)
    {
        if (string.IsNullOrEmpty(h.HangfireJobId)) return;
        _cancellingIds.Add(h.Id);
        try
        {
            await JobService.CancelJobAsync(h.HangfireJobId);
            await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка отмены", ex.Message);
        }
        finally
        {
