@page "/orders-sync"
@attribute [Authorize(Roles = "Admin")]
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using StudioB2B.Application.Common
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Domain.Entities.Orders
@inject ITenantProvider TenantProvider
@inject IOrderSyncJobService JobService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Загрузка заказов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри рабочего пространства (тенанта).
    </RadzenAlert>
}
else
{
    <RadzenCard Style="max-width: 960px; margin: 0 auto;">
        <RadzenTabs>
            <Tabs>

                <!-- ══════════════════ TAB 1: Синхронизация ══════════════════ -->
                <RadzenTabsItem Text="Загрузка заказов Ozon (FBS)">
                    <RadzenStack Gap="1.5rem">

                        <RadzenStack Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600;">
                                Синхронизация заказов из Ozon
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                Выберите период (не более 30 дней). Задача выполняется в фоне — вы можете
                                продолжить работу в другом разделе.
                            </RadzenText>
                        </RadzenStack>

                        @if (!_showSyncProcess)
                        {
                            <RadzenStack Gap="1rem">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Start">
                                    <div class="rz-p-12 rz-text-align-center" style="flex: 1;">
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-2">Дата начала периода</RadzenText>
                                        <RadzenDatePicker @bind-Value="_from" Inline="true" ShowTime="false" />
                                    </div>
                                    <div class="rz-p-12 rz-text-align-center" style="flex: 1;">
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-2">Дата окончания периода</RadzenText>
                                        <RadzenDatePicker @bind-Value="_to" Inline="true" ShowTime="false" />
                                    </div>
                                </RadzenStack>

                                <RadzenStack Gap="0.5rem">
                                    <RadzenButton Text="Запустить синхронизацию"
                                                  Icon="cloud_sync"
                                                  Shade="Shade.Light"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy="@_isSyncEnqueuing"
                                                  Disabled="@_isSyncEnqueuing"
                                                  Click="@RunSyncAsync" />
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                        Максимальная длина периода — 30 дней.
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenStack>
                        }
                        else
                        {
                            <RadzenTimeline>
                                <Items>
                                    <RadzenTimelineItem PointStyle="@SyncStepStyle(0)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@SyncStepLabelStyle(0)">Подготовка</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@SyncStepDescStyle(0)">
                                                Поиск клиентов Ozon FBS и подготовка параметров синхронизации.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                    <RadzenTimelineItem PointStyle="@SyncStepStyle(1)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@SyncStepLabelStyle(1)">Загрузка заказов</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@SyncStepDescStyle(1)">
                                                Вызов Ozon API, получение FBS‑отправлений и цен товаров.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                    <RadzenTimelineItem PointStyle="@SyncStepStyle(2)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@SyncStepLabelStyle(2)">Сохранение и результат</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@SyncStepDescStyle(2)">
                                                Обновление базы данных и отображение результата по клиентам.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                </Items>
                            </RadzenTimeline>

                            <RadzenStack Gap="0.75rem">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <RadzenButton Text="@SyncStatusButtonText"
                                                  Icon="cloud_sync"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy="@IsSyncActive"
                                                  Disabled="true" />

                                    @if (IsSyncActive)
                                    {
                                        <RadzenButton Text="Остановить"
                                                      Icon="stop_circle"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Size="ButtonSize.Medium"
                                                      IsBusy="@_isSyncCancelling"
                                                      Disabled="@_isSyncCancelling"
                                                      Click="@CancelSyncAsync" />
                                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                            Синхронизация выполняется в фоне...
                                        </RadzenText>
                                    }
                                </RadzenStack>
                                @if (IsSyncActive)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false"
                                                       Style="width: 100%; max-width: 420px;" />
                                }
                            </RadzenStack>
                        }

                        <!-- Результат -->
                        @if (_syncHistory is not null)
                        {
                            <SyncResultPanel History="@_syncHistory" />
                        }

                    </RadzenStack>
                </RadzenTabsItem>

                <!-- ══════════════════ TAB 2: Обновление статусов ══════════════════ -->
                <RadzenTabsItem Text="Обновление статусов">
                    <RadzenStack Gap="1.5rem">

                        <RadzenStack Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600;">
                                Обновление статусов отправлений Ozon
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                Получает актуальный статус, дату отгрузки и трек-номер по каждому активному
                                отправлению из Ozon API (<code>/v3/posting/fbs/get</code>).
                                Задача выполняется в фоне.
                            </RadzenText>
                        </RadzenStack>

                        @if (!_showUpdateProcess)
                        {
                            <RadzenStack Gap="0.5rem">
                                <RadzenButton Text="Обновить статусы отправлений"
                                              Icon="sync"
                                              Shade="Shade.Light"
                                              ButtonStyle="ButtonStyle.Secondary"
                                              Size="ButtonSize.Medium"
                                              IsBusy="@_isUpdateEnqueuing"
                                              Disabled="@_isUpdateEnqueuing"
                                              Click="@RunUpdateAsync" />
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                    Обновляются только отправления с незавершёнными статусами.
                                </RadzenText>
                            </RadzenStack>
                        }
                        else
                        {
                            <RadzenTimeline>
                                <Items>
                                    <RadzenTimelineItem PointStyle="@UpdateStepStyle(0)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@UpdateStepLabelStyle(0)">Запрос к API</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@UpdateStepDescStyle(0)">
                                                Получение актуальных данных по каждому отправлению из Ozon API.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                    <RadzenTimelineItem PointStyle="@UpdateStepStyle(1)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@UpdateStepLabelStyle(1)">Сохранение</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@UpdateStepDescStyle(1)">
                                                Обновление статусов, дат отгрузки и трек-номеров в базе данных.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                </Items>
                            </RadzenTimeline>

                            <RadzenStack Gap="0.75rem">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <RadzenButton Text="@UpdateStatusButtonText"
                                                  Icon="sync"
                                                  ButtonStyle="ButtonStyle.Secondary"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy="@IsUpdateActive"
                                                  Disabled="true" />

                                    @if (IsUpdateActive)
                                    {
                                        <RadzenButton Text="Остановить"
                                                      Icon="stop_circle"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Size="ButtonSize.Medium"
                                                      IsBusy="@_isUpdateCancelling"
                                                      Disabled="@_isUpdateCancelling"
                                                      Click="@CancelUpdateAsync" />
                                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                            Обновление выполняется в фоне...
                                        </RadzenText>
                                    }
                                </RadzenStack>
                                @if (IsUpdateActive)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false"
                                                       Style="width: 100%; max-width: 420px;" />
                                }
                            </RadzenStack>
                        }

                        @if (_updateHistory is not null)
                        {
                            <UpdateResultPanel History="@_updateHistory" />
                        }

                    </RadzenStack>
                </RadzenTabsItem>

                <!-- ══════════════════ TAB 3: История задач ══════════════════ -->
                <RadzenTabsItem Text="История задач">
                    <RadzenStack Gap="1rem">
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600;">История фоновых задач</RadzenText>
                            <RadzenButton Text="Обновить" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                          Size="ButtonSize.Small" Click="@LoadHistoryAsync" />
                        </RadzenStack>

                        <RadzenDataGrid TItem="SyncJobHistory"
                                        Data="@_historyItems"
                                        Density="Density.Compact"
                                        AllowPaging="true"
                                        PageSize="15"
                                        ShowPagingSummary="true"
                                        AllowSorting="true"
                                        PageSizeText="@RadzenRuStrings.PageSizeText"
                                        PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                                        EmptyText="@RadzenRuStrings.EmptyText">
                            <Columns>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Property="JobType" Title="Тип" Width="120px">
                                    <Template Context="h">
                                        <RadzenBadge BadgeStyle="@(h.JobType == SyncJobType.Sync ? BadgeStyle.Primary : BadgeStyle.Secondary)"
                                                     Text="@(h.JobType == SyncJobType.Sync ? "Синхронизация" : "Обновление")" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Property="Status" Title="Статус" Width="140px">
                                    <Template Context="h">
                                        <RadzenBadge BadgeStyle="@StatusBadgeStyle(h.Status)" Text="@StatusLabel(h.Status)" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Title="Период" Width="200px">
                                    <Template Context="h">
                                        @if (h.DateFrom.HasValue && h.DateTo.HasValue)
                                        {
                                            @($"{h.DateFrom.Value.ToLocalTime():dd.MM.yyyy} – {h.DateTo.Value.ToLocalTime():dd.MM.yyyy}")
                                        }
                                        else
                                        {
                                            <span style="color:var(--rz-text-secondary-color)">—</span>
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Property="StartedAtUtc" Title="Запуск" Width="160px">
                                    <Template Context="h">@($"{h.StartedAtUtc.ToLocalTime():g}")</Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Property="FinishedAtUtc" Title="Завершено" Width="160px">
                                    <Template Context="h">
                                        @if (h.FinishedAtUtc.HasValue)
                                        {
                                            @($"{h.FinishedAtUtc.Value.ToLocalTime():g}")
                                        }
                                        else
                                        {
                                            <span style="color:var(--rz-text-secondary-color)">—</span>
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="SyncJobHistory" Title="" Width="120px" Sortable="false">
                                    <Template Context="h">
                                        @if (!string.IsNullOrEmpty(h.ResultJson))
                                        {
                                            <RadzenButton Text="Результат" Icon="info" Size="ButtonSize.ExtraSmall"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Click="@(() => ShowResultDialogAsync(h))" />
                                        }
                                        else if (!string.IsNullOrEmpty(h.ErrorMessage))
                                        {
                                            <RadzenButton Text="Ошибка" Icon="error" Size="ButtonSize.ExtraSmall"
                                                          ButtonStyle="ButtonStyle.Danger"
                                                          Click="@(() => ShowErrorDialogAsync(h))" />
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenStack>
                </RadzenTabsItem>

            </Tabs>
        </RadzenTabs>
    </RadzenCard>
}

@code {
    // ── Sync ─────────────────────────────────────────────────────────────────
    private DateTime? _from = DateTime.Today.AddDays(-7);
    private DateTime? _to   = DateTime.Today;

    private Guid?          _syncHistoryId;
    private SyncJobHistory? _syncHistory;
    private bool            _showSyncProcess;
    private bool            _isSyncEnqueuing;
    private bool            _isSyncCancelling;
    private int             _syncStep;
    private PeriodicTimer?  _syncTimer;
    private CancellationTokenSource _syncPollCts = new();

    // ── Update ───────────────────────────────────────────────────────────────
    private Guid?           _updateHistoryId;
    private SyncJobHistory? _updateHistory;
    private bool            _showUpdateProcess;
    private bool            _isUpdateEnqueuing;
    private bool            _isUpdateCancelling;
    private int             _updateStep;
    private PeriodicTimer?  _updateTimer;
    private CancellationTokenSource _updatePollCts = new();

    // ── History ──────────────────────────────────────────────────────────────
    private List<SyncJobHistory> _historyItems = new();

    // ── SignalR ──────────────────────────────────────────────────────────────
    private HubConnection? _hubConnection;

    // ── Computed ─────────────────────────────────────────────────────────────
    private bool IsSyncActive   => _syncHistory?.Status   is SyncJobStatus.Enqueued or SyncJobStatus.Processing;
    private bool IsUpdateActive => _updateHistory?.Status is SyncJobStatus.Enqueued or SyncJobStatus.Processing;

    private string SyncStatusButtonText => _syncHistory?.Status switch
    {
        SyncJobStatus.Succeeded => "Синхронизация завершена",
        SyncJobStatus.Failed    => "Синхронизация завершилась с ошибкой",
        SyncJobStatus.Cancelled => "Синхронизация отменена",
        _                       => "Синхронизация запущена"
    };

    private string UpdateStatusButtonText => _updateHistory?.Status switch
    {
        SyncJobStatus.Succeeded => "Обновление завершено",
        SyncJobStatus.Failed    => "Обновление завершилось с ошибкой",
        SyncJobStatus.Cancelled => "Обновление отменено",
        _                       => "Обновление запущено"
    };

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantProvider.IsResolved) return;

        await ConnectSignalRAsync();
        await LoadHistoryAsync();
    }

    private async Task ConnectSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/sync"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<JobCompletedPayload>("JobCompleted", async payload =>
        {
            await InvokeAsync(async () =>
            {
                // Sync
                if (_syncHistoryId.HasValue && payload.HistoryId == _syncHistoryId.Value)
                {
                    await StopSyncPollingAsync();
                    _syncHistory = await JobService.GetJobAsync(_syncHistoryId.Value);
                    NotifyJobResult(_syncHistory, "Синхронизация");
                    await LoadHistoryAsync();
                    StateHasChanged();
                }

                // Update
                if (_updateHistoryId.HasValue && payload.HistoryId == _updateHistoryId.Value)
                {
                    await StopUpdatePollingAsync();
                    _updateHistory = await JobService.GetJobAsync(_updateHistoryId.Value);
                    NotifyJobResult(_updateHistory, "Обновление статусов");
                    await LoadHistoryAsync();
                    StateHasChanged();
                }
            });
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinTenantGroup", TenantProvider.TenantId!.Value.ToString());
        }
        catch (Exception ex)
        {
            // SignalR недоступен — продолжаем без push-уведомлений, polling обеспечит обновление статуса
            Console.WriteLine($"[SignalR] Connection failed, polling-only mode: {ex.Message}");
        }
    }

    // ── Run Sync ─────────────────────────────────────────────────────────────

    private async Task RunSyncAsync()
    {
        if (!TenantProvider.IsResolved) return;
        if (_isSyncEnqueuing) return;

        if (!_from.HasValue || !_to.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Некорректный период", "Выберите даты начала и окончания.");
            return;
        }

        var from = _from.Value.Date;
        var to   = _to.Value.Date.AddDays(1).AddTicks(-1);

        if (from > to)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Некорректный период", "Дата начала не может быть позже даты окончания.");
            return;
        }

        if ((to - from).TotalDays > 30)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Слишком длинный период", "Максимальная длина периода — 30 дней.");
            return;
        }

        _isSyncEnqueuing  = true;
        _showSyncProcess  = true;
        _syncStep         = 0;
        _syncHistory      = null;
        _isSyncCancelling = false;

        try
        {
            _syncHistoryId = await JobService.EnqueueSyncAsync(from, to);
            _syncHistory   = await JobService.GetJobAsync(_syncHistoryId.Value);
            await LoadHistoryAsync();
            StateHasChanged();
            _ = StartSyncPollingAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка постановки задачи", ex.Message);
            _showSyncProcess = false;
        }
        finally
        {
            _isSyncEnqueuing = false;
        }
    }

    private async Task StartSyncPollingAsync()
    {
        await StopSyncPollingAsync();
        _syncPollCts = new CancellationTokenSource();
        _syncTimer   = new PeriodicTimer(TimeSpan.FromSeconds(3));

        try
        {
            while (await _syncTimer.WaitForNextTickAsync(_syncPollCts.Token))
            {
                if (!_syncHistoryId.HasValue) break;

                _syncHistory = await JobService.GetJobAsync(_syncHistoryId.Value);
                if (_syncHistory is not null)
                    _syncStep = _syncHistory.Status == SyncJobStatus.Processing ? 1 : 0;

                _historyItems = await JobService.GetHistoryAsync(30);

                await InvokeAsync(StateHasChanged);

                if (_syncHistory?.Status is SyncJobStatus.Succeeded or SyncJobStatus.Failed or SyncJobStatus.Cancelled)
                    break;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _syncTimer?.Dispose();
            _syncTimer = null;
        }
    }

    private async Task StopSyncPollingAsync()
    {
        _syncPollCts.Cancel();
        _syncTimer?.Dispose();
        _syncTimer = null;
        await Task.CompletedTask;
    }

    private async Task CancelSyncAsync()
    {
        if (_syncHistory?.HangfireJobId is null) return;
        _isSyncCancelling = true;
        try
        {
            await JobService.CancelJobAsync(_syncHistory.HangfireJobId);
            // polling подхватит изменение статуса
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка отмены", ex.Message);
            _isSyncCancelling = false;
        }
    }

    // ── Run Update ───────────────────────────────────────────────────────────

    private async Task RunUpdateAsync()
    {
        if (!TenantProvider.IsResolved) return;
        if (_isUpdateEnqueuing) return;

        _isUpdateEnqueuing  = true;
        _showUpdateProcess  = true;
        _updateStep         = 0;
        _updateHistory      = null;
        _isUpdateCancelling = false;

        try
        {
            _updateHistoryId = await JobService.EnqueueUpdateAsync();
            _updateHistory   = await JobService.GetJobAsync(_updateHistoryId.Value);
            await LoadHistoryAsync();
            StateHasChanged();
            _ = StartUpdatePollingAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка постановки задачи", ex.Message);
            _showUpdateProcess = false;
        }
        finally
        {
            _isUpdateEnqueuing = false;
        }
    }

    private async Task StartUpdatePollingAsync()
    {
        await StopUpdatePollingAsync();
        _updatePollCts = new CancellationTokenSource();
        _updateTimer   = new PeriodicTimer(TimeSpan.FromSeconds(3));

        try
        {
            while (await _updateTimer.WaitForNextTickAsync(_updatePollCts.Token))
            {
                if (!_updateHistoryId.HasValue) break;

                _updateHistory = await JobService.GetJobAsync(_updateHistoryId.Value);
                if (_updateHistory is not null)
                    _updateStep = _updateHistory.Status == SyncJobStatus.Processing ? 1 : 0;

                _historyItems = await JobService.GetHistoryAsync(30);

                await InvokeAsync(StateHasChanged);

                if (_updateHistory?.Status is SyncJobStatus.Succeeded or SyncJobStatus.Failed or SyncJobStatus.Cancelled)
                    break;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _updateTimer?.Dispose();
            _updateTimer = null;
        }
    }

    private async Task StopUpdatePollingAsync()
    {
        _updatePollCts.Cancel();
        _updateTimer?.Dispose();
        _updateTimer = null;
        await Task.CompletedTask;
    }

    private async Task CancelUpdateAsync()
    {
        if (_updateHistory?.HangfireJobId is null) return;
        _isUpdateCancelling = true;
        try
        {
            await JobService.CancelJobAsync(_updateHistory.HangfireJobId);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка отмены", ex.Message);
            _isUpdateCancelling = false;
        }
    }

    // ── History ──────────────────────────────────────────────────────────────

    private async Task LoadHistoryAsync()
    {
        _historyItems = await JobService.GetHistoryAsync(30);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowResultDialogAsync(SyncJobHistory history)
    {
        if (string.IsNullOrEmpty(history.ResultJson)) return;

        var summary = JsonSerializer.Deserialize<OrderSyncSummary>(history.ResultJson);
        if (summary is null) return;

        await DialogService.OpenAsync(
            history.JobType == SyncJobType.Sync ? "Результат синхронизации" : "Результат обновления",
            ds => @<SyncResultDialogContent Summary="@summary" JobType="@history.JobType" />,
            new DialogOptions { Width = "900px", Resizable = true, Draggable = true });
    }

    private async Task ShowErrorDialogAsync(SyncJobHistory history)
    {
        await DialogService.Alert(history.ErrorMessage ?? "Неизвестная ошибка", "Ошибка задачи",
            new AlertOptions { OkButtonText = "Закрыть" });
    }

    // ── Helpers ──────────────────────────────────────────────────────────────

    private void NotifyJobResult(SyncJobHistory? h, string jobName)
    {
        if (h is null) return;
        switch (h.Status)
        {
            case SyncJobStatus.Succeeded:
                NotificationService.Notify(NotificationSeverity.Success, $"{jobName} завершена",
                    "Задача успешно выполнена. Откройте вкладку «История задач» для просмотра результата.");
                break;
            case SyncJobStatus.Failed:
                NotificationService.Notify(NotificationSeverity.Error, $"{jobName} завершилась с ошибкой",
                    h.ErrorMessage ?? "Неизвестная ошибка.");
                break;
            case SyncJobStatus.Cancelled:
                NotificationService.Notify(NotificationSeverity.Warning, $"{jobName} отменена", "Задача была остановлена.");
                break;
        }
    }

    // ── Timeline helpers: Sync ────────────────────────────────────────────────

    private bool SyncFinished => _syncHistory?.Status is SyncJobStatus.Succeeded;

    private PointStyle SyncStepStyle(int step)
    {
        if (SyncFinished) return PointStyle.Success;
        return step switch
        {
            _ when step < _syncStep  => PointStyle.Success,
            _ when step == _syncStep => PointStyle.Primary,
            _                        => PointStyle.Secondary
        };
    }

    private string SyncStepLabelStyle(int step)
    {
        if (SyncFinished) return "color: var(--rz-success); font-weight: 700;";
        return step == _syncStep
            ? "color: var(--rz-primary); font-weight: 700;"
            : step < _syncStep ? "color: var(--rz-success);" : "color: var(--rz-text-disabled-color);";
    }

    private string SyncStepDescStyle(int step) => step <= _syncStep ? string.Empty : "color: var(--rz-text-disabled-color);";

    // ── Timeline helpers: Update ──────────────────────────────────────────────

    private bool UpdateFinished => _updateHistory?.Status is SyncJobStatus.Succeeded;

    private PointStyle UpdateStepStyle(int step)
    {
        if (UpdateFinished) return PointStyle.Success;
        return step switch
        {
            _ when step < _updateStep  => PointStyle.Success,
            _ when step == _updateStep => PointStyle.Primary,
            _                          => PointStyle.Secondary
        };
    }

    private string UpdateStepLabelStyle(int step)
    {
        if (UpdateFinished) return "color: var(--rz-success); font-weight: 700;";
        return step == _updateStep
            ? "color: var(--rz-primary); font-weight: 700;"
            : step < _updateStep ? "color: var(--rz-success);" : "color: var(--rz-text-disabled-color);";
    }

    private string UpdateStepDescStyle(int step) => step <= _updateStep ? string.Empty : "color: var(--rz-text-disabled-color);";

    // ── Status badge ──────────────────────────────────────────────────────────

    private static BadgeStyle StatusBadgeStyle(SyncJobStatus s) => s switch
    {
        SyncJobStatus.Enqueued   => BadgeStyle.Warning,
        SyncJobStatus.Processing => BadgeStyle.Info,
        SyncJobStatus.Succeeded  => BadgeStyle.Success,
        SyncJobStatus.Failed     => BadgeStyle.Danger,
        SyncJobStatus.Cancelled  => BadgeStyle.Secondary,
        _                        => BadgeStyle.Light
    };

    private static string StatusLabel(SyncJobStatus s) => s switch
    {
        SyncJobStatus.Enqueued   => "В очереди",
        SyncJobStatus.Processing => "Выполняется",
        SyncJobStatus.Succeeded  => "Завершена",
        SyncJobStatus.Failed     => "Ошибка",
        SyncJobStatus.Cancelled  => "Отменена",
        _                        => s.ToString()
    };

    // ── IAsyncDisposable ──────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        await StopSyncPollingAsync();
        await StopUpdatePollingAsync();
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

    // ── SignalR payload ───────────────────────────────────────────────────────

    private record JobCompletedPayload(Guid HistoryId, string Status, string JobType);
}
