@page "/orders-sync"
@attribute [Authorize(Roles = "Admin")]
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using StudioB2B.Domain.Constants
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Features.Orders
@using StudioB2B.Infrastructure.Interfaces
@inject ITenantProvider TenantProvider
@inject IOrderSyncJobService JobService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<link rel="stylesheet" href="css/orders.css"/>

<PageTitle>Фоновые задачи</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри рабочего пространства (тенанта).
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Фоновые задачи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Запустить задачу" Icon="play_arrow"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Small"
                          Click="@OpenEnqueueDialogAsync" />
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
        </RadzenStack>
    </RadzenStack>
    <!-- ══ Расписания ══ -->
    <RadzenStack Gap="0.75rem" Style="margin-bottom: 1.5rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween">
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600; margin:0;">Расписания</RadzenText>
            <RadzenButton Text="Добавить расписание" Icon="add_alarm"
                          ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@OpenCreateScheduleDialogAsync" />
        </RadzenStack>

        @if (_schedules.Count == 0)
        {
            <RadzenText TextStyle="TextStyle.Body2" Style="color:var(--rz-text-secondary-color);">
                Нет активных расписаний. Нажмите «Добавить расписание», чтобы настроить автоматический запуск задач.
            </RadzenText>
        }
        else
        {
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                @foreach (var s in _schedules)
                {
                    <RadzenCard Style="@($"min-width:260px; max-width:320px; border-left: 4px solid {(s.IsEnabled ? "var(--rz-success)" : "var(--rz-text-disabled-color)")};")">
                        <RadzenStack Gap="0.4rem">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                         JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenBadge BadgeStyle="@(s.JobType == SyncJobTypeEnum.Sync ? BadgeStyle.Primary : BadgeStyle.Secondary)"
                                             Text="@(s.JobType == SyncJobTypeEnum.Sync ? "Загрузка заказов" : "Обновление статусов")" />
                                <RadzenToggleButton Value="@s.IsEnabled"
                                                    ButtonStyle="ButtonStyle.Light"
                                                    ToggleButtonStyle="ButtonStyle.Success"
                                                    Icon="@(s.IsEnabled ? "toggle_on" : "toggle_off")"
                                                    Size="ButtonSize.ExtraSmall"
                                                    title="@(s.IsEnabled ? "Отключить" : "Включить")"
                                                    Click="@(() => ToggleScheduleAsync(s))" />
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:600;">
                                @ScheduleCronBuilder.Describe(s)
                            </RadzenText>
                            @if (s.JobType == SyncJobTypeEnum.Sync && !string.IsNullOrEmpty(s.SyncParams))
                            {
                                var daysBack = ParseDaysBack(s.SyncParams);
                                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                                    Период: последние @daysBack дн.
                                </RadzenText>
                            }
                            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                                Создал: @(s.CreatedByEmail ?? "—")
                            </RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem" JustifyContent="JustifyContent.End">
                                <RadzenButton Icon="edit" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Light" title="Редактировать"
                                              Click="@(() => OpenEditScheduleDialogAsync(s))" />
                                <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Light" title="Удалить"
                                              IsBusy="@_deletingScheduleIds.Contains(s.Id)"
                                              Disabled="@_deletingScheduleIds.Contains(s.Id)"
                                              Click="@(() => DeleteScheduleAsync(s))" />
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                }
            </RadzenStack>
        }
    </RadzenStack>

    @if (_hasActiveJobs)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false"
                           Style="width: 100%; height: 3px; margin-bottom: 4px;" />
    }

    <RadzenDataGrid class="orders-grid"
                    TItem="SyncJobHistory"
                    Data="@_filteredItems"
                    Density="@_density"
                    AllowPaging="true"
                    PageSize="20"
                    ShowPagingSummary="true"
                    AllowSorting="true"
                    AllowFiltering="true"
                    FilterMode="FilterMode.Advanced"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    PageSizeOptions="@(new int[]{10,20,50})"
                    IsLoading="@_isLoading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText"
                    Style="width: 100%;">
        <Columns>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="JobType" Title="Тип" Width="210px"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    <RadzenBadge BadgeStyle="@(h.JobType == SyncJobTypeEnum.Sync ? BadgeStyle.Primary : BadgeStyle.Secondary)"
                                 Text="@(h.JobType == SyncJobTypeEnum.Sync ? "Загрузка заказов" : "Обновление статусов")" />
                </Template>
                <FilterTemplate Context="col">
                    <div class="filter-all-item @(_filterType == null ? "active" : "")"
                         @onclick="@(() => { _filterType = null; ApplyFilters(); })">Все</div>
                    <RadzenListBox TValue="SyncJobTypeEnum?" @bind-Value="_filterType"
                                   Data="@_filterTypeOptions" TextProperty="Label" ValueProperty="Value"
                                   AllowClear="true" Style="width:100%;"
                                   Change="@(_ => ApplyFilters())" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="Status" Title="Статус" Width="160px"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    <RadzenBadge BadgeStyle="@StatusBadgeStyle(h.Status)" Text="@StatusLabel(h.Status)" />
                </Template>
                <FilterTemplate Context="col">
                    <div class="filter-all-item @(_filterStatus == null ? "active" : "")"
                         @onclick="@(() => { _filterStatus = null; ApplyFilters(); })">Все</div>
                    <RadzenListBox TValue="SyncJobStatusEnum?" @bind-Value="_filterStatus"
                                   Data="@_filterStatusOptions" TextProperty="Label" ValueProperty="Value"
                                   AllowClear="true" Style="width:100%;"
                                   Change="@(_ => ApplyFilters())" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="Параметры" Width="260px"
                                  Filterable="false" HeaderCssClass="half-painted-header">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2" Class="rz-text-truncate" title="@FormatParameters(h)">
                        @FormatParameters(h)
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="StartedAtUtc" Title="Запуск" Width="160px"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2">@($"{h.StartedAtUtc.ToLocalTime():g}")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="FinishedAtUtc" Title="Завершено" Width="160px"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    @if (h.FinishedAtUtc.HasValue)
                    { <RadzenText TextStyle="TextStyle.Body2">@($"{h.FinishedAtUtc.Value.ToLocalTime():g}")</RadzenText> }
                    else
                    { <span style="color:var(--rz-text-secondary-color)">—</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="Продолжительность" Width="240px"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    <RadzenText TextStyle="TextStyle.Body2">@FormatDuration(h)</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Property="InitiatedByEmail" Title="Запустил"
                                  HeaderCssClass="half-painted-header">
                <Template Context="h">
                    @if (!string.IsNullOrEmpty(h.InitiatedByEmail))
                    { <RadzenText TextStyle="TextStyle.Body2" Class="rz-text-truncate" title="@h.InitiatedByEmail">@h.InitiatedByEmail</RadzenText> }
                    else
                    { <span style="color:var(--rz-text-secondary-color)">—</span> }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="SyncJobHistory" Title="" Width="90px" Sortable="false" Filterable="false"
                                  TextAlign="TextAlign.Right" HeaderCssClass="half-painted-header"
                                  Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                <Template Context="h">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.End" Style="flex-wrap: nowrap;">
                        @if (h.Status is SyncJobStatusEnum.Enqueued or SyncJobStatusEnum.Processing)
                        {
                            <RadzenButton Icon="stop_circle" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Danger"
                                          IsBusy="@_cancellingIds.Contains(h.Id)"
                                          Disabled="@_cancellingIds.Contains(h.Id)"
                                          Click="@(() => CancelJobAsync(h))" title="Остановить" />
                        }
                        @if (!string.IsNullOrEmpty(h.ResultJson))
                        {
                            <RadzenButton Icon="info" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Light"
                                          Click="@(() => ShowResultDialogAsync(h))" title="Результат" />
                        }
                        else if (!string.IsNullOrEmpty(h.ErrorMessage))
                        {
                            <RadzenButton Icon="error" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Click="@(() => ShowErrorDialogAsync(h))" title="Ошибка" />
                        }
                        @if (h.Status is not (SyncJobStatusEnum.Enqueued or SyncJobStatusEnum.Processing))
                        {
                            <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Light"
                                          IsBusy="@_deletingIds.Contains(h.Id)"
                                          Disabled="@_deletingIds.Contains(h.Id)"
                                          Click="@(() => DeleteJobAsync(h))" title="Удалить запись" />
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private List<SyncJobHistory> _historyItems = new();
    private List<SyncJobHistory> _filteredItems = new();
    private bool _hasActiveJobs;
    private bool _isLoading;
    private Density _density = Density.Default;

    private SyncJobTypeEnum? _filterType;
    private SyncJobStatusEnum? _filterStatus;

    private record FilterOption<T>(string Label, T? Value);

    private readonly List<FilterOption<SyncJobTypeEnum>> _filterTypeOptions = new()
    {
        new("Загрузка заказов", SyncJobTypeEnum.Sync),
        new("Обновление статусов", SyncJobTypeEnum.Update)
    };

    private readonly List<FilterOption<SyncJobStatusEnum>> _filterStatusOptions = new()
    {
        new("В очереди", SyncJobStatusEnum.Enqueued),
        new("Выполняется", SyncJobStatusEnum.Processing),
        new("Завершена", SyncJobStatusEnum.Succeeded),
        new("Ошибка", SyncJobStatusEnum.Failed),
        new("Отменена", SyncJobStatusEnum.Cancelled),
    };

    private readonly HashSet<Guid> _cancellingIds = new();
    private readonly HashSet<Guid> _deletingIds = new();

    private List<SyncJobSchedule> _schedules = new();
    private readonly HashSet<Guid> _deletingScheduleIds = new();
    private readonly HashSet<Guid> _togglingScheduleIds = new();

    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource _pollCts = new();

    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        await LoadHistoryAsync();
        await LoadSchedulesAsync();
        // Polling запускается всегда — чтобы видеть задачи запущенные по расписанию
        StartPollingIfNeeded();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!TenantProvider.IsResolved) return;

        await ConnectSignalRAsync();
    }

    private async Task ConnectSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/sync"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<JobCompletedPayload>("JobStarted", async payload =>
        {
            await InvokeAsync(async () =>
            {
                await LoadHistoryAsync();
                StateHasChanged();
            });
        });

        _hubConnection.On<JobCompletedPayload>("JobCompleted", async payload =>
        {
            await InvokeAsync(async () =>
            {
                await LoadHistoryAsync();
                var h = _historyItems.FirstOrDefault(x => x.Id == payload.HistoryId);
                if (h is not null)
                    NotifyJobResult(h, h.JobType == SyncJobTypeEnum.Sync ? "Загрузка заказов" : "Обновление статусов");
                StateHasChanged();
            });
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinTenantGroup", TenantProvider.TenantId!.Value.ToString());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SignalR] Connection failed, polling-only mode: {ex.Message}");
        }
    }

    private async Task OpenEnqueueDialogAsync()
    {
        var result = await DialogService.OpenAsync(
            "Запустить фоновую задачу",
            ds => @<EnqueueJobDialog JobService="@JobService"
                                     DialogService="@ds"
                                     NotificationService="@NotificationService" />,
            new DialogOptions { Width = "700px", Resizable = true, Draggable = true });

        if (result is true)
        {
            NotificationService.Notify(NotificationSeverity.Info, "Задача поставлена в очередь",
                "Следите за прогрессом в таблице ниже.");
            await LoadHistoryAsync();
            StartPollingIfNeeded();
        }
    }

    private async Task CancelJobAsync(SyncJobHistory h)
    {
        if (string.IsNullOrEmpty(h.HangfireJobId)) return;
        _cancellingIds.Add(h.Id);
        try
        {
            await JobService.CancelJobAsync(h.HangfireJobId);
            await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка отмены", ex.Message);
        }
        finally
        {
            _cancellingIds.Remove(h.Id);
        }
    }

    private async Task DeleteJobAsync(SyncJobHistory h)
    {
        var confirmed = await DialogService.Confirm(
            "Удалить запись из истории?",
            "Подтверждение",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена" });

        if (confirmed != true) return;

        _deletingIds.Add(h.Id);
        try
        {
            await JobService.DeleteJobAsync(h.Id);
            await LoadHistoryAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка удаления", ex.Message);
        }
        finally
        {
            _deletingIds.Remove(h.Id);
        }
    }

    private void StartPollingIfNeeded()
    {
        if (_pollTimer is not null) return; // уже запущен

        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        _ = Task.Run(async () =>
        {
            try
            {
                while (await _pollTimer.WaitForNextTickAsync(_pollCts.Token))
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadHistoryAsync();
                        StateHasChanged();
                    });
                    // Polling не останавливается — scheduled jobs могут появиться в любой момент
                }
            }
            catch (OperationCanceledException) { }
            finally
            {
                _pollTimer?.Dispose();
                _pollTimer = null;
            }
        });
    }

    private void StopPolling()
    {
        _pollCts.Cancel();
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

    private async Task LoadSchedulesAsync()
    {
        _schedules = await JobService.GetSchedulesAsync();
    }

    private async Task OpenCreateScheduleDialogAsync()
    {
        var result = await DialogService.OpenAsync(
            "Новое расписание",
            ds => @<ScheduleJobDialog JobService="@JobService" DialogService="@ds" />,
            new DialogOptions { Width = "930px", Resizable = true, Draggable = true });

        if (result is true)
            await LoadSchedulesAsync();
    }

    private async Task OpenEditScheduleDialogAsync(SyncJobSchedule schedule)
    {
        var result = await DialogService.OpenAsync(
            "Редактировать расписание",
            ds => @<ScheduleJobDialog JobService="@JobService" DialogService="@ds" EditSchedule="@schedule" />,
            new DialogOptions { Width = "930px", Resizable = true, Draggable = true });

        if (result is true)
            await LoadSchedulesAsync();
    }

    private async Task ToggleScheduleAsync(SyncJobSchedule s)
    {
        if (_togglingScheduleIds.Contains(s.Id)) return;
        _togglingScheduleIds.Add(s.Id);
        try
        {
            await JobService.SetScheduleEnabledAsync(s.Id, !s.IsEnabled);
            await LoadSchedulesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
        finally
        {
            _togglingScheduleIds.Remove(s.Id);
        }
    }

    private async Task DeleteScheduleAsync(SyncJobSchedule s)
    {
        var confirmed = await DialogService.Confirm(
            "Удалить расписание? Задача больше не будет запускаться автоматически.",
            "Подтверждение",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена" });

        if (confirmed != true) return;

        _deletingScheduleIds.Add(s.Id);
        try
        {
            await JobService.DeleteScheduleAsync(s.Id);
            await LoadSchedulesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка удаления", ex.Message);
        }
        finally
        {
            _deletingScheduleIds.Remove(s.Id);
        }
    }

    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        try
        {
            _historyItems = await JobService.GetHistoryAsync(200);
            _hasActiveJobs = _historyItems.Any(h => h.Status is SyncJobStatusEnum.Enqueued or SyncJobStatusEnum.Processing);
            ApplyFilters();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        var q = _historyItems.AsEnumerable();

        if (_filterType.HasValue)
            q = q.Where(h => h.JobType == _filterType.Value);

        if (_filterStatus.HasValue)
            q = q.Where(h => h.Status == _filterStatus.Value);

        _filteredItems = q.OrderByDescending(h => h.StartedAtUtc).ToList();
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };

    private async Task ShowResultDialogAsync(SyncJobHistory history)
    {
        if (string.IsNullOrEmpty(history.ResultJson)) return;

        var summary = JsonSerializer.Deserialize<OrderSyncSummary>(history.ResultJson);
        if (summary is null) return;

        await DialogService.OpenAsync(
            history.JobType == SyncJobTypeEnum.Sync ? "Результат синхронизации" : "Результат обновления",
            ds => @<SyncResultDialogContent Summary="@summary" JobType="@history.JobType" />,
            new DialogOptions { Width = "900px", Resizable = true, Draggable = true });
    }

    private async Task ShowErrorDialogAsync(SyncJobHistory history)
    {
        await DialogService.Alert(history.ErrorMessage ?? "Неизвестная ошибка", "Ошибка задачи",
            new AlertOptions { OkButtonText = "Закрыть" });
    }

    private void NotifyJobResult(SyncJobHistory? h, string jobName)
    {
        if (h is null) return;
        switch (h.Status)
        {
            case SyncJobStatusEnum.Succeeded:
                NotificationService.Notify(NotificationSeverity.Success, $"{jobName} завершена", "Задача успешно выполнена.");
                break;
            case SyncJobStatusEnum.Failed:
                NotificationService.Notify(NotificationSeverity.Error, $"{jobName} завершилась с ошибкой",
                    h.ErrorMessage ?? "Неизвестная ошибка.");
                break;
            case SyncJobStatusEnum.Cancelled:
                NotificationService.Notify(NotificationSeverity.Warning, $"{jobName} отменена", "Задача была остановлена.");
                break;
        }
    }

    private static string FormatParameters(SyncJobHistory h)
    {
        if (string.IsNullOrEmpty(h.ParametersJson)) return "—";
        try
        {
            using var doc = JsonDocument.Parse(h.ParametersJson);
            var root = doc.RootElement;
            if (root.TryGetProperty("From", out var fromEl) && root.TryGetProperty("To", out var toEl))
            {
                var from = fromEl.GetDateTime().ToLocalTime();
                var to = toEl.GetDateTime().ToLocalTime();
                return $"{from:dd.MM.yyyy} – {to:dd.MM.yyyy}";
            }
            return h.ParametersJson;
        }
        catch { return h.ParametersJson; }
    }

    private static string FormatDuration(SyncJobHistory h)
    {
        if (!h.FinishedAtUtc.HasValue) return "—";
        var d = h.FinishedAtUtc.Value - h.StartedAtUtc;
        if (d < TimeSpan.Zero) return "—";
        var mins = (int)d.TotalMinutes;
        var secs = d.Seconds;
        return mins > 0 ? $"{mins} мин {secs} сек" : $"{secs} сек";
    }

    private static BadgeStyle StatusBadgeStyle(SyncJobStatusEnum s) => s switch
    {
        SyncJobStatusEnum.Enqueued => BadgeStyle.Warning,
        SyncJobStatusEnum.Processing => BadgeStyle.Info,
        SyncJobStatusEnum.Succeeded => BadgeStyle.Success,
        SyncJobStatusEnum.Failed => BadgeStyle.Danger,
        SyncJobStatusEnum.Cancelled => BadgeStyle.Secondary,
        _ => BadgeStyle.Light
    };

    private static string StatusLabel(SyncJobStatusEnum s) => s switch
    {
        SyncJobStatusEnum.Enqueued => "В очереди",
        SyncJobStatusEnum.Processing => "Выполняется",
        SyncJobStatusEnum.Succeeded => "Завершена",
        SyncJobStatusEnum.Failed => "Ошибка",
        SyncJobStatusEnum.Cancelled => "Отменена",
        _ => s.ToString()
    };

    private static int ParseDaysBack(string? syncParams)
    {
        if (string.IsNullOrEmpty(syncParams)) return 7;
        try
        {
            using var doc = JsonDocument.Parse(syncParams);
            if (doc.RootElement.TryGetProperty("DaysBack", out var el) && el.TryGetInt32(out var d))
                return d;
        }
        catch { }
        return 7;
    }

    public async ValueTask DisposeAsync()
    {
        StopPolling();
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }

