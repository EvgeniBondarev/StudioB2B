    private static int ParseDaysBack(string? syncParams)
    {
        if (string.IsNullOrEmpty(syncParams)) return 7;
        try
        {
            using var doc = JsonDocument.Parse(syncParams);
            if (doc.RootElement.TryGetProperty("DaysBack", out var el) && el.TryGetInt32(out var d))
                return d;
        }
        catch { }
        return 7;
    }

