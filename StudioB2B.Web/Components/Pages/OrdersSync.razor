    private async Task RunScheduleNowAsync(SyncJobSchedule s)
    {
        if (_runningScheduleIds.Contains(s.Id)) return;
        _runningScheduleIds.Add(s.Id);
        try
        {
            var daysBack = ParseDaysBack(s.SyncParams);
            var from = DateTime.Now.Date.AddDays(-daysBack);
            var to = DateTime.Now.Date.AddDays(1).AddTicks(-1);
            var jobTypeLabel = JobTypeLabel(s.JobType);

            if (s.JobType == SyncJobType.Sync)
                await JobService.EnqueueSyncAsync(from, to);
            else if (s.JobType == SyncJobType.Returns)
                await JobService.EnqueueReturnsSyncAsync(from, to);
            else
                await JobService.EnqueueUpdateAsync(from, to);

            NotificationService.Notify(NotificationSeverity.Info, $"{jobTypeLabel} запущена",
                "Следите за прогрессом в таблице ниже.");
            await LoadHistoryAsync();
            StartPollingIfNeeded();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка запуска", ex.Message);
        }
        finally
        {
            _runningScheduleIds.Remove(s.Id);
        }
    }
