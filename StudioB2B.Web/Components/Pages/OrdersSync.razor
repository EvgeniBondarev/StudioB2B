@page "/orders-sync"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Application.Common
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Domain.Entities.Orders
@using StudioB2B.Domain.Entities.Marketplace
@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject IOrderSyncService OrderSyncService
@inject NotificationService NotificationService

<PageTitle>Загрузка заказов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри рабочего пространства (тенанта).
    </RadzenAlert>
}
else
{
    <RadzenCard Style="max-width: 960px; margin: 0 auto;">
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Загрузка заказов Ozon (FBS)">
                    <RadzenStack Gap="1.5rem">

                        <RadzenStack Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600;">
                                Синхронизация заказов из Ozon
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                Выберите период (не более 30 дней), за который нужно загрузить FBS‑отправления
                                для всех клиентов с типом <b>Ozon</b> и режимом <b>FBS</b>.
                            </RadzenText>
                        </RadzenStack>

                        @if (!_showProcess)
                        {
                            <!-- Форма выбора периода -->
                            <RadzenStack Gap="1rem">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Start">
                                    <div class="rz-p-12 rz-text-align-center" style="flex: 1;">
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-2">
                                            Дата начала периода
                                        </RadzenText>
                                        <RadzenDatePicker @bind-Value="_from"
                                                          Inline="true"
                                                          ShowTime="false" />
                                    </div>
                                    <div class="rz-p-12 rz-text-align-center" style="flex: 1;">
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-2">
                                            Дата окончания периода
                                        </RadzenText>
                                        <RadzenDatePicker @bind-Value="_to"
                                                          Inline="true"
                                                          ShowTime="false" />
                                    </div>
                                </RadzenStack>

                                <RadzenStack Gap="0.5rem">
                                    <RadzenButton Text="Запустить синхронизацию"
                                                  Icon="cloud_sync"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy="@_isSyncRunning"
                                                  Disabled="@_isSyncRunning"
                                                  Click="@RunSyncAsync" />
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                        Максимальная длина периода — 30 дней.
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenStack>
                        }
                        else
                        {
                            <!-- Визуализация этапов процесса -->
                            <RadzenTimeline>
                                <Items>
                                    <RadzenTimelineItem PointStyle="@StepStyle(0)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                        Style="@StepLabelStyle(0)">Подготовка</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(0)">
                                                Поиск клиентов Ozon FBS и подготовка параметров синхронизации.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>

                                    <RadzenTimelineItem PointStyle="@StepStyle(1)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                        Style="@StepLabelStyle(1)">Загрузка заказов</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(1)">
                                                Вызов Ozon API, получение FBS‑отправлений и цен товаров.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>

                                    <RadzenTimelineItem PointStyle="@StepStyle(2)" PointSize="PointSize.Medium">
                                        <LabelContent>
                                            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                        Style="@StepLabelStyle(2)">Сохранение и результат</RadzenText>
                                        </LabelContent>
                                        <ChildContent>
                                            <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(2)">
                                                Обновление базы данных и отображение результата по клиентам.
                                            </RadzenText>
                                        </ChildContent>
                                    </RadzenTimelineItem>
                                </Items>
                            </RadzenTimeline>

                            <!-- Кнопка запуска и анимация процесса -->
                            <RadzenStack Gap="0.75rem">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <RadzenButton Text="Синхронизация запущена"
                                                  Icon="cloud_sync"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Size="ButtonSize.Medium"
                                                  IsBusy="@_isSyncRunning"
                                                  Disabled="true" />

                                    @if (_isSyncRunning)
                                    {
                                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                            Синхронизация выполняется, пожалуйста, подождите...
                                        </RadzenText>
                                    }
                                </RadzenStack>

                                @if (_isSyncRunning)
                                {
                                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate"
                                                       ShowValue="false"
                                                       Style="width: 100%; max-width: 420px;" />
                                }
                            </RadzenStack>
                        }

                        <!-- Результат последнего запуска -->
                        <RadzenStack Gap="0.75rem">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">
                                Результат последней синхронизации
                            </RadzenText>

                            @if (!_hasResult)
                            {
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                    Синхронизация ещё не выполнялась в текущей сессии.
                                </RadzenText>
                            }
                            else
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenText TextStyle="TextStyle.Body2">
                                            Новых отправлений: <b>@_newShipmentsCount</b>. Клиентов с новыми заказами: <b>@_clientsWithNewShipments</b>.
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2">
                                            Загружено (новых): <b>@_syncResult.ShipmentsCreated</b> отправлений, <b>@_syncResult.OrdersCreated</b> заказов.
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2">
                                            Обновлено: <b>@_syncResult.ShipmentsUpdated</b> отправлений, <b>@_syncResult.OrdersUpdated</b> заказов.
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Body2">
                                            Не тронуто: <b>@_syncResult.ShipmentsUntouched</b> отправлений, <b>@_syncResult.OrdersUntouched</b> заказов.
                                        </RadzenText>
                                        @if (_startedAtUtc.HasValue && _finishedAtUtc.HasValue)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                                Запуск: @_startedAtUtc.Value.ToLocalTime():g · Завершено: @_finishedAtUtc.Value.ToLocalTime():g
                                            </RadzenText>
                                        }
                                    </RadzenStack>
                                </RadzenAlert>

                                @if (_clientResults.Count > 0)
                                {
                                    <RadzenDataGrid TItem="ClientResult"
                                                    Data="@_clientResults"
                                                    Density="Density.Compact"
                                                    AllowPaging="true"
                                                    PageSize="10"
                                                    ShowPagingSummary="true"
                                                    AllowSorting="true"
                                                    Style="margin-top: 0.5rem;">
                                        <Columns>
                                            <RadzenDataGridColumn TItem="ClientResult"
                                                                  Property="ClientName"
                                                                  Title="Клиент"
                                                                  Width="220px" />
                                            <RadzenDataGridColumn TItem="ClientResult"
                                                                  Property="Mode"
                                                                  Title="Режим"
                                                                  Width="120px" />
                                            <RadzenDataGridColumn TItem="ClientResult"
                                                                  Property="NewShipments"
                                                                  Title="Новые отправления"
                                                                  TextAlign="TextAlign.Center"
                                                                  Width="160px" />
                                        </Columns>
                                    </RadzenDataGrid>
                                }
                            }
                        </RadzenStack>
                    </RadzenStack>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </RadzenCard>
}

@code {
    private bool _isSyncRunning;
    private int _step;
    private bool _hasResult;
    private int _newShipmentsCount;
    private int _clientsWithNewShipments;
    private OrderSyncResult _syncResult = new();
    private DateTime? _startedAtUtc;
    private DateTime? _finishedAtUtc;
    private readonly List<ClientResult> _clientResults = new();
    private DateTime? _from = DateTime.Today.AddDays(-7);
    private DateTime? _to = DateTime.Today;
    private bool _showProcess;

    private async Task RunSyncAsync()
    {
        if (!TenantProvider.IsResolved)
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Нет тенанта", "Синхронизация доступна только внутри рабочего пространства.");
            return;
        }

        if (_isSyncRunning)
            return;

        if (!_from.HasValue || !_to.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Некорректный период", "Выберите даты начала и окончания периода.");
            return;
        }

        var from = _from.Value.Date;
        var to = _to.Value.Date.AddDays(1).AddTicks(-1);

        if (from > to)
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Некорректный период", "Дата начала не может быть позже даты окончания.");
            return;
        }

        if ((to - from).TotalDays > 30)
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Слишком длинный период", "Максимальная длина периода — 30 дней.");
            return;
        }

        _isSyncRunning = true;
        _hasResult = false;
        _step = 0;
        _newShipmentsCount = 0;
        _clientsWithNewShipments = 0;
        _syncResult = new OrderSyncResult();
        _clientResults.Clear();
        _startedAtUtc = DateTime.UtcNow;
        _finishedAtUtc = null;
        _showProcess = true;

        try
        {
            await using var db = Factory.CreateDbContext();

            // Шаг 0: подготовка
            _step = 0;
            StateHasChanged();

            // Шаг 1: запуск доменной синхронизации
            _step = 1;
            _syncResult = await OrderSyncService.SyncAllAsync(from, to, CancellationToken.None);

            // Шаг 2: считаем результат по только что созданным отправлениям
            _step = 2;
            _finishedAtUtc = DateTime.UtcNow;

            var fromCreated = _startedAtUtc ?? DateTime.UtcNow.AddMinutes(-5);

            var newShipmentsQuery = db.Shipments!
                .Include(s => s.MarketplaceClient)
                .Include(s => s.MarketplaceClient!.Mode)
                .Where(s => s.CreatedAt >= fromCreated);

            var newShipments = await newShipmentsQuery.ToListAsync();

            _newShipmentsCount = newShipments.Count;

            var grouped = newShipments
                .Where(s => s.MarketplaceClient != null)
                .GroupBy(s => s.MarketplaceClient!)
                .ToList();

            _clientsWithNewShipments = grouped.Count;

            foreach (var g in grouped.OrderByDescending(g => g.Count()))
            {
                _clientResults.Add(new ClientResult
                {
                    ClientName = g.Key.Name,
                    Mode = g.Key.Mode?.Name ?? string.Empty,
                    NewShipments = g.Count()
                });
            }

            _hasResult = true;

            NotificationService.Notify(NotificationSeverity.Success,
                "Синхронизация завершена",
                _syncResult.ShipmentsCreated + _syncResult.ShipmentsUpdated > 0
                    ? $"Загружено: {_syncResult.ShipmentsCreated} отправлений, {_syncResult.OrdersCreated} заказов. Обновлено: {_syncResult.ShipmentsUpdated} отправлений, {_syncResult.OrdersUpdated} заказов."
                    : "Новых и обновлённых записей не найдено.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error,
                "Ошибка синхронизации", ex.Message);
        }
        finally
        {
            _isSyncRunning = false;
        }
    }

    private PointStyle StepStyle(int step)
    {
        // После завершения синхронизации подсвечиваем все шаги зелёным
        if (!_isSyncRunning && _hasResult)
            return PointStyle.Success;

        return step switch
        {
            _ when step < _step  => PointStyle.Success,
            _ when step == _step => PointStyle.Primary,
            _                    => PointStyle.Secondary
        };
    }

    private string StepLabelStyle(int step)
    {
        if (!_isSyncRunning && _hasResult)
            return "color: var(--rz-success); font-weight: 700;";

        return step == _step
            ? "color: var(--rz-primary); font-weight: 700;"
            : step < _step
                ? "color: var(--rz-success);"
                : "color: var(--rz-text-disabled-color);";
    }

    private string StepDescStyle(int step) => step <= _step
        ? string.Empty
        : "color: var(--rz-text-disabled-color);";

    private sealed class ClientResult
    {
        public string ClientName { get; set; } = string.Empty;
        public string Mode { get; set; } = string.Empty;
        public int NewShipments { get; set; }
    }
}

