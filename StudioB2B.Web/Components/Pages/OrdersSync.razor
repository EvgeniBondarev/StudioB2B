    private void StartPollingIfNeeded()
    {
        if (_pollTimer is not null) return; // уже запущен

        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        _ = Task.Run(async () =>
        {
            try
            {
                while (await _pollTimer.WaitForNextTickAsync(_pollCts.Token))
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadHistoryAsync();
                        StateHasChanged();
                    });
                    // Polling не останавливается — scheduled jobs могут появиться в любой момент
                }
            }
            catch (OperationCanceledException) { }
            finally
            {
                _pollTimer?.Dispose();
                _pollTimer = null;
            }
        });
    }

    private void StopPolling()
    {
        _pollCts.Cancel();
        _pollTimer?.Dispose();
        _pollTimer = null;
    }

