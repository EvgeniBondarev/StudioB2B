    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        try
        {
            _historyItems = await JobService.GetHistoryAsync(200);
            _hasActiveJobs = _historyItems.Any(h => h.Status is SyncJobStatus.Enqueued or SyncJobStatus.Processing);
            ApplyFilters();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        var q = _historyItems.AsEnumerable();

        if (_filterType.HasValue)
            q = q.Where(h => h.JobType == _filterType.Value);

        if (_filterStatus.HasValue)
            q = q.Where(h => h.Status == _filterStatus.Value);

        _filteredItems = q.OrderByDescending(h => h.StartedAtUtc).ToList();

        // Recompute counts from full history
        _typeCountSync = _historyItems.Count(h => h.JobType == SyncJobType.Sync);
        _typeCountUpdate = _historyItems.Count(h => h.JobType == SyncJobType.Update);
        _typeCountReturns = _historyItems.Count(h => h.JobType == SyncJobType.Returns);
        _statusCountEnqueued = _historyItems.Count(h => h.Status == SyncJobStatus.Enqueued);
        _statusCountProcessing = _historyItems.Count(h => h.Status == SyncJobStatus.Processing);
        _statusCountSucceeded = _historyItems.Count(h => h.Status == SyncJobStatus.Succeeded);
        _statusCountFailed = _historyItems.Count(h => h.Status == SyncJobStatus.Failed);
        _statusCountCancelled = _historyItems.Count(h => h.Status == SyncJobStatus.Cancelled);
    }

