@page "/audit"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using Radzen
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Domain.Entities.Common
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services
@using System.Text.Json

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject DialogService DialogService

@implements IDisposable

<PageTitle>Журнал изменений</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Журнал изменений</RadzenText>
        <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                      Click="@ToggleDensity" Title="@GetDensityTitle()" />
    </RadzenStack>

    <!-- Фильтры над таблицей -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End"
                 Gap="1rem" Style="margin-bottom: 1rem; flex-wrap: wrap;">

        <RadzenStack Gap="0.25rem">
            <RadzenLabel Text="Сущность" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color);" />
            <RadzenDropDown @bind-Value="_filterEntity"
                            Data="@_entityNames"
                            Placeholder="Все"
                            AllowClear="true"
                            Style="min-width: 180px;"
                            Change="@OnFilterChange">
                <Template Context="entityName">
                    @AuditDisplayHelper.GetEntityDisplayName((string)entityName)
                </Template>
                <ValueTemplate Context="entityName">
                    @AuditDisplayHelper.GetEntityDisplayName((string)entityName)
                </ValueTemplate>
            </RadzenDropDown>
        </RadzenStack>

        <RadzenStack Gap="0.25rem">
            <RadzenLabel Text="Операция" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color);" />
            <RadzenDropDown @bind-Value="_filterChangeType"
                            Data="@_changeTypes"
                            Placeholder="Все"
                            AllowClear="true"
                            Style="min-width: 140px;"
                            Change="@OnFilterChange" />
        </RadzenStack>

        <RadzenStack Gap="0.25rem">
            <RadzenLabel Text="Пользователь" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color);" />
            <RadzenDropDown @bind-Value="_filterUser"
                            Data="@_userNames"
                            Placeholder="Все"
                            AllowClear="true"
                            Style="min-width: 180px;"
                            Change="@OnFilterChange" />
        </RadzenStack>

        <RadzenStack Gap="0.25rem">
            <RadzenLabel Text="С" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color);" />
            <RadzenDatePicker @bind-Value="_filterFrom"
                              DateFormat="dd.MM.yyyy"
                              Style="min-width: 140px;"
                              Change="@OnDateFilterChange" />
        </RadzenStack>

        <RadzenStack Gap="0.25rem">
            <RadzenLabel Text="По" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color);" />
            <RadzenDatePicker @bind-Value="_filterTo"
                              DateFormat="dd.MM.yyyy"
                              Style="min-width: 140px;"
                              Change="@OnDateFilterChange" />
        </RadzenStack>

        <RadzenButton Icon="clear_all" Text="Сбросить" Shade="Shade.Light" ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Small" Click="@ResetFilters" />
    </RadzenStack>

    <RadzenDataGrid @ref="_grid"
                    TItem="FieldAuditLog"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    AllowFiltering="false"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="30"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    IsLoading="@_loading"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="ChangedAtUtc"
                                  Title="Дата" Width="150px" Sortable="true">
                <Template Context="log">
                    <span title="@log.ChangedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")">
                        @log.ChangedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="ChangeType"
                                  Title="Операция" Width="110px" Sortable="true">
                <Template Context="log">
                    @{
                        var (icon, color, label) = log.ChangeType switch
                        {
                            "Added"    => ("add_circle",   "var(--rz-success)", "Создано"),
                            "Modified" => ("edit",         "var(--rz-info)",    "Изменено"),
                            "Deleted"  => ("delete",       "var(--rz-danger)",  "Удалено"),
                            _          => ("help_outline", "var(--rz-text-secondary-color)", log.ChangeType)
                        };
                    }
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                        <RadzenIcon Icon="@icon" Style="@($"font-size: 1rem; color: {color};")" />
                        <span style="@($"font-size: 0.8rem; color: {color}; font-weight: 600;")">@label</span>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="EntityName"
                                  Title="Сущность" Width="150px" Sortable="true">
                <Template Context="log">
                    <span style="font-size: 0.85rem; font-weight: 500;">@AuditDisplayHelper.GetEntityDisplayName(log.EntityName)</span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="EntityId"
                                  Title="ID записи" Width="130px" Sortable="false">
                <Template Context="log">
                    <span style="font-family: monospace; font-size: 0.75rem; color: var(--rz-text-secondary-color);"
                          title="@log.EntityId">
                        @ShortenId(log.EntityId)
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="FieldName"
                                  Title="Поле" Width="160px" Sortable="true">
                <Template Context="log">
                    <span style="font-size: 0.8rem;">@AuditDisplayHelper.GetFieldDisplayName(log.EntityName, log.FieldName)</span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Title="Было" Width="220px" Sortable="false">
                <Template Context="log">
                    <span style="color: var(--rz-danger); font-size: 0.85rem; word-break: break-word;">
                        @FormatValue(log.OldValue)
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Title="Стало" Width="220px" Sortable="false">
                <Template Context="log">
                    <span style="color: var(--rz-success); font-size: 0.85rem; word-break: break-word;">
                        @FormatValue(log.NewValue)
                    </span>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Property="ChangedByUserName"
                                  Title="Кто изменил" Width="180px" Sortable="true">
                <Template Context="log">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.3rem">
                        <RadzenIcon Icon="@(log.ChangedByUserName == SystemUser.RobotEmail ? "smart_toy" : "person")"
                                    Style="font-size: 0.9rem; color: var(--rz-text-secondary-color);" />
                        <span style="font-size: 0.82rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                              title="@log.ChangedByUserName">
                            @(log.ChangedByUserName == SystemUser.RobotEmail ? "Система" : log.ChangedByUserName)
                        </span>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="FieldAuditLog" Title="" Width="52px"
                                  Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="log">
                    <RadzenButton Icon="history" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                  Variant="Variant.Text"
                                  Title="История записи"
                                  Click="@(() => OpenEntityHistory(log))" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private TenantDbContext? _db;
    private RadzenDataGrid<FieldAuditLog>? _grid;

    private List<FieldAuditLog> _pageItems  = [];
    private int                 _totalCount = 0;
    private bool                _loading    = false;

    private Density _density = Density.Default;
    private readonly int[] _pageSizeOptions = [15, 30, 50, 100];

    // Данные для фильтров
    private List<string> _entityNames   = [];
    private List<string> _changeTypes   = ["Added", "Modified", "Deleted"];
    private List<string> _userNames     = [];

    // Значения фильтров
    private string?   _filterEntity     = null;
    private string?   _filterChangeType = null;
    private string?   _filterUser       = null;
    private DateTime? _filterFrom       = null;
    private DateTime? _filterTo         = null;

    protected override async Task OnInitializedAsync()
    {
        _db = Factory.CreateDbContext();
        await LoadFilterDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _grid is not null)
            await _grid.Reload();
    }

    private async Task LoadFilterDataAsync()
    {
        _entityNames = await _db!.FieldAuditLogs
            .Select(x => x.EntityName)
            .Distinct()
            .OrderBy(x => x)
            .AsNoTracking()
            .ToListAsync();

        _userNames = await _db.FieldAuditLogs
            .Where(x => x.ChangedByUserName != null)
            .Select(x => x.ChangedByUserName!)
            .Distinct()
            .OrderBy(x => x)
            .AsNoTracking()
            .ToListAsync();
    }

    private async Task LoadData(LoadDataArgs args)
    {
        // _db может быть null если grid вызвал LoadData до завершения OnInitializedAsync
        if (_db is null)
            return;

        _loading = true;
        StateHasChanged();

        try
        {
            var query = BuildQuery();

            _totalCount = await query.CountAsync();

            // Сортировка
            if (!string.IsNullOrEmpty(args.OrderBy))
                query = query.OrderBy(args.OrderBy);
            else
                query = query.OrderByDescending(x => x.ChangedAtUtc);

            _pageItems = await query
                .Skip(args.Skip ?? 0)
                .Take(args.Top ?? 30)
                .AsNoTracking()
                .ToListAsync();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private IQueryable<FieldAuditLog> BuildQuery()
    {
        var q = _db!.FieldAuditLogs.AsQueryable();

        if (!string.IsNullOrEmpty(_filterEntity))
            q = q.Where(x => x.EntityName == _filterEntity);

        if (!string.IsNullOrEmpty(_filterChangeType))
            q = q.Where(x => x.ChangeType == _filterChangeType);

        if (!string.IsNullOrEmpty(_filterUser))
            q = q.Where(x => x.ChangedByUserName == _filterUser);

        if (_filterFrom.HasValue)
            q = q.Where(x => x.ChangedAtUtc >= _filterFrom.Value.ToUniversalTime());

        if (_filterTo.HasValue)
            q = q.Where(x => x.ChangedAtUtc <= _filterTo.Value.AddDays(1).ToUniversalTime());

        return q;
    }

    private async Task OnFilterChange(object? _)
    {
        await RefreshGrid();
    }

    private async Task OnDateFilterChange(DateTime? _)
    {
        await RefreshGrid();
    }

    private async Task ResetFilters()
    {
        _filterEntity     = null;
        _filterChangeType = null;
        _filterUser       = null;
        _filterFrom       = null;
        _filterTo         = null;
        await RefreshGrid();
    }

    private async Task RefreshGrid()
    {
        if (_grid is not null)
            await _grid.Reload();
    }

    private async Task OpenEntityHistory(FieldAuditLog log)
    {
        await DialogService.OpenAsync<FieldAuditDialog>(
            $"История: {AuditDisplayHelper.GetEntityDisplayName(log.EntityName)}",
            new Dictionary<string, object?>
            {
                [nameof(FieldAuditDialog.EntityName)] = log.EntityName,
                [nameof(FieldAuditDialog.EntityId)]   = log.EntityId
            },
            new DialogOptions
            {
                Width    = "min(800px, 95vw)",
                Resizable = true,
                Draggable = true
            });
    }

    private void ToggleDensity() =>
        _density = _density == Density.Default ? Density.Compact : Density.Default;

    private string GetDensityTitle() =>
        _density == Density.Default ? "Компактный режим" : "Обычный режим";

    private static string ShortenId(string id) =>
        id.Length > 8 ? $"{id[..8]}…" : id;

    private static string FormatValue(string? raw)
    {
        if (raw is null || raw == "null") return "—";

        try
        {
            using var doc = JsonDocument.Parse(raw);
            var el = doc.RootElement;
            return el.ValueKind switch
            {
                JsonValueKind.String => el.GetString() ?? "—",
                JsonValueKind.Number => el.GetRawText(),
                JsonValueKind.True   => "да",
                JsonValueKind.False  => "нет",
                JsonValueKind.Null   => "—",
                _                    => raw
            };
        }
        catch { return raw; }
    }

    public void Dispose() => _db?.Dispose();
}



