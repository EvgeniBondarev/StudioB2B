@page "/transactions-history"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory

@implements IDisposable

<PageTitle>История проведений</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">История проведений документов</RadzenText>
        <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                      Click="@ToggleDensity" Title="@GetDensityTitle()" />
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Body2"
                Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem; display: block;">
        Журнал проведений документов: вид документа, заказ, время, результат, пользователь.
    </RadzenText>

    <RadzenDataGrid @ref="_grid"
                    TItem="OrderTransactionHistory"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    RowRender="@OnRowRender"
                    Density="@_density"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="25"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="OrderTransactionHistory" Property="OrderTransaction.Name" Title="Документ" Width="200px">
                <Template Context="h">
                    @if (h.OrderTransaction != null)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            @{
                                var hBg = GetSoftBackground(h.OrderTransaction.Color);
                                var hFg = IsLightColor(hBg) ? "#1f2937" : "#ffffff";
                            }
                            <span style="@($"width:24px;height:24px;border-radius:6px;background:{hBg};display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;")">
                                @if (!string.IsNullOrEmpty(h.OrderTransaction.Icon))
                                {
                                    <i class="rzi" style="font-size:15px;color:@hFg;">@h.OrderTransaction.Icon</i>
                                }
                            </span>
                            <span>@h.OrderTransaction.Name</span>
                        </RadzenStack>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransactionHistory" Title="Заказ" Width="320px" Filterable="false" Sortable="false">
                <Template Context="h">
                    @if (h.Order != null)
                    {
                        var postingNumber = h.Order.Shipment?.PostingNumber ?? h.Order.OzonOrderId?.ToString() ?? h.Order.Id.ToString("N")[..8];
                        var product = h.Order.ProductInfo?.Product;
                        <RadzenStack Gap="0.5rem" Style="min-width: 280px;">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin: 0;">
                                @postingNumber
                            </RadzenText>
                            @if (product != null)
                            {
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" Gap="0.5rem">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl"
                                             class="rz-border-radius"
                                             style="width: 48px; height: 48px; object-fit: contain; flex-shrink: 0;"
                                             alt="" />
                                    }
                                    <RadzenStack Gap="0.25rem" Style="flex: 1; min-width: 0;">
                                        @if (!string.IsNullOrEmpty(product.Article))
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); margin: 0;">
                                                Артикул: @product.Article
                                            </RadzenText>
                                        }
                                        <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; line-height: 1.3;"
                                                    title="@(product.Description ?? product.Name)">
                                            @(product.Description ?? product.Name)
                                        </RadzenText>
                                    </RadzenStack>
                                </RadzenStack>
                            }
                        </RadzenStack>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransactionHistory" Property="PerformedAtUtc" Title="Время" Width="160px" Sortable="true">
                <Template Context="h">
                    @h.PerformedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransactionHistory" Title="Результат" Width="200px">
                <Template Context="h">
                    @if (h.Success)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success"
                                     Text="@(h.PricesUpdated > 0 || h.FieldsUpdated > 0 ? $"OK, цен: {h.PricesUpdated}, полей: {h.FieldsUpdated}" : "OK")" />
                    }
                    else
                    {
                        <span title="@h.ErrorMessage">
                            <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="Ошибка" />
                        </span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransactionHistory" Property="PerformedByUserName" Title="Пользователь" Width="200px">
                <Template Context="h">
                    @(h.PerformedByUserName ?? "—")
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<OrderTransactionHistory>? _grid;
    private TenantDbContext? _db;
    private IEnumerable<OrderTransactionHistory> _pageItems = Array.Empty<OrderTransactionHistory>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && TenantProvider.IsResolved && _grid != null)
            await _grid.Reload();
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        await EnsureInitializedAsync();

        var query = _db!.OrderTransactionHistories
            .Include(h => h.Order!)
                .ThenInclude(o => o!.Shipment)
            .Include(h => h.Order!)
                .ThenInclude(o => o!.ProductInfo)
                    .ThenInclude(pi => pi!.Product)
            .Include(h => h.OrderTransaction)
            .AsNoTracking()
            .AsQueryable();

        if (!string.IsNullOrEmpty(args.Filter))
            query = query.Where(args.Filter);

        _totalCount = await query.CountAsync();

        query = !string.IsNullOrEmpty(args.OrderBy)
            ? query.OrderBy(args.OrderBy)
            : query.OrderByDescending(h => h.PerformedAtUtc);

        var skip = args.Skip ?? 0;
        var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 25);
        _pageItems = await query.Skip(skip).Take(take).ToListAsync();

        _loading = false;
    }

    private async Task EnsureInitializedAsync()
    {
        if (_db != null) return;
        _db = Factory.CreateDbContext();
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };

    private void OnRowRender(RowRenderEventArgs<OrderTransactionHistory> args)
    {
        if (args.Data == null) return;
        var color = args.Data.OrderTransaction?.Color;
        if (!string.IsNullOrEmpty(color))
        {
            var bg = GetSoftBackground(color);
            var fg = IsLightColor(bg) ? "#1f2937" : "#ffffff";
            args.Attributes["style"] = $"background-color: {bg}; color: {fg};";
        }
    }

    private static string GetSoftBackground(string? color)
    {
        if (string.IsNullOrEmpty(color)) return "#ececff";
        color = color.TrimStart('#').Trim();
        if (color.Length < 6) return "#ececff";
        try
        {
            var r = Convert.ToInt32(color[..2], 16);
            var g = Convert.ToInt32(color[2..4], 16);
            var b = Convert.ToInt32(color[4..6], 16);
            r = (int)(r + (255 - r) * 0.7);
            g = (int)(g + (255 - g) * 0.7);
            b = (int)(b + (255 - b) * 0.7);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return "#ececff"; }
    }

    private static bool IsLightColor(string hex)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length < 6) return true;
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 128;
        }
        catch { return true; }
    }

    public void Dispose() => _db?.Dispose();
}
