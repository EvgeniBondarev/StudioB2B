@page "/questions"
@attribute [Authorize(Roles = "QuestionsView")]
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Shared.DTOs

@inject ITenantProvider TenantProvider
@inject IMarketplaceClientService MarketplaceClientService
@inject IOzonQuestionsService QuestionsService
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject UserContext UserContext

<link rel="stylesheet" href="css/questions.css" />

<PageTitle>Вопросы покупателей</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <div class="questions-page-root">

        <div class="questions-top">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 0.5rem; margin-top:0.35rem">
                <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Вопросы покупателей</RadzenText>
                <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Light" Size="ButtonSize.Small"
                              Click="@ReloadAsync" IsBusy="@_loading" Text="Обновить"/>
            </RadzenStack>

            <div class="questions-tab-bar">
                <span class="questions-tab @(_activeTab == 0 ? "active" : "")" @onclick="@(() => SwitchTab(0))">
                    Вопросы
                </span>
                <span class="questions-tab @(_activeTab == 1 ? "active" : "")" @onclick="@(() => SwitchTab(1))">
                    Топ товаров
                </span>
            </div>
        </div>

        @if (_activeTab == 0)
        {
            @if (_questionCounts is not null)
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                             Style="padding: 0 0 0.75rem 0; flex-wrap: wrap;">
                    @{ var allActive = string.IsNullOrEmpty(_filterStatus); }
                    <span class="q-pill @(allActive ? "active" : "")" style="background:@(allActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allActive ? "#fff" : "var(--rz-text-color)");"
                          @onclick="@(async () => { _filterStatus = null; await OnStatusPillClick(); })">
                        Все
                        @if (_questionCounts.All > 0)
                        {
                            <span class="q-pill-count">@_questionCounts.All</span>
                        }
                    </span>
                    <span class="q-pill @(_filterStatus == "NEW" ? "active" : "")" style="background:@(_filterStatus == "NEW" ? "#3b82f6" : "#dbeafe"); color:@(_filterStatus == "NEW" ? "#fff" : "#1e3a5f");"
                          @onclick="@(async () => { _filterStatus = _filterStatus == "NEW" ? null : "NEW"; await OnStatusPillClick(); })">
                        Новые
                        @if (_questionCounts.New > 0)
                        {
                            <span class="q-pill-count">@_questionCounts.New</span>
                        }
                    </span>
                    <span class="q-pill @(_filterStatus == "VIEWED" ? "active" : "")" style="background:@(_filterStatus == "VIEWED" ? "#8b5cf6" : "#ede9fe"); color:@(_filterStatus == "VIEWED" ? "#fff" : "#4c1d95");"
                          @onclick="@(async () => { _filterStatus = _filterStatus == "VIEWED" ? null : "VIEWED"; await OnStatusPillClick(); })">
                        Просмотренные
                        @if (_questionCounts.Viewed > 0)
                        {
                            <span class="q-pill-count">@_questionCounts.Viewed</span>
                        }
                    </span>
                    <span class="q-pill @(_filterStatus == "PROCESSED" ? "active" : "")" style="background:@(_filterStatus == "PROCESSED" ? "#10b981" : "#d1fae5"); color:@(_filterStatus == "PROCESSED" ? "#fff" : "#064e3b");"
                          @onclick="@(async () => { _filterStatus = _filterStatus == "PROCESSED" ? null : "PROCESSED"; await OnStatusPillClick(); })">
                        Обработанные
                        @if (_questionCounts.Processed > 0)
                        {
                            <span class="q-pill-count">@_questionCounts.Processed</span>
                        }
                    </span>
                    <span class="q-pill @(_filterStatus == "UNPROCESSED" ? "active" : "")" style="background:@(_filterStatus == "UNPROCESSED" ? "#f59e0b" : "#fef3c7"); color:@(_filterStatus == "UNPROCESSED" ? "#fff" : "#78350f");"
                          @onclick="@(async () => { _filterStatus = _filterStatus == "UNPROCESSED" ? null : "UNPROCESSED"; await OnStatusPillClick(); })">
                        Необработанные
                        @if (_questionCounts.Unprocessed > 0)
                        {
                            <span class="q-pill-count">@_questionCounts.Unprocessed</span>
                        }
                    </span>
                </RadzenStack>
            }

            <RadzenCard Style="margin-bottom: 0.6rem; padding: 0.5rem 0.75rem;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                             Gap="0.75rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                        <RadzenLabel Text="Маркетплейс:" Style="white-space: nowrap;" />
                        <RadzenDropDown TValue="Guid?" @bind-Value="_filterClientId"
                                        Data="@_clientOptions"
                                        TextProperty="Name" ValueProperty="Id"
                                        Placeholder="Все"
                                        AllowClear="true"
                                        Style="width: 180px;"
                                        Change="@OnFilterChanged" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                        <RadzenLabel Text="Дата с:" Style="white-space: nowrap;" />
                        <RadzenDatePicker @bind-Value="_filterFrom"
                                          DateFormat="dd.MM.yyyy"
                                          Style="width: 150px;" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                        <RadzenLabel Text="по:" Style="white-space: nowrap;" />
                        <RadzenDatePicker @bind-Value="_filterTo"
                                          DateFormat="dd.MM.yyyy"
                                          Style="width: 150px;" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>

        <div class="questions-layout">

            <div class="question-list-panel">
                @if (_loading && !_questions.Any())
                {
                    <div class="dlg-loading" style="flex: 1; padding: 2rem;">
                        <div class="dlg-spinner"></div>
                    </div>
                }
                else if (!_questions.Any())
                {
                    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                                 Style="flex: 1; padding: 2rem; gap: 0.5rem;">
                        <RadzenIcon Icon="help_outline"
                                    Style="font-size: 2.5rem; color: var(--rz-text-secondary-color);" />
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Style="color: var(--rz-text-secondary-color); text-align: center;">
                            Вопросов не найдено
                        </RadzenText>
                    </RadzenStack>
                }
                else
                {
                    <div class="question-list-scroll">
                        @foreach (var q in _questions)
                        {
                            var isSelected = _selectedQuestion?.Id == q.Id &&
                                             _selectedQuestion?.MarketplaceClientId == q.MarketplaceClientId;
                            var cardClass = isSelected ? "question-item-card selected" : "question-item-card";
                            <RadzenCard @key="q.Id"
                                        Class="@cardClass"
                                        @onclick="@(() => SelectQuestion(q))">
                                <div class="question-item-header">
                                    <div class="question-item-title">
                                        <span class="question-item-client" title="@q.MarketplaceClientName">
                                            @q.MarketplaceClientName
                                        </span>
                                        <span class="question-item-sku">
                                            SKU: @q.Sku
                                        </span>
                                    </div>
                                    <span class="question-item-date">
                                        @FormatTimeAgo(q.PublishedAt)
                                    </span>
                                </div>
                                <div class="question-item-text" title="@q.Text">
                                    @q.Text
                                </div>
                                <div class="question-item-footer">
                                    <RadzenBadge Text="@GetStatusLabel(q.Status)"
                                                 BadgeStyle="@GetStatusBadgeStyle(q.Status)" />
                                    @if (q.AnswersCount > 0)
                                    {
                                        <RadzenBadge Text="@($"Ответов: {q.AnswersCount}")"
                                                     BadgeStyle="BadgeStyle.Secondary" />
                                    }
                                </div>
                            </RadzenCard>
                        }

                        @if (_hasMore)
                        {
                            <div class="questions-load-more">
                                @if (_loadingMore)
                                {
                                    <div class="dlg-spinner" style="width:24px;height:24px;border-width:2px;"></div>
                                    <span>Загрузка...</span>
                                }
                                else
                                {
                                    <RadzenButton Text="Загрузить ещё"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Shade="Shade.Lighter"
                                                  Variant="Variant.Filled"
                                                  Size="ButtonSize.Small"
                                                  Icon="expand_more"
                                                  Click="@LoadMoreAsync" />
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="question-detail-panel">
                @if (_selectedQuestion is null)
                {
                    <div class="question-empty-state">
                        <RadzenIcon Icon="help_outline" Style="font-size: 3rem;" />
                        <RadzenText TextStyle="TextStyle.H6"
                                    Style="color: var(--rz-text-secondary-color);">
                            Выберите вопрос из списка
                        </RadzenText>
                    </div>
                }
                else if (_detailLoading)
                {
                    <div class="dlg-loading" style="flex: 1; padding: 2rem; flex-direction: column; gap: 0.5rem;">
                        <div class="dlg-spinner"></div>
                        <span style="font-size:0.85rem;color:var(--rz-text-secondary-color);">Загрузка информации...</span>
                    </div>
                }
                else
                {
                    <div class="question-detail-header">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.2rem">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin: 0; font-weight: 600;">
                                @_selectedQuestion.Text
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="margin:0; color: var(--rz-text-secondary-color);">
                                @_selectedQuestion.AuthorName • SKU: @_selectedQuestion.Sku •
                                @_selectedQuestion.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </RadzenText>
                        </RadzenStack>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenBadge Text="@GetStatusLabel(_selectedQuestion.Status)"
                                         BadgeStyle="@GetStatusBadgeStyle(_selectedQuestion.Status)" />
                            <RadzenButton Icon="open_in_new"
                                          ButtonStyle="ButtonStyle.Light"
                                          Size="ButtonSize.Small"
                                          Click="@OpenQuestionLink"
                                          Disabled="string.IsNullOrWhiteSpace(_selectedQuestion.QuestionLink)"
                                          Title="Открыть вопрос на Ozon" />
                        </RadzenStack>
                    </div>

                    <div class="question-detail-body">
                        @if (_detail is not null && !_detail.QuestionInfoAvailable)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false"
                                         Style="margin-bottom: 0.75rem; font-size: 0.85rem;">
                                Подробная информация недоступна (требуется подписка Premium Plus)
                            </RadzenAlert>
                        }

                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.4rem">
                            <RadzenText TextStyle="TextStyle.Body1">
                                @(_selectedQuestion.Text)
                            </RadzenText>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center">
                                <RadzenLink Text="Открыть товар"
                                            Path="@_selectedQuestion.ProductUrl"
                                            Target="_blank"
                                            Icon="shopping_bag"
                                            Disabled="string.IsNullOrWhiteSpace(_selectedQuestion.ProductUrl)" />
                                <RadzenLink Text="Открыть вопрос"
                                            Path="@_selectedQuestion.QuestionLink"
                                            Target="_blank"
                                            Icon="help_outline"
                                            Disabled="string.IsNullOrWhiteSpace(_selectedQuestion.QuestionLink)" />
                            </RadzenStack>
                        </RadzenStack>

                        @if (_detail?.Product is not null)
                        {
                            <div class="question-product-card">
                                <RadzenText TextStyle="TextStyle.Subtitle2"
                                            Style="font-weight: 600; margin-bottom: 0.5rem; color: var(--rz-text-secondary-color);">
                                    Товар
                                </RadzenText>
                                <div class="question-product-layout">
                                    @if (!string.IsNullOrWhiteSpace(_detail.Product.PrimaryImage))
                                    {
                                        <img src="@_detail.Product.PrimaryImage"
                                             alt="@_detail.Product.Name"
                                             class="question-product-image"
                                             @onclick="@(() => _lightboxSrc = _detail.Product.PrimaryImage)"
                                             title="Нажмите для просмотра" />
                                    }
                                    <div class="question-product-info">
                                        <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; margin: 0;">
                                            @_detail.Product.Name
                                        </RadzenText>
                                        <div class="question-product-props">
                                            <span><strong>SKU:</strong> @_detail.Product.Sku</span>
                                            <span><strong>Артикул:</strong> @_detail.Product.OfferId</span>
                                            @if (!string.IsNullOrWhiteSpace(_detail.Product.Barcode))
                                            {
                                                <span><strong>Штрихкод:</strong> @_detail.Product.Barcode</span>
                                            }
                                            @if (_detail.Product.Weight > 0)
                                            {
                                                <span><strong>Вес:</strong> @_detail.Product.Weight @(_detail.Product.WeightUnit ?? "г")</span>
                                            }
                                            @if (_detail.Product.Height > 0 || _detail.Product.Width > 0 || _detail.Product.Depth > 0)
                                            {
                                                <span><strong>Габариты:</strong> @_detail.Product.Height × @_detail.Product.Width × @_detail.Product.Depth @(_detail.Product.DimensionUnit ?? "мм")</span>
                                            }
                                        </div>
                                        <RadzenButton Text="Заказы с этим товаром"
                                                      Icon="receipt_long"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      Shade="Shade.Lighter"
                                                      Size="ButtonSize.Small"
                                                      Style="margin-top: 0.5rem;"
                                                      Click="@(() => NavigateToOrders(_detail.Product.Sku))" />
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_detail.Product.Description))
                                {
                                    <div class="question-product-description">
                                        <RadzenText TextStyle="TextStyle.Subtitle2"
                                                    Style="font-weight: 600; margin-bottom: 0.35rem; color: var(--rz-text-secondary-color);">
                                            Описание
                                        </RadzenText>
                                        <div class="question-product-description-text @(_descriptionExpanded ? "expanded" : "")">
                                            @_detail.Product.Description
                                        </div>
                                        @if (_detail.Product.Description.Length > 300)
                                        {
                                            <button class="question-description-toggle" @onclick="@(() => _descriptionExpanded = !_descriptionExpanded)">
                                                @(_descriptionExpanded ? "Свернуть" : "Показать полностью")
                                            </button>
                                        }
                                    </div>
                                }

                                @if (_detail.Product.Images.Count > 1)
                                {
                                    <div class="question-product-images">
                                        <RadzenText TextStyle="TextStyle.Subtitle2"
                                                    Style="font-weight: 600; margin-bottom: 0.35rem; color: var(--rz-text-secondary-color);">
                                            Фотографии товара (@_detail.Product.Images.Count)
                                        </RadzenText>
                                        <div class="question-product-images-grid">
                                            @foreach (var img in _detail.Product.Images)
                                            {
                                                <img src="@img"
                                                     alt="Фото товара"
                                                     class="question-product-thumb @(_lightboxSrc == img ? "active" : "")"
                                                     loading="lazy"
                                                     @onclick="@(() => _lightboxSrc = img)"
                                                     title="Нажмите для просмотра" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (_detail?.Answers.Count > 0)
                        {
                            <div class="question-answers-section">
                                <RadzenText TextStyle="TextStyle.Subtitle2"
                                            Style="font-weight: 600; margin-bottom: 0.5rem; color: var(--rz-text-secondary-color);">
                                    Ответы (@_detail.Answers.Count)
                                </RadzenText>
                                @foreach (var ans in _detail.Answers)
                                {
                                    <div class="question-answer-item">
                                        <div class="question-answer-meta">
                                            <span class="question-answer-author">@ans.AuthorName</span>
                                            <span class="question-answer-date">@ans.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                            <RadzenButton Icon="delete"
                                                          ButtonStyle="ButtonStyle.Danger"
                                                          Shade="Shade.Lighter"
                                                          Variant="Variant.Text"
                                                          Size="ButtonSize.ExtraSmall"
                                                          Style="margin-left: auto; padding: 0 4px;"
                                                          Title="Удалить ответ"
                                                          IsBusy="@(_deletingAnswerId == ans.Id)"
                                                          Click="@(() => DeleteAnswerAsync(ans))" />
                                        </div>
                                        <div class="question-answer-text">@ans.Text</div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="question-answer-composer">
                            <div class="question-answer-input-row">
                                <RadzenTextArea @bind-Value="_answerText"
                                                Rows="1"
                                                Placeholder="Напишите ответ…"
                                                Style="flex: 1; resize: none; padding: 2px 10px; max-height: 140px;"
                                                Disabled="@_sendingAnswer"
                                                oninput="this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,200)+'px';" />
                                <RadzenButton Icon="send"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Size="ButtonSize.Small"
                                              IsBusy="@_sendingAnswer"
                                              Disabled="@(string.IsNullOrWhiteSpace(_answerText) || (_answerText?.Length ?? 0) < 2 || (_answerText?.Length ?? 0) > 3000)"
                                              Click="@SendAnswerAsync"
                                              Title="Ответить" />
                            </div>
                            <div class="question-answer-char-counter @((_answerText?.Length ?? 0) > 3000 ? "over-limit" : "")">
                                @(_answerText?.Length ?? 0) / 3000
                            </div>
                        </div>

                        @if (_lightboxSrc is not null)
                        {
                            <div class="question-lightbox" @onclick="@(() => _lightboxSrc = null)">
                                <img src="@_lightboxSrc" alt="Просмотр фото" @onclick:stopPropagation="true" />
                                <button class="question-lightbox-close" @onclick="@(() => _lightboxSrc = null)" title="Закрыть">✕</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        }
        @if (_activeTab == 1)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                         Style="margin-bottom: 0.75rem;">
                <RadzenLabel Text="Маркетплейс:" Style="white-space: nowrap;" />
                <RadzenDropDown TValue="Guid?" @bind-Value="_topSkuClientId"
                                Data="@_clientOptions"
                                TextProperty="Name" ValueProperty="Id"
                                Placeholder="Все"
                                AllowClear="true"
                                Style="width: 180px;"
                                Change="@OnTopSkuFilterChanged" />
            </RadzenStack>

            @if (_topSkuLoading)
            {
                <div class="dlg-loading" style="flex: 1; padding: 3rem; flex-direction: column; gap: 0.5rem;">
                    <div class="dlg-spinner"></div>
                    <span style="font-size:0.85rem;color:var(--rz-text-secondary-color);">Загрузка топ товаров...</span>
                </div>
            }
            else if (_topSkuPremiumRequired)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false"
                             Style="margin: 1rem 0; font-size: 0.85rem;">
                    Данный раздел доступен только для продавцов с подпиской Premium Plus.
                </RadzenAlert>
            }
            else if (_topSkuProducts is null || _topSkuProducts.Count == 0)
            {
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="flex: 1; padding: 3rem; gap: 0.5rem;">
                    <RadzenIcon Icon="inventory_2"
                                Style="font-size: 2.5rem; color: var(--rz-text-secondary-color);" />
                    <RadzenText TextStyle="TextStyle.Body2"
                                Style="color: var(--rz-text-secondary-color); text-align: center;">
                        Нет данных о топ товарах
                    </RadzenText>
                </RadzenStack>
            }
            else
            {
                <div class="top-sku-grid">
                    @{ var rank = 0; }
                    @foreach (var product in _topSkuProducts.Take(_topSkuVisibleCount))
                    {
                        rank++;
                        <RadzenCard Class="top-sku-card">
                            <div class="top-sku-rank">@rank</div>
                            <div class="top-sku-layout">
                                @if (!string.IsNullOrWhiteSpace(product.PrimaryImage))
                                {
                                    <img src="@product.PrimaryImage"
                                         alt="@product.Name"
                                         class="top-sku-image"
                                         @onclick="@(() => _lightboxSrc = product.PrimaryImage)"
                                         title="Нажмите для просмотра" />
                                }
                                <div class="top-sku-info">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; margin: 0;">
                                        @product.Name
                                    </RadzenText>
                                    <div class="question-product-props">
                                        <span><strong>SKU:</strong> @product.Sku</span>
                                        @if (!string.IsNullOrWhiteSpace(product.OfferId))
                                        {
                                            <span><strong>Артикул:</strong> @product.OfferId</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(product.Barcode))
                                        {
                                            <span><strong>Штрихкод:</strong> @product.Barcode</span>
                                        }
                                        @if (product.Weight > 0)
                                        {
                                            <span><strong>Вес:</strong> @product.Weight @(product.WeightUnit ?? "г")</span>
                                        }
                                        @if (product.Height > 0 || product.Width > 0 || product.Depth > 0)
                                        {
                                            <span><strong>Габариты:</strong> @product.Height × @product.Width × @product.Depth @(product.DimensionUnit ?? "мм")</span>
                                        }
                                    </div>
                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Style="margin-top: 0.5rem;">
                                        <RadzenButton Text="Заказы"
                                                      Icon="receipt_long"
                                                      ButtonStyle="ButtonStyle.Primary"
                                                      Shade="Shade.Lighter"
                                                      Size="ButtonSize.Small"
                                                      Click="@(() => NavigateToOrders(product.Sku))" />
                                    </RadzenStack>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(product.Description))
                            {
                                <div class="top-sku-description">
                                    @product.Description
                                </div>
                            }
                        </RadzenCard>
                    }
                </div>

                @if (_topSkuVisibleCount < _topSkuProducts.Count)
                {
                    <RadzenStack AlignItems="AlignItems.Center" Style="margin-top: 1rem; margin-bottom: 0.5rem;">
                        <RadzenButton Text="Дальше" Icon="expand_more"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Medium"
                                      Click="@LoadMoreTopSku" />
                    </RadzenStack>
                }

                @if (_lightboxSrc is not null)
                {
                    <div class="question-lightbox" @onclick="@(() => _lightboxSrc = null)">
                        <img src="@_lightboxSrc" alt="Просмотр фото" @onclick:stopPropagation="true" />
                        <button class="question-lightbox-close" @onclick="@(() => _lightboxSrc = null)" title="Закрыть">✕</button>
                    </div>
                }
            }
        }
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    private List<ClientOptionDto> _clientOptions = new();
    private OzonQuestionCountResponseDto? _questionCounts;
    private List<OzonQuestionViewModelDto> _questions = new();
    private OzonQuestionViewModelDto? _selectedQuestion;
    private OzonQuestionDetailDto? _detail;
    private bool _detailLoading;
    private string? _lightboxSrc;
    private bool _descriptionExpanded;
    private string? _deletingAnswerId;
    private string? _answerText;
    private bool _sendingAnswer;

    private bool _loading;
    private bool _loadingMore;
    private string? _cursor;
    private bool _hasMore;

    private Guid? _filterClientId;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private string? _filterStatus;

    private int _activeTab;
    private List<OzonQuestionProductInfoDto>? _topSkuProducts;
    private bool _topSkuLoading;
    private bool _topSkuPremiumRequired;
    private Guid? _topSkuClientId;
    private int _topSkuVisibleCount = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        await LoadClientOptionsAsync();
        // По умолчанию показываем вопросы за последние 7 дней
        _filterTo = DateTime.UtcNow.Date.AddDays(1);
        _filterFrom = DateTime.UtcNow.Date.AddDays(-7);
        _ = LoadQuestionCountsAsync();
        await ReloadAsync();
    }

    private async Task LoadClientOptionsAsync()
    {
        try
        {
            _clientOptions = await MarketplaceClientService.GetClientOptionsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
    }

    private async Task ReloadAsync()
    {
        _cursor = null;
        _questions.Clear();
        _selectedQuestion = null;

        if (_activeTab == 1)
        {
            _topSkuProducts = null;
            _ = LoadTopSkuAsync();
        }

        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        if (_loading) return;
        _loading = true;
        StateHasChanged();

        try
        {
            var page = await QuestionsService.GetQuestionsPageAsync(
                pageSize: 20,
                cursor: _cursor,
                dateFrom: _filterFrom,
                dateTo: _filterTo,
                status: _filterStatus,
                marketplaceClientId: _filterClientId);

            if (string.IsNullOrEmpty(_cursor))
                _questions = page.Questions;
            else
                _questions.AddRange(page.Questions);

            _cursor = page.NextCursor;
            _hasMore = !string.IsNullOrEmpty(page.NextCursor);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки вопросов", ex.Message, 5000);
        }
        finally
        {
            _loading = false;
            _loadingMore = false;
            StateHasChanged();
        }
    }

    private Task LoadMoreAsync()
    {
        if (!_hasMore || _loadingMore || _cursor is null) return Task.CompletedTask;
        _loadingMore = true;
        return LoadPageAsync();
    }

    private Task OnFilterChanged(object? _)
    {
        _ = LoadQuestionCountsAsync();
        return ReloadAsync();
    }

    private async Task OnStatusPillClick()
    {
        StateHasChanged();
        await ReloadAsync();
    }

    private async Task LoadQuestionCountsAsync()
    {
        try
        {
            _questionCounts = await QuestionsService.GetQuestionCountsAsync(_filterClientId);
            StateHasChanged();
        }
        catch
        {
            // Counts are non-critical; silently ignore
        }
    }

    private void SwitchTab(int tab)
    {
        _activeTab = tab;
        if (tab == 1 && _topSkuProducts is null && !_topSkuLoading)
            _ = LoadTopSkuAsync();
    }

    private void LoadMoreTopSku()
    {
        _topSkuVisibleCount += 20;
        StateHasChanged();
    }

    private void OnTopSkuFilterChanged()
    {
        _topSkuProducts = null;
        _topSkuVisibleCount = 20;
        _ = LoadTopSkuAsync();
    }

    private async Task LoadTopSkuAsync()
    {
        _topSkuLoading = true;
        _topSkuPremiumRequired = false;
        StateHasChanged();

        try
        {
            var result = await QuestionsService.GetTopSkuProductsAsync(_topSkuClientId, limit: 100);
            if (result is null)
                _topSkuPremiumRequired = true;
            else
                _topSkuProducts = result;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки топ товаров", ex.Message, 5000);
        }
        finally
        {
            _topSkuLoading = false;
            StateHasChanged();
        }
    }

    private void SelectQuestion(OzonQuestionViewModelDto q)
    {
        _selectedQuestion = q;
        _detail = null;
        _detailLoading = true;
        _lightboxSrc = null;
        _descriptionExpanded = false;
        _answerText = null;
        StateHasChanged();
        _ = LoadDetailAsync(q);
    }

    private async Task LoadDetailAsync(OzonQuestionViewModelDto q)
    {
        try
        {
            _detail = await QuestionsService.GetQuestionDetailAsync(q);
            _selectedQuestion = _detail.Question;
            _ = QuestionsService.ChangeQuestionStatusAsync(q, "VIEWED");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки деталей", ex.Message, 4000);
        }
        finally
        {
            _detailLoading = false;
            StateHasChanged();
        }
    }

    private void NavigateToOrders(long sku)
    {
        Navigation.NavigateTo($"/orders?search={sku}");
    }

    private async Task DeleteAnswerAsync(OzonQuestionAnswerDto answer)
    {
        if (_selectedQuestion is null || _detail is null) return;
        _deletingAnswerId = answer.Id;
        try
        {
            var result = await QuestionsService.DeleteQuestionAnswerAsync(_selectedQuestion, answer.Id);
            if (result)
            {
                _detail.Answers.Remove(answer);
                NotificationService.Notify(NotificationSeverity.Success, "Ответ удалён", duration: 3000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось удалить ответ", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _deletingAnswerId = null;
            StateHasChanged();
        }
    }

    private async Task SendAnswerAsync()
    {
        if (_selectedQuestion is null || _detail is null) return;
        if (string.IsNullOrWhiteSpace(_answerText)) return;

        _sendingAnswer = true;
        try
        {
            var answerId = await QuestionsService.CreateQuestionAnswerAsync(_selectedQuestion, _answerText.Trim());
            if (answerId is not null)
            {
                _detail.Answers.Add(new OzonQuestionAnswerDto
                {
                    Id = answerId,
                    QuestionId = _selectedQuestion.Id,
                    Sku = _selectedQuestion.Sku,
                    AuthorName = "Продавец",
                    Text = _answerText.Trim(),
                    PublishedAt = DateTime.UtcNow
                });
                _answerText = null;
                NotificationService.Notify(NotificationSeverity.Success, "Ответ опубликован", duration: 3000);
                _ = QuestionsService.ChangeQuestionStatusAsync(_selectedQuestion, "PROCESSED");
                _selectedQuestion.Status = "PROCESSED";
                if (_questionCounts is not null)
                    _ = LoadQuestionCountsAsync();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось отправить ответ", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _sendingAnswer = false;
            StateHasChanged();
        }
    }

    private void OpenQuestionLink()
    {
        if (_selectedQuestion is null) return;
        if (string.IsNullOrWhiteSpace(_selectedQuestion.QuestionLink)) return;
        var link = _selectedQuestion.QuestionLink;
        // Используем стандартный переход браузера
        Navigation.NavigateTo(link, forceLoad: true);
    }

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalSeconds < 60) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин. назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч. назад";
        if (diff.TotalDays < 2) return "вчера";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} дн. назад";
        return utcTime.ToLocalTime().ToString("dd.MM.yyyy");
    }

    private static string GetStatusLabel(string? status) => status switch
    {
        "NEW" => "Новый",
        "VIEWED" => "Просмотрен",
        "PROCESSED" => "Обработан",
        "UNPROCESSED" => "Необработан",
        "ALL" => "Все",
        _ => status ?? "—"
    };

    private static BadgeStyle GetStatusBadgeStyle(string? status) => status switch
    {
        "NEW" => BadgeStyle.Warning,
        "VIEWED" => BadgeStyle.Info,
        "PROCESSED" => BadgeStyle.Success,
        "UNPROCESSED" => BadgeStyle.Danger,
        _ => BadgeStyle.Secondary
    };
}

