@page "/transactions"
@attribute [Authorize(Roles = nameof(PageEnum.TransactionsView))]
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces

@inject ITenantProvider TenantProvider
@inject IOrderTransactionManagementService TransactionService
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JsRuntime

@implements IDisposable

<PageTitle>Документы заказов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Документы заказов</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            @if (_viewMode == "table")
            {
                <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@ToggleDensity" Title="@GetDensityTitle()" />
            }
            <!-- View-mode toggle -->
            <RadzenButton Icon="table_chart"
                          ButtonStyle="@(_viewMode == "table" ? ButtonStyle.Primary : ButtonStyle.Light)"
                          Size="ButtonSize.Small" Title="Режим таблицы"
                          Click="@(() => SetViewMode("table"))" />
            <RadzenButton Icon="account_tree"
                          ButtonStyle="@(_viewMode == "canvas" ? ButtonStyle.Primary : ButtonStyle.Light)"
                          Size="ButtonSize.Small" Title="Режим холста"
                          Click="@(() => SetViewMode("canvas"))" />
            @if (_viewMode == "table")
            {
                <AuthorizeView Roles="@nameof(FunctionEnum.TransactionsManage)">
                    <Authorized>
                        <RadzenButton Icon="add" Text="Добавить" ButtonStyle="ButtonStyle.Primary"
                                      Click="@OpenCreateDialog" />
                    </Authorized>
                </AuthorizeView>
            }
        </RadzenStack>
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Body2"
                Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem; display: block;">
        Документ — переход заказа из одного системного статуса в другой с изменением цен по правилам.
    </RadzenText>

    @if (_viewMode == "canvas")
    {
        <TransactionFlowCanvas @ref="_canvas" OnTransactionsChanged="@OnCanvasTransactionsChanged" />
    }
    else
    {
    @if (_statusMatrix != null && _statusMatrix.Statuses.Count > 0)
    {
        <RadzenCard Style="margin-bottom: 1.5rem;">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-bottom: 0.75rem; display: block;">
                Матрица переходов статусов
            </RadzenText>
            <div style="overflow-x: auto;">
                <table class="rz-table rz-table-sm" style="min-width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="padding: 0.5rem 0.75rem; text-align: left; border: 1px solid var(--rz-border-color); background: var(--rz-base-100); font-weight: 600; min-width: 140px;">Из → В</th>
                            @foreach (var to in _statusMatrix.Statuses)
                            {
                                <th style="padding: 0.5rem 0.75rem; text-align: center; border: 1px solid var(--rz-border-color); background: var(--rz-base-100); font-size: 0.8rem; min-width: 120px;" title="@to.Name">@to.Name</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var from in _statusMatrix.Statuses)
                        {
                            <tr>
                                <td style="padding: 0.5rem 0.75rem; border: 1px solid var(--rz-border-color); background: var(--rz-base-50); font-weight: 500; font-size: 0.8rem;" title="@from.Name">@from.Name</td>
                                @foreach (var to in _statusMatrix.Statuses)
                                {
                                    var names = _statusMatrix.GetTransactionNames(from.Id, to.Id);
                                    <td style="padding: 0.5rem 0.75rem; border: 1px solid var(--rz-border-color); text-align: center; font-size: 0.8rem;">
                                        @if (names.Count > 0)
                                        {
                                            @string.Join(", ", names)
                                        }
                                        else
                                        {
                                            <span style="color: var(--rz-text-disabled-color);">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </RadzenCard>
    }

    <RadzenDataGrid @ref="_grid"
                    TItem="OrderTransaction"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="20"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="OrderTransaction" Property="Name" Title="Название" Width="220px" Frozen="true" Visible="@Col(nameof(PageColumnEnum.TransColName))">
                <Template Context="t">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        @{
                            var tBg = GetSoftBackground(t.Color);
                            var tFg = IsLightColor(tBg) ? "#1f2937" : "#ffffff";
                        }
                        <span style="@($"width:22px;height:22px;border-radius:6px;background:{tBg};display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;")">
                            @if (!string.IsNullOrEmpty(t.Icon))
                            {
                                <i class="rzi" style="font-size:14px;color:@tFg;">@t.Icon</i>
                            }
                        </span>

                        <RadzenText TextStyle="TextStyle.Body2">@t.Name</RadzenText>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransaction" Title="Иконка" Width="80px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Visible="@Col(nameof(PageColumnEnum.TransColIcon))">
                <Template Context="t">
                    @if (!string.IsNullOrEmpty(t.Icon))
                    {
                        var iBg = GetSoftBackground(t.Color);
                        var iFg = IsLightColor(iBg) ? "#1f2937" : "#ffffff";
                        <span style="@($"width:32px;height:32px;border-radius:8px;background:{iBg};display:inline-flex;align-items:center;justify-content:center;")">
                            <i class="rzi" style="font-size:18px;color:@iFg;">@t.Icon</i>
                        </span>
                    }
                    else if (!string.IsNullOrEmpty(t.Color))
                    {
                        <span style="@($"display:inline-block;width:24px;height:24px;border-radius:6px;background:{GetSoftBackground(t.Color)};border:1px solid var(--rz-border-color);")"></span>
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransaction" Property="FromSystemStatus.Name" Title="Исходный статус" Width="180px" Visible="@Col(nameof(PageColumnEnum.TransColFromStatus))">
                <Template Context="t">
                    @if (t.FromSystemStatus != null)
                    {
                        <RadzenBadge Text="@t.FromSystemStatus.Name" BadgeStyle="BadgeStyle.Secondary" />
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransaction" Property="ToSystemStatus.Name" Title="Целевой статус" Width="180px" Visible="@Col(nameof(PageColumnEnum.TransColToStatus))">
                <Template Context="t">
                    @if (t.ToSystemStatus != null)
                    {
                        <RadzenBadge Text="@t.ToSystemStatus.Name" BadgeStyle="BadgeStyle.Success" />
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransaction" Title="Правил" Width="80px" TextAlign="TextAlign.Center" Filterable="false" Sortable="false" Visible="@Col(nameof(PageColumnEnum.TransColRulesCount))">
                <Template Context="t">
                    @(t.Rules?.Count ?? 0)
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderTransaction" Property="IsEnabled" Title="Активна" Width="100px" TextAlign="TextAlign.Center" Visible="@Col(nameof(PageColumnEnum.TransColIsEnabled))">
                <Template Context="t">
                    @if (t.IsEnabled)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Да" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">Нет</span>
                    }
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
    } @* end else (table mode) *@
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private RadzenDataGrid<OrderTransaction>? _grid;
    private TransactionFlowCanvas? _canvas;
    private IEnumerable<OrderTransaction> _pageItems = Array.Empty<OrderTransaction>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private bool _canManage;
    private System.Security.Claims.ClaimsPrincipal? _user;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];
    private string _viewMode = "table";

    private bool Col(string role) => _user?.IsInRole("Admin") == true || _user?.IsInRole(role) == true;
    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "transactions-grid-settings";
    private StatusTransitionMatrix? _statusMatrix;

    private sealed class StatusTransitionMatrix
    {
        public List<OrderStatus> Statuses { get; } = [];
        private readonly Dictionary<(Guid From, Guid To), List<string>> _map = new();

        public void Add(OrderTransaction t)
        {
            if (t.FromSystemStatus == null || t.ToSystemStatus == null) return;
            var fromId = t.FromSystemStatusId;
            var toId = t.ToSystemStatusId;
            if (!Statuses.Any(s => s.Id == fromId))
                Statuses.Add(t.FromSystemStatus);
            if (!Statuses.Any(s => s.Id == toId))
                Statuses.Add(t.ToSystemStatus);
            var key = (fromId, toId);
            if (!_map.TryGetValue(key, out var list))
            {
                list = [];
                _map[key] = list;
            }
            if (!list.Contains(t.Name))
                list.Add(t.Name);
        }

        public IReadOnlyList<string> GetTransactionNames(Guid fromId, Guid toId) =>
            _map.TryGetValue((fromId, toId), out var list) ? list : [];
    }

    private async Task SetViewMode(string mode)
    {
        _viewMode = mode;
        if (mode == "table" && _grid != null)
        {
            await _grid.Reload();
        }
    }

    private async Task OnCanvasTransactionsChanged()
    {
        // When a transaction is saved from the canvas, reload the grid data too
        if (_grid != null)
            await _grid.Reload();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var state = await AuthState;
            _user = state.User;
            _canManage = state.User.IsInRole("Admin") || state.User.IsInRole(nameof(FunctionEnum.TransactionsManage));
            await LoadGridSettingsAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;

        var skip = args.Skip ?? 0;
        var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 20);

        var (items, count) = await TransactionService.GetPagedAsync(
            args.Filter,
            args.OrderBy,
            skip,
            take);

        _pageItems = items;
        _totalCount = count;

        await LoadStatusMatrixAsync();
        _loading = false;
    }


    private async Task LoadStatusMatrixAsync()
    {
        var transactions = await TransactionService.GetAllEnabledAsync();

        _statusMatrix = new StatusTransitionMatrix();
        foreach (var t in transactions)
            _statusMatrix.Add(t);
        _statusMatrix.Statuses.Sort((a, b) => string.Compare(a.Name, b.Name, StringComparison.Ordinal));
    }

    private async Task OpenCreateDialog()
    {
        var result = await DialogService.OpenAsync<OrderTransactionDialog>(
            "Новый документ",
            new Dictionary<string, object?>(),
            new DialogOptions { Width = "min(900px, 95vw)", Resizable = true });

        if (result is bool b && b && _grid != null)
            await _grid.Reload();
    }

    private async Task OpenEditDialog(OrderTransaction t)
    {
        var result = await DialogService.OpenAsync<OrderTransactionDialog>(
            "Редактировать документ",
            new Dictionary<string, object?> { ["TransactionId"] = t.Id },
            new DialogOptions { Width = "min(900px, 95vw)", Resizable = true });

        if (result is bool b && b && _grid != null)
            await _grid.Reload();
    }

    private async Task DeleteAsync(OrderTransaction t)
    {
        var confirmed = await DialogService.Confirm(
            $"Удалить документ «{t.Name}»?",
            "Подтверждение",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена" });

        if (confirmed != true) return;

        var deleted = await TransactionService.SoftDeleteAsync(t.Id);
        if (deleted)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Документ удалён");
            await _grid!.Reload();
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<OrderTransaction> args)
    {
        var items = new List<ContextMenuItem>();
        if (_canManage)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" });
        }
        if (items.Count == 0) return;

        ContextMenuService.Open(args, items,
        async e =>
        {
            ContextMenuService.Close();
            if (e.Value?.ToString() == "edit")
                await OpenEditDialog(args.Data!);
            else if (e.Value?.ToString() == "delete")
                await DeleteAsync(args.Data!);
        });
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };

    private static string GetSoftBackground(string? color)
    {
        if (string.IsNullOrEmpty(color))
            return "#ececff";
        color = color.TrimStart('#');
        if (color.Length < 6) return "#ececff";
        try
        {
            var r = Convert.ToInt32(color[..2], 16);
            var g = Convert.ToInt32(color[2..4], 16);
            var b = Convert.ToInt32(color[4..6], 16);
            r = (int)(r + (255 - r) * 0.7);
            g = (int)(g + (255 - g) * 0.7);
            b = (int)(b + (255 - b) * 0.7);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch { return "#ececff"; }
    }

    public void Dispose() { }

    private static bool IsLightColor(string hex)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length < 6) return true;
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 128;
        }
        catch { return true; }
    }
}
