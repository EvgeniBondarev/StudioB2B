@page "/register"
@rendermode InteractiveServer
@layout EmptyLayout
@using StudioB2B.Application.Common.Interfaces
@using System.ComponentModel.DataAnnotations
@inject ITenantService TenantService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Регистрация компании - StudioB2B</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-6">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            Регистрация компании
        </MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">
            Создайте свою multi-tenant базу для управления заказами
        </MudText>

        @if (_success)
        {
            <MudAlert Severity="Severity.Success" Class="my-4">
                <MudText Typo="Typo.subtitle1"><b>Регистрация успешна!</b></MudText>
                <MudText Typo="Typo.body2">Перенаправление на страницу входа...</MudText>
            </MudAlert>
        }
        else
        {
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField T="string"
                    Label="Название компании"
                    @bind-Value="_model.CompanyName"
                    For="@(() => _model.CompanyName)"
                    Variant="Variant.Outlined"
                    Class="mb-4"
                    FullWidth="true" />

                <MudTextField T="string"
                    Label="Субдомен"
                    @bind-Value="_model.Subdomain"
                    For="@(() => _model.Subdomain)"
                    Variant="Variant.Outlined"
                    HelperText="Только латиница, цифры и дефис (3-30 символов)"
                    Adornment="Adornment.End"
                    AdornmentText=".studiob2b.local"
                    Class="mb-4"
                    FullWidth="true" />

                <MudTextField T="string"
                    Label="Email администратора"
                    @bind-Value="_model.AdminEmail"
                    For="@(() => _model.AdminEmail)"
                    Variant="Variant.Outlined"
                    InputType="InputType.Email"
                    Class="mb-4"
                    FullWidth="true" />

                <MudTextField T="string"
                    Label="Пароль"
                    @bind-Value="_model.Password"
                    For="@(() => _model.Password)"
                    Variant="Variant.Outlined"
                    InputType="InputType.Password"
                    HelperText="Минимум 6 символов"
                    Class="mb-4"
                    FullWidth="true" />

                <MudTextField T="string"
                    Label="Подтверждение пароля"
                    @bind-Value="_model.ConfirmPassword"
                    For="@(() => _model.ConfirmPassword)"
                    Variant="Variant.Outlined"
                    InputType="InputType.Password"
                    Class="mb-4"
                    FullWidth="true" />

                <MudButton
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    Color="Color.Success"
                    FullWidth="true"
                    Size="Size.Large"
                    Disabled="@_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Регистрация...</span>
                    }
                    else
                    {
                        <span>Зарегистрировать компанию</span>
                    }
                </MudButton>

                <ValidationSummary />
            </EditForm>

            <MudDivider Class="my-4" />

            <MudText Align="Align.Center">
                Уже есть аккаунт? <MudLink Href="/login" Color="Color.Primary">Войти</MudLink>
            </MudText>
        }
    </MudPaper>
</MudContainer>

@code {
    private RegisterModel _model = new();
    private bool _loading;
    private bool _success;

    private async Task HandleSubmit()
    {
        _loading = true;
        try
        {
            if (_model.Password != _model.ConfirmPassword)
            {
                Snackbar.Add("Пароли не совпадают", Severity.Error);
                return;
            }

            var result = await TenantService.RegisterAsync(
                _model.CompanyName,
                _model.Subdomain,
                _model.AdminEmail,
                _model.Password);

            if (result.Success)
            {
                _success = true;
                Snackbar.Add("Компания успешно зарегистрирована!", Severity.Success);
                await Task.Delay(2000);
                Navigation.NavigateTo($"http://{_model.Subdomain}.studiob2b.local/login", true);
            }
            else
            {
                Snackbar.Add(result.Error ?? "Ошибка регистрации", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "Введите название компании")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "От 2 до 100 символов")]
        public string CompanyName { get; set; } = "";

        [Required(ErrorMessage = "Введите субдомен")]
        [RegularExpression(@"^[a-z0-9-]{3,30}$", ErrorMessage = "Только латиница, цифры и дефис (3-30 символов)")]
        public string Subdomain { get; set; } = "";

        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Некорректный email")]
        public string AdminEmail { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        [MinLength(6, ErrorMessage = "Минимум 6 символов")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Подтвердите пароль")]
        public string ConfirmPassword { get; set; } = "";
    }
}
