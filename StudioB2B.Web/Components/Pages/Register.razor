@page "/register"
@rendermode InteractiveServer
@using StudioB2B.Application.Common.Interfaces
@inject ITenantService TenantService
@inject NavigationManager Navigation

<PageTitle>Регистрация компании - StudioB2B</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Регистрация компании</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    @if (_isSuccess)
                    {
                        <div class="alert alert-success">
                            <h5>Регистрация успешна!</h5>
                            <p>Ваша компания зарегистрирована. Войдите в систему.</p>
                            <a href="/login" class="btn btn-primary">Войти</a>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="register">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">Название компании</label>
                                <InputText @bind-Value="_model.CompanyName" class="form-control" placeholder="ООО Ромашка" />
                                <ValidationMessage For="() => _model.CompanyName" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Субдомен</label>
                                <div class="input-group">
                                    <InputText @bind-Value="_model.Subdomain" class="form-control" placeholder="romashka" />
                                    <span class="input-group-text">.studiob2b.com</span>
                                </div>
                                <small class="text-muted">Только буквы, цифры и дефисы (3-30 символов)</small>
                                <ValidationMessage For="() => _model.Subdomain" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email администратора</label>
                                <InputText @bind-Value="_model.AdminEmail" class="form-control" type="email" placeholder="admin@company.com" />
                                <ValidationMessage For="() => _model.AdminEmail" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Пароль</label>
                                <InputText @bind-Value="_model.Password" class="form-control" type="password" />
                                <small class="text-muted">Минимум 6 символов, включая цифры и буквы</small>
                                <ValidationMessage For="() => _model.Password" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Подтвердите пароль</label>
                                <InputText @bind-Value="_model.ConfirmPassword" class="form-control" type="password" />
                                <ValidationMessage For="() => _model.ConfirmPassword" class="text-danger" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100" disabled="@_isLoading">
                                @if (_isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Зарегистрировать компанию
                            </button>
                        </EditForm>

                        <hr />
                        <p class="text-center mb-0">
                            Уже есть аккаунт? <a href="/login">Войти</a>
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel _model = new();
    private bool _isLoading;
    private bool _isSuccess;
    private string? _errorMessage;

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (_model.Password != _model.ConfirmPassword)
            {
                _errorMessage = "Пароли не совпадают";
                return;
            }

            var result = await TenantService.RegisterAsync(
                _model.CompanyName,
                _model.Subdomain,
                _model.AdminEmail,
                _model.Password);

            if (result.Success)
            {
                _isSuccess = true;
            }
            else
            {
                _errorMessage = result.Error ?? "Ошибка регистрации";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Произошла ошибка. Попробуйте позже.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите название компании")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 2, ErrorMessage = "От 2 до 100 символов")]
        public string CompanyName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите субдомен")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[a-z0-9][a-z0-9\-]*[a-z0-9]$|^[a-z0-9]$", ErrorMessage = "Только буквы, цифры и дефисы")]
        [System.ComponentModel.DataAnnotations.StringLength(30, MinimumLength = 3, ErrorMessage = "От 3 до 30 символов")]
        public string Subdomain { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите email")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некорректный email")]
        public string AdminEmail { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите пароль")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Минимум 6 символов")]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Подтвердите пароль")]
        public string ConfirmPassword { get; set; } = "";
    }
}
