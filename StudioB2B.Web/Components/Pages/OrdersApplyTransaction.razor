@page "/orders/apply-transaction"
@attribute [Authorize(Roles = "OrdersView")]
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Constants
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject IOrderTransactionService TransactionService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject TabService TabService

@implements IDisposable

<PageTitle>Провести документ</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 200px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else if (_orderIds.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Не указаны заказы. Выберите заказы на странице <a href="/orders">Заказы</a> и нажмите кнопку документа для проведения.
    </RadzenAlert>
}
else if (_orders.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Заказы не найдены.
    </RadzenAlert>
}
else if (_statusGroups > 1)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Выбранные заказы имеют разные системные статусы. Выберите заказы с одинаковым статусом.
    </RadzenAlert>
}
else if (_preview == null)
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">
            Выберите документ для проведения по @_orders.Count заказам (статус: @_currentStatusName)
        </RadzenText>
        <RadzenDataGrid TItem="OrderTransaction"
                        Data="@_transactions"
                        Density="Density.Compact"
                        AllowSorting="false"
                        AllowFiltering="false"
                        AllowPaging="false"
                        RowClick="@OnTransactionSelect"
                        RowRender="@OnTransactionRowRender"
                        Style="cursor: pointer;"
                        EmptyText="Нет доступных документов">
            <Columns>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Документ" Width="240px">
                    <Template Context="t">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            @if (!string.IsNullOrEmpty(t.Color))
                            {
                                var sw = GetSoftBackground(t.Color);
                                var swFg = GetTextColor(sw);
                                <span style="width:22px;height:22px;border-radius:6px;background:@sw;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;" title="@t.Color">
                                    @if (!string.IsNullOrEmpty(t.Icon))
                                    {
                                        <i class="rzi" style="font-size:14px;color:@swFg;">@t.Icon</i>
                                    }
                                </span>
                            }
                            else if (!string.IsNullOrEmpty(t.Icon))
                            {
                                <RadzenIcon Icon="@t.Icon" Style="font-size:1rem;flex-shrink:0;" />
                            }
                            <span>@t.Name</span>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Целевой статус" Width="180px">
                    <Template Context="t">
                        @t.ToSystemStatus?.Name
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Правил цен" Width="90px" TextAlign="TextAlign.Center">
                    <Template Context="t">
                        @(t.Rules?.Count ?? 0)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Правил полей" Width="100px" TextAlign="TextAlign.Center">
                    <Template Context="t">
                        @(t.FieldRules?.Count ?? 0)
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
}
else
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">
                @_preview.TransactionName → @_preview.ToStatusName
            </RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="Назад" ButtonStyle="ButtonStyle.Light" Click="@BackToSelect" />
                <RadzenButton Text="Провести" ButtonStyle="ButtonStyle.Primary" Click="@ApplyAllAsync"
                              Disabled="@(_preview != null && GetValidationErrors().Count > 0)" />
            </RadzenStack>
        </RadzenStack>

        @if (_preview.FieldRules.Any(x => x.RequiresUserInput))
        {
            <RadzenStack Gap="0.5rem" Style="margin-bottom: 0.5rem;">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500;">Режим изменения полей:</RadzenText>
                    <RadzenRadioButtonList TValue="string" @bind-Value="_fieldEditMode" Data="@_fieldModeOptions"
                                          TextProperty="Text" ValueProperty="Value"
                                          Style="flex-direction: row; gap: 1rem;" />
                </RadzenStack>
                @if (_fieldEditMode == "Mass")
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Style="flex-wrap: wrap;">
                        @foreach (var fr in _preview.FieldRules.Where(x => x.RequiresUserInput))
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                <RadzenLabel Text="@(fr.DisplayName + (fr.IsRequired ? " *" : ""))" Style="min-width: 140px;" />
                                @RenderFieldControlMass(fr)
                            </RadzenStack>
                        }
                    </RadzenStack>
                }
            </RadzenStack>
        }

        <RadzenDataGrid TItem="OrderEntity" Data="@_orders" Density="Density.Compact"
                        AllowSorting="false" AllowFiltering="false" AllowPaging="false"
                        EmptyText="@RadzenRuStrings.EmptyText">
            <Columns>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Номер отправления" Width="200px">
                    <Template Context="o">
                        <CopyableText Text="@(o.Shipment?.PostingNumber ?? string.Empty)"
                                      Class="rz-monospace rz-text-sm"
                                      Tooltip="Нажмите, чтобы скопировать номер отправления">
                            <RadzenText TextStyle="TextStyle.Body2"
                                          Class="rz-text-truncate rz-monospace"
                                          title="@o.Shipment?.PostingNumber">
                                @o.Shipment?.PostingNumber
                            </RadzenText>
                        </CopyableText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Клиент" Width="160px">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    title="@o.Shipment?.MarketplaceClient?.Name">@o.Shipment?.MarketplaceClient?.Name
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Принят" Width="130px">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    title="@FormatDateTooltip(o.Shipment?.InProcessAt)">@FormatDateDisplay(o.Shipment?.InProcessAt)
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Срок отгрузки" Width="130px">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    title="@FormatDateTooltip(o.Shipment?.ShipmentDate)">@FormatDateDisplay(o.Shipment?.ShipmentDate)
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Артикул" Width="160px">
                    <Template Context="o">
                        <CopyableText Text="@(o.ProductInfo?.Product?.Article ?? string.Empty)"
                                      Class="rz-monospace rz-text-sm"
                                      Tooltip="Нажмите, чтобы скопировать артикул">
                            <RadzenText TextStyle="TextStyle.Body2"
                                          Class="rz-text-truncate rz-monospace"
                                          title="@o.ProductInfo?.Product?.Article">
                                @o.ProductInfo?.Product?.Article
                            </RadzenText>
                        </CopyableText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Товар" Width="280px">
                    <Template Context="o">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem"
                                     Class="rz-w-100">
                            @if (!string.IsNullOrEmpty(o.ProductInfo?.Product?.ImageUrl))
                            {
                                <img src="@o.ProductInfo?.Product?.ImageUrl"
                                     class="rz-border-radius rz-flex-shrink-0"
                                     style="width:36px; height:36px; object-fit:contain;"
                                     alt=""/>
                            }
                            <span
                                class="rz-text-sm rz-flex-shrink-1 rz-text-truncate rz-ms-1"
                                title="@o.ProductInfo?.Product?.Name">
                                @o.ProductInfo?.Product?.Name
                            </span>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Кол-во" Width="120px" TextAlign="TextAlign.Center">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:600">
                            @o.Quantity
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Статус маркетплейса" Width="190px">
                    <Template Context="o">
                        <RadzenStack JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center">
                            @if (o.Status != null)
                            {
                                var bg = string.IsNullOrEmpty(o.Status.Color) ? "#ececff" : o.Status.Color + "20";
                                var fg = IsLightColor(bg) ? "#1f2937" : "#ffffff";
                                <RadzenBadge Text="@o.Status.Name"
                                             Style="@($"background:{bg}; color:{fg};")"
                                             Class="status-badge"/>
                            }
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Статус приложения" Width="190px">
                    <Template Context="o">
                        <RadzenStack JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center">
                            @if (o.SystemStatus != null)
                            {
                                var bg = GetSoftBackground(o.SystemStatus.Color);
                                var fg = GetTextColor(bg);
                                <RadzenBadge Text="@o.SystemStatus.Name"
                                             Style="@($"background:{bg}; color:{fg};")"
                                             Class="status-badge"/>
                            }
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Способ доставки" Width="180px">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    title="@o.Shipment?.DeliveryMethod?.Name">
                            @o.Shipment?.DeliveryMethod?.Name
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Склад" Width="160px">
                    <Template Context="o">
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    title="@o.WarehouseInfo?.SenderWarehouse?.Name">
                            @o.WarehouseInfo?.SenderWarehouse?.Name
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderEntity" Title="Цена" Width="120px">
                    <Template Context="o">
                        @{
                            var price = o.Prices.FirstOrDefault(p => p.PriceType?.Name == "Цена");
                        }
                        @if (price != null)
                        {
                            var priceText = $"{price.Value:N2} {price.Currency?.Code}";
                            <RadzenText TextStyle="TextStyle.Body2"
                                        Class="rz-text-truncate"
                                        Style="@($"font-weight:600; letter-spacing:0.2px; {GetPriceColor(price.Value)}")"
                                        title="@priceText">
                                @priceText
                            </RadzenText>
                        }
                        else
                        {
                            <span style="color: var(--rz-danger);">—</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
                @if (_calcRules.Count > 0)
                {
                    @if (!_computedSplitByColumns)
                    {
                        <RadzenDataGridColumn TItem="OrderEntity" Title="Расчёты" Width="200px">
                            <HeaderTemplate>
                                <span style="cursor: pointer; text-decoration: underline; font-size: 0.85rem;"
                                      title="Щёлкните, чтобы переключить режим отображения расчётов"
                                      @onclick="ToggleComputedLayout">
                                    Расчёты
                                    (@(_computedSplitByColumns ? "по столбцам" : "в одном столбце"))
                                </span>
                            </HeaderTemplate>
                            <Template Context="o">
                                @if (_computed.TryGetValue(o.Id, out var fields) && fields.Count > 0)
                                {
                                    <RadzenStack Gap="0.15rem">
                                        @foreach (var rule in _calcRules)
                                        {
                                            @if (fields.TryGetValue(rule.ResultKey, out var val) && val != decimal.MinValue)
                                            {
                                                var bd = _computedBreakdown.TryGetValue(o.Id, out var bdDict) && bdDict.TryGetValue(rule.ResultKey, out var bdText) ? bdText : rule.Formula;
                                                <span
                                                    style="font-size: 0.78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: help;"
                                                    title="@bd">
                                                    <span style="color: var(--rz-text-secondary-color);">@rule.Name:</span>
                                                    <strong style="@GetPriceColor(val)">@val.ToString("N2")</strong>
                                                </span>
                                            }
                                        }
                                    </RadzenStack>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    }
                    else
                    {
                        @foreach (var rule in _calcRules)
                        {
                            <RadzenDataGridColumn TItem="OrderEntity"
                                                  Title="@rule.Name"
                                                  Width="120px"
                                                  Filterable="false"
                                                  Sortable="false"
                                                  TextAlign="TextAlign.Right">
                                <Template Context="o">
                                    @if (_computed.TryGetValue(o.Id, out var fields) &&
                                         fields.TryGetValue(rule.ResultKey, out var val) &&
                                         val != decimal.MinValue)
                                    {
                                        var bd = _computedBreakdown.TryGetValue(o.Id, out var bdDict) && bdDict.TryGetValue(rule.ResultKey, out var bdText) ? bdText : rule.Formula;
                                        <span title="@bd" style="cursor: help; @GetPriceColor(val)">@val.ToString("N2")</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        }
                    }
                }
                @if (_fieldEditMode == "PerOrder")
                {
                    @foreach (var fr in _preview.FieldRules.Where(x => x.RequiresUserInput))
                    {
                        <RadzenDataGridColumn TItem="OrderEntity" Title="@(fr.DisplayName + (fr.IsRequired ? " *" : ""))" Width="180px" @key="fr.RuleId">
                            <Template Context="o">
                                @RenderFieldControlPerOrder(o.Id, fr)
                            </Template>
                        </RadzenDataGridColumn>
                    }
                }
                @foreach (var rule in _preview.Rules)
                {
                    <RadzenDataGridColumn TItem="OrderEntity" Title="@(rule.PriceTypeName + (rule.IsRequired ? " *" : ""))" Width="140px" @key="rule.RuleId">
                        <Template Context="o">
                            @{
                                var orderPreview = _orderPreviews.GetValueOrDefault(o.Id);
                                var rulePreview = orderPreview?.Rules.FirstOrDefault(r => r.RuleId == rule.RuleId);
                            }
                            @if (rulePreview != null)
                            {
                                @if (rulePreview.RequiresUserInput)
                                {
                                    var uv = GetUserValue(o.Id, rule.RuleId);
                                    <RadzenNumeric TValue="decimal" Value="@uv"
                                                  ValueChanged="@(v => OnUserValueChanged(o.Id, rule.RuleId, v))"
                                                  Style="@($"width: 100%; {GetPriceColor(uv)}")" Min="0" Format="N2"
                                                  Placeholder="Введите" />
                                }
                                else
                                {
                                    var cv = rulePreview.ComputedValue;
                                    var breakdown = rulePreview.FormulaBreakdown ?? rulePreview.Formula ?? "";
                                    <RadzenText TextStyle="TextStyle.Body2" Style="@($"cursor: help; font-family: monospace; {GetPriceColor(cv)}")" title="@breakdown">
                                        @(cv?.ToString("N2") ?? "—")
                                    </RadzenText>
                                }
                            }
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
}

@code {
    [SupplyParameterFromQuery(Name = "ids")]
    public string? IdsQuery { get; set; }

    [SupplyParameterFromQuery(Name = "transactionId")]
    public string? TransactionIdQuery { get; set; }

    private TenantDbContext? _db;
    private bool _loading = true;
    private List<Guid> _orderIds = [];
    private List<OrderEntity> _orders = [];
    private List<OrderTransaction> _transactions = [];
    private string? _currentStatusName;
    private Guid? _selectedTransactionId;
    private TransactionApplyPreviewDto? _preview;
    private Dictionary<Guid, TransactionApplyPreviewDto> _orderPreviews = [];
    private Dictionary<Guid, Dictionary<Guid, decimal>> _userValues = [];
    private Dictionary<Guid, string> _fieldUserValues = [];
    private Dictionary<Guid, Dictionary<Guid, string>> _fieldUserValuesPerOrder = [];
    private string _fieldEditMode = "Mass";
    private static readonly List<object> _fieldModeOptions =
    [
        new { Value = "Mass", Text = "Массово (одно значение для всех)" },
        new { Value = "PerOrder", Text = "По каждому заказу" }
    ];
    private int _statusGroups;
    private List<OrderStatus> _orderStatuses = [];
    private List<Product> _products = [];
    private List<Supplier> _suppliers = [];
    private List<Warehouse> _warehouses = [];
    private List<DeliveryMethod> _deliveryMethods = [];
    private List<Recipient> _recipients = [];
    private List<Address> _addresses = [];
    private List<WarehouseInfo> _warehouseInfos = [];
    private List<OrderProductInfo> _orderProductInfos = [];
    private List<CalculationRule> _calcRules = [];
    private Dictionary<Guid, Dictionary<string, decimal>> _computed = [];
    private Dictionary<Guid, Dictionary<string, string>> _computedBreakdown = [];
    private bool _computedSplitByColumns;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(IdsQuery))
        {
            _orderIds = [];
        }
        else
        {
            _orderIds = IdsQuery.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(s => Guid.TryParse(s, out var g) ? g : (Guid?)null)
                .Where(g => g.HasValue)
                .Select(g => g!.Value)
                .Distinct()
                .ToList();
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _db = Factory.CreateDbContext();

        if (_orderIds.Count > 0)
        {
            _orders = await _db.Orders
                .IncludeForGrid()
                .Include(o => o.Prices).ThenInclude(p => p.PriceType)
                .Include(o => o.ProductInfo).ThenInclude(pi => pi!.Product)
                .Include(o => o.SystemStatus)
                .Where(o => _orderIds.Contains(o.Id))
                .AsNoTracking()
                .ToListAsync();

            var statusIds = _orders.Select(o => o.SystemStatusId).Where(s => s.HasValue).Distinct().ToList();
            _statusGroups = statusIds.Count + (_orders.Any(o => !o.SystemStatusId.HasValue) ? 1 : 0);
            _currentStatusName = _orders.FirstOrDefault()?.SystemStatus?.Name;

            if (_statusGroups == 1 && statusIds.Count == 1)
            {
                var statusId = statusIds[0];
                _transactions = await _db.OrderTransactions
                    .Include(t => t.ToSystemStatus)
                    .Include(t => t.Rules)
                    .Include(t => t.FieldRules)
                    .Where(t => !t.IsDeleted && t.IsEnabled && t.FromSystemStatusId == statusId)
                    .OrderBy(t => t.Name)
                    .AsNoTracking()
                    .ToListAsync();
            }

            _calcRules = await _db.GetActiveRulesAsync();
        }

        _loading = false;

        if (!string.IsNullOrEmpty(TransactionIdQuery) && Guid.TryParse(TransactionIdQuery, out var tid) && _transactions.Count > 0)
        {
            var t = _transactions.FirstOrDefault(x => x.Id == tid);
            if (t != null)
                await SelectTransactionAsync(t);
        }
    }

    private async Task RecomputeAllAsync()
    {
        if (!_selectedTransactionId.HasValue || _calcRules.Count == 0)
        {
            _computed = [];
            _computedBreakdown = [];
            return;
        }

        _computed = [];
        _computedBreakdown = [];
        foreach (var order in _orders)
        {
            var ctx = await TransactionService.GetMergedContextAsync(order.Id, _selectedTransactionId.Value, _userValues.GetValueOrDefault(order.Id) ?? []);
            if (ctx == null) continue;

            var dict = new Dictionary<string, decimal>();
            var breakdownDict = new Dictionary<string, string>();
            foreach (var rule in _calcRules)
            {
                var key = CalculationEngine.SanitizeKey(rule.ResultKey);
                if (!string.IsNullOrEmpty(key) && ctx.TryGetValue(key, out var val))
                {
                    dict[rule.ResultKey] = val;
                    var ctxForRule = new Dictionary<string, decimal>(ctx, StringComparer.OrdinalIgnoreCase);
                    ctxForRule.Remove(key);
                    breakdownDict[rule.ResultKey] = CalculationEngine.BuildFormulaBreakdown(rule.Formula ?? "", ctxForRule, val);
                }
            }
            _computed[order.Id] = dict;
            _computedBreakdown[order.Id] = breakdownDict;
        }
    }

    private void OnTransactionRowRender(RowRenderEventArgs<OrderTransaction> args)
    {
        var color = args.Data?.Color;
        if (!string.IsNullOrEmpty(color))
        {
            var bg = GetSoftBackground(color);
            var fg = IsLightColor(bg) ? "#1f2937" : "#ffffff";
            args.Attributes["style"] = $"background-color: {bg}; color: {fg}; cursor: pointer;";
        }
    }

    private async Task OnTransactionSelect(DataGridRowMouseEventArgs<OrderTransaction> args)
    {
        if (args.Data != null)
            await SelectTransactionAsync(args.Data);
    }

    private async Task SelectTransactionAsync(OrderTransaction t)
    {
        _loading = true;
        StateHasChanged();

        _selectedTransactionId = t.Id;
        _orderPreviews = [];
        _userValues = [];
        _fieldUserValues = [];

        foreach (var order in _orders)
        {
            var preview = await TransactionService.GetApplyPreviewAsync(order.Id, t.Id);
            if (preview != null)
            {
                _orderPreviews[order.Id] = preview;
                _preview = preview;
                foreach (var rule in preview.Rules.Where(r => r.RequiresUserInput))
                {
                    if (!_userValues.ContainsKey(order.Id))
                        _userValues[order.Id] = [];
                    var existingPrice = order.Prices?.FirstOrDefault(p => p.PriceTypeId == rule.PriceTypeId)?.Value ?? 0m;
                    _userValues[order.Id][rule.RuleId] = existingPrice;
                }
            }
        }
        foreach (var fr in _preview?.FieldRules.Where(r => r.RequiresUserInput) ?? [])
        {
            _fieldUserValues[fr.RuleId] = string.Empty;
            foreach (var order in _orders)
            {
                if (!_fieldUserValuesPerOrder.ContainsKey(order.Id))
                    _fieldUserValuesPerOrder[order.Id] = [];
                _fieldUserValuesPerOrder[order.Id][fr.RuleId] = string.Empty;
            }
        }
        if (_preview != null)
            await LoadReferenceDataAsync(_preview.FieldRules.Where(r => r.RequiresUserInput));

        foreach (var order in _orders)
        {
            if (_orderPreviews.ContainsKey(order.Id) && _selectedTransactionId.HasValue)
            {
                var preview = await TransactionService.GetApplyPreviewWithUserValuesAsync(order.Id, _selectedTransactionId.Value, _userValues.GetValueOrDefault(order.Id));
                if (preview != null)
                    _orderPreviews[order.Id] = preview;
            }
        }

        await RecomputeAllAsync();
        _loading = false;
        StateHasChanged();
    }

    private decimal GetUserValue(Guid orderId, Guid ruleId)
    {
        return _userValues.TryGetValue(orderId, out var dict) && dict.TryGetValue(ruleId, out var v) ? v : 0m;
    }

    private async Task OnUserValueChanged(Guid orderId, Guid ruleId, decimal value)
    {
        if (!_userValues.ContainsKey(orderId))
            _userValues[orderId] = [];
        _userValues[orderId][ruleId] = value;

        if (_selectedTransactionId.HasValue)
        {
            var preview = await TransactionService.GetApplyPreviewWithUserValuesAsync(orderId, _selectedTransactionId.Value, _userValues[orderId]);
            if (preview != null)
                _orderPreviews[orderId] = preview;
            await RecomputeAllAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void BackToSelect()
    {
        _preview = null;
        _selectedTransactionId = null;
        _orderPreviews = [];
        _userValues = [];
        _fieldUserValues = [];
        _fieldUserValuesPerOrder = [];
    }

    private async Task LoadReferenceDataAsync(IEnumerable<TransactionApplyFieldRulePreviewDto> fieldRules)
    {
        if (_db == null) return;
        var refTypes = fieldRules.Select(f => f.ReferenceType).Distinct().ToList();
        if (refTypes.Contains(FieldReferenceTypeEnum.OrderStatus))
            _orderStatuses = await _db.OrderStatuses.Where(s => !s.IsDeleted).OrderBy(s => s.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.Product))
            _products = await _db.Products.Where(p => !p.IsDeleted).OrderBy(p => p.Article).Take(1000).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.Supplier))
            _suppliers = await _db.Suppliers.Where(s => !s.IsDeleted).OrderBy(s => s.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.Warehouse))
            _warehouses = await _db.Warehouses.Where(w => !w.IsDeleted).OrderBy(w => w.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.DeliveryMethod))
            _deliveryMethods = await _db.DeliveryMethods.Where(d => !d.IsDeleted).OrderBy(d => d.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.Recipient))
            _recipients = await _db.Recipients.OrderBy(r => r.Name).Take(500).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.Address))
            _addresses = await _db.Addresses.Take(500).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.WarehouseInfo))
            _warehouseInfos = await _db.WarehouseInfos
                .Include(wi => wi.RecipientWarehouse)
                .Include(wi => wi.SenderWarehouse)
                .OrderBy(wi => wi.Id)
                .Take(500)
                .AsNoTracking()
                .ToListAsync();
        if (refTypes.Contains(FieldReferenceTypeEnum.OrderProductInfo))
            _orderProductInfos = await _db.OrderProductInfos
                .Include(opi => opi.Product)
                .Where(opi => !opi.IsDeleted)
                .OrderBy(opi => opi.Product != null ? opi.Product.Article : "")
                .Take(500)
                .AsNoTracking()
                .ToListAsync();
    }

    private RenderFragment RenderFieldControlMass(TransactionApplyFieldRulePreviewDto fr) => builder =>
    {
        var value = _fieldUserValues.GetValueOrDefault(fr.RuleId) ?? "";
        RenderFieldControlInternal(builder, fr, value, v => { _fieldUserValues[fr.RuleId] = v; });
    };

    private RenderFragment RenderFieldControlPerOrder(Guid orderId, TransactionApplyFieldRulePreviewDto fr) => builder =>
    {
        var dict = _fieldUserValuesPerOrder.GetValueOrDefault(orderId);
        var value = dict != null && dict.TryGetValue(fr.RuleId, out var v) ? v : "";
        RenderFieldControlInternal(builder, fr, value, v =>
        {
            if (!_fieldUserValuesPerOrder.ContainsKey(orderId))
                _fieldUserValuesPerOrder[orderId] = [];
            _fieldUserValuesPerOrder[orderId][fr.RuleId] = v;
        });
    };

    private void RenderFieldControlInternal(
        Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder,
        TransactionApplyFieldRulePreviewDto fr,
        string value,
        Action<string> setValue)
    {
        if (fr.ReferenceType != FieldReferenceTypeEnum.None && fr.ValueType == TransactionFieldValueTypeEnum.Guid)
        {
            var items = GetReferenceItems(fr.ReferenceType);
            var currentGuid = Guid.TryParse(value, out var g) ? g : (Guid?)null;
            builder.OpenComponent<RadzenDropDown<Guid?>>(0);
            builder.AddAttribute(1, "Data", items);
            builder.AddAttribute(2, "ValueProperty", "Id");
            builder.AddAttribute(3, "TextProperty", "Name");
            builder.AddAttribute(4, "Value", currentGuid);
            builder.AddAttribute(5, "ValueChanged", EventCallback.Factory.Create<Guid?>(this, v => { setValue(v?.ToString() ?? ""); StateHasChanged(); }));
            builder.AddAttribute(6, "Style", "width: 100%; min-width: 140px;");
            builder.AddAttribute(7, "Placeholder", "Выберите...");
            builder.AddAttribute(8, "AllowClear", true);
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueTypeEnum.DateTime)
        {
            var dt = DateTime.TryParse(value, out var d) ? d : (DateTime?)null;
            builder.OpenComponent<RadzenDatePicker<DateTime?>>(0);
            builder.AddAttribute(1, "Value", dt);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<DateTime?>(this, v => { setValue(v?.ToString("yyyy-MM-dd") ?? ""); StateHasChanged(); }));
            builder.AddAttribute(3, "Style", "width: 100%;");
            builder.AddAttribute(4, "Placeholder", "гггг-мм-дд");
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueTypeEnum.Int)
        {
            var n = int.TryParse(value, out var v) ? v : (int?)null;
            builder.OpenComponent<RadzenNumeric<int?>>(0);
            builder.AddAttribute(1, "Value", n);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<int?>(this, v => { setValue(v?.ToString() ?? ""); StateHasChanged(); }));
            builder.AddAttribute(3, "Style", "width: 100%;");
            builder.AddAttribute(4, "Format", "D0");
            builder.AddAttribute(5, "Placeholder", "Число");
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueTypeEnum.Decimal)
        {
            var n = decimal.TryParse(value, out var v) ? v : (decimal?)null;
            builder.OpenComponent<RadzenNumeric<decimal?>>(0);
            builder.AddAttribute(1, "Value", n);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<decimal?>(this, v => { setValue(v?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? ""); StateHasChanged(); }));
            builder.AddAttribute(3, "Style", "width: 100%;");
            builder.AddAttribute(4, "Format", "N2");
            builder.AddAttribute(5, "Placeholder", "Число");
            builder.CloseComponent();
        }
        else
        {
            builder.OpenComponent<RadzenTextBox>(0);
            builder.AddAttribute(1, "Value", value);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<string>(this, v => { setValue(v ?? ""); StateHasChanged(); }));
            builder.AddAttribute(3, "Style", "width: 100%;");
            builder.AddAttribute(4, "Placeholder", "Значение");
            builder.CloseComponent();
        }
    }

    private object GetReferenceItems(FieldReferenceTypeEnum refType) => refType switch
    {
        FieldReferenceTypeEnum.OrderStatus => _orderStatuses.Select(s => new { s.Id, Name = s.Name ?? "" }).ToList(),
        FieldReferenceTypeEnum.Product => _products.Select(p => new { p.Id, Name = $"{p.Article} — {p.Name}" }).ToList(),
        FieldReferenceTypeEnum.Supplier => _suppliers.Select(s => new { s.Id, Name = s.Name ?? "" }).ToList(),
        FieldReferenceTypeEnum.Warehouse => _warehouses.Select(w => new { w.Id, Name = w.Name ?? "" }).ToList(),
        FieldReferenceTypeEnum.WarehouseInfo => _warehouseInfos.Select(wi => new { wi.Id, Name = $"{wi.SenderWarehouse?.Name ?? "—"} → {wi.RecipientWarehouse?.Name ?? "—"}" }).ToList(),
        FieldReferenceTypeEnum.DeliveryMethod => _deliveryMethods.Select(d => new { d.Id, Name = d.Name ?? "" }).ToList(),
        FieldReferenceTypeEnum.OrderProductInfo => _orderProductInfos.Select(opi => new { opi.Id, Name = $"{opi.Product?.Article ?? "—"} — {opi.Product?.Name ?? ""}" }).ToList(),
        FieldReferenceTypeEnum.Recipient => _recipients.Select(r => new { r.Id, Name = r.Name ?? "" }).ToList(),
        FieldReferenceTypeEnum.Address => _addresses.Select(a => new { a.Id, Name = $"{a.City} {a.Street}".Trim() }).ToList(),
        _ => Array.Empty<object>()
    };

    private List<string> GetValidationErrors()
    {
        if (_preview == null) return [];
        var errors = new List<string>();

        foreach (var order in _orders)
        {
            var orderPreview = _orderPreviews.GetValueOrDefault(order.Id);
            var postingNumber = order.Shipment?.PostingNumber ?? order.Id.ToString("N")[..8];
            var ruleValues = _userValues.GetValueOrDefault(order.Id);

            foreach (var rule in orderPreview?.Rules.Where(r => r.RequiresUserInput && r.IsRequired) ?? [])
            {
                if (ruleValues == null || !ruleValues.ContainsKey(rule.RuleId))
                    errors.Add($"Заказ {postingNumber}: {rule.PriceTypeName}");
            }
        }

        var requiredFieldRules = _preview.FieldRules.Where(r => r.RequiresUserInput && r.IsRequired).ToList();
        if (_fieldEditMode == "Mass")
        {
            foreach (var fr in requiredFieldRules)
            {
                var value = _fieldUserValues.GetValueOrDefault(fr.RuleId) ?? "";
                if (IsFieldValueEmpty(value, fr.ValueType))
                    errors.Add(fr.DisplayName);
            }
        }
        else
        {
            foreach (var order in _orders)
            {
                var dict = _fieldUserValuesPerOrder.GetValueOrDefault(order.Id);
                var postingNumber = order.Shipment?.PostingNumber ?? order.Id.ToString("N")[..8];
                foreach (var fr in requiredFieldRules)
                {
                    var value = dict != null && dict.TryGetValue(fr.RuleId, out var v) ? v : "";
                    if (IsFieldValueEmpty(value, fr.ValueType))
                        errors.Add($"Заказ {postingNumber}: {fr.DisplayName}");
                }
            }
        }
        return errors;
    }

    private static bool IsFieldValueEmpty(string value, TransactionFieldValueTypeEnum valueType)
    {
        if (string.IsNullOrWhiteSpace(value)) return true;
        return valueType switch
        {
            TransactionFieldValueTypeEnum.Guid => !Guid.TryParse(value.Trim(), out var g) || g == Guid.Empty,
            TransactionFieldValueTypeEnum.DateTime => !DateTime.TryParse(value, out _),
            TransactionFieldValueTypeEnum.Int => !int.TryParse(value, out _),
            TransactionFieldValueTypeEnum.Decimal => !decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out _),
            _ => false
        };
    }

    private async Task ApplyAllAsync()
    {
        if (!_selectedTransactionId.HasValue) return;

        var validationErrors = GetValidationErrors();
        if (validationErrors.Count > 0)
        {
            await DialogService.OpenAsync<TransactionErrorDialog>(
                "Ошибка валидации",
                new Dictionary<string, object?>
                {
                    [nameof(TransactionErrorDialog.Title)] = "Ошибка валидации",
                    [nameof(TransactionErrorDialog.Message)] = "Не заполнены обязательные поля. Заполните все поля, отмеченные звёздочкой (*).",
                    [nameof(TransactionErrorDialog.ValidationErrors)] = validationErrors
                });
            return;
        }

        var successCount = 0;
        var errorCount = 0;
        var applyErrors = new List<string>();

        foreach (var order in _orders)
        {
            var ruleValues = _userValues.GetValueOrDefault(order.Id);
            var fieldValues = _fieldEditMode == "Mass"
                ? _fieldUserValues
                : _fieldUserValuesPerOrder.GetValueOrDefault(order.Id) ?? new Dictionary<Guid, string>();
            var result = await TransactionService.ApplyAsync(order.Id, _selectedTransactionId.Value, ruleValues, fieldValues);
            if (result.Success)
                successCount++;
            else
            {
                errorCount++;
                var postingNumber = order.Shipment?.PostingNumber ?? order.Id.ToString("N")[..8];
                applyErrors.Add($"Заказ {postingNumber}: {result.ErrorMessage ?? "Неизвестная ошибка"}");
                foreach (var ve in result.ValidationErrors)
                    applyErrors.Add($" • {ve}");
            }
        }

        if (errorCount > 0)
        {
            await DialogService.OpenAsync<TransactionErrorDialog>(
                "Результат проведения",
                new Dictionary<string, object?>
                {
                    [nameof(TransactionErrorDialog.Title)] = "Результат проведения",
                    [nameof(TransactionErrorDialog.Message)] = $"Применено: {successCount}, ошибок: {errorCount}",
                    [nameof(TransactionErrorDialog.ValidationErrors)] = applyErrors
                });
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Success, "Документ проведён",
                $"Обновлено заказов: {successCount}");
        }

        var path = new Uri(Navigation.Uri).PathAndQuery;
        var navigateTo = TabService.Close(path);
        Navigation.NavigateTo(navigateTo ?? "/orders", forceLoad: true);
    }

