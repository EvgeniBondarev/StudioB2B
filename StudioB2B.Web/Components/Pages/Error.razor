@page "/error"
@layout Components.Layout.EmptyLayout

<PageTitle>Ошибка - StudioB2B</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-6">
        <MudAlert Severity="Severity.Error">
            <MudText Typo="Typo.h5" GutterBottom="true">Произошла ошибка</MudText>
            <MudText Typo="Typo.body1">Что-то пошло не так. Попробуйте перезагрузить страницу.</MudText>
        </MudAlert>

        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" FullWidth="true">
            Вернуться на главную
        </MudButton>
    </MudPaper>
</MudContainer>

