@page "/order-statuses"
@attribute [Authorize(Roles = "OrderStatusesView")]
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Interfaces

@inject ITenantProvider TenantProvider
@inject IOrderStatusService StatusService
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JsRuntime


<link rel="stylesheet" href="css/orders.css" />
<PageTitle>Статусы заказов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Статусы заказов</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <AuthorizeView Roles="OrderStatusesManage">
                <Authorized>
                    <RadzenButton Icon="add" Text="Добавить" Shade="Shade.Light" ButtonStyle="ButtonStyle.Primary"
                                  Click="@AddRow" />
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                 Style="padding: 0 0 0.6rem 0; flex-wrap: wrap;">
        @{ var noOsFilter = string.IsNullOrEmpty(_filterType) && _filterMarketplaceTypeId == null && !_filterTerminal.HasValue; }
        <span class="q-pill @(noOsFilter ? "active" : "")"
              style="background:@(noOsFilter ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(noOsFilter ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(async () => { _filterType = null; _filterMarketplaceTypeId = null; _filterTerminal = null; await OnFilterChange(); })">
            Все
        </span>
        <span class="q-pill @(_filterType == "internal" ? "active" : "")"
              style="background:@(_filterType == "internal" ? "#3b82f6" : "#dbeafe"); color:@(_filterType == "internal" ? "#fff" : "#1e3a5f");"
              @onclick="@(async () => { _filterType = _filterType == "internal" ? null : "internal"; await OnFilterChange(); })">
            Системные
            @if (_countInternal > 0) { <span class="q-pill-count">@_countInternal</span> }
        </span>
        <span class="q-pill @(_filterType == "marketplace" ? "active" : "")"
              style="background:@(_filterType == "marketplace" ? "#8b5cf6" : "#ede9fe"); color:@(_filterType == "marketplace" ? "#fff" : "#4c1d95");"
              @onclick="@(async () => { _filterType = _filterType == "marketplace" ? null : "marketplace"; await OnFilterChange(); })">
            Маркетплейсовые
            @if (_countMarketplace > 0) { <span class="q-pill-count">@_countMarketplace</span> }
        </span>

        @if (_clientTypes.Any())
        {
            <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>
            @foreach (var ct in _clientTypes)
            {
                var ctId = ct.Id;
                var ctName = ct.Name;
                var isCtActive = _filterMarketplaceTypeId == ctId;
                var ctCnt = _countByClientTypeId.GetValueOrDefault(ctId);
                <span class="q-pill @(isCtActive ? "active" : "")"
                      style="background:@(isCtActive ? "var(--rz-primary)" : "#ececff"); color:@(isCtActive ? "#fff" : "#1f2937");"
                      @onclick="@(async () => { _filterMarketplaceTypeId = isCtActive ? null : ctId; await OnFilterChange(); })">
                    @ctName
                    @if (ctCnt > 0) { <span class="q-pill-count">@ctCnt</span> }
                </span>
            }
        }

        <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>

        <span class="q-pill @(_filterTerminal == true ? "active" : "")"
              style="background:@(_filterTerminal == true ? "#10b981" : "#d1fae5"); color:@(_filterTerminal == true ? "#fff" : "#065f46");"
              @onclick="@(async () => { _filterTerminal = _filterTerminal == true ? null : (bool?)true; await OnFilterChange(); })">
            Конечные
            @if (_countTerminal > 0) { <span class="q-pill-count">@_countTerminal</span> }
        </span>
        <span class="q-pill @(_filterTerminal == false ? "active" : "")"
              style="background:@(_filterTerminal == false ? "#6b7280" : "#f3f4f6"); color:@(_filterTerminal == false ? "#fff" : "#374151");"
              @onclick="@(async () => { _filterTerminal = _filterTerminal == false ? null : (bool?)false; await OnFilterChange(); })">
            Не конечные
            @if (_countNonTerminal > 0) { <span class="q-pill-count">@_countNonTerminal</span> }
        </span>
    </RadzenStack>

    <RadzenDataGrid @ref="_grid"
                    TItem="OrderStatus"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="20"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="@OnUpdate"
                    RowCreate="@OnCreate"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="OrderStatus" Property="Name"
                                  Title="Название" Width="220px" Frozen="true" Visible="@Col("OStatusColName")">
                <EditTemplate Context="s">
                    <RadzenTextBox @bind-Value="s.Name" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Property="Color" Title="Цвет"
                                  Width="120px" TextAlign="TextAlign.Center"
                                  Filterable="false" Sortable="false" Visible="@Col("OStatusColColor")">
                <Template Context="s">
                    @if (!string.IsNullOrEmpty(s.Color))
                    {
                        var bg = GetSoftBackground(s.Color);
                        var fg = GetTextColor(bg);

                        <RadzenBadge Text="@s.Name"
                                     Style="@($"background:{bg}; color:{fg};")"
                                     Class="status-badge"/>

                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="s">
                    <RadzenColorPicker Value="@s.Color"
                                       ValueChanged="@(v => OnColorChanged(s, v))"
                                       ShowHSV="true"
                                       ShowRGBA="false"
                                       ShowColors="true"
                                       ShowButton="true"
                                       Style="min-width: 120px;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Property="IsTerminal" Title="Конечный"
                                  Width="100px" TextAlign="TextAlign.Center" Filterable="false" Visible="@Col("OStatusColIsTerminal")">
                <Template Context="s">
                    @if (s.IsTerminal)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success"
                                     Class="status-badge" Text="Да" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="s">
                    <RadzenCheckBox @bind-Value="s.IsTerminal" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Property="IsInternal" Title="Системный"
                                  Width="110px" TextAlign="TextAlign.Center" Filterable="true" Visible="@Col("OStatusColIsInternal")">

                <FilterTemplate>
                    <div class="filter-all-item @( _filterType == null ? "active" : "" )"
                         @onclick="() => ClearFilter(() => _filterType = null)">
                        Все
                    </div>
                    <RadzenListBox @bind-Value="_filterType"
                                   Data="@_typeFilterOptions"
                                   TextProperty="Label"
                                   ValueProperty="Value"
                                   Placeholder="Все"
                                   AllowClear="true"
                                   Style="width:100%; max-height: 370px;"
                                   Change="@OnFilterChange"/>
                </FilterTemplate>
                <Template Context="s">
                    @if (s.IsInternal)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                     Class="status-badge" Text="Да" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="s">
                    <RadzenCheckBox @bind-Value="s.IsInternal" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Property="Synonym" Title="Синоним (API)"
                                  Width="240px" Visible="@Col("OStatusColSynonym")">
                <Template Context="s">
                    @if (!string.IsNullOrEmpty(s.Synonym))
                    {
                        <span style="font-family: monospace; font-size: 0.8rem; color: var(--rz-text-secondary-color);">@s.Synonym</span>
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="s">
                    <RadzenTextBox @bind-Value="s.Synonym" Style="width: 100%;"
                                   Placeholder="awaiting_deliver" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Property="MarketplaceClientType.Name"
                                  Title="Маркетплейс" Width="160px" Sortable="false" Filterable="true" Visible="@Col("OStatusColClientType")">
                <FilterTemplate>
                    <div class="filter-all-item @( _filterMarketplaceTypeId == null ? "active" : "" )"
                         @onclick="() => ClearFilter(() => _filterMarketplaceTypeId = null)">
                        Все
                    </div>
                    <RadzenListBox @bind-Value="_filterMarketplaceTypeId"
                                   Data="@_clientTypes"
                                   TextProperty="Name"
                                   ValueProperty="Id"
                                   Placeholder="Все"
                                   AllowClear="true"
                                   Style="width: 100%; min-width: 0; max-height: 370px;"
                                   Change="@OnFilterChange"/>

                </FilterTemplate>

                <Template Context="s">
                    @if (s.MarketplaceClientType != null)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Secondary"
                                     Class="status-badge"
                                     Text="@s.MarketplaceClientType.Name" />
                    }
                    else if (s.IsInternal)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                     Class="status-badge"
                                     Text="Системный" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="s">
                    <RadzenDropDown Data="@_clientTypes"
                                    TextProperty="Name"
                                    ValueProperty="Id"
                                    @bind-Value="s.MarketplaceClientTypeId"
                                    Placeholder="Не привязан"
                                    AllowClear="true"
                                    Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="OrderStatus" Filterable="false" Sortable="false"
                                  Width="110px" TextAlign="TextAlign.Center" Title="">
                <EditTemplate Context="s">
                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => SaveRow(s))" Style="margin-right: 4px;" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => CancelRow(s))" />
                </EditTemplate>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private RadzenDataGrid<OrderStatus>? _grid;
    private bool _initialized;
    private IEnumerable<OrderStatus> _pageItems = Array.Empty<OrderStatus>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private bool _canManage;
    private System.Security.Claims.ClaimsPrincipal? _user;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    private bool Col(string role) => _user?.IsInRole("Admin") == true || _user?.IsInRole(role) == true;

    private List<MarketplaceClientType> _clientTypes = new();

    private string? _filterType;
    private Guid? _filterMarketplaceTypeId;
    private bool? _filterTerminal;

    private int _countInternal;
    private int _countMarketplace;
    private int _countTerminal;
    private int _countNonTerminal;
    private Dictionary<Guid, int> _countByClientTypeId = new();

    private record FilterOption(string Label, string Value);
    private readonly List<FilterOption> _typeFilterOptions =
    [
        new("Системные", "internal"),
        new("Маркетплейсовые", "marketplace")
    ];

    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "order-statuses-grid-settings";
    private const string FiltersKey = "order-statuses-filters";

    private record StatusFilters(string? FilterType, Guid? MarketplaceTypeId, bool? FilterTerminal = null);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var state = await AuthState;
            _user = state.User;
            _canManage = state.User.IsInRole("Admin") || state.User.IsInRole("OrderStatusesManage");
            await LoadGridSettingsAsync();
            await LoadFiltersAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadFiltersAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", FiltersKey);
            if (!string.IsNullOrEmpty(json))
            {
                var f = System.Text.Json.JsonSerializer.Deserialize<StatusFilters>(json);
                if (f != null)
                {
                    _filterType = f.FilterType;
                    _filterMarketplaceTypeId = f.MarketplaceTypeId;
                    _filterTerminal = f.FilterTerminal;
                    StateHasChanged();
                }
            }
        }
        catch { }
    }

    private async Task SaveFiltersAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(new StatusFilters(_filterType, _filterMarketplaceTypeId, _filterTerminal));
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", FiltersKey, json);
        }
        catch { }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        await EnsureInitializedAsync();

        var filter = new OrderStatusPageFilter(_filterType, _filterMarketplaceTypeId, _filterTerminal);
        var skip   = args.Skip ?? 0;
        var take   = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 20);

        var result = await StatusService.GetPagedAsync(filter, args.Filter, args.OrderBy, skip, take);
        _pageItems  = result.Items;
        _totalCount = result.TotalCount;
        _loading = false;
    }

    private async Task EnsureInitializedAsync()
    {
        if (_initialized) return;
        var data = await StatusService.GetInitDataAsync();
        _clientTypes         = data.ClientTypes;
        _countInternal       = data.CountInternal;
        _countMarketplace    = data.CountMarketplace;
        _countTerminal       = data.CountTerminal;
        _countNonTerminal    = data.CountNonTerminal;
        _countByClientTypeId = data.CountByClientTypeId;
        _initialized = true;
    }

    private async Task OnFilterChange()
    {
        _ = SaveFiltersAsync();
        if (_grid != null)
            await _grid.Reload();
    }

    private async Task ClearFilter(Action clear)
    {
        clear();
        await OnFilterChange();
    }

    private async Task AddRow()
    {
        await EnsureInitializedAsync();
        var newStatus = new OrderStatus { Id = Guid.NewGuid() };
        await _grid!.InsertRow(newStatus);
    }

    private async Task EditRow(OrderStatus s) => await _grid!.EditRow(s);

    private async Task SaveRow(OrderStatus s) => await _grid!.UpdateRow(s);

    private void CancelRow(OrderStatus s) => _grid!.CancelEditRow(s);

    private async Task OnUpdate(OrderStatus s)
    {
        try
        {
            s.Color = ToHex(s.Color) ?? s.Color;
            await StatusService.UpdateAsync(s);
            NotificationService.Notify(NotificationSeverity.Success, "Статус обновлён");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private async Task OnCreate(OrderStatus s)
    {
        try
        {
            s.Color = ToHex(s.Color) ?? s.Color;
            await StatusService.CreateAsync(s);
            NotificationService.Notify(NotificationSeverity.Success, "Статус создан");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
            await _grid!.Reload();
        }
    }

    private async Task DeleteRow(OrderStatus s)
    {
        var confirmed = await DialogService.Confirm(
            $"Удалить статус «{s.Name}»?",
            "Подтверждение",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена" });

        if (confirmed != true) return;

        try
        {
            await StatusService.SoftDeleteAsync(s);
            await _grid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Статус удалён");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<OrderStatus> args)
    {
        var items = new List<ContextMenuItem>();
        if (_canManage)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" });
        }
        if (items.Count == 0) return;

        ContextMenuService.Open(args, items,
            e =>
            {
                ContextMenuService.Close();
                if (e.Value?.ToString() == "edit")
                    InvokeAsync(() => EditRow(args.Data!));
                else if (e.Value?.ToString() == "delete")
                    InvokeAsync(() => DeleteRow(args.Data!));
            });
    }

    private void OnColorChanged(OrderStatus status, string? value)
    {
        status.Color = ToHex(value);
        StateHasChanged();
    }

    private static string? ToHex(string? color)
    {
        if (string.IsNullOrWhiteSpace(color)) return null;

        color = color.Trim();
        if (color.StartsWith("#"))
        {
            var hex = color.TrimStart('#');
            if (hex.Length == 6 && hex.All(c => "0123456789abcdefABCDEF".Contains(c)))
                return "#" + hex.ToUpperInvariant();
            if (hex.Length == 3 && hex.All(c => "0123456789abcdefABCDEF".Contains(c)))
                return "#" + string.Concat(hex.Select(c => $"{c}{c}")).ToUpperInvariant();
            return null;
        }

        var rgba = System.Text.RegularExpressions.Regex.Match(
            color, @"rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)(?:\s*,\s*[\d.]+)?\s*\)");
        if (rgba.Success)
        {
            var r = int.Parse(rgba.Groups[1].Value);
            var g = int.Parse(rgba.Groups[2].Value);
            var b = int.Parse(rgba.Groups[3].Value);
            return $"#{r:X2}{g:X2}{b:X2}";
        }

        return null;
    }

    private static bool IsLightColor(string hex)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length < 6) return true;
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 128;
        }
        catch { return true; }
    }

    string GetSoftBackground(string color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "#ececff";

        color = color.TrimStart('#').Trim();
        if (color.Length < 6)
            return "#ececff";

        try
        {
            var r = Convert.ToInt32(color[..2], 16);
            var g = Convert.ToInt32(color[2..4], 16);
            var b = Convert.ToInt32(color[4..6], 16);

            // делаем пастельную версию
            r = (int)(r + (255 - r) * 0.6);
            g = (int)(g + (255 - g) * 0.6);
            b = (int)(b + (255 - b) * 0.6);

            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch (FormatException)
        {
            return "#ececff";
        }
    }

    string GetTextColor(string bg)
    {
        return IsLightColor(bg) ? "#1f2937" : "#ffffff";
    }


    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };
}
