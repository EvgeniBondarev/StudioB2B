@page "/orders-bulk-transaction"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using Radzen
@using StudioB2B.Application.Common
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Domain.Entities.Orders
@using StudioB2B.Infrastructure.Features.Orders
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Web.Services

@inject ITenantDbContextFactory Factory
@inject IOrderTransactionService TransactionService
@inject BulkOrderTransactionContext BulkOrderContext
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

@implements IDisposable

<PageTitle>Транзакция заказов</PageTitle>

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 200px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else if (_orders.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Не выбраны заказы для транзакции. Вернитесь на страницу
        <a href="/orders">«Заказы»</a> и отметьте нужные строки.
    </RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem" Style="margin-bottom: 1rem;">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.H5" Style="font-weight:700; margin:0;">
                Транзакция для @(_orders.Count) заказ(ов)
            </RadzenText>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                <RadzenDropDown TItem="OrderTransaction"
                                TValue="Guid?"
                                Data="@_transactions"
                                TextProperty="Name"
                                ValueProperty="Id"
                                Style="min-width: 260px;"
                                Placeholder="Выберите транзакцию"
                                Value="@_selectedTransactionId"
                                ValueChanged="OnTransactionChanged" />
                <RadzenButton Text="Применить ко всем"
                              Icon="done_all"
                              ButtonStyle="ButtonStyle.Primary"
                              Disabled="@(!_selectedTransactionId.HasValue)"
                              Click="@ApplyToAllAsync" />
            </RadzenStack>
        </RadzenStack>

        @if (_selectedTransactionId.HasValue && _previews.Count > 0)
        {
            <RadzenDataGrid TItem="Order"
                            Data="@_orders"
                            AllowPaging="false"
                            AllowSorting="false"
                            AllowFiltering="false"
                            Density="Density.Compact"
                            EmptyText="@RadzenRuStrings.EmptyText">
                <Columns>
                    <RadzenDataGridColumn TItem="Order" Title="Номер отправления" Width="200px">
                        <Template Context="o">
                            @o.Shipment?.PostingNumber
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Order" Title="Клиент" Width="160px">
                        <Template Context="o">
                            @o.Shipment?.MarketplaceClient?.Name
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Order" Title="Статус приложения" Width="190px">
                        <Template Context="o">
                            @o.SystemStatus?.Name
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Order" Title="Правила транзакции" Width="420px">
                        <Template Context="o">
                            @if (_previews.TryGetValue(o.Id, out var preview) && preview != null && preview.Rules.Count > 0)
                            {
                                <RadzenStack Gap="0.25rem">
                                    @foreach (var rule in preview.Rules)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" Style="flex-wrap:wrap;">
                                            <RadzenText TextStyle="TextStyle.Body2" Style="min-width:140px;">
                                                @rule.PriceTypeName
                                                @if (!string.IsNullOrEmpty(rule.ProductName))
                                                {
                                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">
                                                        (@rule.ProductName)
                                                    </RadzenText>
                                                }
                                            </RadzenText>
                                            @if (rule.RequiresUserInput)
                                            {
                                                <RadzenNumeric TValue="decimal"
                                                              Style="width:120px;"
                                                              Min="0"
                                                              Format="N2"
                                                              Value="@GetUserValue(o.Id, rule.RuleId)"
                                                              ValueChanged="@(v => SetUserValue(o.Id, rule.RuleId, v))"
                                                              Placeholder="Введите" />
                                            }
                                            else
                                            {
                                                <RadzenText TextStyle="TextStyle.Body2">
                                                    @(rule.ComputedValue?.ToString("N2") ?? "—")
                                                </RadzenText>
                                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">
                                                    (по формуле)
                                                </RadzenText>
                                            }
                                        </RadzenStack>
                                    }
                                </RadzenStack>
                            }
                            else
                            {
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">
                                    Транзакция неприменима к этому заказу
                                </RadzenText>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                Выберите транзакцию, чтобы увидеть расчёты по каждому заказу.
            </RadzenAlert>
        }
    </RadzenStack>
}

@code {
    private TenantDbContext? _db;
    private bool _loading = true;
    private List<Order> _orders = [];
    private List<OrderTransaction> _transactions = [];
    private Guid? _selectedTransactionId;
    private readonly Dictionary<Guid, TransactionApplyPreview?> _previews = new();
    private readonly Dictionary<string, decimal> _userValues = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _db = Factory.CreateDbContext();

        var ids = BulkOrderContext.OrderIds;
        if (ids == null || ids.Count == 0)
        {
            _loading = false;
            return;
        }

        _orders = await _db.Orders
            .IncludeForGrid()
            .Where(o => ids.Contains(o.Id))
            .AsNoTracking()
            .OrderBy(o => o.Shipment.PostingNumber)
            .ToListAsync();

        var systemStatusIds = _orders
            .Select(o => o.SystemStatusId)
            .Where(id => id.HasValue)
            .Select(id => id!.Value)
            .Distinct()
            .ToList();

        _transactions = await _db.OrderTransactions
            .Include(t => t.FromSystemStatus)
            .Include(t => t.ToSystemStatus)
            .Where(t => !t.IsDeleted && t.IsEnabled && systemStatusIds.Contains(t.FromSystemStatusId))
            .OrderBy(t => t.Name)
            .AsNoTracking()
            .ToListAsync();

        _loading = false;
    }

    private async Task OnTransactionChanged(Guid? transactionId)
    {
        _selectedTransactionId = transactionId;
        _previews.Clear();
        _userValues.Clear();

        if (!_selectedTransactionId.HasValue)
            return;

        foreach (var order in _orders)
        {
            var preview = await TransactionService.GetApplyPreviewAsync(order.Id, _selectedTransactionId.Value);
            _previews[order.Id] = preview;

            if (preview != null)
            {
                foreach (var rule in preview.Rules.Where(r => r.RequiresUserInput))
                {
                    var key = MakeKey(order.Id, rule.RuleId);
                    if (!_userValues.ContainsKey(key))
                        _userValues[key] = 0m;
                }
            }
        }
    }

    private decimal GetUserValue(Guid orderId, Guid ruleId)
    {
        var key = MakeKey(orderId, ruleId);
        return _userValues.TryGetValue(key, out var v) ? v : 0m;
    }

    private void SetUserValue(Guid orderId, Guid ruleId, decimal value)
    {
        var key = MakeKey(orderId, ruleId);
        _userValues[key] = value;
    }

    private static string MakeKey(Guid orderId, Guid ruleId) => $"{orderId:N}:{ruleId:N}";

    private async Task ApplyToAllAsync()
    {
        if (!_selectedTransactionId.HasValue)
            return;

        var success = 0;
        var failed = 0;

        foreach (var order in _orders)
        {
            if (!_previews.TryGetValue(order.Id, out var preview) || preview == null)
            {
                failed++;
                continue;
            }

            var perOrder = new Dictionary<Guid, decimal>();
            foreach (var rule in preview.Rules.Where(r => r.RequiresUserInput))
            {
                var key = MakeKey(order.Id, rule.RuleId);
                if (_userValues.TryGetValue(key, out var v))
                    perOrder[rule.RuleId] = v;
            }

            var result = await TransactionService.ApplyAsync(order.Id, _selectedTransactionId.Value, perOrder);
            if (result.Success)
                success++;
            else
                failed++;
        }

        NotificationService.Notify(
            failed == 0 ? NotificationSeverity.Success : NotificationSeverity.Warning,
            "Массовая транзакция",
            $"Успешно: {success}, с ошибками: {failed}");

        NavigationManager.NavigateTo("/orders");
    }

    public void Dispose() => _db?.Dispose();
}

