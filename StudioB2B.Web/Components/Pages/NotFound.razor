@page "/not-found"

<PageTitle>Страница не найдена — StudioB2B</PageTitle>

<div style="display: flex; justify-content: center; padding-top: 4rem; text-align: center;">
    <div style="max-width: 400px;">
        <RadzenIcon Icon="search_off" Style="font-size: 6rem; color: var(--rz-text-secondary-color); display: block; margin-bottom: 1rem;" />
        <RadzenText TextStyle="TextStyle.H3" Style="font-weight: 700; margin-bottom: 0.5rem;">404</RadzenText>
        <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom: 0.5rem;">Страница не найдена</RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color); margin-bottom: 2rem;">
            Запрошенная страница не существует.
        </RadzenText>
    </div>
</div>
