@page "/roles"
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Entities.Common
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Persistence.Master

@inject MasterDbContext Db
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService

<PageTitle>Роли — StudioB2B</PageTitle>

<MasterOnlyGuard>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 0.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Роли</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <RadzenButton Icon="add" Text="Создать роль" ButtonStyle="ButtonStyle.Primary" Click="@InsertRow" />
        </RadzenStack>
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Body2"
                Style="color: var(--rz-text-secondary-color); margin-bottom: 1.5rem; display: block;">
        Роли хранятся в мастер-базе и доступны для всех пользователей системы.
    </RadzenText>

    <RadzenDataGrid @ref="_grid"
                    TItem="Role"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="15"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    EditMode="DataGridEditMode.Single"
                    RowCreate="@OnCreate"
                    RowUpdate="@OnUpdate"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading">
        <Columns>

            <RadzenDataGridColumn TItem="Role" Property="Name" Title="Название" Width="300px">
                <EditTemplate Context="r">
                    <RadzenTextBox @bind-Value="r.Name" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <!-- Кнопки сохранения/отмены — только в режиме редактирования строки -->
            <RadzenDataGridColumn TItem="Role" Filterable="false" Sortable="false"
                                  Width="110px" TextAlign="TextAlign.Center" Title="">
                <Template Context="r">
                </Template>
                <EditTemplate Context="r">
                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.ExtraSmall"
                                  Click="@(() => SaveRow(r))" Style="margin-right: 4px;" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                  Click="@(() => CancelRow(r))" />
                </EditTemplate>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>

</MasterOnlyGuard>

@code {
    private RadzenDataGrid<Role>? _grid;
    private IEnumerable<Role> _pageItems = Array.Empty<Role>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        var a = await Db.Roles.AsNoTracking().AsQueryable().ToListAsync();
        var query = Db.Roles.AsNoTracking().AsQueryable();

        if (!string.IsNullOrEmpty(args.Filter))
            query = query.Where(args.Filter);

        query = !string.IsNullOrEmpty(args.OrderBy)
            ? query.OrderBy(args.OrderBy)
            : query.OrderBy(r => r.Name);

        _totalCount = await query.CountAsync();

        var skip = args.Skip ?? 0;
        var take = (args.Top is > 0) ? args.Top.Value : (_grid?.PageSize ?? 15);

        _pageItems = await query.Skip(skip).Take(take).ToListAsync();
        _loading = false;
    }

    private async Task InsertRow()
    {
        var role = new Role { Id = Guid.NewGuid() };
        await _grid!.InsertRow(role);
    }

    private async Task EditRow(Role role) => await _grid!.EditRow(role);

    private async Task SaveRow(Role role) => await _grid!.UpdateRow(role);

    private void CancelRow(Role role) => _grid!.CancelEditRow(role);

    private async Task OnCreate(Role role)
    {
        try
        {
            await Db.CreateAsync(role);
            NotificationService.Notify(NotificationSeverity.Success, "Роль создана");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
            _grid!.CancelEditRow(role);
        }
    }

    private async Task OnUpdate(Role role)
    {
        try
        {
            await Db.UpdateAsync(role);
            NotificationService.Notify(NotificationSeverity.Success, "Роль обновлена");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private async Task DeleteRow(Role role)
    {
        try
        {
            await Db.DeleteAsync(role.Id);
            await _grid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Роль удалена");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<Role> args)
    {
        ContextMenuService.Open(args,
            [
                new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" },
                new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" }
            ],
            e =>
            {
                ContextMenuService.Close();
                if (e.Value?.ToString() == "edit")
                    InvokeAsync(() => EditRow(args.Data));
                else if (e.Value?.ToString() == "delete")
                    InvokeAsync(() => DeleteRow(args.Data));
            });
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };
}
