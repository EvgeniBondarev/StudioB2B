@page "/users"
@attribute [Authorize(Roles = "Директор")]
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Entities.Tenant
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory DbFactory
@inject IPasswordHasher PasswordHasher
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService

@implements IDisposable

<PageTitle>Пользователи</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Пользователи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <RadzenButton Icon="person_add" Text="Добавить пользователя" ButtonStyle="ButtonStyle.Primary"
                          Click="@OpenCreateForm" />
        </RadzenStack>
    </RadzenStack>

    @if (_editUser != null)
    {
        <div style="background: var(--rz-sidebar-background-color); border: 1px solid var(--rz-border-color);
                    border-radius: var(--rz-border-radius); padding: 1.5rem; margin-bottom: 1.5rem;">
            <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 1rem; font-weight: 600;">
                @(_editUser.Id == Guid.Empty ? "Новый пользователь" : "Редактировать пользователя")
            </RadzenText>

            <RadzenTemplateForm TItem="UserEditModel" Data="_editUser" Submit="@SaveUser">
                <RadzenStack Gap="1rem">

                    <RadzenFormField Text="Email" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_editUser.Email" Name="Email" Style="width: 100%;"
                                       Disabled="@(_editUser.Id != Guid.Empty)" />
                    </RadzenFormField>

                    <RadzenFormField Text="Фамилия" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_editUser.Surname" Name="Surname" Style="width: 100%;" />
                    </RadzenFormField>

                    <RadzenFormField Text="Имя" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_editUser.FirstName" Name="FirstName" Style="width: 100%;" />
                    </RadzenFormField>

                    <RadzenFormField Text="Отчество" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_editUser.Patronymic" Name="Patronymic" Style="width: 100%;" />
                    </RadzenFormField>

                    @if (_editUser.Id == Guid.Empty)
                    {
                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <RadzenPassword @bind-Value="_editUser.Password" Name="Password" Style="width: 100%;" />
                        </RadzenFormField>
                    }

                    <RadzenFormField Text="Роли" Style="width: 100%;">
                        <RadzenDropDown Data="@_availableRoles"
                                        TextProperty="Name"
                                        ValueProperty="Id"
                                        @bind-Value="_editUser.RoleIds"
                                        Multiple="true"
                                        AllowClear="true"
                                        Style="width: 100%;" />
                    </RadzenFormField>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenButton ButtonType="ButtonType.Submit" Text="Сохранить"
                                      ButtonStyle="ButtonStyle.Primary" IsBusy="@_saving" />
                        <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => _editUser = null)" />
                    </RadzenStack>

                </RadzenStack>
            </RadzenTemplateForm>
        </div>
    }

    <RadzenDataGrid @ref="_grid"
                    TItem="UserRowModel"
                    Data="@_users"
                    Density="@_density"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="15"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    ColumnWidth="180px"
                    IsLoading="@_loading"
                    CellContextMenu="@ShowContextMenu">
        <Columns>
            <RadzenDataGridColumn TItem="UserRowModel" Property="Email" Title="Email" Width="260px" Frozen="true" />
            <RadzenDataGridColumn TItem="UserRowModel" Property="Surname" Title="Фамилия" Width="160px" />
            <RadzenDataGridColumn TItem="UserRowModel" Property="FirstName" Title="Имя" Width="140px" />
            <RadzenDataGridColumn TItem="UserRowModel" Property="Patronymic" Title="Отчество" Width="160px" />

            <RadzenDataGridColumn TItem="UserRowModel" Title="Роли" Width="280px"
                                  Sortable="false" Filterable="false">
                <Template Context="u">
                    @string.Join(", ", u.RoleNames)
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<UserRowModel>? _grid;
    private List<UserRowModel> _users = [];
    private List<TenantRole> _availableRoles = [];
    private bool _loading = true;
    private bool _saving;
    private Density _density = Density.Default;
    private UserEditModel? _editUser;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    private TenantDbContext? _db;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved)
        {
            _db = DbFactory.CreateDbContext();
            await LoadAsync();
        }
        else
        {
            _loading = false;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _availableRoles = await _db!.Roles.AsNoTracking().OrderBy(r => r.Name).ToListAsync();
        var users = await _db!.Users.GetAllAsync();
        _users = users.Select(u => new UserRowModel
        {
            Id = u.Id,
            Email = u.Email,
            Surname = u.Surname,
            FirstName = u.FirstName,
            Patronymic = u.Patronymic,
            RoleNames = u.Roles.Select(r => r.Name).ToList()
        }).ToList();
        _loading = false;
    }

    private void OpenCreateForm()
    {
        _editUser = new UserEditModel { Id = Guid.Empty };
    }

    private void OpenEditForm(UserRowModel user)
    {
        var roleIds = _availableRoles
            .Where(r => user.RoleNames.Contains(r.Name))
            .Select(r => r.Id)
            .ToList();

        _editUser = new UserEditModel
        {
            Id = user.Id,
            Email = user.Email,
            Surname = user.Surname,
            FirstName = user.FirstName,
            Patronymic = user.Patronymic,
            RoleIds = roleIds
        };
    }

    private async Task SaveUser(UserEditModel model)
    {
        _saving = true;
        try
        {
            var selectedRoles = _availableRoles.Where(r => model.RoleIds.Contains(r.Id)).ToList();

            if (model.Id == Guid.Empty)
            {
                if (string.IsNullOrWhiteSpace(model.Email) || string.IsNullOrWhiteSpace(model.Password))
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", "Email и пароль обязательны");
                    return;
                }

                var exists = await _db!.Users.AnyAsync(u => u.Email == model.Email);
                if (exists)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", "Пользователь с таким email уже существует");
                    return;
                }

                // Attach roles from tenant db context so EF tracks them
                var tenantRoles = new List<TenantRole>();
                foreach (var r in selectedRoles)
                {
                    var tracked = await _db!.Roles.FindAsync(r.Id)
                                  ?? _db!.Roles.Attach(new TenantRole { Id = r.Id, Name = r.Name }).Entity;
                    tenantRoles.Add(tracked);
                }

                var user = new TenantUser
                {
                    Id = Guid.NewGuid(),
                    Email = model.Email,
                    Surname = model.Surname,
                    FirstName = model.FirstName,
                    Patronymic = model.Patronymic,
                    PasswordHash = PasswordHasher.Hash(model.Password!),
                    Roles = tenantRoles
                };

                await _db.CreateAsync(user);
                NotificationService.Notify(NotificationSeverity.Success, "Пользователь создан");
                _editUser = null;
                await LoadAsync();
            }
            else
            {
                var user = await _db!.Users
                    .Include(u => u.Roles)
                    .FirstOrDefaultAsync(u => u.Id == model.Id);

                if (user is null)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", "Пользователь не найден");
                    return;
                }

                // Update FIO
                user.Surname = model.Surname;
                user.FirstName = model.FirstName;
                user.Patronymic = model.Patronymic;

                // Sync roles
                user.Roles.Clear();
                foreach (var r in selectedRoles)
                {
                    var tracked = await _db!.Roles.FindAsync(r.Id)
                                  ?? _db!.Roles.Attach(new TenantRole { Id = r.Id, Name = r.Name }).Entity;
                    user.Roles.Add(tracked);
                }

                await _db!.UpdateAsync(user);
                NotificationService.Notify(NotificationSeverity.Success, "Пользователь обновлён");
                _editUser = null;
                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteUser(UserRowModel user)
    {
        try
        {
            await TenantUserExtensions.DeleteAsync(_db!, user.Id);
            NotificationService.Notify(NotificationSeverity.Success, "Пользователь удалён");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<UserRowModel> args)
    {
        ContextMenuService.Open(args,
            [
                new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" },
                new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" }
            ],
            e =>
            {
                ContextMenuService.Close();
                if (e.Value?.ToString() == "edit")
                    InvokeAsync(() => { OpenEditForm(args.Data); return Task.CompletedTask; });
                else if (e.Value?.ToString() == "delete")
                    InvokeAsync(() => DeleteUser(args.Data));
            });
    }

    public void Dispose() => _db?.Dispose();

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };

    private class UserRowModel
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = "";
        public string Surname { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string Patronymic { get; set; } = "";
        public List<string> RoleNames { get; set; } = [];
    }

    private class UserEditModel
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = "";
        public string Surname { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string Patronymic { get; set; } = "";
        public string? Password { get; set; }
        public List<Guid> RoleIds { get; set; } = [];
    }
}
