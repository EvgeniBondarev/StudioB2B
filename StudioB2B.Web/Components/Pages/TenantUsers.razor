@page "/users"
@attribute [Authorize(Roles = nameof(PageEnum.UsersView))]
@using StudioB2B.Infrastructure.Interfaces

@inject IUserService UserService
@inject ITenantProvider TenantProvider
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JsRuntime

<link rel="stylesheet" href="css/orders.css" />
<PageTitle>Пользователи</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Пользователи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <AuthorizeView Roles="@nameof(FunctionEnum.UsersManage)">
                <Authorized>
                    <RadzenButton Icon="person_add" Text="Добавить пользователя" Shade="Shade.Light"
                                  ButtonStyle="ButtonStyle.Primary" Click="@OpenCreateDialog" />
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                 Style="padding: 0 0 0.6rem 0; flex-wrap: wrap;">
        @{ var allActiveFilter = !_filterActive.HasValue; }
        <span class="q-pill @(allActiveFilter ? "active" : "")"
              style="background:@(allActiveFilter ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allActiveFilter ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(() => { _filterActive = null; StateHasChanged(); })">
            Все
            @if (_users.Count > 0) { <span class="q-pill-count">@_users.Count</span> }
        </span>
        <span class="q-pill @(_filterActive == true ? "active" : "")"
              style="background:@(_filterActive == true ? "#10b981" : "#d1fae5"); color:@(_filterActive == true ? "#fff" : "#065f46");"
              @onclick="@(() => { _filterActive = _filterActive == true ? null : (bool?)true; StateHasChanged(); })">
            Активные
            @if (_users.Count(u => u.IsActive) > 0) { <span class="q-pill-count">@_users.Count(u => u.IsActive)</span> }
        </span>
        <span class="q-pill @(_filterActive == false ? "active" : "")"
              style="background:@(_filterActive == false ? "#ef4444" : "#fee2e2"); color:@(_filterActive == false ? "#fff" : "#7f1d1d");"
              @onclick="@(() => { _filterActive = _filterActive == false ? null : (bool?)false; StateHasChanged(); })">
            Неактивные
            @if (_users.Count(u => !u.IsActive) > 0) { <span class="q-pill-count">@_users.Count(u => !u.IsActive)</span> }
        </span>
    </RadzenStack>

    <RadzenDataGrid @ref="_grid"
                    TItem="UserListDto"
                    Data="@FilteredUsers"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="15"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    ColumnWidth="180px"
                    IsLoading="@_loading"
                    CellContextMenu="@ShowContextMenu"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>
            <RadzenDataGridColumn TItem="UserListDto" Property="LastName" Title="Фамилия" Width="180px" Frozen="true" Visible="@Col(nameof(PageColumnEnum.UsersColLastName))" />
            <RadzenDataGridColumn TItem="UserListDto" Property="FirstName" Title="Имя" Width="160px" Visible="@Col(nameof(PageColumnEnum.UsersColFirstName))" />
            <RadzenDataGridColumn TItem="UserListDto" Property="MiddleName" Title="Отчество" Width="160px" Visible="@Col(nameof(PageColumnEnum.UsersColMiddleName))" />
            <RadzenDataGridColumn TItem="UserListDto" Property="Email" Title="Email" Width="240px" Visible="@Col(nameof(PageColumnEnum.UsersColEmail))" />

            <RadzenDataGridColumn TItem="UserListDto" Property="IsActive" Title="Активен"
                                  Width="110px" TextAlign="TextAlign.Center" Filterable="false"
                                  Visible="@Col(nameof(PageColumnEnum.UsersColIsActive))">
                <Template Context="u">
                    <RadzenCheckBox TValue="bool" Value="@u.IsActive" Disabled="true" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="UserListDto" Title="Права" Width="260px"
                                  Sortable="false" Filterable="false"
                                  Visible="@Col(nameof(PageColumnEnum.UsersColPermissions))">
                <Template Context="u">
                    @string.Join(", ", u.Permissions)
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private RadzenDataGrid<UserListDto>? _grid;
    private List<UserListDto> _users = [];
    private bool _loading = true;
    private bool _canManage;
    private System.Security.Claims.ClaimsPrincipal? _user;
    private Density _density = Density.Default;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    private bool? _filterActive;
    private IEnumerable<UserListDto> FilteredUsers =>
        _filterActive.HasValue ? _users.Where(u => u.IsActive == _filterActive.Value) : _users;

    private bool Col(string role) => _user?.IsInRole("Admin") == true || _user?.IsInRole(role) == true;

    // ...existing code...

    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "tenant-users-grid-settings";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        _user = state.User;
        _canManage = state.User.IsInRole("Admin") || state.User.IsInRole(nameof(FunctionEnum.UsersManage));

        if (TenantProvider.IsResolved)
            await LoadAsync();
        else
            _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadGridSettingsAsync();
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _users = await UserService.GetAllUsersAsync(CancellationToken.None);
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var result = await DialogService.OpenAsync<UserEditDialog>(
            "Новый пользователь",
            new Dictionary<string, object?>
            {
                [nameof(UserEditDialog.UserId)] = Guid.Empty
            },
            new DialogOptions { Width = "min(640px, 96vw)", CloseDialogOnOverlayClick = true });

        if (result is true)
        {
            await LoadAsync();                              // data first
            var state = await AuthState;
            _canManage = state.User.IsInRole("Admin") || state.User.IsInRole(nameof(FunctionEnum.UsersManage));
        }
    }

    private async Task OpenEditDialog(UserListDto userArg)
    {
        // Pass only UserId — the dialog loads fresh data via GetUserById itself,
        // so we never risk showing stale data captured in args.Data.
        var result = await DialogService.OpenAsync<UserEditDialog>(
            "Редактировать пользователя",
            new Dictionary<string, object?>
            {
                [nameof(UserEditDialog.UserId)] = userArg.Id
            },
            new DialogOptions { Width = "min(640px, 96vw)", CloseDialogOnOverlayClick = true });

        if (result is true)
        {
            await LoadAsync();                              // data first
            var state = await AuthState;
            _canManage = state.User.IsInRole("Admin") || state.User.IsInRole(nameof(FunctionEnum.UsersManage));
        }
    }

    private async Task DeleteUser(UserListDto user)
    {
        var confirmed = await DialogService.Confirm(
            $"Удалить пользователя «{user.LastName} {user.FirstName}»?",
            "Подтверждение удаления",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена",
                                 CloseDialogOnOverlayClick = true });

        if (confirmed != true) return;

        var (ok, error) = await UserService.DeleteUserAsync(user.Id, CancellationToken.None);
        if (ok)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Пользователь удалён");
            await LoadAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка удаления");
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<UserListDto> args)
    {
        var items = new List<ContextMenuItem>();
        if (_canManage)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" });
        }
        if (items.Count == 0) return;

        ContextMenuService.Open(args, items, e =>
        {
            ContextMenuService.Close();
            if (e.Value?.ToString() == "edit")
                InvokeAsync(() => OpenEditDialog(args.Data!));
            else if (e.Value?.ToString() == "delete")
                InvokeAsync(() => DeleteUser(args.Data!));
        });
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };
}
