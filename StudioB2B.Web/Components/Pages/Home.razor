@page "/"
@using StudioB2B.Application.Common.Interfaces
@inject ITenantProvider TenantProvider
@inject ITenantService TenantService

<PageTitle>StudioB2B</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">StudioB2B</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Multi-Tenant Order Management System</MudText>

<MudGrid>
    <!-- Информация о пользователе -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
                        Текущий пользователь
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <AuthorizeView>
                    <Authorized>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">
                                <MudText><strong>Статус:</strong></MudText>
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Авторизован</MudChip>
                            </MudListItem>
                            <MudListItem T="string">
                                <MudText><strong>Email:</strong> <code>@context.User.Identity?.Name</code></MudText>
                            </MudListItem>
                            @if (context.User.IsInRole("Admin"))
                            {
                                <MudListItem T="string">
                                    <MudText><strong>Роль:</strong></MudText>
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Admin</MudChip>
                                </MudListItem>
                            }
                        </MudList>
                        <MudButton
                            Href="/account/logout"
                            Variant="Variant.Outlined"
                            Color="Color.Error"
                            Size="Size.Small"
                            Class="mt-2">
                            Выйти
                        </MudButton>
                    </Authorized>
                    <NotAuthorized>
                        <MudAlert Severity="Severity.Info">
                            <MudText Typo="Typo.subtitle2"><b>Вы не авторизованы.</b></MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">Войдите в систему для доступа к функциям.</MudText>
                            <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                Войти
                            </MudButton>
                        </MudAlert>
                    </NotAuthorized>
                </AuthorizeView>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Информация о тенанте -->
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
                        Информация о тенанте
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (TenantProvider.IsResolved)
                {
                    <MudList T="string" Dense="true">
                        <MudListItem T="string">
                            <MudText><strong>Статус:</strong></MudText>
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Подключён</MudChip>
                        </MudListItem>
                        <MudListItem T="string">
                            <MudText><strong>Субдомен:</strong> <code>@TenantProvider.Subdomain</code></MudText>
                        </MudListItem>
                        <MudListItem T="string">
                            <MudText><strong>Tenant ID:</strong> <code style="font-size: 0.75em;">@TenantProvider.TenantId</code></MudText>
                        </MudListItem>
                        @if (_tenant != null)
                        {
                            <MudListItem T="string">
                                <MudText><strong>Компания:</strong> @_tenant.Name</MudText>
                            </MudListItem>
                            <MudListItem T="string">
                                <MudText><strong>Тариф:</strong></MudText>
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@_tenant.Tariff</MudChip>
                                @if (_tenant.IsTrialExpired())
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-1">Истёк</MudChip>
                                }
                            </MudListItem>
                            @if (_tenant.TrialExpiresAtUtc.HasValue)
                            {
                                <MudListItem T="string">
                                    <MudText><strong>Триал до:</strong> @_tenant.TrialExpiresAtUtc.Value.ToString("dd.MM.yyyy HH:mm")</MudText>
                                </MudListItem>
                            }
                            <MudListItem T="string">
                                <MudText><strong>Создан:</strong> @_tenant.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</MudText>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning">
                        <MudText Typo="Typo.subtitle2"><b>Тенант не определён.</b></MudText>
                        <MudText Typo="Typo.body2">Перейдите по адресу вашей компании.</MudText>
                    </MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Быстрые ссылки -->
    <MudItem xs="12">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Link" Class="mr-2" />
                        Быстрые ссылки
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Row="true" Spacing="2">
                    <AuthorizeView>
                        <NotAuthorized>
                            @if (TenantProvider.IsResolved)
                            {
                                <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary">
                                    Войти в систему
                                </MudButton>
                            }
                        </NotAuthorized>
                    </AuthorizeView>
                    <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Success">
                        Зарегистрировать компанию
                    </MudButton>
                    <MudButton Href="/health" Variant="Variant.Outlined" Color="Color.Default">
                        Health Check
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private Domain.Entities.Tenants.Tenant? _tenant;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved && TenantProvider.TenantId.HasValue)
        {
            _tenant = await TenantService.GetByIdAsync(TenantProvider.TenantId.Value);
        }
    }
}

