@page "/"
@inject ITenantProvider TenantProvider

<PageTitle>StudioB2B</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-8" Elevation="3">
        @if (!TenantProvider.IsResolved)
        {
            <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6" Style="font-weight:700">
                StudioB2B
            </MudText>

            <AuthorizeView>
                <Authorized>
                    <MudText Align="Align.Center" Class="mb-1">
                        Вы вошли как <strong>@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</strong>
                    </MudText>
                    <MudStack Row="true" Justify="Justify.Center" Class="mb-4" Wrap="Wrap.Wrap">
                        @foreach (var role in context.User.FindAll(System.Security.Claims.ClaimTypes.Role))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @role.Value
                            </MudChip>
                        }
                    </MudStack>
                    <MudButton Href="/register-tenant"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="mb-3"
                               StartIcon="@Icons.Material.Outlined.AddBusiness">
                        Добавить тенант
                    </MudButton>
                    <MudButton OnClick="Logout"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               FullWidth="true">
                        Выйти
                    </MudButton>
                </Authorized>
                <NotAuthorized>
                    <MudButton Href="/login"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="mb-3"
                               StartIcon="@Icons.Material.Outlined.Login">
                        Войти
                    </MudButton>
                    <MudButton Href="/register"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Outlined.PersonAdd">
                        Зарегистрироваться
                    </MudButton>
                </NotAuthorized>
            </AuthorizeView>
        }
        else
        {
            <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-2" Style="font-weight:700">
                @TenantProvider.Subdomain
            </MudText>

            <AuthorizeView>
                <Authorized>
                    <MudText Align="Align.Center" Class="mb-1">
                        Вы вошли как <strong>@context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</strong>
                    </MudText>
                    <MudStack Row="true" Justify="Justify.Center" Class="mb-4" Wrap="Wrap.Wrap">
                        @foreach (var role in context.User.FindAll(System.Security.Claims.ClaimTypes.Role))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                @role.Value
                            </MudChip>
                        }
                    </MudStack>
                    <MudButton OnClick="Logout"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               FullWidth="true">
                        Выйти
                    </MudButton>
                </Authorized>
                <NotAuthorized>
                    <MudButton Href="/login"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Outlined.Login">
                        Войти
                    </MudButton>
                </NotAuthorized>
            </AuthorizeView>
        }
    </MudPaper>
</MudContainer>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void Logout()
    {
        // forceLoad=true — полный page load, контроллер удалит куку и редиректит на /
        Navigation.NavigateTo("/auth/logout", forceLoad: true);
    }
}

