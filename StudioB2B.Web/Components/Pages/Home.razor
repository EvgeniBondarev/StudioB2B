@page "/"
@using StudioB2B.Application.Common.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject ITenantProvider TenantProvider
@inject ITenantService TenantService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>StudioB2B</PageTitle>

<div class="container mt-4">
    <h1>StudioB2B</h1>
    <p class="lead">Multi-Tenant Order Management System</p>

    <hr />

    <div class="row">
        <!-- Информация о пользователе -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Текущий пользователь</h5>
                </div>
                <div class="card-body">
                    <AuthorizeView>
                        <Authorized>
                            <table class="table table-sm mb-2">
                                <tr>
                                    <th>Статус:</th>
                                    <td><span class="badge bg-success">Авторизован</span></td>
                                </tr>
                                <tr>
                                    <th>Email:</th>
                                    <td><code>@context.User.Identity?.Name</code></td>
                                </tr>
                                @if (context.User.IsInRole("Admin"))
                                {
                                    <tr>
                                        <th>Роль:</th>
                                        <td><span class="badge bg-danger">Admin</span></td>
                                    </tr>
                                }
                            </table>
                            <a href="/account/logout" class="btn btn-outline-danger btn-sm">
                                Выйти
                            </a>
                        </Authorized>
                        <NotAuthorized>
                            <div class="alert alert-info mb-0">
                                <strong>Вы не авторизованы.</strong>
                                <p class="mb-2">Войдите в систему для доступа к функциям.</p>
                                <a href="/login" class="btn btn-primary btn-sm">Войти</a>
                            </div>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>

        <!-- Информация о тенанте -->
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Информация о тенанте</h5>
                </div>
                <div class="card-body">
                    @if (TenantProvider.IsResolved)
                    {
                        <table class="table table-sm mb-0">
                            <tr>
                                <th>Статус:</th>
                                <td><span class="badge bg-success">Подключён</span></td>
                            </tr>
                            <tr>
                                <th>Субдомен:</th>
                                <td><code>@TenantProvider.Subdomain</code></td>
                            </tr>
                            <tr>
                                <th>Tenant ID:</th>
                                <td><code style="font-size: 0.75em;">@TenantProvider.TenantId</code></td>
                            </tr>
                            @if (_tenant != null)
                            {
                                <tr>
                                    <th>Компания:</th>
                                    <td><strong>@_tenant.Name</strong></td>
                                </tr>
                                <tr>
                                    <th>Тариф:</th>
                                    <td>
                                        <span class="badge bg-primary">@_tenant.Tariff</span>
                                        @if (_tenant.IsTrialExpired())
                                        {
                                            <span class="badge bg-danger ms-1">Истёк</span>
                                        }
                                    </td>
                                </tr>
                                @if (_tenant.TrialExpiresAtUtc.HasValue)
                                {
                                    <tr>
                                        <th>Триал до:</th>
                                        <td>@_tenant.TrialExpiresAtUtc.Value.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                                <tr>
                                    <th>Создан:</th>
                                    <td>@_tenant.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <strong>Тенант не определён.</strong>
                            <p class="mb-0">Перейдите по адресу вашей компании.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Быстрые ссылки -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Быстрые ссылки</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 flex-wrap">
                        <AuthorizeView>
                            <NotAuthorized>
                                @if (TenantProvider.IsResolved)
                                {
                                    <a href="/login" class="btn btn-primary">
                                        Войти в систему
                                    </a>
                                }
                            </NotAuthorized>
                        </AuthorizeView>
                        <a href="/register" class="btn btn-success">
                            Зарегистрировать компанию
                        </a>
                        <a href="/health" class="btn btn-outline-secondary">
                            Health Check
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private StudioB2B.Domain.Entities.Tenants.Tenant? _tenant;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved && TenantProvider.TenantId.HasValue)
        {
            _tenant = await TenantService.GetByIdAsync(TenantProvider.TenantId.Value);
        }
    }
}