@page "/"
@using System.ComponentModel.DataAnnotations
@using StudioB2B.Domain.Options
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Shared
@using StudioB2B.Web.Services
@inject ITenantProvider TenantProvider
@inject ITenantService TenantService
@inject NavigationManager Navigation
@inject IMarketplaceClientService MarketplaceClientService
@inject HttpClient Http
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject IMasterAuthApiService MasterAuthApi
@inject MasterAuthStateService MasterAuthState
@inject Microsoft.Extensions.Options.IOptions<MultiTenancyOptions> MultiTenancyOptions
@inject NavService NavService
@inject PageRegistry PageRegistry

<PageTitle>StudioB2B</PageTitle>



@if (_initializing)
{
    <div style="display: flex; justify-content: center; padding-top: 4rem;">
        <div style="width: 100%; max-width: 440px;">
            <div style="text-align: center; margin-bottom: 2rem;">
                <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.75rem;">
                    StudioB2B
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2"
                            Style="color: var(--rz-text-secondary-color); display:block; margin-bottom: 1rem;">
                    Загрузка рабочей области...
                </RadzenText>
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate"
                                   ShowValue="false"
                                   Style="width: 100%; max-width: 260px; margin: 0 auto;"/>
            </div>
        </div>
    </div>
}
else if (!TenantProvider.IsResolved)
{
    <div style="display: flex; justify-content: center; padding-top: 4rem;">
        <div style="width: 100%; max-width: 440px;">
            @if (!_masterAuthenticated)
            {
                <!-- Master-домен: требуется авторизация -->
                <div style="text-align: center; margin-bottom: 2rem;">
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">StudioB2B
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        Войдите, чтобы управлять рабочими пространствами
                    </RadzenText>
                </div>

                @if (_masterLoginError != null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false"
                                 Style="margin-bottom: 1rem;">
                        @_masterLoginError
                    </RadzenAlert>
                }

                <EditForm Model="@_masterLogin" OnValidSubmit="HandleMasterLogin" Context="masterForm">
                    <DataAnnotationsValidator/>
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_masterLogin.Email" Style="width: 100%;"
                                           InputType="InputType.Email"/>
                        </RadzenFormField>

                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <RadzenPassword @bind-Value="_masterLogin.Password" Style="width: 100%;"/>
                        </RadzenFormField>

                        <ValidationSummary style="color: var(--rz-danger); font-size: 0.875rem;"/>

                        <RadzenButton ButtonType="ButtonType.Submit" Text="Войти"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Style="width: 100%; justify-content: center;"
                                      IsBusy="@_masterLoginLoading"/>
                    </RadzenStack>
                </EditForm>

                <hr style="margin-top: 1.5rem;"/>
                <div style="text-align: center; margin-top: 0.75rem;">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        Нет аккаунта?
                        <RadzenLink Text="Зарегистрироваться" Path="/register" Style="margin-left: 0.25rem;"/>
                    </RadzenText>
                </div>
            }
            else
            {
                <!-- Master-домен: авторизован — создание tenant -->
                <div style="text-align: center; margin-bottom: 2rem;">
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">StudioB2B
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        Создайте рабочее пространство для компании
                    </RadzenText>
                </div>

                @if (!(_masterUserInfo?.CanCreateTenant ?? false))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
                        У вашего аккаунта нет прав для создания рабочих пространств.
                        Обратитесь к администратору.
                    </RadzenAlert>
                }
                else if (_registerSuccess)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">
                        Компания зарегистрирована! Перенаправление...
                    </RadzenAlert>
                }
                else if (!_showRegTimeline)
                {
                    @if (_registerError != null)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false"
                                     Style="margin-bottom: 1rem;">
                            @_registerError
                        </RadzenAlert>
                    }

                    <EditForm Model="@_reg" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator/>
                        <RadzenStack Gap="1rem">
                            <RadzenFormField Text="Название компании" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.CompanyName" Style="width: 100%;"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Субдомен" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenTextBox @bind-Value="_reg.Subdomain" Style="width: 100%;"/>
                                </ChildContent>
                                <Helper>
                                    <RadzenText TextStyle="TextStyle.Caption">Только a-z, 0-9, дефис (3–30 символов) —
                                        добавится .@DomainAdornment</RadzenText>
                                </Helper>
                            </RadzenFormField>

                            <RadzenText TextStyle="TextStyle.Subtitle2"
                                        Style="margin-bottom: -0.5rem; color: var(--rz-text-secondary-color);">
                                Данные администратора рабочего пространства
                            </RadzenText>

                            <RadzenFormField Text="Email администратора" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.AdminEmail" Style="width: 100%;"
                                               InputType="InputType.Email"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Фамилия" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.LastName" Style="width: 100%;"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Имя" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.FirstName" Style="width: 100%;"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Отчество" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.MiddleName" Style="width: 100%;"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Пароль администратора" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenPassword @bind-Value="_reg.Password" Style="width: 100%;"/>
                                </ChildContent>
                                <Helper>
                                    <RadzenText TextStyle="TextStyle.Caption">Минимум 6 символов. Можно использовать
                                        свой текущий пароль.
                                    </RadzenText>
                                </Helper>
                            </RadzenFormField>

                            <RadzenFormField Text="Подтверждение пароля" Style="width: 100%;">
                                <RadzenPassword @bind-Value="_reg.ConfirmPassword" Style="width: 100%;"/>
                            </RadzenFormField>

                            <ValidationSummary style="color: var(--rz-danger); font-size: 0.875rem;"/>

                            <RadzenButton ButtonType="ButtonType.Submit" Text="Создать рабочее пространство"
                                          ButtonStyle="ButtonStyle.Primary" Style="width: 100%;"
                                          IsBusy="@_regLoading"/>
                        </RadzenStack>
                    </EditForm>
                }
                else
                {
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.Body1"
                                    Style="color: var(--rz-text-secondary-color); text-align: center;">
                            Создаём рабочее пространство, это может занять немного времени...
                        </RadzenText>
                        <RadzenTimeline>
                            <Items>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(0)" PointSize="PointSize.Small">
                                    <LabelContent>
                                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                    Style="@RegStepLabelStyle(0)">Ввод данных
                                        </RadzenText>
                                    </LabelContent>
                                    <ChildContent>
                                        <RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(0)">Подготовка
                                            параметров.
                                        </RadzenText>
                                    </ChildContent>
                                </RadzenTimelineItem>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(1)" PointSize="PointSize.Small">
                                    <LabelContent>
                                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                    Style="@RegStepLabelStyle(1)">Создание базы
                                        </RadzenText>
                                    </LabelContent>
                                    <ChildContent>
                                        <RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(1)">Создание БД
                                            и миграции.
                                        </RadzenText>
                                    </ChildContent>
                                </RadzenTimelineItem>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(2)" PointSize="PointSize.Small">
                                    <LabelContent>
                                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                                    Style="@RegStepLabelStyle(2)">Готово
                                        </RadzenText>
                                    </LabelContent>
                                    <ChildContent>
                                        <RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(2)">Настройка
                                            администратора.
                                        </RadzenText>
                                    </ChildContent>
                                </RadzenTimelineItem>
                            </Items>
                        </RadzenTimeline>
                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false" Style="width: 100%;"/>
                    </RadzenStack>
                }
            }
        </div>
    </div>
}
else
{
    <AuthorizeView>
        <NotAuthorized>
            <div style="display: flex; justify-content: center; padding-top: 4rem;">
                <div style="width: 100%; max-width: 440px;">
                    <!-- Тенант-домен, не авторизован: форма входа -->
                    <div style="text-align: center; margin-bottom: 2rem;">
                        <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">
                            StudioB2B
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                            Вход в <strong>@TenantProvider.Subdomain</strong>
                        </RadzenText>
                    </div>

                    @if (_loginError != null)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false"
                                     Style="margin-bottom: 1rem;">
                            @_loginError
                        </RadzenAlert>
                    }

                    <EditForm Model="@_login" OnValidSubmit="HandleLogin" Context="loginForm">
                        <DataAnnotationsValidator/>
                        <RadzenStack Gap="1rem">
                            <RadzenFormField Text="Email" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_login.Email" Style="width: 100%;"
                                               InputType="InputType.Email"/>
                            </RadzenFormField>

                            <RadzenFormField Text="Пароль" Style="width: 100%;">
                                <RadzenPassword @bind-Value="_login.Password" Style="width: 100%;"/>
                            </RadzenFormField>

                            <RadzenButton ButtonType="ButtonType.Submit" Text="Войти"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Style="width: 100%; justify-content: center;"
                                          IsBusy="@_loginLoading"/>
                        </RadzenStack>
                    </EditForm>
                </div>
            </div>
        </NotAuthorized>


        <Authorized>
            <div style="display:flex; gap:1.5rem; align-items:flex-start; flex-wrap:wrap;">
                <!-- Тенант-домен, авторизован: профиль -->
                @if (TenantProvider.IsResolved)
                {
                    <RadzenCard style=" flex:1; min-width:320px; border-radius:12px; box-shadow: var(--rz-shadow-3);padding:1rem;">

                        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));gap: 0.5rem;">
                            @foreach (var group in NavService.Groups.Where(g => g.Items.Count > 1))
                            {
                                <!-- Группа -->
                                <RadzenStack Gap="0.5rem">

                                    <!-- Заголовок группы -->
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                                 Gap="0.5rem">
                                        <i class="notranslate rzi"
                                           style="color: var(--rz-primary-light); font-size:1.2rem;">@group.Icon</i>
                                        <RadzenText Text="@group.Title" TextStyle="TextStyle.H6"
                                                    Style="color: var(--rz-primary-light); font-weight:600;"/>
                                    </RadzenStack>

                                    <!-- Список страниц -->
                                    <RadzenStack Gap="0.25rem">
                                        @foreach (var item in group.Items)
                                        {
                                            @if (string.IsNullOrEmpty(item.Role))
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal"
                                                             AlignItems="AlignItems.Center"
                                                             Gap="0.5rem"
                                                             Style="cursor:pointer;"
                                                             Click="@(() => Navigation.NavigateTo(item.Path))">

                                                    <RadzenIcon Icon="@PageRegistry.Pages[item.Path].Icon"
                                                                Style="font-size:1rem;" />

                                                    <RadzenText Text="@PageRegistry.Pages[item.Path].Title"
                                                                TextStyle="TextStyle.Body1" />

                                                </RadzenStack>
                                            }
                                            else
                                            {
                                                <AuthorizeView Roles="@item.Role">
                                                    <Authorized Context="authContext">
                                                        <RadzenStack Orientation="Orientation.Horizontal"
                                                                     AlignItems="AlignItems.Center"
                                                                     Gap="0.5rem"
                                                                     Style="cursor:pointer;"
                                                                     Click="@(() => Navigation.NavigateTo(item.Path))">

                                                            <RadzenIcon Icon="@PageRegistry.Pages[item.Path].Icon"
                                                                        Style="font-size:1rem;" />

                                                            <RadzenText Text="@PageRegistry.Pages[item.Path].Title"
                                                                        TextStyle="TextStyle.Body1" />

                                                        </RadzenStack>
                                                    </Authorized>
                                                </AuthorizeView>
                                            }
                                        }
                                    </RadzenStack>
                                </RadzenStack>
                            }
                        </div>
                    </RadzenCard>
                }

                <RadzenCard Style="width: 320px; border-radius:12px; box-shadow: var(--rz-shadow-3);">

                    <!-- 👤 Профиль -->
                    <RadzenStack Gap="0.5rem" Orientation="Orientation.Horizontal"
                                 JustifyContent="JustifyContent.SpaceBetween"
                                 Style="align-items:center; text-align:center; margin-bottom:0.75rem;">

                        <div style="width:56px; height:56px; border-radius:50%;
                        background: var(--rz-primary-light); color:white;
                        display:flex; align-items:center; justify-content:center;
                        font-weight:600; font-size:1.2rem;">
                            @GetInitials(context.User.Identity?.Name)
                        </div>

                        <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;">
                            @context.User.Identity?.Name
                        </RadzenText>

                        <RadzenBadge
                            Text="@(context.User.IsInRole("Admin") ? "Admin" : "User")"
                            BadgeStyle="@(context.User.IsInRole("Admin") ? BadgeStyle.Primary : BadgeStyle.Light)"
                            Shade="Shade.Light"
                            Style="height: 20px"/>
                    </RadzenStack>

                    <!-- 🏢 Тенант -->
                    @if (_tenant != null)
                    {
                        <RadzenCard
                            Style="background: var(--rz-base-100); border-radius:8px; padding:0.5rem; margin-bottom:0.75rem;">

                            <RadzenStack Gap="0.25rem">

                                <RadzenStack Orientation="Orientation.Horizontal"
                                             JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenText TextStyle="TextStyle.Caption"
                                                Style="color: var(--rz-text-secondary-color);">
                                        Компания
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Caption">
                                        @_tenant.Name
                                    </RadzenText>
                                </RadzenStack>

                                <RadzenStack Orientation="Orientation.Horizontal"
                                             JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenText TextStyle="TextStyle.Caption"
                                                Style="color: var(--rz-text-secondary-color);">
                                        Субдомен
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Caption">
                                        @TenantProvider.Subdomain
                                    </RadzenText>
                                </RadzenStack>

                            </RadzenStack>
                        </RadzenCard>
                    }

                    <!-- ⚠️ Alert -->
                    @if (context.User.IsInRole("Admin") && !_hasMarketplaceClients)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info"
                                     ShowIcon="true"
                                     AllowClose="false"
                                     Style="margin-bottom:0.75rem;">

                            <RadzenStack Gap="0.25rem">
                                <RadzenText TextStyle="TextStyle.Caption">
                                    Нет клиентов маркетплейса
                                </RadzenText>

                                <RadzenButton Text="Добавить"
                                              Icon="store"
                                              Size="ButtonSize.Small"
                                              Style="width:100%;"
                                              Click="@(() => Navigation.NavigateTo("/marketplace-clients"))"/>
                            </RadzenStack>

                        </RadzenAlert>
                    }

                    <!-- 🚪 Logout -->
                    <div style="display:flex; justify-content:flex-end;">
                        <RadzenButton Text="Выйти"
                                      Icon="logout"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Click="@HandleLogout"/>
                    </div>

                </RadzenCard>
            </div>
        </Authorized>
    </AuthorizeView>
}

@code {
    private Domain.Entities.TenantEntity? _tenant;
    private bool _initializing = true;
    private bool _hasMarketplaceClients;

    // Master auth — читаем через MasterAuthState service
    private bool _masterAuthenticated => MasterAuthState.IsAuthenticated;
    private MasterUserInfo? _masterUserInfo => MasterAuthState.UserInfo;

    private bool _masterLoginLoading;
    private string? _masterLoginError;
    private MasterLoginModelDto _masterLogin = new();

    // Tenant registration
    private RegisterModelDto _reg = new();
    private bool _regLoading;
    private bool _registerSuccess;
    private string? _registerError;
    private bool _showRegTimeline;
    private int _regStep;

    private string DomainAdornment =>
        MultiTenancyOptions.Value.MasterDomain?.Trim().TrimEnd('/') ?? "localhost";

    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    // Tenant login
    private LoginModelDto _login = new();
    private bool _loginLoading;
    private string? _loginError;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved && TenantProvider.TenantId.HasValue)
        {
            _tenant = await TenantService.GetByIdAsync(TenantProvider.TenantId.Value);
            _hasMarketplaceClients = await MarketplaceClientService.HasAnyAsync();
        }
        else if (!MasterAuthState.IsAuthenticated)
        {
            // Проверяем localStorage только если сервис ещё не инициализирован
            var isAuth = await AuthStateProvider.IsMasterAuthenticatedAsync();
            if (isAuth)
            {
                var userInfo = await AuthStateProvider.GetMasterUserInfoAsync();
                MasterAuthState.Set(true, userInfo);
                FillRegFromUserInfo();
            }
        }
        else
        {
            FillRegFromUserInfo();
        }

        _initializing = false;
    }

    private void FillRegFromUserInfo()
    {
        if (_masterUserInfo is null) return;
        _reg.AdminEmail = _masterUserInfo.Email;
        _reg.FirstName = _masterUserInfo.FirstName;
        _reg.LastName = _masterUserInfo.LastName;
        _reg.MiddleName = _masterUserInfo.MiddleName;
    }

    private async Task HandleMasterLogin()
    {
        _masterLoginError = null;
        _masterLoginLoading = true;
        try
        {
            _masterLoginError = await MasterAuthApi.LoginAsync(_masterLogin.Email, _masterLogin.Password);
            if (_masterLoginError is null)
                FillRegFromUserInfo();
        }
        finally
        {
            _masterLoginLoading = false;
        }
    }


    private async Task HandleRegister()
    {
        if (_regLoading) return;

        if (_reg.Password != _reg.ConfirmPassword)
        {
            _registerError = "Пароли не совпадают";
            return;
        }

        _registerError = null;
        _regLoading = true;
        _showRegTimeline = true;
        _regStep = 0;
        _ = RunRegTimelineAsync();

        try
        {
            var result = await TenantService.RegisterAsync(
                _reg.CompanyName, _reg.Subdomain,
                _reg.AdminEmail, _reg.Password,
                _reg.FirstName, _reg.LastName, _reg.MiddleName,
                _masterUserInfo?.UserId);

            if (result.Success)
            {
                _registerSuccess = true;
                await Task.Delay(1500);

                var uri = new Uri(Navigation.Uri);
                var port = uri.Port is 80 or 443 ? "" : $":{uri.Port}";
                var masterDomain = MultiTenancyOptions.Value.MasterDomain?.ToLowerInvariant() ?? "localhost";

                string redirectHost;
                string scheme;

                if (masterDomain.Contains("localhost"))
                {
                    redirectHost = $"{_reg.Subdomain}.localhost";
                    scheme = uri.Scheme;
                }
                else
                {
                    redirectHost = $"{_reg.Subdomain}.{masterDomain}";
                    scheme = "https";
                }

                Navigation.NavigateTo($"{scheme}://{redirectHost}{port}/", forceLoad: true);
            }
            else
            {
                _showRegTimeline = false;
                _registerError = result.Error ?? "Неизвестная ошибка";
            }
        }
        catch (Exception ex)
        {
            _showRegTimeline = false;
            _registerError = ex.Message;
        }
        finally
        {
            _regLoading = false;
        }
    }

    private async Task RunRegTimelineAsync()
    {
        _regStep = 0;
        StateHasChanged();
        await Task.Delay(800);
        if (!_showRegTimeline) return;
        _regStep = 1;
        StateHasChanged();
        await Task.Delay(1200);
        if (!_showRegTimeline) return;
        _regStep = 2;
        StateHasChanged();
    }

    private PointStyle RegStepStyle(int step) => step switch
    {
        _ when step < _regStep => PointStyle.Success,
        _ when step == _regStep => PointStyle.Primary,
        _ => PointStyle.Secondary
    };

    private string RegStepLabelStyle(int step) => step == _regStep
        ? "color: var(--rz-primary); font-weight: 700;"
        : step < _regStep
            ? "color: var(--rz-success);"
            : "color: var(--rz-text-disabled-color);";

    private string RegStepDescStyle(int step) =>
        step <= _regStep ? string.Empty : "color: var(--rz-text-disabled-color);";

    private async Task HandleLogin()
    {
        _loginError = null;
        _loginLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login", new
            {
                _login.Email,
                _login.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                if (result?.Token is not null)
                {
                    await AuthStateProvider.LoginAsync(result.Token);
                    var returnUrl = ReturnUrl ?? "/";
                    Navigation.NavigateTo(returnUrl, forceLoad: false);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _loginError = "Неверный email или пароль";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                _loginError = "Аккаунт деактивирован";
            }
            else
            {
                _loginError = "Произошла ошибка при входе";
            }
        }
        catch
        {
            _loginError = "Произошла ошибка при входе";
        }
        finally
        {
            _loginLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthStateProvider.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var local = name.Split('@')[0];
        return local.Length >= 2 ? local[..2].ToUpper() : local.ToUpper();
    }

}
