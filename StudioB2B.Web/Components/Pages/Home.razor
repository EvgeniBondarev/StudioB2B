@page "/"
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Infrastructure.Services
@using System.ComponentModel.DataAnnotations
@using StudioB2B.Domain.Options
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Shared
@inject ITenantProvider TenantProvider
@inject ITenantService TenantService
@inject NavigationManager Navigation
@inject ITenantDbContextFactory Factory
@inject HttpClient Http
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject Microsoft.Extensions.Options.IOptions<MultiTenancyOptions> MultiTenancyOptions

<PageTitle>StudioB2B</PageTitle>

<div style="display: flex; justify-content: center; padding-top: 4rem;">
    <div style="width: 100%; max-width: 440px;">

        @if (_initializing)
        {
            <div style="text-align: center; margin-bottom: 2rem;">
                <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.75rem;">
                    StudioB2B
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); display:block; margin-bottom: 1rem;">
                    Загрузка рабочей области...
                </RadzenText>
                <RadzenProgressBar Mode="ProgressBarMode.Indeterminate"
                                   ShowValue="false"
                                   Style="width: 100%; max-width: 260px; margin: 0 auto;" />
            </div>
        }
        else if (!TenantProvider.IsResolved)
        {
            @if (!_masterAuthenticated)
            {
                <!-- Master-домен: требуется авторизация -->
                <div style="text-align: center; margin-bottom: 2rem;">
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">StudioB2B</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        Войдите, чтобы управлять рабочими пространствами
                    </RadzenText>
                </div>

                @if (_masterLoginError != null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin-bottom: 1rem;">
                        @_masterLoginError
                    </RadzenAlert>
                }

                <EditForm Model="@_masterLogin" OnValidSubmit="HandleMasterLogin" Context="masterForm">
                    <DataAnnotationsValidator />
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <RadzenTextBox @bind-Value="_masterLogin.Email" Style="width: 100%;" InputType="InputType.Email" />
                        </RadzenFormField>

                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <RadzenPassword @bind-Value="_masterLogin.Password" Style="width: 100%;" />
                        </RadzenFormField>

                        <ValidationSummary style="color: var(--rz-danger); font-size: 0.875rem;" />

                        <RadzenButton ButtonType="ButtonType.Submit" Text="Войти"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Style="width: 100%; justify-content: center;"
                                      IsBusy="@_masterLoginLoading" />
                    </RadzenStack>
                </EditForm>
            }
            else
            {
                <!-- Master-домен: авторизован — создание tenant -->
                <div style="text-align: center; margin-bottom: 2rem;">
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">StudioB2B</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        Создайте рабочее пространство для компании
                    </RadzenText>
                </div>

                @if (_registerSuccess)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">
                        Компания зарегистрирована! Перенаправление...
                    </RadzenAlert>
                }
                else if (!_showRegTimeline)
                {
                    @if (_registerError != null)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin-bottom: 1rem;">
                            @_registerError
                        </RadzenAlert>
                    }

                    <EditForm Model="@_reg" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />
                        <RadzenStack Gap="1rem">
                            <RadzenFormField Text="Название компании" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.CompanyName" Style="width: 100%;" />
                            </RadzenFormField>

                            <RadzenFormField Text="Субдомен" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenTextBox @bind-Value="_reg.Subdomain" Style="width: 100%;" />
                                </ChildContent>
                                <Helper>
                                    <RadzenText TextStyle="TextStyle.Caption">Только a-z, 0-9, дефис (3–30 символов) — добавится .@DomainAdornment</RadzenText>
                                </Helper>
                            </RadzenFormField>

                            <RadzenFormField Text="Email администратора" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_reg.AdminEmail" Style="width: 100%;" />
                            </RadzenFormField>

                            <RadzenFormField Text="Пароль администратора" Style="width: 100%;">
                                <ChildContent>
                                    <RadzenPassword @bind-Value="_reg.Password" Style="width: 100%;" />
                                </ChildContent>
                                <Helper>
                                    <RadzenText TextStyle="TextStyle.Caption">Минимум 6 символов</RadzenText>
                                </Helper>
                            </RadzenFormField>

                            <RadzenFormField Text="Подтверждение пароля" Style="width: 100%;">
                                <RadzenPassword @bind-Value="_reg.ConfirmPassword" Style="width: 100%;" />
                            </RadzenFormField>

                            <ValidationSummary style="color: var(--rz-danger); font-size: 0.875rem;" />

                            <RadzenButton ButtonType="ButtonType.Submit" Text="Создать рабочее пространство"
                                          ButtonStyle="ButtonStyle.Primary" Style="width: 100%;"
                                          IsBusy="@_regLoading" />
                        </RadzenStack>
                    </EditForm>
                }
                else
                {
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color); text-align: center;">
                            Создаём рабочее пространство, это может занять немного времени...
                        </RadzenText>
                        <RadzenTimeline>
                            <Items>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(0)" PointSize="PointSize.Small">
                                    <LabelContent><RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@RegStepLabelStyle(0)">Ввод данных</RadzenText></LabelContent>
                                    <ChildContent><RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(0)">Подготовка параметров.</RadzenText></ChildContent>
                                </RadzenTimelineItem>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(1)" PointSize="PointSize.Small">
                                    <LabelContent><RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@RegStepLabelStyle(1)">Создание базы</RadzenText></LabelContent>
                                    <ChildContent><RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(1)">Создание БД и миграции.</RadzenText></ChildContent>
                                </RadzenTimelineItem>
                                <RadzenTimelineItem PointStyle="@RegStepStyle(2)" PointSize="PointSize.Small">
                                    <LabelContent><RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0" Style="@RegStepLabelStyle(2)">Готово</RadzenText></LabelContent>
                                    <ChildContent><RadzenText TextStyle="TextStyle.Body2" Style="@RegStepDescStyle(2)">Настройка администратора.</RadzenText></ChildContent>
                                </RadzenTimelineItem>
                            </Items>
                        </RadzenTimeline>
                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" ShowValue="false" Style="width: 100%;" />
                    </RadzenStack>
                }

                <hr style="margin-top: 1.5rem;" />
                <RadzenButton Text="Выйти из панели управления" Icon="logout"
                              ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Style="width: 100%; justify-content: center; margin-top: 0.5rem;"
                              Click="@HandleMasterLogout" />
            }
        }
        else
        {
            <AuthorizeView>
                <NotAuthorized>
                    <!-- Тенант-домен, не авторизован: форма входа -->
                    <div style="text-align: center; margin-bottom: 2rem;">
                        <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; margin-bottom: 0.5rem;">StudioB2B</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                            Вход в <strong>@TenantProvider.Subdomain</strong>
                        </RadzenText>
                    </div>

                    @if (_loginError != null)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin-bottom: 1rem;">
                            @_loginError
                        </RadzenAlert>
                    }

                    <EditForm Model="@_login" OnValidSubmit="HandleLogin" Context="loginForm">
                        <DataAnnotationsValidator />
                        <RadzenStack Gap="1rem">
                            <RadzenFormField Text="Email" Style="width: 100%;">
                                <RadzenTextBox @bind-Value="_login.Email" Style="width: 100%;" InputType="InputType.Email" />
                            </RadzenFormField>

                            <RadzenFormField Text="Пароль" Style="width: 100%;">
                                <RadzenPassword @bind-Value="_login.Password" Style="width: 100%;" />
                            </RadzenFormField>

                            <RadzenButton ButtonType="ButtonType.Submit" Text="Войти"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Style="width: 100%; justify-content: center;"
                                          IsBusy="@_loginLoading" />
                        </RadzenStack>
                    </EditForm>
                </NotAuthorized>

                <Authorized>
                    <!-- Тенант-домен, авторизован: профиль -->
                    <div style="text-align: center; margin-bottom: 1.5rem;">
                        <div style="width: 64px; height: 64px; border-radius: 50%;
                                    background: var(--rz-primary); color: white;
                                    display: flex; align-items: center; justify-content: center;
                                    font-size: 1.4rem; font-weight: 600; margin: 0 auto 1rem;">
                            @GetInitials(context.User.Identity?.Name)
                        </div>
                        <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600; margin-bottom: 0.25rem;">
                            @context.User.Identity?.Name
                        </RadzenText>
                        <RadzenBadge Text="@(context.User.IsInRole("Admin") ? "Admin" : "User")"
                                     BadgeStyle="@(context.User.IsInRole("Admin") ? BadgeStyle.Primary : BadgeStyle.Light)" />
                    </div>

                    @if (_tenant != null)
                    {
                        <RadzenStack Gap="0.5rem" Style="margin-bottom: 1.5rem;">
                            <RadzenStack Orientation="Orientation.Horizontal"
                                         JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenText TextStyle="TextStyle.Body2"
                                            Style="color: var(--rz-text-secondary-color);">Компания</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body2">@_tenant.Name</RadzenText>
                            </RadzenStack>
                            <hr style="margin: 0.25rem 0;" />
                            <RadzenStack Orientation="Orientation.Horizontal"
                                         JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenText TextStyle="TextStyle.Body2"
                                            Style="color: var(--rz-text-secondary-color);">Субдомен</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body2">@TenantProvider.Subdomain</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    }

                    @if (context.User.IsInRole("Admin") && !_hasMarketplaceClients)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info"
                                     ShowIcon="true"
                                     AllowClose="false"
                                     Style="margin-bottom: 1.5rem; text-align: left;">
                            <RadzenStack Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.Body2">
                                    В этом рабочем пространстве ещё нет ни одного клиента маркетплейса.
                                </RadzenText>
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                    Добавьте, например, клиента Ozon на странице
                                    <strong>«Клиенты маркетплейсов»</strong>, чтобы начать работу с заказами.
                                </RadzenText>
                                <RadzenButton Text="Перейти к клиентам маркетплейсов"
                                              Icon="store"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Size="ButtonSize.Small"
                                              Click="@(() => Navigation.NavigateTo("/marketplace-clients"))" />
                            </RadzenStack>
                        </RadzenAlert>
                    }

                    <hr style="margin-bottom: 1.5rem;" />

                    <RadzenButton Text="Выйти" Icon="logout" ButtonStyle="ButtonStyle.Danger"
                                  Style="width: 100%; justify-content: center;"
                                  Click="@HandleLogout" />
                </Authorized>
            </AuthorizeView>
        }

    </div>
</div>

@code {
    private Domain.Entities.TenantEntity? _tenant;
    private bool _initializing = true;
    private bool _hasMarketplaceClients;

    // Master auth state
    private bool _masterAuthenticated;
    private bool _masterLoginLoading;
    private string? _masterLoginError;
    private MasterLoginModelDto _masterLogin = new();

    // Tenant registration
    private RegisterModelDto _reg = new();
    private bool _regLoading;
    private bool _registerSuccess;
    private string? _registerError;
    private bool _showRegTimeline;
    private int _regStep;

    private string DomainAdornment =>
        MultiTenancyOptions.Value.MasterDomain?.Trim().TrimEnd('/') ?? "localhost";

    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    // Tenant login
    private LoginModelDto _login = new();
    private bool _loginLoading;
    private string? _loginError;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved && TenantProvider.TenantId.HasValue)
        {
            _tenant = await TenantService.GetByIdAsync(TenantProvider.TenantId.Value);

            await using var db = Factory.CreateDbContext();
            _hasMarketplaceClients = await db.MarketplaceClients!
                .AsNoTracking()
                .AnyAsync();
        }
        else
        {
            _masterAuthenticated = await AuthStateProvider.IsMasterAuthenticatedAsync();
        }

        _initializing = false;
    }

    private async Task HandleMasterLogin()
    {
        _masterLoginError = null;
        _masterLoginLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/master/auth/login", new
            {
                _masterLogin.Email,
                _masterLogin.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                if (result?.Token is not null)
                {
                    await AuthStateProvider.MasterLoginAsync(result.Token);
                    _masterAuthenticated = true;
                }
            }
            else
            {
                _masterLoginError = "Неверный email или пароль";
            }
        }
        catch
        {
            _masterLoginError = "Произошла ошибка при входе";
        }
        finally
        {
            _masterLoginLoading = false;
        }
    }

    private async Task HandleMasterLogout()
    {
        await AuthStateProvider.MasterLogoutAsync();
        _masterAuthenticated = false;
        _reg = new RegisterModelDto();
        _showRegTimeline = false;
        _registerSuccess = false;
        _registerError = null;
    }

    private async Task HandleRegister()
    {
        if (_regLoading) return;

        if (_reg.Password != _reg.ConfirmPassword)
        {
            _registerError = "Пароли не совпадают";
            return;
        }

        _registerError = null;
        _regLoading = true;
        _showRegTimeline = true;
        _regStep = 0;
        _ = RunRegTimelineAsync();

        try
        {
            var result = await TenantService.RegisterAsync(
                _reg.CompanyName, _reg.Subdomain, _reg.AdminEmail, _reg.Password);

            if (result.Success)
            {
                _registerSuccess = true;
                await Task.Delay(1500);

                var uri = new Uri(Navigation.Uri);
                var port = uri.Port is 80 or 443 ? "" : $":{uri.Port}";
                var masterDomain = MultiTenancyOptions.Value.MasterDomain?.ToLowerInvariant() ?? "localhost";

                string redirectHost;
                string scheme;

                if (masterDomain.Contains("localhost"))
                {
                    redirectHost = $"{_reg.Subdomain}.localhost";
                    scheme = uri.Scheme;
                }
                else
                {
                    redirectHost = $"{_reg.Subdomain}.{masterDomain}";
                    scheme = "https";
                }

                Navigation.NavigateTo($"{scheme}://{redirectHost}{port}/", forceLoad: true);
            }
            else
            {
                _showRegTimeline = false;
                _registerError = result.Error ?? "Неизвестная ошибка";
            }
        }
        catch (Exception ex)
        {
            _showRegTimeline = false;
            _registerError = ex.Message;
        }
        finally
        {
            _regLoading = false;
        }
    }

    private async Task RunRegTimelineAsync()
    {
        _regStep = 0; StateHasChanged();
        await Task.Delay(800);
        if (!_showRegTimeline) return;
        _regStep = 1; StateHasChanged();
        await Task.Delay(1200);
        if (!_showRegTimeline) return;
        _regStep = 2; StateHasChanged();
    }

    private PointStyle RegStepStyle(int step) => step switch
    {
        _ when step < _regStep => PointStyle.Success,
        _ when step == _regStep => PointStyle.Primary,
        _ => PointStyle.Secondary
    };

    private string RegStepLabelStyle(int step) => step == _regStep
        ? "color: var(--rz-primary); font-weight: 700;"
        : step < _regStep ? "color: var(--rz-success);" : "color: var(--rz-text-disabled-color);";

    private string RegStepDescStyle(int step) =>
        step <= _regStep ? string.Empty : "color: var(--rz-text-disabled-color);";

    private async Task HandleLogin()
    {
        _loginError = null;
        _loginLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login", new
            {
                _login.Email,
                _login.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseDto>();
                if (result?.Token is not null)
                {
                    await AuthStateProvider.LoginAsync(result.Token);
                    var returnUrl = ReturnUrl ?? "/";
                    Navigation.NavigateTo(returnUrl, forceLoad: false);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _loginError = "Неверный email или пароль";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                _loginError = "Аккаунт деактивирован";
            }
            else
            {
                _loginError = "Произошла ошибка при входе";
            }
        }
        catch
        {
            _loginError = "Произошла ошибка при входе";
        }
        finally
        {
            _loginLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthStateProvider.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var local = name.Split('@')[0];
        return local.Length >= 2 ? local[..2].ToUpper() : local.ToUpper();
    }
}
