        _warehouses = await _db.Warehouses
            .OrderBy(w => w.Name)
            .AsNoTracking()
            .ToListAsync();

        _calcRules = await _db.GetActiveRulesAsync();

        var msCounts = await _db.Orders
            .AsNoTracking()
            .Where(o => o.StatusId != null)
            .GroupBy(o => o.StatusId!.Value)
            .Select(g => new { StatusId = g.Key, Count = g.Count() })
            .ToListAsync();
        _statusCounts = msCounts.ToDictionary(x => x.StatusId, x => x.Count);

        var ssCounts = await _db.Orders
            .AsNoTracking()
            .Where(o => o.SystemStatusId != null)
            .GroupBy(o => o.SystemStatusId!.Value)
            .Select(g => new { StatusId = g.Key, Count = g.Count() })
            .ToListAsync();
        _systemStatusCounts = ssCounts.ToDictionary(x => x.StatusId, x => x.Count);

        _returnCount = await _db.Orders
            .AsNoTracking()
            .Where(o => o.Shipment!.HasReturn)
            .Select(o => o.ShipmentId)
            .Distinct()
            .CountAsync();
    }

