    private static (string text, string style, string tooltip) FormatDeliveryInfo(OrderEntity o)
    {
        var term = o.DeliveryTerm;
        if (term is null)
            return ("\u2014", "", "");

        var status = o.ShipmentStatus;
        var shipDate = o.Shipment!.ShipmentDate!.Value;
        var accepted = o.Shipment!.InProcessAt!.Value;

        var termText = FormatSpanCompact(term.Value);
        var baseTooltip = $"Срок: {(int)term.Value.TotalDays}д {term.Value.Hours}ч ({accepted:dd.MM HH:mm} \u2192 {shipDate:dd.MM HH:mm})";

        if (status.IsBeforeShipment())
        {
            var remaining = shipDate - DateTime.Now;
            if (remaining.TotalMinutes <= 0)
            {
                var overdue = DateTime.Now - shipDate;
                return ($"{termText}·пр",
                    "color:var(--rz-danger);font-weight:600;",
                    $"{baseTooltip}\nПросрочено на {FormatSpanFull(overdue)}");
            }
            return ($"{termText}·{FormatSpanCompact(remaining)}",
                remaining.TotalHours < 12 ? "color:var(--rz-danger);font-weight:600;"
                : remaining.TotalHours < 24 ? "color:var(--rz-warning-dark);"
                : "",
                $"{baseTooltip}\nОсталось: {FormatSpanFull(remaining)}");
        }

        return ($"{termText}·отгр",
            "color:var(--rz-text-secondary-color);",
            $"{baseTooltip}\nОтгружено");
    }

    private static string FormatSpanCompact(TimeSpan s)
    {
        var d = (int)s.TotalDays;
        var h = s.Hours;
        return d > 0 ? $"{d}д{h}ч" : $"{h}ч";
    }

    private static string FormatSpanFull(TimeSpan s) =>
        $"{(int)s.TotalDays} дн. {s.Hours} ч. {s.Minutes} мин.";

    private static string FormatDateDisplay(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy");
    }

    private static string FormatDateTooltip(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy HH:mm");
    }

