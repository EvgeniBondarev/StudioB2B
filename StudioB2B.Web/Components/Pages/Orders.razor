    private async Task EnsureInitializedAsync()
    {
        if (_db != null) return;
        _db = Factory.CreateDbContext(); // set before first await — prevents re-entry

        _clients = await _db.MarketplaceClients!
            .Include(c => c.ClientType)
            .Include(c => c.Mode)
            .Where(c => c.ClientType!.Name == "Ozon" && c.Mode!.Name == "FBS")
            .OrderBy(c => c.Name)
            .AsNoTracking()
            .ToListAsync();

        _marketplaceStatuses = await _db.OrderStatuses
            .Where(s => !s.IsInternal && !s.IsDeleted)
            .OrderBy(s => s.Name)
            .AsNoTracking()
            .ToListAsync();

        _systemStatuses = await _db.OrderStatuses
            .Where(s => s.IsInternal && !s.IsDeleted)
            .OrderBy(s => s.Name)
            .AsNoTracking()
            .ToListAsync();

        _warehouses = await _db.Warehouses
            .OrderBy(w => w.Name)
            .AsNoTracking()
            .ToListAsync();

        _calcRules = await _db.GetActiveRulesAsync();
    }

