                    @if (price != null)
                    {
                        if (_currencyCode == null && !string.IsNullOrEmpty(price.Currency?.Code))
                            _currencyCode = price.Currency!.Code;
                        var priceText = FormatPrice(price.Value, price.Currency?.Code);
                        <span style="font-weight:600; letter-spacing:0.2px; white-space:nowrap; @GetPriceColor(price.Value)"
                              title="@($"{price.Value:N2} {price.Currency?.Code}")">
                            @priceText
                        </span>
                    }
                    else
                    {
                        <span style="color: var(--rz-danger);">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            @if (_calcRules.Count > 0)
            {
                @if (!_computedSplitByColumns)
                {
                    <RadzenDataGridColumn TItem="OrderEntity" Title="Расчёты"

                                          Width="@GetColumn(OrderGridColumns.ExtraCalculations).Width"
                                          Visible="@GetColumn(OrderGridColumns.ExtraCalculations).Visible"
                                          Filterable="false" Sortable="false" HeaderCssClass="half-painted-header">
                        <HeaderTemplate>
                            <span style="cursor: pointer; text-decoration: underline; font-size: 0.85rem;"
                                  title="Щёлкните, чтобы переключить режим отображения расчётов"
                                  @onclick="ToggleComputedLayout">
                                Расчёты
                                (@(_computedSplitByColumns ? "по столбцам" : "в одном столбце"))
                            </span>
                        </HeaderTemplate>
                        <Template Context="o">
                            @if (_computed.TryGetValue(o.Id, out var fields) && fields.Count > 0)
                            {
                                <RadzenStack Gap="0.15rem">
                                    @foreach (var rule in _calcRules)
                                    {
                                        @if (fields.TryGetValue(rule.ResultKey, out var val) && val != decimal.MinValue)
                                        {
                                            <span
                                                style="font-size: 0.78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: help;"
                                                title="@GetFormulaBreakdown(o, rule, val)">
                                                <span style="color: var(--rz-text-secondary-color);">@rule.Name:</span>
                                                <strong style="@GetPriceColor(val)">@FormatCalcValue(val)</strong>
                                            </span>
                                        }
                                    }
                                </RadzenStack>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                }
                else
                {
                    @foreach (var rule in _calcRules)
                    {
                        var capturedRule = rule;
                        var propName = $"Computed_{StudioB2B.Infrastructure.Services.CalculationEngine.SanitizeKey(capturedRule.ResultKey)}";
                        <RadzenDataGridColumn TItem="OrderEntity"
                                              Title="@capturedRule.Name"
                                              Property="@propName"
                                              Visible="@GetColumn(OrderGridColumns.ExtraCalculations).Visible"
                                              Filterable="false"
                                              Sortable="true"
                                              HeaderCssClass="half-painted-header">
                            <Template Context="o">
                                @if (_computed.TryGetValue(o.Id, out var fields) &&
                                     fields.TryGetValue(capturedRule.ResultKey, out var val) &&
                                     val != decimal.MinValue)
                                {
                                    <span title="@GetFormulaBreakdown(o, capturedRule, val)" style="cursor: help; @GetPriceColor(val)">@FormatCalcValue(val)</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    }
                }
            }
        </Columns>
    </RadzenDataGrid>
}

<script>
window.gridResize = {
    getWidth: () => window.innerWidth,
    getHeight: () => window.innerHeight,

    register: (dotNetHelper) => {
        window.addEventListener("resize", () => {
            dotNetHelper.invokeMethodAsync("OnWindowResize", window.innerWidth, window.innerHeight);
        });
    }
};
</script>

@code {
    [SupplyParameterFromQuery(Name = "openReturn")]
    public string? OpenReturnId { get; set; }

    private RadzenDataGrid<OrderEntity>? _grid;

