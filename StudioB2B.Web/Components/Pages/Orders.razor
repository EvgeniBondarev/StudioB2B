    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "orders-grid-settings-v3";
    private const string FiltersKey = "orders-filters";
    private const string ColumnsKey = "orders-columns-visibility";

    private static readonly Dictionary<string, string> SortPropertyTitles = new()
    {
        ["Shipment.PostingNumber"] = "№ Отправления",
        ["Shipment.MarketplaceClient.Name"] = "Клиент",
        ["Shipment.InProcessAt"] = "Принят",
        ["Shipment.ShipmentDate"] = "Отгрузка",
        ["ProductInfo.Product.Article"] = "Артикул",
