@page "/orders"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor.Rendering
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Infrastructure.Features.Orders
@using StudioB2B.Infrastructure.Interfaces

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService
@inject NotificationService NotificationService
@inject IOrderSyncService OrderSyncService
@inject NavigationManager Navigation
@inject TabService TabService
@inject IJSRuntime JsRuntime

@implements IDisposable

<PageTitle>Заказы</PageTitle>

<Popup @ref="columnsPopup" Lazy="true" class="my-popup">
    <RadzenStack Gap="8px">
        @foreach (var col in Columns)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                <RadzenCheckBox TValue="bool"
                                Value="@(col.UserVisible ?? col.AutoVisible)"
                                Change="@(value => OnColumnChecked(col, value))"
                               />
                <span>@col.Title</span>
            </RadzenStack>
        }
    </RadzenStack>
</Popup>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Заказы</RadzenText>
            @if (_selectedOrderIds.Count > 0)
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-base-600);">
                    Выбрано: @_selectedOrderIds.Count
                </RadzenText>
                @if (_loadingTransactions)
                {
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                }
                else if (_selectionStatusGroups > 1)
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-danger);">
                        Разные статусы — выберите заказы с одинаковым статусом
                    </RadzenText>
                }
                else if (_availableTransactions.Count > 0)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="flex-wrap: wrap;">
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-base-600); margin: 0;">Провести:</RadzenText>
                        @foreach (var t in _availableTransactions)
                        {
                            var bg = GetSoftBackground(t.Color ?? string.Empty);
                            var fg = IsLightColor(bg) ? "#1f2937" : "#ffffff";
                            var tooltip = $"{t.Name}: {t.FromSystemStatus?.Name ?? "—"} \u2192 {t.ToSystemStatus?.Name ?? "—"}";
                            <RadzenButton Text="@t.Name"
                                          Icon="@(string.IsNullOrEmpty(t.Icon) ? null : t.Icon)"
                                          ButtonStyle="ButtonStyle.Light"
                                          Size="ButtonSize.Small"
                                          Title="@tooltip"
                                          Style="@($"background-color: {bg}; color: {fg}; border: 1px solid {bg}; border-radius: 20px;")"
                                          Click="@(() => OpenApplyTransactionTab(t.Id))" />
                        }
                    </RadzenStack>
                }
                else if (_selectionStatusGroups == 1 && !_loadingTransactions)
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">
                        Нет доступных документов для статуса «@_selectionStatusName»
                    </RadzenText>
                }
                <RadzenButton Icon="close" Text="Снять выбор" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Variant="Variant.Text" Click="@ClearSelection" />
            }
        </RadzenStack>
        <div>
            <RadzenButton @ref="columnsButton"
                          Icon="settings"
                          Shade="Shade.Light"
                          ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Small"
                          Text="Колонки"
                          Click="@(_ => ToggleColumnsPopup())"
                          Style="margin-right: 10px"/>
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()"/>
        </div>
    </RadzenStack>

    @if (_marketplaceStatuses.Any() || _systemStatuses.Any())
    {
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                     Style="padding: 0 0 0.75rem 0; flex-wrap: wrap;">

            @{
                var allActive = _filterStatusId == null && _filterSystemStatusId == null && !_filterHasReturn;
            }
            <span @onclick="@(async () => { _filterStatusId = null; _filterSystemStatusId = null; _filterHasReturn = false; await OnFilterChange(); })"
                  style="@($"display:inline-flex;align-items:center;gap:5px;padding:3px 12px 3px 10px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;background:{(allActive ? "var(--rz-primary)" : "var(--rz-base-200)")};color:{(allActive ? "#fff" : "var(--rz-text-color)")};border:2px solid transparent;")">
                Все
            </span>

            @foreach (var s in _marketplaceStatuses
                .Where(s => _statusCounts.ContainsKey(s.Id))
                .OrderByDescending(s => _statusCounts.GetValueOrDefault(s.Id)))
            {
                var bg = GetSoftBackground(s.Color ?? string.Empty);
                var fg = GetTextColor(bg);
                var isActive = _filterStatusId == s.Id;
                var cnt = _statusCounts.GetValueOrDefault(s.Id);
                <span @onclick="@(async () => { _filterStatusId = isActive ? (Guid?)null : s.Id; _filterSystemStatusId = null; _filterHasReturn = false; await OnFilterChange(); })"
                      style="@($"display:inline-flex;align-items:center;gap:5px;padding:3px 12px 3px 10px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;background:{bg};color:{fg};border:2px solid {(isActive ? fg : "transparent")};")">
                    @s.Name
                    <span style="font-size:0.74rem;opacity:0.6;font-weight:400;">@cnt</span>
                </span>
            }

            @if (_marketplaceStatuses.Any(s => _statusCounts.ContainsKey(s.Id)) &&
                 _systemStatuses.Any(s => _systemStatusCounts.ContainsKey(s.Id)))
            {
                <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>
            }

            @foreach (var s in _systemStatuses
                .Where(s => _systemStatusCounts.ContainsKey(s.Id))
                .OrderByDescending(s => _systemStatusCounts.GetValueOrDefault(s.Id)))
            {
                var bg = GetSoftBackground(s.Color ?? string.Empty);
                var fg = GetTextColor(bg);
                var isActive = _filterSystemStatusId == s.Id;
                var cnt = _systemStatusCounts.GetValueOrDefault(s.Id);
                <span @onclick="@(async () => { _filterSystemStatusId = isActive ? (Guid?)null : s.Id; _filterStatusId = null; _filterHasReturn = false; await OnFilterChange(); })"
                      style="@($"display:inline-flex;align-items:center;gap:5px;padding:3px 12px 3px 10px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;background:{bg};color:{fg};border:2px solid {(isActive ? fg : "transparent")};")">
                    @s.Name
                    <span style="font-size:0.74rem;opacity:0.6;font-weight:400;">@cnt</span>
                </span>
            }

            @if (_returnCount > 0)
            {
                <span @onclick="@(async () => { _filterHasReturn = !_filterHasReturn; _filterStatusId = null; _filterSystemStatusId = null; await OnFilterChange(); })"
                      style="@($"display:inline-flex;align-items:center;gap:5px;padding:3px 12px 3px 10px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;background:{(_filterHasReturn ? "#fee2e2" : "#f9fafb")};color:{(_filterHasReturn ? "#991b1b" : "#6b7280")};border:2px solid {(_filterHasReturn ? "#f87171" : "transparent")};")">
                    Возвраты
                    <span style="font-size:0.74rem;opacity:0.6;font-weight:400;">@_returnCount</span>
                </span>
            }

        </RadzenStack>
    }

    <RadzenDataGrid
        @ref="_grid"
        TItem="Order"
        Data="@_pageItems"
        Count="@_totalCount"
        LoadData="@LoadData"
        Settings="@_gridSettings"
        SettingsChanged="@OnGridSettingsChanged"
        Density="@_density"
        AllowFiltering="true"
        AllowColumnResize="true"
        AllowAlternatingRows="false"
        FilterMode="FilterMode.Advanced"
        LogicalFilterOperator="LogicalFilterOperator.Or"
        AllowSorting="true"
        AllowPaging="true"
        PageSize="10"
        PageSizeOptions="@_pageSizeOptions"
        ShowPagingSummary="true"
        PagerHorizontalAlign="HorizontalAlign.Left"
        CellContextMenu="@ShowContextMenu"
        RowRender="@OnRowRender"
        IsLoading="@_loading"
        FilterText="@RadzenRuStrings.FilterText"
        ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
        ClearFilterText="@RadzenRuStrings.ClearFilterText"
        ContainsText="@RadzenRuStrings.ContainsText"
        DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
        EqualsText="@RadzenRuStrings.EqualsText"
        NotEqualsText="@RadzenRuStrings.NotEqualsText"
        StartsWithText="@RadzenRuStrings.StartsWithText"
        EndsWithText="@RadzenRuStrings.EndsWithText"
        GreaterThanText="@RadzenRuStrings.GreaterThanText"
        GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
        LessThanText="@RadzenRuStrings.LessThanText"
        LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
        IsNullText="@RadzenRuStrings.IsNullText"
        IsNotNullText="@RadzenRuStrings.IsNotNullText"
        AndOperatorText="@RadzenRuStrings.AndOperatorText"
        OrOperatorText="@RadzenRuStrings.OrOperatorText"
        PageSizeText="@RadzenRuStrings.PageSizeText"
        PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
        EmptyText="@RadzenRuStrings.EmptyText">

        <Columns>
            <RadzenDataGridColumn TItem="Order" Title="" Width="44px" Frozen="true" Sortable="false" Filterable="false">
                <HeaderTemplate>
                    <RadzenCheckBox TValue="bool" Value="@IsAllSelected" ValueChanged="@OnSelectAllChanged" />
                </HeaderTemplate>
                <Template Context="o">
                    <RadzenCheckBox TValue="bool" Value="@_selectedOrderIds.Contains(o.Id)"
                                   ValueChanged="@(v => ToggleOrderSelection(o.Id, v))" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Order" Property="Shipment.PostingNumber"
                                  Title="@GetColumn(OrderGridColumns.ShipmentNumber).Title"
                                  Width="@GetColumn(OrderGridColumns.ShipmentNumber).Width"
                                  Frozen="@GetColumn(OrderGridColumns.ShipmentNumber).Frozen"
                                  Visible="@GetColumn(OrderGridColumns.ShipmentNumber).Visible"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <CopyableText Text="@(o.Shipment?.PostingNumber ?? string.Empty)"
                                  Class="rz-monospace rz-text-sm"
                                  Tooltip="Нажмите, чтобы скопировать номер отправления">

                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate rz-monospace"
                                    Style="margin-left: 10px;"
                                    title="@o.Shipment?.PostingNumber">
                            @o.Shipment?.PostingNumber
                        </RadzenText>
                    </CopyableText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="Shipment.MarketplaceClient.Name"
                                  Title="@GetColumn(OrderGridColumns.Client).Title"
                                  Width="@GetColumn(OrderGridColumns.Client).Width"
                                  Visible="@GetColumn(OrderGridColumns.Client).Visible"
                                  Sortable="true"
                                  Filterable="true"
                                  HeaderCssClass="half-painted-header">
                <FilterTemplate>
                    <div class="filter-all-item @( _filterClientId == null ? "active" : "" )"
                         @onclick="@(async () => await ClearFilter(() => _filterClientId = null))">
                        Все
                    </div>
                    <RadzenListBox @bind-Value="_filterClientId"
                                   Data="@_clients"
                                   TextProperty="Name"
                                   ValueProperty="Id"
                                   Placeholder="Все"
                                   AllowClear="true"
                                   Style="width:100%;"
                                   Change="@(async () => await OnFilterChange())"/>
                </FilterTemplate>

                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2"
                                Class="rz-text-truncate"
                                Style="margin-left: 6px;"
                                title="@o.Shipment?.MarketplaceClient?.Name">@o.Shipment?.MarketplaceClient?.Name
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="Shipment.InProcessAt"
                                  Title="@GetColumn(OrderGridColumns.AcceptedDate).Title"
                                  Width="@GetColumn(OrderGridColumns.AcceptedDate).Width"
                                  Visible="@GetColumn(OrderGridColumns.AcceptedDate).Visible"
                                  FormatString="{0:dd.MM.yyyy}"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2"
                                Class="rz-text-truncate"
                                title="@FormatDateTooltip(o.Shipment?.InProcessAt)">@FormatDateDisplay(o.Shipment?.InProcessAt)
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="Shipment.ShipmentDate"
                                  Title="@GetColumn(OrderGridColumns.ShippingDate).Title"
                                  Width="@GetColumn(OrderGridColumns.ShippingDate).Width"
                                  Visible="@GetColumn(OrderGridColumns.ShippingDate).Visible"
                                  FormatString="{0:dd.MM.yyyy}"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2"
                                Class="rz-text-truncate"
                                title="@FormatDateTooltip(o.Shipment?.ShipmentDate)">@FormatDateDisplay(o.Shipment?.ShipmentDate)
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="ProductInfo.Product.Article"
                                  Title="@GetColumn(OrderGridColumns.Article).Title"
                                  Width="@GetColumn(OrderGridColumns.Article).Width"
                                  Visible="@GetColumn(OrderGridColumns.Article).Visible"
                                  Filterable="true" Sortable="true"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <CopyableText Text="@(o.ProductInfo?.Product?.Article ?? string.Empty)"
                                  Class="rz-monospace rz-text-sm"
                                  Tooltip="Нажмите, чтобы скопировать артикул">

                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate rz-monospace"
                                    title="@o.ProductInfo?.Product?.Article">
                            @o.ProductInfo?.Product?.Article
                        </RadzenText>
                    </CopyableText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="ProductInfo.Product.Name"
                                  Title="@GetColumn(OrderGridColumns.Product).Title"
                                  Width="@GetColumn(OrderGridColumns.Product).Width"
                                  Visible="@GetColumn(OrderGridColumns.Product).Visible"
                                  Filterable="false" Sortable="false"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem"
                                 Class="rz-w-100">
                        @if (!string.IsNullOrEmpty(o.ProductInfo?.Product?.ImageUrl))
                        {
                            <img src="@o.ProductInfo?.Product?.ImageUrl"
                                 class="rz-border-radius rz-flex-shrink-0"
                                 style="width:36px; height:36px; object-fit:contain;"
                                 alt=""/>
                        }
                        <span
                            class="rz-text-sm  rz-flex-shrink-1 rz-text-truncate rz-ms-1"
                            title="@o.ProductInfo?.Product?.Name">
                            @o.ProductInfo?.Product?.Name
                        </span>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="Quantity"
                                  Title="@GetColumn(OrderGridColumns.Quantity).Title"
                                  Width="@GetColumn(OrderGridColumns.Quantity).Width"
                                  Visible="@GetColumn(OrderGridColumns.Quantity).Visible"
                                  TextAlign="TextAlign.Center"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight:600">
                        @o.Quantity
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order"
                                  Property="Status.Name"
                                  Title="@GetColumn(OrderGridColumns.MarketplaceStatus).Title"
                                  Width="@GetColumn(OrderGridColumns.MarketplaceStatus).Width"
                                  Visible="@GetColumn(OrderGridColumns.MarketplaceStatus).Visible"
                                  Filterable="false"
                                  Sortable="true" HeaderCssClass="half-painted-header">

                <FilterTemplate>
                    <div class="filter-all-item @( _filterStatusId == null ? "active" : "" )"
                         @onclick="@(async () => await ClearFilter(() => _filterStatusId = null))">
                        Все
                    </div>
                    <RadzenListBox TItem="OrderStatus"
                                   @bind-Value="_filterStatusId"
                                   Data="@_marketplaceStatuses"
                                   ValueProperty="Id"
                                   TextProperty="Name"
                                   AllowClear="true"
                                   Placeholder="Все"
                                   Style="width:100%; max-height:370px"
                                   Change="@(async () => await OnFilterChange())">

                        <Template Context="item">
                            <RadzenBadge Text="@item.Name"
                                         Style="@($"background:{GetSoftBackground(item.Color)}; color:{GetTextColor(GetSoftBackground(item.Color))};")"
                                         Class="status-badge"/>
                        </Template>

                    </RadzenListBox>
                </FilterTemplate>

                <Template Context="o">
                    <RadzenStack JustifyContent="JustifyContent.Center"
                                 AlignItems="AlignItems.Center">
                        @if (o.Status != null)
                        {
                            var bg = string.IsNullOrEmpty(o.Status.Color) ? "#ececff" : o.Status.Color + "20";
                            var fg = IsLightColor(bg) ? "#1f2937" : "#ffffff";

                            <RadzenBadge Text="@o.Status.Name"
                                         Style="@($"background:{bg}; color:{fg};")"
                                         Class="status-badge"/>
                            @if (o.Shipment.HasReturn)
                            {
                                <span style="color:#ef4444;cursor:pointer;font-size:0.78rem;font-weight:600;margin-left:3px;"
                                      title="Есть возврат — нажмите для просмотра"
                                      @onclick:stopPropagation="true"
                                      @onclick="@(() => OpenOrderDetailAsync(o, openReturnTab: true))">/ Возв.</span>
                            }
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order"
                                  Property="SystemStatus.Name"
                                  Title="@GetColumn(OrderGridColumns.AppStatus).Title"
                                  Width="@GetColumn(OrderGridColumns.AppStatus).Width"
                                  Visible="@GetColumn(OrderGridColumns.AppStatus).Visible"
                                  Filterable="true"
                                  Sortable="true"
                                  HeaderCssClass="half-painted-header">

                <FilterTemplate>
                    <div class="filter-all-item @( _filterSystemStatusId == null ? "active" : "" )"
                         @onclick="@(async () => await ClearFilter(() => _filterSystemStatusId = null))">
                        Все
                    </div>
                    <RadzenListBox TItem="OrderStatus"
                                   @bind-Value="_filterSystemStatusId"
                                   Data="@_systemStatuses"
                                   TextProperty="Name"
                                   ValueProperty="Id"
                                   Placeholder="Все"
                                   AllowClear="true"
                                   Style="width:100%; max-height: 370px;"
                                   Change="@(async () => await OnFilterChange())">

                        <Template Context="item">
                            <RadzenBadge Text="@item.Name"
                                         Style="@($"background:{GetSoftBackground(item.Color)}; color:{GetTextColor(GetSoftBackground(item.Color))};")"
                                         Class="status-badge"/>
                        </Template>
                    </RadzenListBox>
                </FilterTemplate>

                <Template Context="o">
                    <RadzenStack JustifyContent="JustifyContent.Center"
                                 AlignItems="AlignItems.Center">
                        @if (o.SystemStatus != null)
                        {
                            var bg = GetSoftBackground(o.SystemStatus.Color ?? string.Empty);
                            var fg = GetTextColor(bg);

                            <RadzenBadge Text="@o.SystemStatus.Name"
                                         Style="@($"background:{bg}; color:{fg};")"
                                         Class="status-badge"/>
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="Shipment.DeliveryMethod.Name"
                                  Title="@GetColumn(OrderGridColumns.DeliveryMethod).Title"
                                  Width="@GetColumn(OrderGridColumns.DeliveryMethod).Width"
                                  Visible="@GetColumn(OrderGridColumns.DeliveryMethod).Visible"
                                  Filterable="false" Sortable="true"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2"
                                Class="rz-text-truncate"
                                title="@o.Shipment?.DeliveryMethod?.Name">
                        @o.Shipment?.DeliveryMethod?.Name
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order" Property="WarehouseInfo.SenderWarehouse.Name"
                                  Title="@GetColumn(OrderGridColumns.Warehouse).Title"
                                  Width="@GetColumn(OrderGridColumns.Warehouse).Width"
                                  Visible="@GetColumn(OrderGridColumns.Warehouse).Visible"
                                  Filterable="true" Sortable="true"
                                  HeaderCssClass="half-painted-header">

                <FilterTemplate>
                    <div class="filter-all-item @( _filterWarehouseId == null ? "active" : "" )"
                         @onclick="@(async () => await ClearFilter(() => _filterWarehouseId = null))">
                        Все
                    </div>
                    <RadzenListBox @bind-Value="_filterWarehouseId"
                                   Data="@_warehouses"
                                   TextProperty="Name"
                                   ValueProperty="Id"
                                   Placeholder="Все"
                                   AllowClear="true"
                                   Style="width: 100%; min-width: 0; max-height: 370px;"
                                   Change="@(async () => await OnFilterChange())"/>

                </FilterTemplate>
                <Template Context="o">
                    <RadzenText TextStyle="TextStyle.Body2"
                                Class="rz-text-truncate"
                                title="@o.WarehouseInfo?.SenderWarehouse?.Name">
                        @o.WarehouseInfo?.SenderWarehouse?.Name
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Order"
                                  Title="@GetColumn(OrderGridColumns.Price).Title"
                                  Width="@GetColumn(OrderGridColumns.Price).Width"
                                  Visible="@GetColumn(OrderGridColumns.Price).Visible"
                                  Filterable="false" Sortable="false"
                                  HeaderCssClass="half-painted-header">
                <Template Context="o">
                    @{
                        var price = o.Prices.FirstOrDefault(p => p.PriceType?.Name == "Цена");
                    }
                    @if (price != null)
                    {
                        var priceText = $"{price.Value:N2} {price.Currency?.Code}";
                        <RadzenText TextStyle="TextStyle.Body2"
                                    Class="rz-text-truncate"
                                    Style="@($"font-weight:600; letter-spacing:0.2px; {GetPriceColor(price.Value)}")"
                                    title="@priceText">
                            @priceText
                        </RadzenText>
                    }
                    else
                    {
                        <span style="color: var(--rz-danger);">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            @if (_calcRules.Count > 0)
            {
                @if (!_computedSplitByColumns)
                {
                    <RadzenDataGridColumn TItem="Order" Title="Расчёты"

                                          Width="@GetColumn(OrderGridColumns.ExtraCalculations).Width"
                                          Visible="@GetColumn(OrderGridColumns.ExtraCalculations).Visible"
                                          Filterable="false" Sortable="false" HeaderCssClass="half-painted-header">
                        <HeaderTemplate>
                            <span style="cursor: pointer; text-decoration: underline; font-size: 0.85rem;"
                                  title="Щёлкните, чтобы переключить режим отображения расчётов"
                                  @onclick="ToggleComputedLayout">
                                Расчёты
                                (@(_computedSplitByColumns ? "по столбцам" : "в одном столбце"))
                            </span>
                        </HeaderTemplate>
                        <Template Context="o">
                            @if (_computed.TryGetValue(o.Id, out var fields) && fields.Count > 0)
                            {
                                <RadzenStack Gap="0.15rem">
                                    @foreach (var rule in _calcRules)
                                    {
                                        @if (fields.TryGetValue(rule.ResultKey, out var val) && val != decimal.MinValue)
                                        {
                                            <span
                                                style="font-size: 0.78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: help;"
                                                title="@GetFormulaBreakdown(o, rule, val)">
                                                <span style="color: var(--rz-text-secondary-color);">@rule.Name:</span>
                                                <strong style="@GetPriceColor(val)">@val.ToString("N2")</strong>
                                            </span>
                                        }
                                    }
                                </RadzenStack>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                }
                else
                {
                    @foreach (var rule in _calcRules)
                    {
                        var propName = $"Computed_{StudioB2B.Infrastructure.Services.CalculationEngine.SanitizeKey(rule.ResultKey)}";
                        <RadzenDataGridColumn TItem="Order"
                                              Title="@rule.Name"
                                              Property="@propName"
                                              Width="@GetColumn(OrderGridColumns.ExtraCalculations).Width"
                                              Visible="@GetColumn(OrderGridColumns.ExtraCalculations).Visible"
                                              Filterable="false"
                                              Sortable="true"
                                              TextAlign="TextAlign.Right"
                                              HeaderCssClass="half-painted-header">
                            <Template Context="o">
                                @if (_computed.TryGetValue(o.Id, out var fields) &&
                                     fields.TryGetValue(rule.ResultKey, out var val) &&
                                     val != decimal.MinValue)
                                {
                                    <span title="@GetFormulaBreakdown(o, rule, val)" style="cursor: help; @GetPriceColor(val)">@val.ToString("N2")</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    }
                }
            }
        </Columns>
    </RadzenDataGrid>
}

