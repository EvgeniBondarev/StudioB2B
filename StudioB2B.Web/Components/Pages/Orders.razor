                NotificationService.Notify(NotificationSeverity.Success,
                    "Статус обновлён",
                    $"{result.PostingNumber}: {result.OldStatusName} → {result.NewStatusName}",
                    duration: 5000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Info,
                    "Без изменений",
                    "Статус отправления не изменился.",
                    duration: 3000);
            }

            await _grid!.Reload();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error,
                "Ошибка",
                ex.Message,
                duration: 5000);
        }
    }

    public void Dispose()
    {
        _db?.Dispose();
        _resizeRef?.Dispose();
    }

    private static string FormatDateDisplay(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy");
    }

    private static string FormatDateTooltip(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy HH:mm");
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };


    private static string GetPriceColor(decimal value) =>
        value < 0 ? "color: var(--rz-danger);" : "";

    private string GetFormulaBreakdown(Order o, CalculationRule rule, decimal val)
    {
        var context = new Dictionary<string, decimal>(CalculationEngine.GetContextSnapshot(o), StringComparer.OrdinalIgnoreCase);
        foreach (var r in _calcRules.OrderBy(x => x.SortOrder))
        {
            if (r.Id == rule.Id) break;
            if (_computed.TryGetValue(o.Id, out var fields) && fields.TryGetValue(r.ResultKey, out var v) && v != decimal.MinValue)
            {
                var key = CalculationEngine.SanitizeKey(r.ResultKey);
                if (!string.IsNullOrEmpty(key))
                    context[key] = v;
            }
        }
        return CalculationEngine.BuildFormulaBreakdown(rule.Formula ?? "", context, val);
    }
}
