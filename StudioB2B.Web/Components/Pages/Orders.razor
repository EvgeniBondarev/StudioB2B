    private IEnumerable<DataGridColumnSettings> GetActiveSorts()
    {
        return _gridSettings?.Columns?
            .Where(c => c.SortOrder.HasValue && !string.IsNullOrEmpty(c.Property))
            .OrderBy(c => c.SortIndex ?? 0) ?? Enumerable.Empty<DataGridColumnSettings>();
    }

    private async Task ClearSortAsync(string property)
    {
        var col = _gridSettings?.Columns?.FirstOrDefault(c => c.Property == property);
        if (col != null)
        {
            col.SortOrder = null;
            col.SortIndex = null;
        }
        await SaveGridSettingsAsync();
        if (_grid != null)
            await _grid.Reload();
    }

    private record OrderFilters(Guid? ClientId, Guid? StatusId, Guid? SystemStatusId, Guid? WarehouseId);

    [Inject] private IJSRuntime Js { get; set; } = default!;

    private DotNetObjectReference<Orders>? _resizeRef;

    private bool _columnsPopupVisible = false;

    private List<string> _selectedColumns = new();

    void ToggleColumnsPopup()
    {
        if (!_columnsPopupVisible)
        {
            _selectedColumns = Columns
                .Where(c => c.UserVisible ?? c.AutoVisible) // видимые сейчас колонки
                .Select(c => c.Key)
                .ToList();
        }

        // Открываем/закрываем popup через Radzen API
        columnsPopup.ToggleAsync(columnsButton.Element);
    }

    RadzenButton columnsButton = null!;
    Popup columnsPopup = null!;

    // Константы колонок
    public static class OrderGridColumns
    {
        public const string ShipmentNumber = "ShipmentNumber";
        public const string Client = "Client";
        public const string AcceptedDate = "AcceptedDate";
        public const string ShippingDate = "ShippingDate";
        public const string Article = "Article";
        public const string Product = "Product";
        public const string Quantity = "Quantity";
        public const string MarketplaceStatus = "MarketplaceStatus";
        public const string AppStatus = "AppStatus";
        public const string DeliveryMethod = "DeliveryMethod";
        public const string Warehouse = "Warehouse";
        public const string Price = "Price";
        public const string ExtraCalculations = "ExtraCalculations";
        public const string DeliveryTerm = "DeliveryTerm";
        public const string Manufacturer = "Manufacturer";
    }

    // Модель конфигурации колонки
    public class ColumnConfig
    {
        public required string Key { get; set; }
        public required string Title { get; set; }

        public bool AutoVisible { get; set; } = true; // управляется шириной экрана
        public bool? UserVisible { get; set; } = null; // null = не переопределено пользователем

        public bool Visible => UserVisible ?? AutoVisible;
        public bool Frozen { get; set; } = false;

        public int Priority { get; set; } = 1;

        public required string Width { get; set; }
    }

    // Список конфигураций колонок
    List<ColumnConfig> Columns = new()
    {
        new() { Key = OrderGridColumns.ShipmentNumber, Title = "№ Отправления", Frozen = true, Width = "10%", Priority = 1 },
        new() { Key = OrderGridColumns.Client, Title = "Клиент", Width = "7%", Priority = 3 },
        new() { Key = OrderGridColumns.AcceptedDate, Title = "Принят", Width = "5.5%", Priority = 9 },
        new() { Key = OrderGridColumns.ShippingDate, Title = "Отгрузка", Width = "5.5%", Priority = 8 },
        new() { Key = OrderGridColumns.Article, Title = "Артикул", Width = "8%", Priority = 13 },
        new() { Key = OrderGridColumns.Product, Title = "Товар", Frozen = true, Width = "14%", Priority = 2 },
        new() { Key = OrderGridColumns.Quantity, Title = "Кол", Width = "3%", Priority = 7 },
        new() { Key = OrderGridColumns.MarketplaceStatus, Title = "Статус МП", Width = "8%", Priority = 4 },
        new() { Key = OrderGridColumns.AppStatus, Title = "Статус", Width = "7%", Priority = 5 },
        new() { Key = OrderGridColumns.DeliveryMethod, Title = "Доставка", Width = "6%", Priority = 10 },
        new() { Key = OrderGridColumns.Warehouse, Title = "Склад", Width = "6%", Priority = 11 },
        new() { Key = OrderGridColumns.Price, Title = "Цена", Width = "6%", Priority = 6 },
        new() { Key = OrderGridColumns.ExtraCalculations, Title = "Расчёты", Width = "9%", Priority = 12 },
        new() { Key = OrderGridColumns.DeliveryTerm, Title = "Срок", Width = "4%", Priority = 14 },
        new() { Key = OrderGridColumns.Manufacturer, Title = "Произв.", Width = "5%", Priority = 15 }
    };

    void UpdateSelectedColumns()
    {
        foreach (var col in Columns)
        {
            col.UserVisible = _selectedColumns.Contains(col.Key);
        }

        StateHasChanged();
    }

    // высчитываем, сколько колонок показывать
    void UpdateColumnsForWidth(int width)
    {
        _windowWidth = width;
        int maxPriority;

        if (width < 900)
            maxPriority = 3; // минимальный набор — 3 колонки
        else if (width < 1000)
            maxPriority = 5; // + Client + Quantity
        else if (width < 1100)
            maxPriority = 7; // + MarketplaceStatus + AppStatus
        else if (width < 1200)
            maxPriority = 9; // + ShippingDate + AcceptedDate
        else if (width < 1300)
            maxPriority = 11; // + DeliveryMethod + Warehouse
        else if (width < 1400)
            maxPriority = 13; // + ExtraCalculations + Article
        else
            maxPriority = 15; // + DeliveryTerm + Manufacturer


        bool changed = false;

        foreach (var col in Columns)
        {
            var auto = col.Priority <= maxPriority;
            if (col.AutoVisible != auto)
            {
                col.AutoVisible = auto;
                changed = true;
            }
        }

        if (changed)
            InvokeAsync(StateHasChanged);
    }

    void OnColumnChecked(ColumnConfig col, bool value)
    {
        col.UserVisible = value;
        StateHasChanged();
        _ = SaveColumnsAsync();
    }

    // Получение конфигурации
    ColumnConfig GetColumn(string key)
    {
        return Columns.First(x => x.Key == key);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (TenantProvider.IsResolved)
                _manufacturerModuleEnabled = await ModuleService.IsEnabledAsync(ModuleCodes.Manufacturers);

            await LoadGridSettingsAsync();
            await LoadFiltersAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();

            var width = await Js.InvokeAsync<int>("gridResize.getWidth");
            var height = await Js.InvokeAsync<int>("gridResize.getHeight");
            UpdateColumnsForWidth(width);
            UpdatePageSizeForHeight(height);
            await LoadColumnsAsync();

            // Синхронизируем dropdown с реально видимыми колонками
            _selectedColumns = Columns
                .Where(c => c.Visible)
                .Select(c => c.Key)
                .ToList();

            _resizeRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("gridResize.register", _resizeRef);

            StateHasChanged();

            if (!string.IsNullOrEmpty(OpenReturnId) &&
                Guid.TryParse(OpenReturnId, out var openReturnId) &&
                TenantProvider.IsResolved)
            {
                OpenReturnId = null;
                await using var db = Factory.CreateDbContext();
                // Сначала ищем как ShipmentId, потом как OrderId (для обратной совместимости)
                var order = await db.Orders
                    .IncludeForGrid()
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.ShipmentId == openReturnId)
                    ?? await db.Orders
                    .IncludeForGrid()
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.Id == openReturnId);
                if (order != null)
                    await OpenOrderDetailAsync(order, openReturnTab: true);
                Navigation.NavigateTo("/orders", replace: true);
            }
        }
    }

    // Метод, который JS будет вызывать при resize
    [JSInvokable]
    public void OnWindowResize(int width, int height)
    {
        UpdateColumnsForWidth(width);
        UpdatePageSizeForHeight(height);
    }

    private void UpdatePageSizeForHeight(int windowHeight)
    {
        // Примерно: header(56) + tabs(50) + toolbar(90) + filters(80) + thead(44) + pager(40) ≈ 360px overhead
        // Каждая строка ≈ 45px (Default density) или ≈ 32px (Compact)
        var overhead = 360;
        var rowHeight = _density == Density.Compact ? 32 : 45;
        var available = windowHeight - overhead;
        var rows = Math.Max(5, available / rowHeight);
        if (rows != _dynamicPageSize)
        {
            _dynamicPageSize = rows;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch
        {
        }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch
        {
        }
    }

    private async Task LoadColumnsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", ColumnsKey);
            if (!string.IsNullOrEmpty(json))
            {
                var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, bool>>(json);
                if (dict != null)
                {
                    foreach (var col in Columns)
                    {
                        if (dict.TryGetValue(col.Key, out var visible))
                            col.UserVisible = visible;
                    }
