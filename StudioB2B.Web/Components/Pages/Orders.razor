    private static bool IsLightColor(string hex)
    {
        try
        {
            hex = hex.TrimStart('#');
            if (hex.Length < 6) return true;
            var r = Convert.ToInt32(hex[..2], 16);
            var g = Convert.ToInt32(hex[2..4], 16);
            var b = Convert.ToInt32(hex[4..6], 16);
            return (r * 299 + g * 587 + b * 114) / 1000 > 128;
        }
        catch
        {
            return true;
        }
    }

    string GetSoftBackground(string color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "#ececff";

        color = color.TrimStart('#').Trim();
        if (color.Length < 6)
            return "#ececff";

        try
        {
            var r = Convert.ToInt32(color[..2], 16);
            var g = Convert.ToInt32(color[2..4], 16);
            var b = Convert.ToInt32(color[4..6], 16);

            r = (int)(r + (255 - r) * 0.7);
            g = (int)(g + (255 - g) * 0.7);
            b = (int)(b + (255 - b) * 0.7);

            return $"#{r:X2}{g:X2}{b:X2}";
        }
        catch (FormatException)
        {
            return "#ececff";
        }
    }

    string GetTextColor(string bg)
    {
        return IsLightColor(bg) ? "#1f2937" : "#ffffff";
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<Order> args)
    {
        ContextMenuService.Open(args,
            [
                new ContextMenuItem { Text = "Открыть", Icon = "open_in_new", Value = "open" },
                new ContextMenuItem { Text = "История изменений", Icon = "history", Value = "history" },
                new ContextMenuItem { Text = "Обновить статус", Icon = "sync", Value = "update_status" }
            ],
            async e =>
            {
                ContextMenuService.Close();
                if (e.Value?.ToString() == "open" && args.Data is not null)
                    await OpenOrderDetailAsync(args.Data);
                else if (e.Value?.ToString() == "history" && args.Data is not null)
                    await OpenAuditHistoryAsync(args.Data);
                else if (e.Value?.ToString() == "update_status" && args.Data is not null)
                    await UpdateSingleOrderStatusAsync(args.Data);
            });
    }

    private HashSet<Guid> _selectedOrderIds = [];
    private List<OrderTransaction> _availableTransactions = [];
    private bool _loadingTransactions;
    private int _selectionStatusGroups;
    private string? _selectionStatusName;

    private bool IsAllSelected => _pageItems.Any() && _pageItems.All(o => _selectedOrderIds.Contains(o.Id));

    private void OnSelectAllChanged(bool selected) => ToggleSelectAll(selected);

    private void ToggleSelectAll(bool selected)
    {
        if (selected)
            foreach (var o in _pageItems)
                _selectedOrderIds.Add(o.Id);
        else
            foreach (var o in _pageItems)
                _selectedOrderIds.Remove(o.Id);
        _ = LoadAvailableTransactionsAsync();
        StateHasChanged();
    }

    private void ToggleOrderSelection(Guid orderId, bool selected)
    {
        if (selected)
            _selectedOrderIds.Add(orderId);
        else
            _selectedOrderIds.Remove(orderId);
        _ = LoadAvailableTransactionsAsync();
        StateHasChanged();
    }

    private void ClearSelection()
    {
        _selectedOrderIds.Clear();
        _availableTransactions = [];
        _selectionStatusGroups = 0;
        _selectionStatusName = null;
        StateHasChanged();
    }

    private async Task LoadAvailableTransactionsAsync()
    {
        _availableTransactions = [];
        _selectionStatusGroups = 0;
        _selectionStatusName = null;
        if (_selectedOrderIds.Count == 0)
        {
            _loadingTransactions = false;
            return;
        }

        _loadingTransactions = true;
        StateHasChanged();

        await EnsureInitializedAsync();
        var statusIdsWithValue = await _db!.Orders
            .Where(o => _selectedOrderIds.Contains(o.Id) && o.SystemStatusId != null)
            .Select(o => o.SystemStatusId!.Value)
            .Distinct()
            .ToListAsync();
        var hasNull = await _db.Orders
            .Where(o => _selectedOrderIds.Contains(o.Id) && o.SystemStatusId == null)
            .AnyAsync();
        _selectionStatusGroups = statusIdsWithValue.Count + (hasNull ? 1 : 0);

        if (_selectionStatusGroups == 1)
        {
            if (statusIdsWithValue.Count == 1)
            {
                var statusId = statusIdsWithValue[0];
                _selectionStatusName = _systemStatuses.FirstOrDefault(s => s.Id == statusId)?.Name ?? "—";
                _availableTransactions = await _db.OrderTransactions
                    .Include(t => t.FromSystemStatus)
                    .Include(t => t.ToSystemStatus)
                    .Where(t => !t.IsDeleted && t.IsEnabled && t.FromSystemStatusId == statusId)
                    .OrderBy(t => t.Name)
                    .AsNoTracking()
                    .ToListAsync();
            }
            else
            {
                _selectionStatusName = "Без статуса";
            }
        }

        _loadingTransactions = false;
        StateHasChanged();
    }

