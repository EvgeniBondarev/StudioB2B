    private async Task LoadData(LoadDataArgs args)
    {
        if (_loadDataInProgress) return;
        _loadDataInProgress = true;
        _loading = true;
        try
        {
        await EnsureInitializedAsync();

        var query = _db!.Orders
            .IncludeForGrid()
            .AsNoTracking()
            .AsQueryable();

        if (_filterClientId.HasValue)
            query = query.Where(o => o.Shipment.MarketplaceClientId == _filterClientId.Value);
        if (_filterStatusId.HasValue)
            query = query.Where(o => o.StatusId == _filterStatusId.Value);
        if (_filterSystemStatusId.HasValue)
            query = query.Where(o => o.SystemStatusId == _filterSystemStatusId.Value);
        if (_filterWarehouseId.HasValue)
            query = query.Where(o => o.WarehouseInfo != null && o.WarehouseInfo.SenderWarehouseId == _filterWarehouseId.Value);
        if (_filterHasReturn)
            query = query.Where(o => o.Shipment!.HasReturn);

        if (!string.IsNullOrEmpty(args.Filter))
            query = query.Where(args.Filter);

        var appliedOrderBy = args.OrderBy;
        var isComputedOrder = _computedSplitByColumns &&
                              !string.IsNullOrEmpty(appliedOrderBy) &&
                              appliedOrderBy.StartsWith("Computed_", StringComparison.OrdinalIgnoreCase);

        if (!isComputedOrder)
        {
            query = !string.IsNullOrEmpty(appliedOrderBy)
                ? query.OrderBy(appliedOrderBy)
                : query.OrderByDescending(o => o.Shipment.InProcessAt)
                    .ThenByDescending(o => o.Shipment.CreatedAt);
        }

        var baseList = isComputedOrder
            ? await query.ToListAsync()
            : null;

        if (baseList == null)
        {
            _totalCount = await query.CountAsync();

            var skip = args.Skip ?? 0;
            var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 15);

            _pageItems = await query.Skip(skip).Take(take).ToListAsync();
        }
        else
        {
            _pageItems = baseList;
        }

        _computed = _calcRules.Count > 0
            ? _pageItems.ToDictionary(
                o => o.Id,
                o => _calcEngine.Calculate(o, _calcRules))
            : new Dictionary<Guid, Dictionary<string, decimal>>();

        if (isComputedOrder && baseList != null)
        {
            var parts = appliedOrderBy!.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var field = parts[0];
            var desc = parts.Length > 1 &&
                       parts[1].Equals("desc", StringComparison.OrdinalIgnoreCase);

            var ruleByProp = _calcRules.ToDictionary(
                r => $"Computed_{StudioB2B.Infrastructure.Services.CalculationEngine.SanitizeKey(r.ResultKey)}",
                r => r.ResultKey,
                StringComparer.OrdinalIgnoreCase);

            if (ruleByProp.TryGetValue(field, out var ruleKey))
            {
                decimal GetSortValue(Order o) =>
                    _computed.TryGetValue(o.Id, out var dict) &&
                    dict.TryGetValue(ruleKey, out var v) && v != decimal.MinValue
                        ? v
                        : 0m;

                _pageItems = desc
                    ? _pageItems.OrderByDescending(GetSortValue).ToList()
                    : _pageItems.OrderBy(GetSortValue).ToList();
            }
        }

        if (baseList != null)
        {
            _totalCount = _pageItems.Count();

            var skip = args.Skip ?? 0;
            var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 15);

            _pageItems = _pageItems.Skip(skip).Take(take).ToList();
        }

        var orderIds = _pageItems.Select(o => o.Id).ToList();
        if (orderIds.Count > 0)
        {
            var histories = await _db!.OrderTransactionHistories
                .Include(h => h.OrderTransaction)
                .Where(h => h.Success && orderIds.Contains(h.OrderId))
                .OrderByDescending(h => h.PerformedAtUtc)
                .ToListAsync();
            _orderLastTransactionColor = histories
                .GroupBy(h => h.OrderId)
                .ToDictionary(g => g.Key, g => g.First().OrderTransaction?.Color);
        }
        else
        {
            _orderLastTransactionColor = new Dictionary<Guid, string?>();
        }

        _loading = false;
        }
        finally
        {
            _loadDataInProgress = false;
        }
    }

