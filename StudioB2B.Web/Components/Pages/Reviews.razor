    List<string> _galleryItems = new();
    int _currentIndex = -1;
    private ElementReference _lightboxDiv;

    enum GalleryType
    {
        Photo,
        Video
    }

    private GalleryType _galleryType = GalleryType.Photo;

    void OpenGallery(List<string> items, int startIndex, GalleryType type = GalleryType.Photo)
    {
        _galleryItems = items;
        _currentIndex = startIndex;
        _galleryType = type;

        // Дождаться рендера и поставить фокус
        _ = InvokeAsync(async () =>
        {
            await Task.Yield(); // гарантируем, что элемент уже есть
            await _lightboxDiv.FocusAsync();
        });
    }

    void Next()
    {
        if (_galleryItems.Count == 0) return;
        _currentIndex = (_currentIndex + 1) % _galleryItems.Count;
    }

    void Prev()
    {
        if (_galleryItems.Count == 0) return;
        _currentIndex = (_currentIndex - 1 + _galleryItems.Count) % _galleryItems.Count;
    }

    void Close()
    {
        _currentIndex = -1;
    }

    void NavigatePhotoViewer(KeyboardEventArgs e)
    {
        if (_currentIndex < 0) return;

        switch (e.Key)
        {
            case "ArrowLeft": Prev(); break;
            case "ArrowRight": Next(); break;
            case "Escape": Close(); break;
        }

        StateHasChanged();
    }

    private async Task RefreshActiveTasksAsync()
    {
        try
        {
            var tasks = await TaskService.GetInProgressTasksAsync();
            _activeTasks = tasks.ToDictionary(t => (t.ExternalId, t.MarketplaceClientId));
            var doneTasks = await TaskService.GetDoneTasksTodayAsync();
            _doneTasks = doneTasks.ToDictionary(t => (t.ExternalId, t.MarketplaceClientId));
            if (_activeTasks.Count > 0)
            {
                _tickTimer ??= new Timer(_ => InvokeAsync(StateHasChanged), null,
                    TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
            }
            else
            {
                _tickTimer?.Dispose();
                _tickTimer = null;
            }
        }
        catch { /* non-critical */ }
    }

    private CommunicationTaskDto? GetActiveTask(string externalId, Guid clientId) =>
        _activeTasks.GetValueOrDefault((externalId, clientId));

    private CommunicationTaskDto? GetDoneTask(string externalId, Guid clientId) =>
        _doneTasks.GetValueOrDefault((externalId, clientId));

    private static string FormatLiveDuration(CommunicationTaskDto task)
    {
        var ticks = task.TotalTimeSpentTicks;
        if (task.HasActiveTimer && task.StartedAt.HasValue)
            ticks += (DateTime.UtcNow - task.StartedAt.Value).Ticks;
        var ts = TimeSpan.FromTicks(ticks);
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}ч {ts.Minutes:D2}м {ts.Seconds:D2}с";
        if (ts.TotalMinutes >= 1) return $"{(int)ts.TotalMinutes}м {ts.Seconds:D2}с";
        return $"{(int)ts.TotalSeconds}с";
    }

    public void Dispose() => _tickTimer?.Dispose();

}

