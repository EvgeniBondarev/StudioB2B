    // ── lightbox navigation ──────────────────────────────────────────────────────

    List<string> _galleryItems = new();
    int _currentIndex = -1;
    private ElementReference _lightboxDiv;
    enum GalleryType
    {
        Photo,
        Video
    }
    private GalleryType _galleryType = GalleryType.Photo;

    void OpenGallery(List<string> items, int startIndex, GalleryType type = GalleryType.Photo)
    {
        _galleryItems = items;
        _currentIndex = startIndex;
        _galleryType = type;

        // Дождаться рендера и поставить фокус
        _ = InvokeAsync(async () =>
        {
            await Task.Yield(); // гарантируем, что элемент уже есть
            await _lightboxDiv.FocusAsync();
        });
    }

    void Next()
    {
        if (_galleryItems.Count == 0) return;
        _currentIndex = (_currentIndex + 1) % _galleryItems.Count;
    }

    void Prev()
    {
        if (_galleryItems.Count == 0) return;
        _currentIndex = (_currentIndex - 1 + _galleryItems.Count) % _galleryItems.Count;
    }

    void Close()
    {
        _currentIndex = -1;
    }

    void HandleKeyDown(KeyboardEventArgs e)
    {
        if (_currentIndex < 0) return;

        switch (e.Key)
        {
            case "ArrowLeft": Prev(); break;
            case "ArrowRight": Next(); break;
            case "Escape": Close(); break;
        }

        StateHasChanged();
    }
}

