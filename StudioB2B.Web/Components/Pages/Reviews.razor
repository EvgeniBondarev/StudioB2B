    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        if (!string.IsNullOrEmpty(PreSelectReviewId) && PreSelectClientId.HasValue)
            _filterClientId = PreSelectClientId;

        await LoadClientOptionsAsync();
        _ = LoadReviewCountsAsync();
        await ReloadAsync();
        _lastPreSelectReviewId = PreSelectReviewId;
        await TryPreSelectAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PreSelectReviewId == _lastPreSelectReviewId) return;
        _lastPreSelectReviewId = PreSelectReviewId;
        if (string.IsNullOrEmpty(PreSelectReviewId)) return;

        if (PreSelectClientId.HasValue)
            _filterClientId = PreSelectClientId;
        _filterStatus = null;

        await ReloadAsync();
        await TryPreSelectAsync();
    }

    private void TryPreSelect() => _ = TryPreSelectAsync();

    private async Task TryPreSelectAsync()
    {
        if (string.IsNullOrEmpty(PreSelectReviewId)) return;

        var match = _reviews.FirstOrDefault(r => r.Id == PreSelectReviewId);

        if (match is null && PreSelectClientId.HasValue)
        {
            try
            {
                var extra = await ReviewsService.GetReviewsPageAsync(
                    pageSize: 50,
                    status: null,
                    marketplaceClientId: PreSelectClientId);
                match = extra.Reviews.FirstOrDefault(r => r.Id == PreSelectReviewId);
                if (match is not null && !_reviews.Any(r => r.Id == match.Id))
                    _reviews.Insert(0, match);
            }
            catch { /* non-critical */ }
        }

        // Last resort: review not found in paginated results (e.g. old review ranked beyond page 50).
        // Borrow API credentials from any loaded review for this client — they all share the same ApiId/ApiKey.
        if (match is null && PreSelectClientId.HasValue)
        {
            var credSource = _reviews.FirstOrDefault();
            var clientName = _clientOptions.FirstOrDefault(c => c.Id == PreSelectClientId)?.Name ?? string.Empty;
            match = new OzonReviewViewModelDto
            {
                Id = PreSelectReviewId,
                MarketplaceClientId = PreSelectClientId.Value,
                MarketplaceClientName = clientName,
                ApiId = credSource?.ApiId ?? string.Empty,
                ApiKey = credSource?.ApiKey ?? string.Empty
            };
            _reviews.Insert(0, match);
        }

        if (match is not null)
            SelectReview(match);
    }

    private async Task LoadClientOptionsAsync()
    {
        try
        {
            _clientOptions = await MarketplaceClientService.GetClientOptionsAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
    }

    private async Task LoadReviewCountsAsync()
    {
        try
        {
            _counts = await ReviewsService.GetReviewCountsAsync(_filterClientId);
            StateHasChanged();
        }
        catch
        {
            // non-critical
        }
    }

    private async Task ReloadAsync()
    {
        _cursor = null;
        _reviews.Clear();
        _selectedReview = null;
        _detail = null;
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        if (_loading) return;
        _loading = true;
        StateHasChanged();

        try
        {
            var page = await ReviewsService.GetReviewsPageAsync(
                pageSize: 20,
                cursor: _cursor,
                status: _filterStatus,
                marketplaceClientId: _filterClientId);

            if (string.IsNullOrEmpty(_cursor))
                _reviews = page.Reviews;
            else
                _reviews.AddRange(page.Reviews);

            _cursor = page.NextCursor;
            _hasMore = page.HasNext;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки отзывов", ex.Message, 5000);
        }
        finally
        {
            _loading = false;
            _loadingMore = false;
            StateHasChanged();
        }

        await RefreshActiveTasksAsync();
    }

    private Task LoadMoreAsync()
    {
        if (!_hasMore || _loadingMore || _cursor is null) return Task.CompletedTask;
        _loadingMore = true;
        return LoadPageAsync();
    }

    private async Task OnStatusPillClick()
    {
        StateHasChanged();
        await ReloadAsync();
    }

    private Task OnFilterChanged(object? _)
    {
        _ = LoadReviewCountsAsync();
        return ReloadAsync();
    }

    private void SelectReview(OzonReviewViewModelDto r)
    {
        _selectedReview = r;
        _detail = null;
        _detailLoading = true;
        _lightboxSrc = null;
        _descriptionExpanded = false;
        _commentText = string.Empty;
        StateHasChanged();
        _ = LoadDetailAsync(r);
    }

    private async Task LoadDetailAsync(OzonReviewViewModelDto r)
    {
        try
        {
            _detail = await ReviewsService.GetReviewDetailAsync(r);
            _selectedReview = _detail.Review;

            // Sync full API data back into the list entry so the sidebar card
            // shows correct Rating, Text, Sku, Status, PublishedAt etc.
            // (important when the item was opened via URL last-resort fallback with a minimal DTO)
            var idx = _reviews.FindIndex(x => x.Id == _selectedReview.Id &&
                                              x.MarketplaceClientId == _selectedReview.MarketplaceClientId);
            if (idx >= 0)
                _reviews[idx] = _selectedReview;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки деталей", ex.Message, 4000);
        }
        finally
        {
            _detailLoading = false;
            StateHasChanged();
        }
    }

    private async Task ChangeStatusAsync(string newStatus)
    {
        if (_selectedReview is null) return;
        _changingStatus = true;
        try
        {
            var ok = await ReviewsService.ChangeReviewStatusAsync(_selectedReview, newStatus);
            if (ok)
            {
                _selectedReview.Status = newStatus;

                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].Status = newStatus;

                NotificationService.Notify(NotificationSeverity.Success,
                    newStatus == "PROCESSED" ? "Отзыв отмечен обработанным" : "Статус снят", duration: 3000);

                _ = LoadReviewCountsAsync();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось изменить статус", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _changingStatus = false;
            StateHasChanged();
        }
    }

    private async Task<bool> SendCommentAsync(string text)
    {
        if (_selectedReview is null || string.IsNullOrWhiteSpace(text)) return false;

        try
        {
            var commentId = await ReviewsService.CreateReviewCommentAsync(
                _selectedReview, text.Trim(), markAsProcessed: true);

            if (commentId is not null)
            {
                _detail ??= new OzonReviewDetailDto { Review = _selectedReview };
                _detail.Comments.Add(new OzonReviewCommentDto
                {
                    Id = commentId,
                    Text = text.Trim(),
                    IsOfficial = true,
                    IsOwner = true,
                    PublishedAt = DateTime.UtcNow
                });
                _selectedReview.CommentsAmount = _detail.Comments.Count;

                // Update list card count
                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].CommentsAmount = _detail.Comments.Count;

                // Mark as processed
                if (_selectedReview.Status == "UNPROCESSED")
                {
                    _selectedReview.Status = "PROCESSED";
                    if (idx >= 0) _reviews[idx].Status = "PROCESSED";
                    _ = LoadReviewCountsAsync();
                }

                text = string.Empty;
                NotificationService.Notify(NotificationSeverity.Success, "Комментарий опубликован", duration: 3000);
                return true;
            }

            NotificationService.Notify(NotificationSeverity.Error, "Не удалось отправить комментарий", duration: 4000);
            return false;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
            return false;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteCommentAsync(OzonReviewCommentDto comment)
    {
        if (_selectedReview is null || _detail is null) return;
        _deletingCommentId = comment.Id;
        try
        {
            var ok = await ReviewsService.DeleteReviewCommentAsync(_selectedReview, comment.Id);
            if (ok)
            {
                _detail.Comments.Remove(comment);
                _selectedReview.CommentsAmount = _detail.Comments.Count;

                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].CommentsAmount = _detail.Comments.Count;

                NotificationService.Notify(NotificationSeverity.Success, "Комментарий удалён", duration: 3000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось удалить комментарий", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _deletingCommentId = null;
            StateHasChanged();
        }
    }

