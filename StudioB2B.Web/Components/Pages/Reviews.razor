    // ── Status change ─────────────────────────────────────────────────────────

    private async Task ChangeStatusAsync(string newStatus)
    {
        if (_selectedReview is null) return;
        _changingStatus = true;
        try
        {
            var ok = await ReviewsService.ChangeReviewStatusAsync(_selectedReview, newStatus);
            if (ok)
            {
                _selectedReview.Status = newStatus;

                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].Status = newStatus;

                NotificationService.Notify(NotificationSeverity.Success,
                    newStatus == "PROCESSED" ? "Отзыв отмечен обработанным" : "Статус снят", duration: 3000);

                _ = LoadReviewCountsAsync();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось изменить статус", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _changingStatus = false;
            StateHasChanged();
        }
    }

    // ── Comments ──────────────────────────────────────────────────────────────

    private async Task SendCommentAsync()
    {
        if (_selectedReview is null || string.IsNullOrWhiteSpace(_commentText)) return;

        _sendingComment = true;
        try
        {
            var commentId = await ReviewsService.CreateReviewCommentAsync(
                _selectedReview, _commentText.Trim(), markAsProcessed: true);

            if (commentId is not null)
            {
                _detail ??= new OzonReviewDetailDto { Review = _selectedReview };
                _detail.Comments.Add(new OzonReviewCommentDto
                {
                    Id = commentId,
                    Text = _commentText.Trim(),
                    IsOfficial = true,
                    IsOwner = true,
                    PublishedAt = DateTime.UtcNow
                });
                _selectedReview.CommentsAmount = _detail.Comments.Count;

                // Update list card count
                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].CommentsAmount = _detail.Comments.Count;

                // Mark as processed
                if (_selectedReview.Status == "UNPROCESSED")
                {
                    _selectedReview.Status = "PROCESSED";
                    if (idx >= 0) _reviews[idx].Status = "PROCESSED";
                    _ = LoadReviewCountsAsync();
                }

                _commentText = null;
                NotificationService.Notify(NotificationSeverity.Success, "Комментарий опубликован", duration: 3000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось отправить комментарий", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _sendingComment = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCommentAsync(OzonReviewCommentDto comment)
    {
        if (_selectedReview is null || _detail is null) return;
        _deletingCommentId = comment.Id;
        try
        {
            var ok = await ReviewsService.DeleteReviewCommentAsync(_selectedReview, comment.Id);
            if (ok)
            {
                _detail.Comments.Remove(comment);
                _selectedReview.CommentsAmount = _detail.Comments.Count;

                var idx = _reviews.FindIndex(r => r.Id == _selectedReview.Id &&
                                                  r.MarketplaceClientId == _selectedReview.MarketplaceClientId);
                if (idx >= 0) _reviews[idx].CommentsAmount = _detail.Comments.Count;

                NotificationService.Notify(NotificationSeverity.Success, "Комментарий удалён", duration: 3000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Не удалось удалить комментарий", duration: 4000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
        finally
        {
            _deletingCommentId = null;
            StateHasChanged();
        }
    }

