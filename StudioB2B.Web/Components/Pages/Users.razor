@page "/users"
@attribute [Authorize]
@rendermode InteractiveServer
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Infrastructure.Services
@using Microsoft.EntityFrameworkCore
@inject ITenantProvider TenantProvider
@inject ITenantService TenantService
@inject ITenantDbContextFactory DbContextFactory
@inject ISnackbar Snackbar

<PageTitle>Пользователи - StudioB2B</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">
    Пользователи
    @if (TenantProvider.IsResolved && _tenantName != null)
    {
        <MudChip T="string" Color="Color.Info" Size="Size.Medium" Class="ml-2">@_tenantName</MudChip>
    }
</MudText>

@if (!TenantProvider.IsResolved)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        <MudText Typo="Typo.subtitle1"><b>Тенант не определён.</b></MudText>
        <MudText>Перейдите по адресу вашей компании (например, demo.localhost:5184).</MudText>
    </MudAlert>
}
else if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">
        <MudText Typo="Typo.subtitle1"><b>Ошибка:</b></MudText>
        <MudText>@_error</MudText>
    </MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="mt-4">
        <MudToolBar>
            <MudText Typo="Typo.h6">Список пользователей (@_users.Count)</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                          Color="Color.Primary"
                          OnClick="LoadUsers"
                          AriaLabel="Обновить" />
        </MudToolBar>

        <MudDataGrid T="UserViewModel"
                     Items="@_users"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                     SortMode="SortMode.Multiple"
                     Dense="true"
                     Hover="true"
                     Striped="true">
            <Columns>
                <PropertyColumn Property="x => x.Email" Title="Email">
                    <CellTemplate>
                        <MudText Typo="Typo.body2"><code>@context.Item.Email</code></MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.FullName" Title="Имя">
                    <CellTemplate>
                        <MudText>@(context.Item.FullName ?? "—")</MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.IsActive" Title="Статус">
                    <CellTemplate>
                        @if (context.Item.IsActive)
                        {
                            <MudChip Color="Color.Success" Size="Size.Small">Активен</MudChip>
                        }
                        else
                        {
                            <MudChip Color="Color.Default" Size="Size.Small">Неактивен</MudChip>
                        }
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.CreatedAtUtc" Title="Создан" Format="dd.MM.yyyy HH:mm" />

                <PropertyColumn Property="x => x.LastLoginAtUtc" Title="Последний вход">
                    <CellTemplate>
                        @if (context.Item.LastLoginAtUtc.HasValue)
                        {
                            <MudText>@context.Item.LastLoginAtUtc.Value.ToString("dd.MM.yyyy HH:mm")</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Default">—</MudText>
                        }
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Title="Действия" Sortable="false" Filterable="false">
                    <CellTemplate>
                        @if (context.Item.IsActive)
                        {
                            <MudButton Size="Size.Small"
                                      Variant="Variant.Outlined"
                                      Color="Color.Error"
                                      OnClick="() => ToggleUserStatus(context.Item)">
                                Деактивировать
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Size="Size.Small"
                                      Variant="Variant.Outlined"
                                      Color="Color.Success"
                                      OnClick="() => ToggleUserStatus(context.Item)">
                                Активировать
                            </MudButton>
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <NoRecordsContent>
                <MudText Class="pa-4">Пользователи не найдены.</MudText>
            </NoRecordsContent>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<UserViewModel> _users = new();
    private string? _tenantName;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved)
        {
            var tenant = await TenantService.GetByIdAsync(TenantProvider.TenantId!.Value);
            _tenantName = tenant?.Name;
            await LoadUsers();
        }
        else
        {
            _loading = false;
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            _loading = true;
            _error = null;
            StateHasChanged();

            using var db = DbContextFactory.CreateDbContext();

            _users = await db.Users
                .AsNoTracking()
                .OrderByDescending(u => u.CreatedAtUtc)
                .Select(u => new UserViewModel
                {
                    Id = u.Id,
                    Email = u.Email!,
                    FullName = u.FullName,
                    IsActive = u.IsActive,
                    CreatedAtUtc = u.CreatedAtUtc,
                    LastLoginAtUtc = u.LastLoginAtUtc
                })
                .ToListAsync();

            Snackbar.Add($"Загружено пользователей: {_users.Count}", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleUserStatus(UserViewModel user)
    {
        try
        {
            using var db = DbContextFactory.CreateDbContext();

            var dbUser = await db.Users.FindAsync(user.Id);
            if (dbUser != null)
            {
                dbUser.IsActive = !dbUser.IsActive;
                await db.SaveChangesAsync();
                user.IsActive = dbUser.IsActive;

                var status = user.IsActive ? "активирован" : "деактивирован";
                Snackbar.Add($"Пользователь {user.Email} {status}", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
    }

    public class UserViewModel
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = null!;
        public string? FullName { get; set; }
        public bool IsActive { get; set; }
        public DateTime CreatedAtUtc { get; set; }
        public DateTime? LastLoginAtUtc { get; set; }
    }
}
