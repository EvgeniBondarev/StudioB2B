@page "/chats"
@attribute [Authorize(Roles = "ChatsView")]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Constants
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Web.Helpers

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject IOzonChatService ChatService
@inject NotificationService NotificationService
@inject IJSRuntime JsRuntime
@inject UserContext UserContext
@inject IEntityFilterService EntityFilterSvc

@implements IDisposable

<link rel="stylesheet" href="css/chats.css" />

<PageTitle>Чаты</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <div class="chats-page-root">

        <!-- Заголовок + фильтры -->
        <div class="chats-top">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem; margin-top:0.35rem">
                <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Чаты</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    @if (_totalUnread > 0)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@_totalUnread.ToString()" Class="badge-unread-msg"/>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); margin:0;">непрочитанных</RadzenText>
                    }
                    <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Light" Size="ButtonSize.Small"
                                  Click="@RefreshAllAsync" IsBusy="@_loadingList" Text="Обновить"/>
                </RadzenStack>
            </RadzenStack>

            <!-- Статус + Тип чата: пилюли на одной строке -->
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                         Style="padding: 0 0 0.6rem 0; flex-wrap: wrap;">
                @{ var allStatusActive = string.IsNullOrEmpty(_filterStatus); }
                <span class="q-pill @(allStatusActive ? "active" : "")"
                      style="background:@(allStatusActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allStatusActive ? "#fff" : "var(--rz-text-color)");"
                      @onclick="@(async () => { _filterStatus = null; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Все
                </span>
                <span class="q-pill @(_filterStatus == "OPENED" ? "active" : "")"
                      style="background:@(_filterStatus == "OPENED" ? "#10b981" : "#d1fae5"); color:@(_filterStatus == "OPENED" ? "#fff" : "#065f46");"
                      @onclick="@(async () => { _filterStatus = _filterStatus == "OPENED" ? null : "OPENED"; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Открыт
                    @if (_chatStatusCounts.GetValueOrDefault("OPENED") > 0)
                    {
                        <span class="q-pill-count">@_chatStatusCounts.GetValueOrDefault("OPENED")</span>
                    }
                </span>
                <span class="q-pill @(_filterStatus == "CLOSED" ? "active" : "")"
                      style="background:@(_filterStatus == "CLOSED" ? "#6b7280" : "#f3f4f6"); color:@(_filterStatus == "CLOSED" ? "#fff" : "#374151");"
                      @onclick="@(async () => { _filterStatus = _filterStatus == "CLOSED" ? null : "CLOSED"; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Закрыт
                    @if (_chatStatusCounts.GetValueOrDefault("CLOSED") > 0)
                    {
                        <span class="q-pill-count">@_chatStatusCounts.GetValueOrDefault("CLOSED")</span>
                    }
                </span>

                <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>

                @{ var allTypeActive = string.IsNullOrEmpty(_filterType); }
                <span class="q-pill @(allTypeActive ? "active" : "")"
                      style="background:@(allTypeActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allTypeActive ? "#fff" : "var(--rz-text-color)");"
                      @onclick="@(async () => { _filterType = null; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Все типы
                </span>
                <span class="q-pill @(_filterType == "BUYER_SELLER" ? "active" : "")"
                      style="background:@(_filterType == "BUYER_SELLER" ? "#f59e0b" : "#fef3c7"); color:@(_filterType == "BUYER_SELLER" ? "#fff" : "#78350f");"
                      @onclick="@(async () => { _filterType = _filterType == "BUYER_SELLER" ? null : "BUYER_SELLER"; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Покупатель — Продавец
                    @if (_chatTypeCounts.GetValueOrDefault("BUYER_SELLER") > 0)
                    {
                        <span class="q-pill-count">@_chatTypeCounts.GetValueOrDefault("BUYER_SELLER")</span>
                    }
                </span>
                <span class="q-pill @(_filterType == "SELLER_SUPPORT" ? "active" : "")"
                      style="background:@(_filterType == "SELLER_SUPPORT" ? "#3b82f6" : "#dbeafe"); color:@(_filterType == "SELLER_SUPPORT" ? "#fff" : "#1e3a5f");"
                      @onclick="@(async () => { _filterType = _filterType == "SELLER_SUPPORT" ? null : "SELLER_SUPPORT"; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Продавец — Поддержка
                    @if (_chatTypeCounts.GetValueOrDefault("SELLER_SUPPORT") > 0)
                    {
                        <span class="q-pill-count">@_chatTypeCounts.GetValueOrDefault("SELLER_SUPPORT")</span>
                    }
                </span>
                <span class="q-pill @(_filterType == "UNSPECIFIED" ? "active" : "")"
                      style="background:@(_filterType == "UNSPECIFIED" ? "#6b7280" : "#f3f4f6"); color:@(_filterType == "UNSPECIFIED" ? "#fff" : "#374151");"
                      @onclick="@(async () => { _filterType = _filterType == "UNSPECIFIED" ? null : "UNSPECIFIED"; _selectedChat = null; _messages.Clear(); await LoadChatsAsync(); })">
                    Не определён
                    @if (_chatTypeCounts.GetValueOrDefault("UNSPECIFIED") > 0)
                    {
                        <span class="q-pill-count">@_chatTypeCounts.GetValueOrDefault("UNSPECIFIED")</span>
                    }
                </span>
            </RadzenStack>

            <!-- Фильтры -->
            <RadzenCard Style="margin-bottom: 0.6rem; padding: 0.5rem 0.75rem;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                             Gap="0.75rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                        <RadzenLabel Text="Маркетплейс:" Style="white-space: nowrap;" />
                        <RadzenDropDown TValue="Guid?" @bind-Value="_filterClientId"
                                        Data="@_clientOptions"
                                        TextProperty="Name" ValueProperty="Id"
                                        Placeholder="Все"
                                        AllowClear="true"
                                        Style="width: 180px;"
                                        Change="@OnFilterChanged" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                        <RadzenCheckBox TValue="bool" @bind-Value="_filterUnreadOnly"
                                        Change="@OnUnreadFilterChanged" />
                        <RadzenLabel Text="Только непрочитанные" Style="cursor: pointer;" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenCard>
        </div>

        <!-- Двухколоночный layout -->
        <div class="chats-layout">

        <!-- Left panel: chat list -->
        <div class="chat-list-panel">
            @if (_loadingList && !_chats.Any())
            {
                <div class="dlg-loading" style="flex: 1; padding: 2rem;">
                    <div class="dlg-spinner"></div>
                </div>
            }
            else if (!_chats.Any())
            {
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="flex: 1; padding: 2rem; gap: 0.5rem;">
                    <RadzenIcon Icon="chat_bubble_outline"
                                Style="font-size: 2.5rem; color: var(--rz-text-secondary-color);" />
                    <RadzenText TextStyle="TextStyle.Body2"
                                Style="color: var(--rz-text-secondary-color); text-align: center;">
                        Чатов не найдено
                    </RadzenText>
                </RadzenStack>
            }
            else
            {
                <div class="chat-list-scroll" id="chat-list-scroll">
                    @foreach (var chat in _chats)
                    {
                        var isSelected = _selectedChat?.ChatId == chat.ChatId &&
                                         _selectedChat?.MarketplaceClientId == chat.MarketplaceClientId;
                        var cardClass = isSelected ? "chat-item-card selected" : "chat-item-card";
                        <RadzenCard @key="@(chat.MarketplaceClientId + "_" + chat.ChatId)"
                                    Class="@cardClass"
                                    @onclick="@(() => SelectChatAsync(chat))">

                            <div class="chat-item-header">
                                <span class="chat-item-client" title="@chat.MarketplaceClientName">
                                    @chat.MarketplaceClientName
                                </span>
                                <div class="chat-item-right">
                                    @if (chat.UnreadCount > 0)
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Secondary"
                                                     Text="@chat.UnreadCount.ToString()"
                                                     Class="badge-unread-msg"/>
                                    }
                                    <span class="chat-item-date"
                                          title="@chat.LastMessageAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">
                                        @FormatTimeAgo(chat.LastMessageAt)
                                    </span>
                                </div>
                            </div>

                            <div class="chat-item-badges">
                                <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(chat.ChatStatus)"
                                             Text="@GetStatusLabel(chat.ChatStatus)"
                                             Style="font-size: 0.65rem; padding: 2px 6px;" />
                                <RadzenBadge BadgeStyle="@GetTypeBadgeStyle(chat.ChatType)"
                                             Text="@GetTypeLabel(chat.ChatType)"
                                             Style="font-size: 0.65rem; padding: 2px 6px;" />
                            </div>
                        </RadzenCard>
                    }

                    @if (_hasMoreChats)
                    {
                        <div class="chat-load-more">
                            @if (_loadingMore)
                            {
                                <div class="dlg-spinner" style="width:24px;height:24px;border-width:2px;"></div>
                                <span>Загрузка...</span>
                            }
                            else
                            {
                                <RadzenButton Text="Загрузить ещё"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Shade="Shade.Lighter"
                                              Variant="Variant.Filled"
                                              Size="ButtonSize.Small"
                                              Icon="expand_more"
                                              Click="@LoadMoreChatsAsync" />
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Right panel: chat window -->
        <div class="chat-window-panel">
            @if (_selectedChat is null)
            {
                <div class="chat-empty-state">
                    <RadzenIcon Icon="forum" Style="font-size: 3rem;" />
                    <RadzenText TextStyle="TextStyle.H6"
                                Style="color: var(--rz-text-secondary-color);">
                        Выберите чат из списка
                    </RadzenText>
                </div>
            }
            else
            {
                <!-- Chat header -->
                <div class="chat-window-header">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.2rem">
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin: 0; font-weight: 600;">
                            @_selectedChat.MarketplaceClientName
                        </RadzenText>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                            <RadzenBadge BadgeStyle="@GetStatusBadgeStyle(_selectedChat.ChatStatus)"
                                         Text="@GetStatusLabel(_selectedChat.ChatStatus)"
                                         Style="font-size: 0.65rem;" />
                            <RadzenBadge BadgeStyle="@GetTypeBadgeStyle(_selectedChat.ChatType)"
                                         Text="@GetTypeLabel(_selectedChat.ChatType)"
                                         Style="font-size: 0.65rem;" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      Click="@RefreshHistoryAsync" IsBusy="@_loadingHistory" />
                    </RadzenStack>
                </div>

                <!-- Messages -->
                <div class="chat-messages-area" id="chat-messages-container">
                    @if (_loadingHistory && !_messages.Any())
                    {
                        <div class="dlg-loading" style="flex: 1;">
                            <div class="dlg-spinner"></div>
                        </div>
                    }
                    else if (!_messages.Any())
                    {
                        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                                     Style="flex: 1; gap: 0.5rem;">
                            <RadzenIcon Icon="chat_bubble_outline"
                                        Style="font-size: 2rem; color: var(--rz-text-secondary-color);" />
                            <RadzenText TextStyle="TextStyle.Caption"
                                        Style="color: var(--rz-text-secondary-color);">
                                Нет сообщений
                            </RadzenText>
                        </RadzenStack>
                    }
                    else
                    {
                        @foreach (var msg in _messages)
                        {
                            @if (_firstUnreadOnOpen == msg.MessageId)
                            {
                                <div id="newMessagesDivider" class="new-messages-divider">
                                    Новые сообщения
                                </div>
                            }

                            var isSeller = IsSellerMessage(msg);
                            var senderLabel = GetSenderLabel(msg);
                            var avatarClass = isSeller ? "chat-avatar seller" : "chat-avatar customer";
                            var avatarLetter = isSeller ? "П" : "К"; // Продавец / Клиент
                            var rowClass = "chat-message-row " + (isSeller ? "from-seller" : "");
                            <div @key="msg.MessageId" class="@rowClass">

                                <!-- Аватар -->
                                <div class="@avatarClass" title="@senderLabel">@avatarLetter</div>

                                <!-- Обёртка: имя + пузырь + мета -->
                                <div class="chat-bubble-wrap">

                                    <!-- Имя отправителя -->
                                    <div class="chat-message-sender">@senderLabel</div>

                                    <!-- Пузырь сообщения -->
                                    <div class="chat-message-bubble @(isSeller ? "from-seller" : "from-customer")">
                                        @if (msg.IsImage)
                                        {
                                            @foreach (var d in msg.Data)
                                            {
                                                @if (!string.IsNullOrWhiteSpace(d))
                                                {
                                                    var imgSrc = GetImageSrc(d);
                                                    <img class="chat-message-image"
                                                         src="@imgSrc"
                                                         alt="изображение"
                                                         loading="lazy"
                                                         @onclick="@(() => OpenLightbox(imgSrc))"
                                                         title="Нажмите для просмотра" />
                                                }
                                            }
                                        }
                                        else
                                        {
                                            @foreach (var d in msg.Data)
                                            {
                                                @if (IsFileData(d))
                                                {
                                                    var fname = GetFileName(d);
                                                    var furl = GetFileDownloadUrl(d);
                                                    <div class="chat-file-link">
                                                        <RadzenIcon Icon="@GetFileIcon(fname)"
                                                                    Style="font-size: 1.1rem; flex-shrink: 0;" />
                                                        <a href="@furl" target="_blank"
                                                           style="font-size: 0.83rem; word-break: break-all;">
                                                            @fname
                                                        </a>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="chat-md">@MarkdownHelper.ToMarkup(d)</div>
                                                }
                                            }
                                        }
                                    </div>

                                    <!-- Время + статус прочтения -->
                                    <div class="chat-message-meta">
                                        <span class="chat-message-time">
                                            @msg.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                        @if (msg.IsRead)
                                        {
                                            <RadzenIcon Icon="done_all"
                                                        Style="font-size: 0.7rem; color: var(--rz-success);"
                                                        title="Прочитано" />
                                        }
                                    </div>

                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- Input footer -->
                @if (_selectedChat.ChatStatus == "OPENED")
                {
                    <div class="chat-input-footer">

                        <!-- Шаблонные ответы -->
                        <div class="chat-quick-replies">
                            @foreach (var tpl in QuickReplies)
                            {
                                <button class="chat-quick-reply-chip" @onclick="@(() => ApplyTemplate(tpl))">
                                    @tpl
                                </button>
                            }
                        </div>

                        @if (_attachedFile is not null)
                        {
                            <div class="chat-attachment-preview">
                                <RadzenIcon Icon="attach_file" Style="font-size: 0.9rem;" />
                                <span>@_attachedFile.Name (@FormatFileSize(_attachedFile.Size))</span>
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger"
                                              Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                              Style="padding: 0; margin-left: auto;"
                                              Click="@ClearAttachment" />
                            </div>
                        }

                        <div class="chat-input-row">
                            <label title="Прикрепить файл (JPG, PNG, PDF, DOC, DOCX, TXT — до 10 МБ)"
                                   style="cursor: pointer;">
                                <RadzenButton Icon="attach_file" ButtonStyle="ButtonStyle.Light"
                                              Size="ButtonSize.Small"
                                              Click="@TriggerFilePicker" />
                            </label>

                            <RadzenTextArea @bind-Value="_messageText"
                                            Rows="1"
                                            Placeholder="Введите сообщение…"
                                            CharacterCounter="true"
                                            MaxLength="1000"
                                            Style="width: 100%; flex: 1; resize: none; padding: 2px 10px; max-height: 140px;"
                                            oninput="this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,200)+'px';"/>

                            <RadzenButton Icon="send" ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Small"
                                          Click="@SendMessageAsync"
                                          IsBusy="@_sending"
                                          Disabled="@(!CanSend)"
                                          Title="Отправить"/>



                        </div>

                        <div class="char-counter @(_messageText.Length > 1000 ? "over-limit" : "")">
                            @_messageText.Length / 1000
                        </div>

                        <!-- Hidden file input -->
                        <InputFile id="chat-file-input"
                                   accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.txt"
                                   OnChange="@OnFileSelected"
                                   style="display: none;" />
                    </div>
                }
                else
                {
                    <div style="padding: 0.5rem 1rem; border-top: 1px solid var(--rz-border-color);">
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false"
                                     Style="margin: 0;">
                            Чат закрыт — отправка сообщений недоступна.
                        </RadzenAlert>
                    </div>
                }
            }
        </div>
    </div> <!-- /.chats-layout -->

    @if (_lightboxSrc is not null)
    {
        <div class="lightbox-overlay" @onclick="CloseLightbox">
            <button class="lightbox-close" @onclick:stopPropagation="true" @onclick="CloseLightbox"
                    title="Закрыть (Esc)">
                <RadzenIcon Icon="close" />
            </button>
            <img class="lightbox-image"
                 src="@_lightboxSrc"
                 alt="изображение"
                 @onclick:stopPropagation="true" />
        </div>
    }

    </div> <!-- /.chats-page-root -->
}

<script>
    window.scrollToNewMessages = function () {
        const el = document.getElementById("newMessagesDivider");
        if (el) {
            el.scrollIntoView({
                behavior: "smooth",
                block: "center"
            });
        }
    };
</script>

@code {
    private List<OzonChatViewModelDto> _chats = new();
    private OzonChatViewModelDto? _selectedChat;
    private List<OzonChatMessageDto> _messages = new();

    private ulong? _firstUnreadOnOpen; // ID первого непрочитанного сообщения при открытии чата

    private bool _loadingList;
    private bool _loadingMore;
    private bool _loadingHistory;
    private bool _sending;

    // Пагинация чатов
    private string? _nextCursor;
    private bool _hasMoreChats;

    private string _messageText = string.Empty;
    private string? _lightboxSrc;

    private static readonly string[] QuickReplies =
    [
        "Здравствуйте!",
        "Здравствуйте, для проверки необходим VIN номер Вашего авто",
        "Заявка на рассмотрении, ожидайте",
        "Оформите возврат"
    ];

    private void ApplyTemplate(string text) => _messageText = text;

    private void OpenLightbox(string src) { _lightboxSrc = src; }
    private void CloseLightbox() { _lightboxSrc = null; }
    private IBrowserFile? _attachedFile;
    private string? _attachedBase64;

    // Polling guard flags
    private bool _isRefreshingList;
    private bool _isRefreshingHistory;

    private Timer? _pollingTimer;
    private int _totalUnread;

    // Filters
    private Guid? _filterClientId;
    private string? _filterStatus;
    private string? _filterType;
    private bool _filterUnreadOnly;

    private Dictionary<string, int> _chatStatusCounts = new();
    private Dictionary<string, int> _chatTypeCounts = new();

    private List<ClientOptionDto> _clientOptions = new();

    private static readonly List<LabelValueDto> StatusOptions =
    [
        new("Открыт", "OPENED"),
        new("Закрыт", "CLOSED"),
    ];

    private static readonly List<LabelValueDto> TypeOptions =
    [
        new ("Покупатель — Продавец", "BUYER_SELLER"),
        new ("Продавец — Поддержка", "SELLER_SUPPORT"),
        new ("Не определён", "UNSPECIFIED"),
    ];

    [Inject]
    private IJSRuntime Js { get; set; } = null!;

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        // Ensure UserContext is populated before any service that uses EntityFilterService
        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        await LoadClientOptionsAsync();
        await LoadChatsAsync();

        _pollingTimer = new Timer(
            callback: _ => InvokeAsync(PollAsync),
            state: null,
            dueTime: TimeSpan.FromSeconds(30),
            period: TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        _pollingTimer?.Dispose();
        _dotNetRef?.Dispose();
    }

    private DotNetObjectReference<Chats>? _dotNetRef;
    private bool _keyHandlerRegistered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_keyHandlerRegistered)
        {
            _keyHandlerRegistered = true;
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("window.__registerChatEscape", _dotNetRef);
        }
    }

    [JSInvokable]
    public void HandleKeyEscape()
    {
        if (_lightboxSrc is not null)
        {
            CloseLightbox();
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadClientOptionsAsync()
    {
        try
        {
            await using var db = Factory.CreateDbContext();
            var allowedIds = await EntityFilterSvc.GetAllowedIdsAsync(BlockedEntityTypeEnum.MarketplaceClient);
            var query = db.MarketplaceClients!
                .AsNoTracking()
                .Where(c => !c.IsDeleted)
                .OrderBy(c => c.Name);
            if (allowedIds is not null)
                _clientOptions = await query
                    .Where(c => allowedIds.Contains(c.Id))
                    .Select(c => new ClientOptionDto { Id = c.Id, Name = c.Name })
                    .ToListAsync();
            else
                _clientOptions = await query
                    .Select(c => new ClientOptionDto { Id = c.Id, Name = c.Name })
                    .ToListAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 4000);
        }
    }

    private async Task LoadChatsAsync()
    {
        _loadingList = true;
        _nextCursor = null;
        _hasMoreChats = false;
        StateHasChanged();
        try
        {
            var page = await ChatService.GetChatsPageAsync(
                pageSize: 20,
                cursor: null,
                chatStatus: _filterStatus,
                chatType: _filterType,
                unreadOnly: _filterUnreadOnly,
                marketplaceClientId: _filterClientId);

            _chats = page.Chats;
            _nextCursor = page.NextCursor;
            _hasMoreChats = page.HasMore;
            _totalUnread = _chats.Sum(c => c.UnreadCount);

            // Save pill counts only from unfiltered load so they stay stable when a filter is active
            if (string.IsNullOrEmpty(_filterStatus) && string.IsNullOrEmpty(_filterType))
            {
                _chatStatusCounts = _chats.GroupBy(c => c.ChatStatus).ToDictionary(g => g.Key, g => g.Count());
                _chatTypeCounts = _chats.GroupBy(c => c.ChatType).ToDictionary(g => g.Key, g => g.Count());
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки чатов", ex.Message, 5000);
        }
        finally
        {
            _loadingList = false;
            StateHasChanged();
        }
    }

    private async Task LoadMoreChatsAsync()
    {
        if (_loadingMore || !_hasMoreChats || _nextCursor is null) return;

        _loadingMore = true;
        StateHasChanged();
        try
        {
            var page = await ChatService.GetChatsPageAsync(
                pageSize: 20,
                cursor: _nextCursor,
                chatStatus: _filterStatus,
                chatType: _filterType,
                unreadOnly: _filterUnreadOnly,
                marketplaceClientId: _filterClientId);

            _chats.AddRange(page.Chats);
            _nextCursor = page.NextCursor;
            _hasMoreChats = page.HasMore;
            _totalUnread = _chats.Sum(c => c.UnreadCount);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки чатов", ex.Message, 5000);
        }
        finally
        {
            _loadingMore = false;
            StateHasChanged();
        }
    }

    private async Task LoadHistoryAsync()
    {
        if (_selectedChat is null) return;

        _loadingHistory = true;
        StateHasChanged();
        try
        {
            var result = await ChatService.GetChatHistoryAsync(
                _selectedChat.MarketplaceClientId,
                _selectedChat.ChatId,
                direction: "Backward",
                limit: 50);

            if (result is not null)
            {
                // Backward = newest first → reverse for display (oldest at top)
                _messages = result.Messages
                    .OrderBy(m => m.CreatedAt)
                    .ToList();

                if (_selectedChat?.UnreadCount > 0 && _messages.Count >= _selectedChat.UnreadCount)
                {
                    _firstUnreadOnOpen = _messages[^_selectedChat.UnreadCount].MessageId;
                }

                // Обновляем время последнего сообщения в карточке чата
                if (_messages.Count > 0 && _selectedChat is not null)
                    _selectedChat.LastMessageAt = _messages[^1].CreatedAt;
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка загрузки истории", ex.Message, 5000);
        }
        finally
        {
            _loadingHistory = false;
            StateHasChanged();

            if (_firstUnreadOnOpen != null)
            {
                await Task.Delay(100);
                await Js.InvokeVoidAsync("scrollToNewMessages");
            }
            else
            {
                await ScrollToBottomAsync();
            }
        }
    }

    private async Task PollAsync()
    {
        await PollListAsync();
        await PollHistoryAsync();
    }

    private async Task PollListAsync()
    {
        if (_isRefreshingList) return;
        _isRefreshingList = true;
        try
        {
            var page = await ChatService.GetChatsPageAsync(
                pageSize: 20,
                cursor: null,
                chatStatus: _filterStatus,
                chatType: _filterType,
                unreadOnly: _filterUnreadOnly,
                marketplaceClientId: _filterClientId);

            foreach (var f in page.Chats)
            {
                var existing = _chats.FirstOrDefault(
                    c => c.ChatId == f.ChatId && c.MarketplaceClientId == f.MarketplaceClientId);
                if (existing is not null)
                {
                    existing.UnreadCount = f.UnreadCount;
                    existing.LastMessageAt = f.LastMessageAt;
                }
                else
                    _chats.Insert(0, f);
            }

            _totalUnread = _chats.Sum(c => c.UnreadCount);
            StateHasChanged();
        }
        catch { /* Silently ignore polling errors */ }
        finally
        {
            _isRefreshingList = false;
        }
    }

    private async Task PollHistoryAsync()
    {
        if (_selectedChat is null || _isRefreshingHistory) return;
        _isRefreshingHistory = true;
        try
        {
            // Fetch only newer messages using the last known message id, direction Forward
            ulong? fromId = _messages.Count > 0 ? _messages[^1].MessageId : null;

            var direction = fromId.HasValue ? "Forward" : "Backward";
            var result = await ChatService.GetChatHistoryAsync(
                _selectedChat.MarketplaceClientId,
                _selectedChat.ChatId,
                direction: direction,
                fromMessageId: fromId,
                limit: 50);

            if (result?.Messages is { Count: > 0 } newMessages)
            {
                var existingIds = _messages.Select(m => m.MessageId).ToHashSet();
                var toAdd = newMessages
                    .Where(m => !existingIds.Contains(m.MessageId))
                    .OrderBy(m => m.CreatedAt)
                    .ToList();

                if (toAdd.Count > 0)
                {
                    _messages.AddRange(toAdd);
                    StateHasChanged();
                    await ScrollToBottomAsync();
                }
            }
        }
        catch { /* Silently ignore polling errors */ }
        finally
        {
            _isRefreshingHistory = false;
        }
    }

    private async Task SelectChatAsync(OzonChatViewModelDto chat)
    {
        _firstUnreadOnOpen = null;

        _selectedChat = chat;
        _messages.Clear();
        _messageText = string.Empty;
        _attachedFile = null;
        _attachedBase64 = null;
        await LoadHistoryAsync();
        await AutoMarkReadAsync();
    }

    private async Task RefreshAllAsync()
    {
        await LoadChatsAsync();
        if (_selectedChat is not null)
            await LoadHistoryAsync();
    }

    private async Task RefreshHistoryAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task OnFilterChanged(object? _)
    {
        _selectedChat = null;
        _messages.Clear();
        await LoadChatsAsync();
    }

    private async Task OnUnreadFilterChanged(bool _)
    {
        _selectedChat = null;
        _messages.Clear();
        await LoadChatsAsync();
    }

    private async Task SendMessageAsync()
    {
        if (_selectedChat is null) return;

        if (_attachedFile is not null && _attachedBase64 is not null)
        {
            await SendFileInternalAsync();
            return;
        }

        if (string.IsNullOrWhiteSpace(_messageText) || _messageText.Length > 1000) return;

        _sending = true;
        StateHasChanged();
        try
        {
            var (ok, error) = await ChatService.SendMessageAsync(
                _selectedChat.MarketplaceClientId,
                _selectedChat.ChatId,
                _messageText.Trim());

            if (ok)
            {
                _messageText = string.Empty;
                await Task.Delay(600);
                await LoadHistoryAsync();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Не удалось отправить сообщение.", 6000);
            }
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private async Task SendFileInternalAsync()
    {
        if (_selectedChat is null || _attachedFile is null || _attachedBase64 is null) return;

        _sending = true;
        StateHasChanged();
        try
        {
            var (ok, error) = await ChatService.SendFileAsync(
                _selectedChat.MarketplaceClientId,
                _selectedChat.ChatId,
                _attachedBase64,
                _attachedFile.Name);

            if (ok)
            {
                _attachedFile = null;
                _attachedBase64 = null;
                _messageText = string.Empty;
                await Task.Delay(600);
                await LoadHistoryAsync();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Не удалось отправить файл.", 6000);
            }
        }
        finally
        {
            _sending = false;
            StateHasChanged();
        }
    }

    private async Task AutoMarkReadAsync()
    {
        if (_selectedChat is null || _selectedChat.UnreadCount == 0) return;
        if (_messages.Count == 0) return;

        var lastId = _messages[^1].MessageId;
        try
        {
            var unread = await ChatService.MarkReadAsync(
                _selectedChat.MarketplaceClientId,
                _selectedChat.ChatId,
                lastId);

            _selectedChat.UnreadCount = unread;
            foreach (var m in _messages) m.IsRead = true;
            _totalUnread = _chats.Sum(c => c.UnreadCount);
        }
        catch { /* не мешаем открытию чата при ошибке */ }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        const long maxSize = 10 * 1024 * 1024; // 10 MB

        var file = e.File;
        if (file.Size > maxSize)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Файл слишком большой",
                "Максимальный размер файла — 10 МБ.", 5000);
            return;
        }

        var allowed = new[] { ".jpg", ".jpeg", ".png", ".pdf", ".doc", ".docx", ".txt" };
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowed.Contains(ext))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Неподдерживаемый формат",
                "Допустимые форматы: JPG, PNG, PDF, DOC, DOCX, TXT.", 5000);
            return;
        }

        try
        {
            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(maxSize);
            await stream.CopyToAsync(ms);
            _attachedBase64 = Convert.ToBase64String(ms.ToArray());
            _attachedFile = file;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка чтения файла", ex.Message, 4000);
        }
    }

