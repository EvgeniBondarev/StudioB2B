    private static string GetSenderLabel(OzonChatMessageDto msg) =>
        msg.User?.Type switch
        {
            "Seller" or "seller" or "Seller_Support" or "SELLER_SUPPORT" => "Продавец",
            // Ozon sometimes sends Cyrillic "С" (U+0421) instead of Latin "C"
            "Customer" or "Сustomer" or "customer" or "BUYER" => "Покупатель",
            "Support" => "Поддержка Ozon",
            _ => msg.User?.Type ?? "Система"
        };

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalSeconds < 60) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин. назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч. назад";
        if (diff.TotalDays < 2) return "вчера";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} дн. назад";
        return utcTime.ToLocalTime().ToString("dd.MM.yyyy");
    }

