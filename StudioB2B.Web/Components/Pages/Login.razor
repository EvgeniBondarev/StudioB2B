@page "/login"
@inject NavigationManager Navigation

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    protected override void OnInitialized()
    {
        var query = new System.Text.StringBuilder("?");
        if (!string.IsNullOrEmpty(Error)) query.Append($"error={Uri.EscapeDataString(Error)}&");
        if (!string.IsNullOrEmpty(ReturnUrl)) query.Append($"returnUrl={Uri.EscapeDataString(ReturnUrl)}&");
        var qs = query.ToString().TrimEnd('&', '?');
        Navigation.NavigateTo("/" + (qs.Length > 0 ? qs : ""), replace: true);
    }
}
