@page "/price-types"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using Radzen
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Domain.Entities.References
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime

@implements IDisposable

<PageTitle>Типы цен</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Типы цен</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <RadzenButton Icon="add" Text="Добавить" ButtonStyle="ButtonStyle.Primary"
                          Click="@AddRow" />
        </RadzenStack>
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Body2"
                Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem; display: block;">
        Пользовательские типы цен участвуют в формулах правил расчёта и в правилах документов. Системные типы создаются при синхронизации с Ozon.
    </RadzenText>

    <RadzenDataGrid @ref="_grid"
                    TItem="PriceType"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="20"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="@OnUpdate"
                    RowCreate="@OnCreate"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="PriceType" Property="Name" Title="Название" Width="220px" Frozen="true">
                <EditTemplate Context="p">
                    <RadzenTextBox @bind-Value="p.Name" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="PriceType" Property="DeliveryScheme" Title="Схема доставки" Width="160px">
                <Template Context="p">
                    @(p.DeliveryScheme ?? "—")
                </Template>
                <EditTemplate Context="p">
                    <RadzenTextBox @bind-Value="p.DeliveryScheme" Style="width: 100%;" Placeholder="fbs, fbo, express" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="PriceType" Property="IsUserDefined" Title="Пользовательский"
                                 Width="140px" TextAlign="TextAlign.Center" Filterable="false">
                <Template Context="p">
                    @if (p.IsUserDefined)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="Да" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="p">
                    <RadzenCheckBox @bind-Value="p.IsUserDefined" Disabled="true" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="PriceType" Filterable="false" Sortable="false"
                                 Width="110px" TextAlign="TextAlign.Center" Title="">
                <EditTemplate Context="p">
                    @if (p.IsUserDefined)
                    {
                        <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success"
                                      Size="ButtonSize.ExtraSmall"
                                      Click="@(() => SaveRow(p))" Style="margin-right: 4px;" />
                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.ExtraSmall"
                                      Click="@(() => CancelRow(p))" />
                    }
                </EditTemplate>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<PriceType>? _grid;
    private TenantDbContext? _db;
    private IEnumerable<PriceType> _pageItems = Array.Empty<PriceType>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];
    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "price-types-grid-settings";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGridSettingsAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        await EnsureInitializedAsync();

        var query = _db!.PriceTypes.AsNoTracking().AsQueryable();

        if (!string.IsNullOrEmpty(args.Filter))
            query = query.Where(args.Filter);

        _totalCount = await query.CountAsync();

        query = !string.IsNullOrEmpty(args.OrderBy)
            ? query.OrderBy(args.OrderBy)
            : query.OrderBy(p => p.Name);

        var skip = args.Skip ?? 0;
        var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 20);
        _pageItems = await query.Skip(skip).Take(take).ToListAsync();

        _loading = false;
    }

    private async Task EnsureInitializedAsync()
    {
        if (_db != null) return;
        _db = Factory.CreateDbContext();
    }

    private void AddRow()
    {
        if (_db == null) return;
        _grid?.InsertRow(new PriceType
        {
            Id = Guid.NewGuid(),
            Name = string.Empty,
            IsUserDefined = true
        });
    }

    private async Task OnCreate(PriceType item)
    {
        if (item == null || _db == null) return;
        if (string.IsNullOrWhiteSpace(item.Name))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Укажите название типа цены.");
            return;
        }
        _db.PriceTypes.Add(item);
        await _db.SaveChangesAsync();
        NotificationService.Notify(NotificationSeverity.Success, "Тип цены создан");
        await _grid!.Reload();
    }

    private async Task OnUpdate(PriceType item)
    {
        if (item == null || _db == null) return;
        if (!item.IsUserDefined)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Системные типы цен нельзя редактировать.");
            return;
        }
        if (string.IsNullOrWhiteSpace(item.Name))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Укажите название типа цены.");
            return;
        }
        var entity = await _db.PriceTypes.FindAsync(item.Id);
        if (entity == null || !entity.IsUserDefined) return;
        entity.Name = item.Name.Trim();
        entity.DeliveryScheme = string.IsNullOrWhiteSpace(item.DeliveryScheme) ? null : item.DeliveryScheme.Trim();
        await _db.SaveChangesAsync();
        NotificationService.Notify(NotificationSeverity.Success, "Изменения сохранены");
        await _grid!.Reload();
    }

    private void SaveRow(PriceType p) => _grid?.UpdateRow(p);
    private void CancelRow(PriceType p) => _grid?.CancelEditRow(p);

    private void ShowContextMenu(DataGridCellMouseEventArgs<PriceType> args)
    {
        var canEdit = args.Data.IsUserDefined;
        var items = new List<ContextMenuItem>();
        if (canEdit)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" });
        }

        if (items.Count == 0) return;

        ContextMenuService.Open(args, items, async e =>
        {
            ContextMenuService.Close();
            if (e.Value?.ToString() == "edit")
                _grid?.EditRow(args.Data);
            else if (e.Value?.ToString() == "delete")
                await DeleteAsync(args.Data);
        });
    }

    private async Task DeleteAsync(PriceType p)
    {
        if (_db == null || !p.IsUserDefined) return;
        var entity = await _db.PriceTypes.FindAsync(p.Id);
        if (entity == null || !entity.IsUserDefined) return;
        entity.IsDeleted = true;
        await _db.SaveChangesAsync();
        NotificationService.Notify(NotificationSeverity.Success, "Тип цены удалён");
        await _grid!.Reload();
    }

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };

    public void Dispose() => _db?.Dispose();
}
