@page "/marketplace-clients"
@attribute [Authorize(Roles = "Admin")]
@using AutoMapper
@using AutoMapper.QueryableExtensions
@using StudioB2B.Application.Common.Interfaces
@using StudioB2B.Shared.DTOs
@using StudioB2B.Web.Components.Common
@using StudioB2B.Infrastructure.Features.Marketplace
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Infrastructure.Services
@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject IMapper Mapper
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Клиенты маркетплейсов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        Раздел доступен только внутри тенанта
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-5">
        <MudText Typo="Typo.h5" Style="font-weight:700;">Клиенты маркетплейсов</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.AddBusiness"
                   OnClick="AddClient">
            Добавить клиента
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }

    <MudPaper Outlined="true">
        <MudTable Items="@_clients" Hover="true" Dense="true" Loading="@_loading"
                  LoadingProgressColor="Color.Primary" Elevation="0">
            <HeaderContent>
                <MudTh>Название</MudTh>
                <MudTh>API Id</MudTh>
                <MudTh>Тип</MudTh>
                <MudTh>Режим</MudTh>
                <!-- created column removed -->
                <MudTh Style="width:130px"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Название">
                    <MudText Style="font-weight:500;">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="API Id">@context.ApiId</MudTd>
                <MudTd DataLabel="Тип">@context.ClientTypeName</MudTd>
                <MudTd DataLabel="Режим">@context.ModeName</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                   Title="Редактировать" OnClick="@(() => EditClient(context))" />
                    <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"
                                   Color="Color.Error" Title="Удалить"
                                   OnClick="@(() => DeleteClient(context))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">Клиентов пока нет</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}

@code {
    private List<MarketplaceClientDto> _clients = [];
    private List<MarketplaceClientTypeDto> _types = [];
    private List<MarketplaceClientModeDto> _modes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (TenantProvider.IsResolved)
            await LoadAsync();
        else
            _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        using var db = Factory.CreateDbContext();
        _types = await db.MarketplaceClientTypes!
                        .AsNoTracking()
                        .OrderBy(t => t.Name)
                        .ProjectTo<MarketplaceClientTypeDto>(Mapper.ConfigurationProvider)
                        .ToListAsync();
        _modes = await db.MarketplaceClientModes!
                        .AsNoTracking()
                        .OrderBy(m => m.Name)
                        .ProjectTo<MarketplaceClientModeDto>(Mapper.ConfigurationProvider)
                        .ToListAsync();
        _clients = await db.MarketplaceClients!.GetAllAsync(Mapper);
        _loading = false;
    }

    private async Task AddClient()
    {
        var parameters = new DialogParameters<MarketplaceClientFormDialog>
        {
            { x => x.Title, "Добавить клиента" },
            { x => x.Model, new MarketplaceClientFormModel() },
            { x => x.ClientTypes, _types },
            { x => x.Modes, _modes }
        };
        var dialog = await DialogService.ShowAsync<MarketplaceClientFormDialog>("Добавить клиента", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: MarketplaceClientFormModel m })
        {
            using var db = Factory.CreateDbContext();
            var request = new CreateMarketplaceClientRequest(
                m.Name ?? string.Empty,
                m.ApiId ?? string.Empty,
                m.Key ?? string.Empty,
                m.ClientTypeId,
                m.ModeId,
                null,
                null);
            await db.CreateAsync(request, Mapper);
            Snackbar.Add("Клиент создан", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task EditClient(MarketplaceClientDto client)
    {
        var model = new MarketplaceClientFormModel
        {
            Id = client.Id,
            Name = client.Name,
            ApiId = client.ApiId,
            Key = client.Key,
            ClientTypeId = client.ClientTypeId,
            ModeId = client.ModeId
        };
        var parameters = new DialogParameters<MarketplaceClientFormDialog>
        {
            { x => x.Title, "Редактировать клиента" },
            { x => x.Model, model },
            { x => x.ClientTypes, _types },
            { x => x.Modes, _modes }
        };
        var dialog = await DialogService.ShowAsync<MarketplaceClientFormDialog>("Редактировать клиента", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: MarketplaceClientFormModel m })
        {
            using var db = Factory.CreateDbContext();
            var req = new UpdateMarketplaceClientRequest(
                m.Id!.Value,
                m.Name ?? string.Empty,
                m.ApiId ?? string.Empty,
                m.Key ?? string.Empty,
                m.ClientTypeId,
                m.ModeId,
                null,
                null);
            var updated = await db.UpdateAsync(req, Mapper);
            if (updated != null)
            {
                Snackbar.Add("Клиент обновлён", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("Ошибка обновления", Severity.Error);
            }
        }
    }

    private async Task DeleteClient(MarketplaceClientDto client)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Удаление клиента",
            $"Удалить клиента «{client.Name}»? Действие необратимо.",
            yesText: "Удалить", cancelText: "Отмена");
        if (confirmed == true)
        {
            using var db = Factory.CreateDbContext();
            var deleted = await db.DeleteAsync(client.Id);
            if (deleted)
            {
                Snackbar.Add("Клиент удалён", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("Ошибка удаления", Severity.Error);
            }
        }
    }

}
