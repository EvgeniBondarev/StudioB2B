@page "/marketplace-clients"
@attribute [Authorize(Roles = "MarketplaceClientsView")]
@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ITenantDbContextFactory Factory
@inject IKeyEncryptionService Encryption
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JsRuntime

@implements IDisposable

<link rel="stylesheet" href="css/orders.css" />
<PageTitle>Клиенты маркетплейсов</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Клиенты маркетплейсов</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <AuthorizeView Roles="MarketplaceClientsManage">
                <Authorized>
                    <RadzenButton Icon="add" Text="Добавить" Shade="Shade.Light" ButtonStyle="ButtonStyle.Primary"
                                  Click="@OpenCreateWizard" />
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem"
                 Style="padding: 0 0 0.6rem 0; flex-wrap: wrap;">
        @{ var allTypesActive = _filterClientTypeId == null; }
        <span class="q-pill @(allTypesActive ? "active" : "")"
              style="background:@(allTypesActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allTypesActive ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(async () => { _filterClientTypeId = null; await OnPillFilter(); })">
            Все типы
        </span>
        @foreach (var t in _types)
        {
            var tid = t.Id;
            var tname = t.Name;
            var isTypeActive = _filterClientTypeId == tid;
            var typeCnt = _typeCountsByTypeId.GetValueOrDefault(tid);
            <span class="q-pill @(isTypeActive ? "active" : "")"
                  style="background:@(isTypeActive ? "var(--rz-primary)" : "#ececff"); color:@(isTypeActive ? "#fff" : "#1f2937");"
                  @onclick="@(async () => { _filterClientTypeId = isTypeActive ? null : tid; await OnPillFilter(); })">
                @tname
                @if (typeCnt > 0) { <span class="q-pill-count">@typeCnt</span> }
            </span>
        }

        <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 6px;"></span>

        @{ var allModesActive = _filterModeId == null; }
        <span class="q-pill @(allModesActive ? "active" : "")"
              style="background:@(allModesActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allModesActive ? "#fff" : "var(--rz-text-color)");"
              @onclick="@(async () => { _filterModeId = null; await OnPillFilter(); })">
            Все режимы
        </span>
        @foreach (var m in _modes)
        {
            var mid = m.Id;
            var mname = m.Name;
            var isModeActive = _filterModeId == mid;
            var modeCnt = _modeCountsByModeId.GetValueOrDefault(mid);
            var modeSchemeClass = mname?.Equals("fbs", StringComparison.OrdinalIgnoreCase) == true ? "scheme-fbs" :
                                  mname?.Equals("fbo", StringComparison.OrdinalIgnoreCase) == true ? "scheme-fbo" : "";
            <span class="q-pill @modeSchemeClass @(isModeActive ? "active" : "")"
                  @onclick="@(async () => { _filterModeId = isModeActive ? null : mid; await OnPillFilter(); })">
                @mname
                @if (modeCnt > 0) { <span class="q-pill-count">@modeCnt</span> }
            </span>
        }
    </RadzenStack>

    <RadzenDataGrid @ref="_grid"
                    TItem="MarketplaceClient"
                    Data="@_pageItems"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    LogicalFilterOperator="LogicalFilterOperator.Or"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="15"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="@OnUpdate"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="MarketplaceClient" Property="Name" Title="Название" Width="220px" Frozen="true" Visible="@Col("MktClientsColName")">
                <EditTemplate Context="c">
                    <RadzenTextBox @bind-Value="c.Name" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Property="ApiId" Title="API ID" Width="180px" Visible="@Col("MktClientsColApiId")">
                <EditTemplate Context="c">
                    <RadzenTextBox @bind-Value="c.ApiId" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <!-- Masked key column with show/hide toggle -->
            <RadzenDataGridColumn TItem="MarketplaceClient" Property="Key" Title="API ключ" Width="240px"
                                  Filterable="false" Sortable="false" Visible="@Col("MktClientsColApiKey")">
                <Template Context="c">
                    <div @key="c.Id" style="display:flex; align-items:center; gap:4px;"
                         @onclick:stopPropagation="true">
                        @if (_revealedKeys.Contains(c.Id))
                        {
                            <span style="font-family: monospace; font-size: 0.8rem; word-break: break-all; max-width:160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @SafeDecrypt(c.Key)
                            </span>
                        }
                        else
                        {
                            <span style="letter-spacing: 3px; color: var(--rz-text-secondary-color); font-size: 1rem;">
                                ••••••••••••
                            </span>
                        }
                        <RadzenButton Icon="@(_revealedKeys.Contains(c.Id) ? "visibility_off" : "visibility")"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.ExtraSmall"
                                      Variant="Variant.Text"
                                      Click="@(() => ToggleKeyVisibility(c.Id))"
                                      Title="@(_revealedKeys.Contains(c.Id) ? "Скрыть" : "Показать")"
                                      Style="flex-shrink: 0;" />
                    </div>
                </Template>
                <EditTemplate Context="c">
                    <RadzenPassword @bind-Value="c.Key" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Property="ClientType.Name" Title="Тип" Width="180px"
                                  Sortable="false" Filterable="false" Visible="@Col("MktClientsColType")">
                <EditTemplate Context="c">
                    <RadzenDropDown Data="@_types"
                                    TextProperty="@nameof(MarketplaceClientType.Name)"
                                    ValueProperty="@nameof(MarketplaceClientType.Id)"
                                    @bind-Value="c.ClientTypeId"
                                    Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Title="Режим (моды)" Width="180px"
                                  Sortable="false" Filterable="false" Visible="@Col("MktClientsColMode")">
                <Template Context="c">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                        @foreach (var modeName in new[] { c.Mode?.Name, c.Mode2?.Name }.Where(n => !string.IsNullOrWhiteSpace(n)))
                        {
                            var mc = modeName!.Equals("fbs", StringComparison.OrdinalIgnoreCase) ? "scheme-fbs" :
                                     modeName.Equals("fbo", StringComparison.OrdinalIgnoreCase) ? "scheme-fbo" : "";
                            <span class="shipment-scheme-icon @mc">@modeName!.ToUpperInvariant()</span>
                        }
                    </RadzenStack>
                </Template>
                <EditTemplate Context="c">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem">
                        @foreach (var m in _modes)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                <RadzenCheckBox TValue="bool"
                                                 Value="@(c.ModeId == m.Id || c.ModeId2 == m.Id)"
                                                 Change="@(value => OnClientModeChanged(c, m.Id, value))" />
                                <RadzenText TextStyle="TextStyle.Body2">@m.Name</RadzenText>
                            </RadzenStack>
                        }
                    </RadzenStack>
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Property="Company" Title="Компания" Width="200px" Visible="@Col("MktClientsColCompany")">
                <EditTemplate Context="c">
                    <RadzenTextBox @bind-Value="c.Company" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Property="INN" Title="ИНН" Width="160px" Visible="@Col("MktClientsColINN")">
                <EditTemplate Context="c">
                    <RadzenTextBox @bind-Value="c.INN" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="MarketplaceClient" Filterable="false" Sortable="false"
                                  Width="110px" TextAlign="TextAlign.Center" Title="">
                <Template Context="c">
                </Template>
                <EditTemplate Context="c">
                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => SaveRow(c))" Style="margin-right: 4px;" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => CancelRow(c))" />
                </EditTemplate>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private RadzenDataGrid<MarketplaceClient>? _grid;

    private TenantDbContext? _db;
    private IEnumerable<MarketplaceClient> _pageItems = Array.Empty<MarketplaceClient>();
    private int _totalCount;
    private List<MarketplaceClientType> _types = [];
    private List<MarketplaceClientMode> _modes = [];
    private Density _density = Density.Default;
    private bool _loading;
    private bool _canManage;
    private System.Security.Claims.ClaimsPrincipal? _user;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];

    private Guid? _filterClientTypeId;
    private Guid? _filterModeId;
    private Dictionary<Guid, int> _typeCountsByTypeId = new();
    private Dictionary<Guid, int> _modeCountsByModeId = new();

    private bool Col(string role) => _user?.IsInRole("Admin") == true || _user?.IsInRole(role) == true;

    // tracks which rows have their key revealed
    private readonly HashSet<Guid> _revealedKeys = [];

    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "marketplace-clients-grid-settings";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var state = await AuthState;
            _user = state.User;
            _canManage = state.User.IsInRole("MarketplaceClientsManage");
            await LoadGridSettingsAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        await EnsureInitializedAsync();

        var query = _db!.MarketplaceClients!
            .IncludeEverything()
            .AsNoTracking()
            .AsQueryable();

        if (_filterClientTypeId.HasValue)
            query = query.Where(c => c.ClientTypeId == _filterClientTypeId.Value);
        if (_filterModeId.HasValue)
            query = query.Where(c => c.ModeId == _filterModeId.Value || c.ModeId2 == _filterModeId.Value);

        if (!string.IsNullOrEmpty(args.Filter))
            query = query.Where(args.Filter);

        query = !string.IsNullOrEmpty(args.OrderBy)
            ? query.OrderBy(args.OrderBy)
            : query.OrderBy(c => c.Name);

        _totalCount = await query.CountAsync();

        var skip = args.Skip ?? 0;
        var take = (args.Top is > 0) ? args.Top.Value : (_grid?.PageSize ?? 15);

        _pageItems = await query.Skip(skip).Take(take).ToListAsync();
        _loading = false;
    }

    private async Task EnsureInitializedAsync()
    {
        if (_db != null) return;

        _db = Factory.CreateDbContext();

        _types = await _db.MarketplaceClientTypes!
            .AsNoTracking().OrderBy(t => t.Name).ToListAsync();

        _modes = await _db.MarketplaceClientModes!
            .AsNoTracking().OrderBy(m => m.Name).ToListAsync();

        var clientData = await _db.MarketplaceClients!
            .AsNoTracking()
            .Where(c => !c.IsDeleted)
            .Select(c => new { c.ClientTypeId, c.ModeId, c.ModeId2 })
            .ToListAsync();
        _typeCountsByTypeId = clientData
            .Where(c => c.ClientTypeId.HasValue)
            .GroupBy(c => c.ClientTypeId!.Value)
            .ToDictionary(g => g.Key, g => g.Count());
        _modeCountsByModeId = clientData
            .SelectMany(c => new[] { c.ModeId, c.ModeId2 })
            .Where(id => id.HasValue)
            .GroupBy(id => id!.Value)
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task OnPillFilter()
    {
        if (_grid != null)
            await _grid.Reload();
    }

    private async Task OpenCreateWizard()
    {
        var created = await DialogService.OpenAsync<MarketplaceClientWizard>(
            "Добавление клиента маркетплейса",
            parameters: new Dictionary<string, object?>(),
            options: new DialogOptions
            {
                Width = "680px",
                CloseDialogOnEsc = true,
                CloseDialogOnOverlayClick = false,
                ShowClose = true
            });

        if (created is true && _grid != null)
            await _grid.Reload();
    }

    private void ToggleKeyVisibility(Guid clientId)
    {
        if (!_revealedKeys.Remove(clientId))
            _revealedKeys.Add(clientId);
        StateHasChanged();
    }

    private string SafeDecrypt(string? encryptedKey)
    {
        if (string.IsNullOrEmpty(encryptedKey)) return string.Empty;
        try { return Encryption.Decrypt(encryptedKey); }
        catch { return encryptedKey; }
    }

    private async Task EditRow(MarketplaceClient client) => await _grid!.EditRow(client);

    private async Task SaveRow(MarketplaceClient client) => await _grid!.UpdateRow(client);

    private void CancelRow(MarketplaceClient client) => _grid!.CancelEditRow(client);

    private void OnClientModeChanged(MarketplaceClient client, Guid modeId, bool isChecked)
    {
        var ids = new List<Guid>(2);
        if (client.ModeId.HasValue) ids.Add(client.ModeId.Value);
        if (client.ModeId2.HasValue) ids.Add(client.ModeId2.Value);

        if (isChecked)
        {
            if (ids.Contains(modeId))
                return;

            if (ids.Count >= 2)
            {
                NotificationService.Notify(NotificationSeverity.Warning,
                    "Ограничение",
                    "В текущей версии можно выбрать максимум 2 режима на клиента.");
                return;
            }

            ids.Add(modeId);
        }
        else
        {
            ids.Remove(modeId);
        }

        client.ModeId = ids.Count > 0 ? ids[0] : null;
        client.ModeId2 = ids.Count > 1 ? ids[1] : null;
    }

    private async Task OnUpdate(MarketplaceClient client)
    {
        try
        {
            // If the key was changed and does NOT look like a base64 cipher text,
            // encrypt it before persisting
            if (!string.IsNullOrEmpty(client.Key) && !IsEncrypted(client.Key))
                client.Key = Encryption.Encrypt(client.Key);

            await _db!.SaveChangesAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Клиент обновлён");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    /// <summary>
    /// Heuristic: if the string is valid base64 and its byte length implies an AES
    /// cipher text (> 16 bytes), treat it as already encrypted.
    /// </summary>
    private static bool IsEncrypted(string value)
    {
        if (value.Length < 24) return false;
        try
        {
            var bytes = Convert.FromBase64String(value);
            return bytes.Length > 16;
        }
        catch
        {
            return false;
        }
    }

    private async Task DeleteRow(MarketplaceClient client)
    {
        try
        {
            _db!.MarketplaceClients!.Remove(client);
            await _db.SaveChangesAsync();
            await _grid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Клиент удалён");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<MarketplaceClient> args)
    {
        var items = new List<ContextMenuItem>();
        if (_canManage)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit", Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить", Icon = "delete", Value = "delete" });
        }
        if (items.Count == 0) return;

        ContextMenuService.Open(args, items,
            e =>
            {
                ContextMenuService.Close();
                if (e.Value?.ToString() == "edit")
                    InvokeAsync(() => EditRow(args.Data!));
                else if (e.Value?.ToString() == "delete")
                    InvokeAsync(() => DeleteRow(args.Data!));
            });
    }

    public void Dispose() => _db?.Dispose();

    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };
}
