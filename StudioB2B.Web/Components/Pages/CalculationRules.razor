@page "/calculation-rules"
@attribute [Authorize(Roles = "CalculationRulesView")]
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services

@inject ITenantProvider TenantProvider
@inject ICalculationRuleService CalculationRuleService
@inject CalculationEngine CalculationEngine
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService
@inject DialogService DialogService
@inject IJSRuntime JsRuntime


<PageTitle>Правила расчёта</PageTitle>

@if (!TenantProvider.IsResolved)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false" Style="margin-top: 1rem;">
        Раздел доступен только внутри тенанта
    </RadzenAlert>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; margin: 0;">Правила расчёта</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenButton Icon="table_rows" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="@ToggleDensity" Title="@GetDensityTitle()" />
            <AuthorizeView Roles="CalculationRulesManage">
                <Authorized>
                    <RadzenButton Icon="add" Text="Добавить" Shade="Shade.Light" ButtonStyle="ButtonStyle.Primary"
                                  Click="@AddRow" />
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenStack>

    <RadzenDataGrid @ref="_grid"
                    TItem="CalculationRule"
                    Data="@_items"
                    Count="@_totalCount"
                    LoadData="@LoadData"
                    Density="@_density"
                    Settings="@_gridSettings"
                    SettingsChanged="@OnGridSettingsChanged"
                    AllowFiltering="true"
                    AllowColumnResize="true"
                    AllowAlternatingRows="false"
                    FilterMode="FilterMode.Advanced"
                    AllowSorting="true"
                    AllowPaging="true"
                    PageSize="20"
                    PageSizeOptions="@_pageSizeOptions"
                    ShowPagingSummary="true"
                    PagerHorizontalAlign="HorizontalAlign.Left"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="@OnUpdate"
                    RowCreate="@OnCreate"
                    CellContextMenu="@ShowContextMenu"
                    IsLoading="@_loading"
                    FilterText="@RadzenRuStrings.FilterText"
                    ApplyFilterText="@RadzenRuStrings.ApplyFilterText"
                    ClearFilterText="@RadzenRuStrings.ClearFilterText"
                    ContainsText="@RadzenRuStrings.ContainsText"
                    DoesNotContainText="@RadzenRuStrings.DoesNotContainText"
                    EqualsText="@RadzenRuStrings.EqualsText"
                    NotEqualsText="@RadzenRuStrings.NotEqualsText"
                    StartsWithText="@RadzenRuStrings.StartsWithText"
                    EndsWithText="@RadzenRuStrings.EndsWithText"
                    GreaterThanText="@RadzenRuStrings.GreaterThanText"
                    GreaterThanOrEqualsText="@RadzenRuStrings.GreaterThanOrEqualsText"
                    LessThanText="@RadzenRuStrings.LessThanText"
                    LessThanOrEqualsText="@RadzenRuStrings.LessThanOrEqualsText"
                    IsNullText="@RadzenRuStrings.IsNullText"
                    IsNotNullText="@RadzenRuStrings.IsNotNullText"
                    AndOperatorText="@RadzenRuStrings.AndOperatorText"
                    OrOperatorText="@RadzenRuStrings.OrOperatorText"
                    PageSizeText="@RadzenRuStrings.PageSizeText"
                    PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                    EmptyText="@RadzenRuStrings.EmptyText">
        <Columns>

            <RadzenDataGridColumn TItem="CalculationRule" Property="SortOrder" Title="#"
                                  Width="60px" TextAlign="TextAlign.Center" Filterable="false" Visible="@Col("CalcRulesColSortOrder")">
                <EditTemplate Context="r">
                    <RadzenNumeric @bind-Value="r.SortOrder" Style="width: 100%;" Min="0" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="CalculationRule" Property="Name" Title="Название" Width="200px" Visible="@Col("CalcRulesColName")">
                <EditTemplate Context="r">
                    <RadzenTextBox @bind-Value="r.Name" Style="width: 100%;" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="CalculationRule" Property="ResultKey" Title="Ключ результата" Width="180px" Visible="@Col("CalcRulesColResultKey")">
                <Template Context="r">
                    <span style="font-family: monospace; font-size: 0.82rem; color: var(--rz-primary);">@r.ResultKey</span>
                </Template>
                <EditTemplate Context="r">
                    <RadzenTextBox @bind-Value="r.ResultKey" Style="width: 100%;" Placeholder="Скидка" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="CalculationRule" Property="Formula" Title="Формула" Width="360px" Visible="@Col("CalcRulesColFormula")">
                <Template Context="r">
                    <span style="font-family: monospace; font-size: 0.82rem;">@r.Formula</span>
                </Template>
                <EditTemplate Context="r">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem">
                        <RadzenTextBox @bind-Value="r.Formula" Style="flex: 1;"
                                       Placeholder="ЦенаДоСкидки - Цена" />
                        <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Info"
                                      Size="ButtonSize.ExtraSmall"
                                      Title="Проверить формулу"
                                      Click="@(() => ValidateFormulaAsync(r))" />
                    </RadzenStack>
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="CalculationRule" Property="IsActive" Title="Активно"
                                  Width="90px" TextAlign="TextAlign.Center" Filterable="false" Visible="@Col("CalcRulesColIsActive")">
                <Template Context="r">
                    @if (r.IsActive)
                    {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Class="status-badge" Text="Да" />
                    }
                    else
                    {
                        <span style="color: var(--rz-text-disabled-color);">—</span>
                    }
                </Template>
                <EditTemplate Context="r">
                    <RadzenCheckBox @bind-Value="r.IsActive" />
                </EditTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="CalculationRule" Filterable="false" Sortable="false"
                                  Width="110px" TextAlign="TextAlign.Center" Title="">
                <EditTemplate Context="r">
                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => SaveRow(r))" Style="margin-right: 4px;" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.ExtraSmall"
                                  Click="@(() => CancelRow(r))" />
                </EditTemplate>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    [CascadingParameter] Task<AuthenticationState> AuthState { get; set; } = null!;

    private RadzenDataGrid<CalculationRule>? _grid;
    private IEnumerable<CalculationRule> _items = Array.Empty<CalculationRule>();
    private int _totalCount;
    private Density _density = Density.Default;
    private bool _loading;
    private bool _canManage;
    private System.Security.Claims.ClaimsPrincipal? _user;
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];
    private List<string> _availableVariables = [];

    private bool _initialized;

    private bool Col(string role) => _user?.IsInRole("Admin") == true || _user?.IsInRole(role) == true;

    private DataGridSettings? _gridSettings;
    private const string GridSettingsKey = "calculation-rules-grid-settings";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var state = await AuthState;
            _user = state.User;
            _canManage = state.User.IsInRole("Admin") || state.User.IsInRole("CalculationRulesManage");
            await LoadGridSettingsAsync();
            if (TenantProvider.IsResolved && _grid != null && _gridSettings == null)
                await _grid.Reload();
        }
    }

    private async Task LoadGridSettingsAsync()
    {
        try
        {
            var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", GridSettingsKey);
            if (!string.IsNullOrEmpty(json))
            {
                _gridSettings = System.Text.Json.JsonSerializer.Deserialize<DataGridSettings>(json);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void OnGridSettingsChanged(DataGridSettings settings)
    {
        _gridSettings = settings;
        _ = SaveGridSettingsAsync();
    }

    private async Task SaveGridSettingsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_gridSettings);
            await JsRuntime.InvokeVoidAsync("localStorage.setItem", GridSettingsKey, json);
        }
        catch { }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        _loading = true;
        await EnsureInitializedAsync();

        var skip = args.Skip ?? 0;
        var take = args.Top is > 0 ? args.Top.Value : (_grid?.PageSize ?? 20);

        var (items, total) = await CalculationRuleService.GetPagedAsync(
            args.Filter,
            args.OrderBy,
            skip,
            take);

        _items      = items;
        _totalCount = total;
        _loading    = false;
    }

    /// <summary>
    /// Однократная инициализация переменных (без DbContext).
    /// </summary>
    private async Task EnsureInitializedAsync()
    {
        if (_initialized) return;
        _availableVariables = await CalculationRuleService.GetAvailableVariablesAsync();
        _initialized = true;
    }

    private async Task AddRow()
    {
        await EnsureInitializedAsync();

        var result = await DialogService.OpenAsync<CalculationRuleDialog>(
            "Новое правило расчёта",
            new Dictionary<string, object?> { ["AvailableVariables"] = _availableVariables },
            new DialogOptions { Width = "850px", CloseDialogOnEsc = true, CloseDialogOnOverlayClick = true });

        if (result is bool b && b && _grid != null)
            await _grid.Reload();
    }

    private async Task EditRow(CalculationRule r)  => await _grid!.EditRow(r);
    private async Task SaveRow(CalculationRule r)  => await _grid!.UpdateRow(r);
    private void      CancelRow(CalculationRule r) => _grid!.CancelEditRow(r);

    private async Task OnUpdate(CalculationRule r)
    {
        try
        {
            await CalculationRuleService.UpdateAsync(r);
            NotificationService.Notify(NotificationSeverity.Success, "Правило обновлено");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private async Task OnCreate(CalculationRule r)
    {
        try
        {
            await CalculationRuleService.CreateAsync(r);
            NotificationService.Notify(NotificationSeverity.Success, "Правило создано");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
            await _grid!.Reload();
        }
    }

    private async Task DeleteRow(CalculationRule r)
    {
        var confirmed = await DialogService.Confirm(
            $"Удалить правило «{r.Name}»?",
            "Подтверждение",
            new ConfirmOptions { OkButtonText = "Удалить", CancelButtonText = "Отмена" });

        if (confirmed != true) return;

        try
        {
            await CalculationRuleService.SoftDeleteAsync(r);
            await _grid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Правило удалено");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message);
        }
    }

    private async Task ValidateFormulaAsync(CalculationRule r)
    {
        await EnsureInitializedAsync();
        var error = CalculationEngine.ValidateFormula(r.Formula, _availableVariables);
        if (error == null)
            NotificationService.Notify(NotificationSeverity.Success, "Формула корректна",
                $"Переменные: {string.Join(", ", _availableVariables)}");
        else
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка в формуле", error, duration: 6000);
    }

    private void ShowContextMenu(DataGridCellMouseEventArgs<CalculationRule> args)
    {
        var items = new List<ContextMenuItem>();
        if (_canManage)
        {
            items.Add(new ContextMenuItem { Text = "Редактировать", Icon = "edit",   Value = "edit" });
            items.Add(new ContextMenuItem { Text = "Удалить",       Icon = "delete", Value = "delete" });
        }
        if (items.Count == 0) return;

        ContextMenuService.Open(args, items, e =>
        {
            ContextMenuService.Close();
            if (e.Value?.ToString() == "edit")
                InvokeAsync(() => EditRow(args.Data!));
            else if (e.Value?.ToString() == "delete")
                InvokeAsync(() => DeleteRow(args.Data!));
        });
    }


    private void ToggleDensity() =>
        _density = _density == Density.Compact ? Density.Default : Density.Compact;

    private string GetDensityTitle() => _density switch
    {
        Density.Compact => "Компактный режим строк",
        _ => "Обычный режим строк"
    };
}
