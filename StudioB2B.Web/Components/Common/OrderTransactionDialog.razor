@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Constants
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantDbContextFactory Factory
@inject NotificationService NotificationService
@inject DialogService DialogService

@implements IDisposable

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 200px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Основные параметры</RadzenText>
            <RadzenStack Gap="0.5rem">
                <RadzenFormField Text="Название">
                    <RadzenTextBox @bind-Value="_name" Style="width: 100%;" Placeholder="Закупка подтверждена" />
                </RadzenFormField>
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Исходный статус">
                            <RadzenDropDown Data="@_nonTerminalStatuses"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            @bind-Value="_fromStatusId"
                                            Style="width: 100%;"
                                            Placeholder="Выберите" />
                        </RadzenFormField>
                        <RadzenText TextStyle="TextStyle.Caption"
                                    Style="color:var(--rz-text-disabled-color);font-size:0.7rem;margin-top:2px;display:block;">
                            Конечные статусы недоступны как исходные
                        </RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Целевой статус">
                            <RadzenDropDown Data="@_internalStatuses"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            @bind-Value="_toStatusId"
                                            Style="width: 100%;"
                                            Placeholder="Выберите" />
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenCheckBox @bind-Value="_isEnabled" />
                    <RadzenLabel Text="Активна" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Start" Style="flex-wrap: wrap;">
                    <RadzenFormField Text="Цвет документа" Style="max-width: 200px;">
                        <RadzenColorPicker @bind-Value="_color"
                                          ShowColors="true"
                                          ShowHex="true"
                                          Style="width: 100%;" />
                    </RadzenFormField>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenFormField Text="Иконка" Style="width: 240px;">
                            <RadzenDropDown Data="@_iconOptions"
                                            TextProperty="Label"
                                            ValueProperty="Value"
                                            @bind-Value="_icon"
                                            AllowClear="true"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            FilterOperator="StringFilterOperator.Contains"
                                            Placeholder="Выберите иконку"
                                            Style="width: 100%;">
                                <Template Context="item">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <i class="rzi" style="font-size:1.1rem;">@item.Value</i>
                                        <span>@item.Label</span>
                                    </RadzenStack>
                                </Template>
                                <ValueTemplate Context="item">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <i class="rzi" style="font-size:1.1rem;">@item.Value</i>
                                        <span>@item.Label</span>
                                    </RadzenStack>
                                </ValueTemplate>
                            </RadzenDropDown>
                        </RadzenFormField>
                        @if (!string.IsNullOrEmpty(_icon))
                        {
                            <RadzenIcon Icon="@_icon" Style="font-size: 1.5rem; margin-top: 1.4rem; color: var(--rz-text-color);" />
                        }
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>
        </RadzenStack>

        <RadzenStack Gap="0.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Правила изменения цен</RadzenText>
                <RadzenButton Icon="add" Text="Добавить правило" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@AddRule" Disabled="@(_priceTypes.Count == 0)" />
            </RadzenStack>
            @if (_priceTypes.Count == 0)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
                    Типы цен не найдены. Создайте типы цен на странице <a href="/price-types" target="_blank">Типы цен</a> или дождитесь синхронизации с маркетплейсом.
                </RadzenAlert>
            }
            @if (_rules.Count > 0)
            {
                <RadzenDataGrid TItem="RuleRow" Data="@_rules" DataKey="Id" @key="_rules.Count" Density="Density.Compact"
                               AllowSorting="false" AllowFiltering="false" AllowPaging="false"
                               EmptyText="@RadzenRuStrings.EmptyText">
                    <Columns>
                        <RadzenDataGridColumn TItem="RuleRow" Title="Тип цены" Width="180px">
                            <Template Context="r">
                                <RadzenDropDown Data="@_priceTypes"
                                                TextProperty="Name"
                                                ValueProperty="Id"
                                                @bind-Value="r.PriceTypeId"
                                                Style="width: 100%;"
                                                Placeholder="Выберите" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RuleRow" Title="Источник" Width="160px">
                            <Template Context="r">
                                <RadzenDropDown @bind-Value="r.ValueSource"
                                                Data="@_valueSourceOptions"
                                                TextProperty="Text"
                                                ValueProperty="Value"
                                                Style="width: 100%;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RuleRow" Title="Формула" Width="220px">
                            <Template Context="r">
                                @if (r.ValueSource == TransactionValueSourceEnum.Formula)
                                {
                                    <RadzenTextBox @bind-Value="r.Formula" Style="width: 100%; font-family: monospace;"
                                                   Placeholder="Цена * 0.85 (переменные — типы цен)" />
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-base-500);">Вводится при проведении</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RuleRow" Title="Товар" Width="200px">
                            <Template Context="r">
                                <RadzenDropDown Data="@_products"
                                                TextProperty="Name"
                                                ValueProperty="Id"
                                                @bind-Value="r.ProductId"
                                                Style="width: 100%;"
                                                Placeholder="Все товары"
                                                AllowClear="true" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RuleRow" Title="Обязательное" Width="120px">
                            <Template Context="r">
                                @if (r.ValueSource == TransactionValueSourceEnum.UserInput)
                                {
                                    <RadzenCheckBox @bind-Value="r.IsRequired" />
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">—</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RuleRow" Title="" Width="60px" Filterable="false" Sortable="false">
                            <Template Context="r">
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall"
                                              Variant="Variant.Text"
                                              Click="@(() => RemoveRule(r))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenStack>

        <RadzenStack Gap="0.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Правила изменения полей</RadzenText>
                <RadzenButton Icon="add" Text="Добавить правило поля" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@AddFieldRule" Disabled="@(_fieldDescriptors.Count == 0)" />
            </RadzenStack>
            @if (_fieldRules.Count > 0)
            {
                <RadzenDataGrid TItem="FieldRuleRow" Data="@_fieldRules" DataKey="Id" @key="_fieldRules.Count" Density="Density.Compact"
                               AllowSorting="false" AllowFiltering="false" AllowPaging="false"
                               EmptyText="@RadzenRuStrings.EmptyText">
                    <Columns>
                        <RadzenDataGridColumn TItem="FieldRuleRow" Title="Поле" Width="220px">
                            <Template Context="r">
                                <RadzenDropDown Data="@_fieldDescriptors"
                                                TextProperty="DisplayName"
                                                ValueProperty="EntityPath"
                                                @bind-Value="r.EntityPath"
                                                Style="width: 100%;"
                                                Placeholder="Выберите поле" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="FieldRuleRow" Title="Источник" Width="160px">
                            <Template Context="r">
                                <RadzenDropDown @bind-Value="r.ValueSource"
                                                Data="@_fieldValueSourceOptions"
                                                TextProperty="Text"
                                                ValueProperty="Value"
                                                Style="width: 100%;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="FieldRuleRow" Title="Фиксированное значение" Width="200px">
                            <Template Context="r">
                                @if (r.ValueSource == TransactionFieldValueSourceEnum.Fixed)
                                {
                                    <RadzenTextBox @bind-Value="r.FixedValue" Style="width: 100%;"
                                                   Placeholder="Значение" />
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-base-500);">Вводится при проведении</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="FieldRuleRow" Title="Обязательное" Width="120px">
                            <Template Context="r">
                                @if (r.ValueSource == TransactionFieldValueSourceEnum.UserInput)
                                {
                                    <RadzenCheckBox @bind-Value="r.IsRequired" />
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">—</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="FieldRuleRow" Title="" Width="60px" Filterable="false" Sortable="false">
                            <Template Context="r">
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall"
                                              Variant="Variant.Text"
                                              Click="@(() => RemoveFieldRule(r))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" Style="margin-top: 0.75rem;">
            <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton Text="Сохранить" ButtonStyle="ButtonStyle.Primary" Click="@SaveAsync" />
        </RadzenStack>
    </RadzenStack>
}

@code {
    [Parameter] public Guid? TransactionId { get; set; }

    /// <summary>Pre-filled when opening from the canvas flow editor.</summary>
    [Parameter] public Guid? InitialFromStatusId { get; set; }
    /// <summary>Pre-filled when opening from the canvas flow editor.</summary>
    [Parameter] public Guid? InitialToStatusId { get; set; }

    private TenantDbContext? _db;
    private bool _loading = true;
    private string _name = string.Empty;
    private Guid? _fromStatusId;
    private Guid? _toStatusId;
    private bool _isEnabled = true;
    private string? _color;
    private string? _icon;
    private List<OrderStatus> _internalStatuses = [];
    /// <summary>Internal statuses that are NOT terminal — valid as a transaction source.</summary>
    private List<OrderStatus> _nonTerminalStatuses = [];
    private List<PriceType> _priceTypes = [];
    private List<Product> _products = [];
    private List<RuleRow> _rules = [];
    private List<FieldRuleRow> _fieldRules = [];
    private List<OrderTransactionFieldDescriptorDto> _fieldDescriptors = [];
    private static readonly List<ValueSourceOption> _valueSourceOptions =
    [
        new(TransactionValueSourceEnum.Formula, "Формула"),
        new(TransactionValueSourceEnum.UserInput, "Ввод при проведении")
    ];
    private static readonly List<FieldValueSourceOption> _fieldValueSourceOptions =
    [
        new(TransactionFieldValueSourceEnum.Fixed, "Фиксированное"),
        new(TransactionFieldValueSourceEnum.UserInput, "Ввод при проведении")
    ];

    private record ValueSourceOption(TransactionValueSourceEnum Value, string Text);
    private record FieldValueSourceOption(TransactionFieldValueSourceEnum Value, string Text);
    private record IconOption(string Value, string Label);

    private static readonly List<IconOption> _iconOptions =
    [
        new("task_alt", "Готово"),
        new("check_circle", "Выполнено"),
        new("done_all", "Всё выполнено"),
        new("local_shipping", "Доставка"),
        new("inventory_2", "Инвентарь"),
        new("inventory", "Товары"),
        new("warehouse", "Склад"),
        new("receipt_long", "Документ"),
        new("description", "Описание"),
        new("assignment", "Задание"),
        new("assignment_turned_in", "Задание выполнено"),
        new("fact_check", "Проверка"),
        new("verified", "Подтверждено"),
        new("approval", "Одобрено"),
        new("pending", "В ожидании"),
        new("pending_actions", "Ожидает действий"),
        new("hourglass_empty", "В процессе"),
        new("swap_horiz", "Перемещение"),
        new("swap_vert", "Перемещение"),
        new("published_with_changes", "Изменения"),
        new("sync", "Синхронизация"),
        new("cached", "Обновление"),
        new("loop", "Возврат/цикл"),
        new("undo", "Отменить"),
        new("redo", "Повторить"),
        new("cancel", "Отмена"),
        new("block", "Заблокировано"),
        new("remove_circle", "Удалено"),
        new("shopping_cart", "Корзина"),
        new("shopping_bag", "Заказ"),
        new("store", "Магазин"),
        new("sell", "Продажа"),
        new("price_check", "Цена проверена"),
        new("payments", "Оплата"),
        new("account_balance_wallet", "Кошелёк"),
        new("production_quantity_limits", "Лимит кол-ва"),
        new("package_2", "Упаковка"),
        new("conveyor_belt", "Конвейер"),
        new("forklift", "Погрузчик"),
        new("flight_takeoff", "Отправлено"),
        new("flight_land", "Получено"),
        new("pin_drop", "Точка доставки"),
        new("location_on", "Местоположение"),
        new("support_agent", "Поддержка"),
        new("person", "Клиент"),
        new("business", "Компания"),
        new("edit", "Редактировать"),
        new("note_add", "Добавить заметку"),
        new("flag", "Флаг"),
        new("star", "Важно"),
        new("priority_high", "Высокий приоритет"),
        new("warning", "Предупреждение"),
        new("error", "Ошибка"),
        new("info", "Информация"),
    ];

    private class RuleRow
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public Guid PriceTypeId { get; set; }
        public TransactionValueSourceEnum ValueSource { get; set; }
        public string? Formula { get; set; }
        public Guid? ProductId { get; set; }
        public bool IsRequired { get; set; }
    }

    private class FieldRuleRow
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string EntityPath { get; set; } = string.Empty;
        public TransactionFieldValueSourceEnum ValueSource { get; set; }
        public string? FixedValue { get; set; }
        public bool IsRequired { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _db = Factory.CreateDbContext();

        _internalStatuses = await _db.OrderStatuses
            .Where(s => s.IsInternal && !s.IsDeleted)
            .OrderBy(s => s.Name)
            .AsNoTracking()
            .ToListAsync();

        // Terminal statuses cannot be the source of a transaction
        _nonTerminalStatuses = _internalStatuses.Where(s => !s.IsTerminal).ToList();

        _priceTypes = await _db.PriceTypes
            .Where(p => !p.IsDeleted)
            .OrderBy(p => p.Name)
            .AsNoTracking()
            .ToListAsync();

        _products = await _db.Products
            .Where(p => !p.IsDeleted)
            .OrderBy(p => p.Article)
            .Take(500)
            .AsNoTracking()
            .ToListAsync();

        _fieldDescriptors = OrderTransactionFieldRegistry.All
            .OrderBy(d => d.DisplayName)
            .ToList();

        if (TransactionId.HasValue)
        {
            var t = await _db.OrderTransactions
                .Include(x => x.Rules).ThenInclude(r => r.PriceType)
                .Include(x => x.FieldRules)
                .AsNoTracking()
                .FirstOrDefaultAsync(x => x.Id == TransactionId.Value);
            if (t != null)
            {
                _name = t.Name;
                _fromStatusId = t.FromSystemStatusId;
                _toStatusId = t.ToSystemStatusId;
                _isEnabled = t.IsEnabled;
                _color = t.Color;
                _icon = t.Icon;
                _rules = t.Rules
                    .OrderBy(r => r.SortOrder)
                    .Select(r => new RuleRow
                    {
                        Id = r.Id,
                        PriceTypeId = r.PriceTypeId,
                        ValueSource = r.ValueSource,
                        Formula = r.Formula,
                        ProductId = r.ProductId,
                        IsRequired = r.IsRequired
                    })
                    .ToList();
                _fieldRules = t.FieldRules
                    .OrderBy(r => r.SortOrder)
                    .Select(r => new FieldRuleRow
                    {
                        Id = r.Id,
                        EntityPath = r.EntityPath,
                        ValueSource = r.ValueSource,
                        FixedValue = r.FixedValue,
                        IsRequired = r.IsRequired
                    })
                    .ToList();
            }
        }
        else if (_priceTypes.Count > 0)
        {
            // Pre-fill statuses when opened from the canvas flow editor
            if (InitialFromStatusId.HasValue) _fromStatusId = InitialFromStatusId;
            if (InitialToStatusId.HasValue) _toStatusId = InitialToStatusId;
            AddRule();
        }
        else
        {
            // No price types — still pre-fill statuses from canvas
            if (InitialFromStatusId.HasValue) _fromStatusId = InitialFromStatusId;
            if (InitialToStatusId.HasValue) _toStatusId = InitialToStatusId;
        }

        _loading = false;
    }

    private void AddRule()
    {
        if (_priceTypes.Count == 0) return;
        _rules = [.._rules, new RuleRow
        {
            PriceTypeId = _priceTypes[0].Id,
            ValueSource = TransactionValueSourceEnum.UserInput,
            IsRequired = false
        }];
        StateHasChanged();
    }

    private void RemoveRule(RuleRow r)
    {
        _rules = _rules.Where(x => x.Id != r.Id).ToList();
        StateHasChanged();
    }

    private void AddFieldRule()
    {
        if (_fieldDescriptors.Count == 0) return;
        _fieldRules = [.._fieldRules, new FieldRuleRow
        {
            EntityPath = _fieldDescriptors[0].EntityPath,
            ValueSource = TransactionFieldValueSourceEnum.UserInput,
            IsRequired = false
        }];
        StateHasChanged();
    }

    private void RemoveFieldRule(FieldRuleRow r)
    {
        _fieldRules = _fieldRules.Where(x => x.Id != r.Id).ToList();
        StateHasChanged();
    }

    private static string? ToHex(string? color)
    {
        if (string.IsNullOrWhiteSpace(color)) return null;
        color = color.Trim();
        if (color.StartsWith("#"))
        {
            var hex = color.TrimStart('#');
            if (hex.Length == 6 && hex.All(c => "0123456789abcdefABCDEF".Contains(c)))
                return "#" + hex.ToUpperInvariant();
            if (hex.Length == 3 && hex.All(c => "0123456789abcdefABCDEF".Contains(c)))
                return "#" + string.Concat(hex.Select(c => $"{c}{c}")).ToUpperInvariant();
            return null;
        }
        var rgba = System.Text.RegularExpressions.Regex.Match(
            color, @"rgba?\s*\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)(?:\s*,\s*[\d.]+)?\s*\)");
        if (rgba.Success)
        {
            var r = int.Parse(rgba.Groups[1].Value);
            var g = int.Parse(rgba.Groups[2].Value);
            var b = int.Parse(rgba.Groups[3].Value);
            return $"#{r:X2}{g:X2}{b:X2}";
        }
        return null;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Укажите название документа.");
            return;
        }
        if (!_fromStatusId.HasValue || !_toStatusId.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Укажите исходный и целевой статусы.");
            return;
        }

        // Terminal status cannot be a transaction source
        var fromStatus = _internalStatuses.FirstOrDefault(s => s.Id == _fromStatusId.Value);
        if (fromStatus?.IsTerminal == true)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Запрещено",
                $"Статус «{fromStatus.Name}» является конечным. Исходящие транзакции из конечного статуса недопустимы.");
            return;
        }
        if (_rules.Count == 0 && _fieldRules.Count == 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Ошибка", "Добавьте хотя бы одно правило (цен или полей).");
            return;
        }

        try
        {
            if (TransactionId.HasValue)
            {
                var t = await _db!.OrderTransactions
                    .Include(x => x.Rules)
                    .Include(x => x.FieldRules)
                    .FirstOrDefaultAsync(x => x.Id == TransactionId.Value);
                if (t != null)
                {
                    t.Name = _name.Trim();
                    t.FromSystemStatusId = _fromStatusId.Value;
                    t.ToSystemStatusId = _toStatusId.Value;
                    t.IsEnabled = _isEnabled;
                    t.Color = ToHex(_color) ?? _color;
                    t.Icon = string.IsNullOrWhiteSpace(_icon) ? null : _icon.Trim();
                    _db.OrderTransactionRules.RemoveRange(t.Rules);
                    _db.OrderTransactionFieldRules.RemoveRange(t.FieldRules);
                    var sortOrder = 0;
                    foreach (var r in _rules)
                    {
                        _db.OrderTransactionRules.Add(new OrderTransactionRule
                        {
                            Id = Guid.NewGuid(),
                            OrderTransactionId = t.Id,
                            PriceTypeId = r.PriceTypeId,
                            ValueSource = r.ValueSource,
                            Formula = r.ValueSource == TransactionValueSourceEnum.Formula ? r.Formula : null,
                            ProductId = r.ProductId,
                            SortOrder = sortOrder++,
                            IsRequired = r.IsRequired
                        });
                    }
                    sortOrder = 0;
                    foreach (var fr in _fieldRules)
                    {
                        if (string.IsNullOrWhiteSpace(fr.EntityPath)) continue;
                        _db.OrderTransactionFieldRules.Add(new OrderTransactionFieldRule
                        {
                            Id = Guid.NewGuid(),
                            OrderTransactionId = t.Id,
                            EntityPath = fr.EntityPath,
                            ValueSource = fr.ValueSource,
                            FixedValue = fr.ValueSource == TransactionFieldValueSourceEnum.Fixed ? fr.FixedValue : null,
                            SortOrder = sortOrder++,
                            IsRequired = fr.IsRequired
                        });
                    }
                    await _db.SaveChangesAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Документ обновлён");
                }
            }
            else
            {
                var t = new OrderTransaction
                {
                    Id = Guid.NewGuid(),
                    Name = _name.Trim(),
                    FromSystemStatusId = _fromStatusId.Value,
                    ToSystemStatusId = _toStatusId.Value,
                    IsEnabled = _isEnabled,
                    Color = ToHex(_color) ?? _color,
                    Icon = string.IsNullOrWhiteSpace(_icon) ? null : _icon.Trim(),
                    SortOrder = 0
                };
                _db!.OrderTransactions.Add(t);
                await _db.SaveChangesAsync();
                var sortOrder = 0;
                foreach (var r in _rules)
                {
                    _db.OrderTransactionRules.Add(new OrderTransactionRule
                    {
                        Id = Guid.NewGuid(),
                        OrderTransactionId = t.Id,
                        PriceTypeId = r.PriceTypeId,
                        ValueSource = r.ValueSource,
                        Formula = r.ValueSource == TransactionValueSourceEnum.Formula ? r.Formula : null,
                        ProductId = r.ProductId,
                        SortOrder = sortOrder++,
                        IsRequired = r.IsRequired
                    });
                }
                await _db.SaveChangesAsync();
                sortOrder = 0;
                foreach (var fr in _fieldRules)
                {
                    if (string.IsNullOrWhiteSpace(fr.EntityPath)) continue;
                    _db.OrderTransactionFieldRules.Add(new OrderTransactionFieldRule
                    {
                        Id = Guid.NewGuid(),
                        OrderTransactionId = t.Id,
                        EntityPath = fr.EntityPath,
                        ValueSource = fr.ValueSource,
                        FixedValue = fr.ValueSource == TransactionFieldValueSourceEnum.Fixed ? fr.FixedValue : null,
                        SortOrder = sortOrder++,
                        IsRequired = fr.IsRequired
                    });
                }
                await _db.SaveChangesAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Документ создан");
            }
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка сохранения", ex.Message);
        }
    }

    public void Dispose() => _db?.Dispose();
}
