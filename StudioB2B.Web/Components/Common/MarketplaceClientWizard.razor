@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces

@inject IMarketplaceClientService MarketplaceClientService
@inject IOzonApiClient OzonApiClient
@inject IKeyEncryptionService Encryption
@inject NotificationService NotificationService
@inject DialogService DialogService

<link rel="stylesheet" href="css/orders.css" />

<div style="padding: 0.5rem 0;">
    <RadzenTimeline>
        <Items>
            <RadzenTimelineItem PointStyle="@StepStyle(0)" PointSize="PointSize.Medium">
                <LabelContent>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                Style="@StepLabelStyle(0)">Тип клиента</RadzenText>
                </LabelContent>
                <ChildContent>
                    <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(0)">
                        Выберите тип подключаемого маркетплейса. Сейчас поддерживается Ozon.
                    </RadzenText>
                </ChildContent>
            </RadzenTimelineItem>

            <RadzenTimelineItem PointStyle="@StepStyle(1)" PointSize="PointSize.Medium">
                <LabelContent>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                Style="@StepLabelStyle(1)">Режим работы</RadzenText>
                </LabelContent>
                <ChildContent>
                    <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(1)">
                        Укажите режим клиента — боевой, тестовый или иной.
                    </RadzenText>
                </ChildContent>
            </RadzenTimelineItem>

            <RadzenTimelineItem PointStyle="@StepStyle(2)" PointSize="PointSize.Medium">
                <LabelContent>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                Style="@StepLabelStyle(2)">Доступ к API</RadzenText>
                </LabelContent>
                <ChildContent>
                    <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(2)">
                        Введите API&nbsp;ID&nbsp;(Client-Id) и API‑ключ. Данные будут зашифрованы.
                    </RadzenText>
                </ChildContent>
            </RadzenTimelineItem>

            <RadzenTimelineItem PointStyle="@StepStyle(3)" PointSize="PointSize.Medium">
                <LabelContent>
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0"
                                Style="@StepLabelStyle(3)">Подтверждение</RadzenText>
                </LabelContent>
                <ChildContent>
                    <RadzenText TextStyle="TextStyle.Body2" Style="@StepDescStyle(3)">
                        Проверьте данные кабинета продавца и подтвердите создание клиента.
                    </RadzenText>
                </ChildContent>
            </RadzenTimelineItem>
        </Items>
    </RadzenTimeline>
</div>

<hr style="margin: 0.5rem 0; border-color: var(--rz-border-color);" />

@if (_step == 0)
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenFormField Text="Тип клиента" Style="width:100%;">
            <RadzenDropDown Data="@_ozonTypes.DefaultIfEmpty()"
                            TextProperty="@nameof(MarketplaceClientType.Name)"
                            ValueProperty="@nameof(MarketplaceClientType.Id)"
                            @bind-Value="_model.ClientTypeId"
                            Style="width:100%;" />
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Далее"
                          ButtonStyle="ButtonStyle.Primary"
                          Disabled="@(!_model.ClientTypeId.HasValue)"
                          Click="@(() => _step = 1)" />
            <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                          Click="@Cancel" />
        </RadzenStack>
    </RadzenStack>
}
else if (_step == 1)
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenFormField Text="Режим клиента (Ozon)" Style="width:100%;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem"
                         Style="flex-wrap:nowrap;">
                @{
                    var fbsActive = _fbsModeId.HasValue && _model.ModeIds.Contains(_fbsModeId.Value);
                    var fboActive = _fboModeId.HasValue && _model.ModeIds.Contains(_fboModeId.Value);
                    var expressExists = _expressModeId.HasValue;
                }

                <span style="display:inline-flex;align-items:center;gap:8px;">
                    @if (expressExists)
                    {
                        <span class="q-pill" style="background:var(--rz-base-200);color:var(--rz-text-color);opacity:0.55;cursor:not-allowed;pointer-events:none;">
                            Express
                        </span>
                    }

                    @if (_fboModeId.HasValue)
                    {
                        <span @onclick="@( () => ToggleMode(_fboModeId.Value, !fboActive) )"
                              class="q-pill scheme-fbo @(fboActive ? "active" : "")"
                              style="white-space:nowrap;">
                            FBO
                        </span>
                    }

                    @if (_fbsModeId.HasValue)
                    {
                        <span @onclick="@( () => ToggleMode(_fbsModeId.Value, !fbsActive) )"
                              class="q-pill scheme-fbs @(fbsActive ? "active" : "")"
                              style="white-space:nowrap;">
                            FBS
                        </span>
                    }
                </span>
            </RadzenStack>

            <RadzenText TextStyle="TextStyle.Caption" Style="display:block;margin-top:0.35rem;color:var(--rz-text-secondary-color);">
                Для Ozon синк поддерживает одновременно FBS и FBO.
            </RadzenText>
        </RadzenFormField>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Назад" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => _step = 0)" />
            <RadzenButton Text="Далее"
                          ButtonStyle="ButtonStyle.Primary"
                          Disabled="@(_model.ModeIds.Count == 0)"
                          Click="@(() => _step = 2)" />
        </RadzenStack>
    </RadzenStack>
}
else if (_step == 2)
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">
            Введите API&nbsp;ID и API‑ключ Ozon. Ключ будет сохранён в зашифрованном виде.
        </RadzenAlert>

        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="API ID (Client-Id)" Style="width:100%;">
                    <RadzenTextBox @bind-Value="_model.ApiId" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="API ключ (Api-Key)" Style="width:100%;">
                    <RadzenPassword @bind-Value="_model.Key" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Назад" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => _step = 1)" />
            <RadzenButton Text="Загрузить данные из Ozon"
                          ButtonStyle="ButtonStyle.Primary"
                          Icon="cloud_download"
                          IsBusy="@_busy"
                          Click="@LoadFromOzonAsync" />
        </RadzenStack>
    </RadzenStack>
}
else if (_step == 3)
{
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        @if (_sellerInfo?.Company is not null)
        {
            var c = _sellerInfo.Company;
            <div class="rz-p-4 rz-border-radius-1" style="border: 1px solid var(--rz-border-color);">
                <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 0.5rem;">
                    @(c.Name ?? c.LegalName)
                </RadzenText>
                <RadzenRow Gap="0.5rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.Body2"><b>Юр. лицо:</b> @c.LegalName</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2"><b>ИНН:</b> @c.Inn</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2"><b>ОГРН:</b> @c.Ogrn</RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenText TextStyle="TextStyle.Body2"><b>Страна:</b> @c.Country</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2"><b>Валюта:</b> @c.Currency</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2"><b>Форма собственности:</b> @c.OwnershipForm</RadzenText>
                    </RadzenColumn>
                </RadzenRow>
            </div>
        }

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Назад" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => _step = 2)" />
            <RadzenButton Text="Создать клиента"
                          ButtonStyle="ButtonStyle.Primary"
                          Icon="check"
                          IsBusy="@_busy"
                          Click="@CreateClientAsync" />
            <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                          Click="@Cancel" />
        </RadzenStack>
    </RadzenStack>
}

@code {
    private List<MarketplaceClientType> _types = [];
    private List<MarketplaceClientType> _ozonTypes = [];
    private List<MarketplaceClientMode> _modes = [];
    private Guid? _fbsModeId;
    private Guid? _fboModeId;
    private Guid? _expressModeId;

    private int _step;
    private bool _busy;
    private NewClientModelDto _model = new();
    private OzonSellerInfoResponseDto? _sellerInfo;

    protected override async Task OnInitializedAsync()
    {
        var data = await MarketplaceClientService.GetInitDataAsync();

        _types = data.Types;
        _ozonTypes = _types
            .Where(t => t.Name.Equals("Ozon", StringComparison.OrdinalIgnoreCase) ||
                        t.Name.Equals("OZON", StringComparison.OrdinalIgnoreCase))
            .ToList();

        _modes        = data.Modes;
        _fbsModeId    = _modes.FirstOrDefault(m => m.Name.Equals("FBS",     StringComparison.OrdinalIgnoreCase))?.Id;
        _fboModeId    = _modes.FirstOrDefault(m => m.Name.Equals("FBO",     StringComparison.OrdinalIgnoreCase))?.Id;
        _expressModeId = _modes.FirstOrDefault(m => m.Name.Equals("Express", StringComparison.OrdinalIgnoreCase))?.Id;

        var modeIds = new List<Guid>(capacity: 2);
        if (_fbsModeId is not null) modeIds.Add(_fbsModeId.Value);
        if (_fboModeId is not null) modeIds.Add(_fboModeId.Value);
        if (modeIds.Count == 0 && _modes.Count > 0) modeIds.Add(_modes[0].Id);

        _model.ModeIds      = modeIds;
        _model.ClientTypeId = _ozonTypes.Count > 0 ? _ozonTypes[0].Id : _types.FirstOrDefault()?.Id;
    }

    private PointStyle StepStyle(int step) => step switch
    {
        _ when step < _step  => PointStyle.Success,
        _ when step == _step => PointStyle.Primary,
        _                    => PointStyle.Secondary
    };

    private string StepLabelStyle(int step) => step == _step
        ? "color: var(--rz-primary); font-weight: 700;"
        : step < _step
            ? "color: var(--rz-success);"
            : "color: var(--rz-text-disabled-color);";

    private string StepDescStyle(int step) => step <= _step
        ? string.Empty
        : "color: var(--rz-text-disabled-color);";

    private void Cancel() => DialogService.Close(false);

    private void OnModeChanged(Guid modeId, bool isChecked)
    {
        if (isChecked)
        {
            if (_model.ModeIds.Contains(modeId)) return;
            if (_model.ModeIds.Count >= 2)
            {
                NotificationService.Notify(NotificationSeverity.Warning,
                    "Ограничение", "В текущей версии можно выбрать максимум 2 режима на клиента.");
                return;
            }
            _model.ModeIds.Add(modeId);
        }
        else
        {
            _model.ModeIds.Remove(modeId);
        }
    }

    private void ToggleMode(Guid modeId, bool shouldSelect) => OnModeChanged(modeId, shouldSelect);

    private async Task LoadFromOzonAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.ApiId) || string.IsNullOrWhiteSpace(_model.Key))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Заполните поля", "Укажите API ID и API ключ.");
            return;
        }

        _busy = true;
        try
        {
            var result = await OzonApiClient.GetSellerInfoAsync(_model.ApiId, _model.Key);
            if (!result.IsSuccess || result.Data is null)
            {
                NotificationService.Notify(NotificationSeverity.Error,
                    "Ошибка Ozon API", result.ErrorMessage ?? "Не удалось получить данные кабинета продавца.");
                return;
            }

            _sellerInfo = result.Data;
            _step = 3;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка при обращении к Ozon", ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CreateClientAsync()
    {
        if (_sellerInfo?.Company is null)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Нет данных", "Данные компании не загружены.");
            return;
        }

        if (_model.ClientTypeId is null || _model.ModeIds.Count == 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Не заполнены параметры", "Выберите тип клиента и хотя бы один режим.");
            return;
        }

        _busy = true;
        try
        {
            if (await MarketplaceClientService.ExistsByApiIdAsync(_model.ApiId))
            {
                NotificationService.Notify(NotificationSeverity.Warning,
                    "Клиент уже существует", "Клиент с таким API ID уже добавлен.");
                return;
            }

            var c = _sellerInfo.Company;
            var request = new CreateMarketplaceClientDto(
                Name:          c.Name ?? c.LegalName ?? "Ozon клиент",
                ApiId:         _model.ApiId,
                Key:           Encryption.Encrypt(_model.Key),
                ClientTypeId:  _model.ClientTypeId,
                ModeIds:       _model.ModeIds,
                Settings:      null,
                Settings1C:    null,
                Company:       c.LegalName ?? c.Name,
                Country:       c.Country,
                Currency:      c.Currency,
                INN:           c.Inn,
                LegalName:     c.LegalName,
                OzonName:      c.Name,
                OGRN:          c.Ogrn,
                OwnershipForm: c.OwnershipForm
            );

            await MarketplaceClientService.CreateAsync(request);

            NotificationService.Notify(NotificationSeverity.Success,
                "Клиент создан",
                $"Ozon · {c.Name ?? c.LegalName ?? _model.ApiId} успешно добавлен.");

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка при сохранении", ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }
}
