@using StudioB2B.Infrastructure.Interfaces
@inject IUserService UserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<EditForm Model="@_model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <RadzenStack Gap="1rem" Style="padding: 0.25rem 0;">

        @if (_error != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                @_error
            </RadzenAlert>
        }

        <RadzenFormField Text="Новый пароль" Style="width: 100%;">
            <ChildContent>
                <RadzenPassword @bind-Value="_model.NewPassword" Name="NewPassword" Style="width: 100%;" />
            </ChildContent>
            <Helper>
                <RadzenText TextStyle="TextStyle.Caption">Минимум 6 символов.</RadzenText>
            </Helper>
        </RadzenFormField>

        <RadzenFormField Text="Подтверждение пароля" Style="width: 100%;">
            <ChildContent>
                <RadzenPassword @bind-Value="_model.ConfirmPassword" Name="ConfirmPassword" Style="width: 100%;" />
            </ChildContent>
        </RadzenFormField>

        <ValidationSummary style="color: var(--rz-danger); font-size: 0.875rem;" />

        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End"
                     Style="margin-top: 0.5rem; border-top: 1px solid var(--rz-border-color); padding-top: 1rem;">
            <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                          Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Сохранить"
                          ButtonStyle="ButtonStyle.Primary" Icon="lock_reset"
                          IsBusy="@_saving" />
        </RadzenStack>

    </RadzenStack>
</EditForm>

@code {
    [Parameter] public Guid UserId { get; set; }

    private ChangePasswordFormModel _model = new();
    private bool _saving;
    private string? _error;

    private async Task HandleSubmit(EditContext context)
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Пароли не совпадают";
            return;
        }

        _error = null;
        _saving = true;
        try
        {
            var (ok, error) = await UserService.ChangePasswordAsync(
                new ChangeUserPasswordDto(UserId, _model.NewPassword),
                CancellationToken.None);

            if (ok)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Пароль изменён");
                DialogService.Close(true);
            }
            else
            {
                _error = error ?? "Ошибка смены пароля";
            }
        }
        finally { _saving = false; }
    }

    private class ChangePasswordFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введите пароль")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Минимум 6 символов")]
        public string NewPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Подтвердите пароль")]
        public string ConfirmPassword { get; set; } = "";
    }
}

