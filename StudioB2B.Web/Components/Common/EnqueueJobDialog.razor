@using StudioB2B.Domain.Entities.Orders
@using StudioB2B.Infrastructure.Interfaces

<RadzenStack Gap="1.5rem">

    <!-- Выбор типа задачи -->
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Тип задачи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem">
            <RadzenCard Style="@CardStyle(SyncJobType.Sync)" class="rz-cursor-pointer" @onclick="@(() => SelectType(SyncJobType.Sync))">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width: 160px; padding: 0.5rem 0.25rem;">
                    <RadzenIcon Icon="cloud_sync" Style="font-size: 2rem; color: var(--rz-primary);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Загрузка заказов</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); text-align: center;">
                        Синхронизация заказов Ozon FBS за выбранный период
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard Style="@CardStyle(SyncJobType.Update)" class="rz-cursor-pointer" @onclick="@(() => SelectType(SyncJobType.Update))">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width: 160px; padding: 0.5rem 0.25rem;">
                    <RadzenIcon Icon="sync" Style="font-size: 2rem; color: var(--rz-secondary);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Обновление статусов</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); text-align: center;">
                        Актуализация статусов активных отправлений
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard Style="@CardStyle(SyncJobType.Returns)" class="rz-cursor-pointer" @onclick="@(() => SelectType(SyncJobType.Returns))">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width: 160px; padding: 0.5rem 0.25rem;">
                    <RadzenIcon Icon="assignment_return" Style="font-size: 2rem; color: var(--rz-info);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Загрузка возвратов</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); text-align: center;">
                        Синхронизация возвратов Ozon за выбранный период
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>
    </RadzenStack>

    <!-- Параметры (только для Sync / Returns) -->
    @if (_selectedType == SyncJobType.Sync || _selectedType == SyncJobType.Returns)
    {
        <RadzenStack Gap="0.75rem">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Параметры</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Start" Wrap="FlexWrap.Wrap">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.Caption">Дата начала периода</RadzenText>
                    <RadzenDatePicker @bind-Value="_from" DateFormat="dd.MM.yyyy" ShowTime="false" Style="width: 160px;" />
                </RadzenStack>
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.Caption">Дата окончания периода</RadzenText>
                    <RadzenDatePicker @bind-Value="_to" DateFormat="dd.MM.yyyy" ShowTime="false" Style="width: 160px;" />
                </RadzenStack>
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                Максимальная длина периода — 30 дней.
            </RadzenText>
        </RadzenStack>
    }
    else if (_selectedType == SyncJobType.Update)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false" Style="margin: 0;">
            Задача не требует дополнительных параметров. Будут обновлены все активные отправления.
        </RadzenAlert>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin: 0;">
            @_errorMessage
        </RadzenAlert>
    }

    <!-- Кнопки -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
        <RadzenButton Text="Запустить" Icon="play_arrow"
                      ButtonStyle="ButtonStyle.Primary"
                      IsBusy="@_isBusy"
                      Disabled="@(_isBusy || _selectedType is null)"
                      Click="@SubmitAsync" />
    </RadzenStack>

</RadzenStack>

@code {
    [Parameter] public IOrderSyncJobService JobService      { get; set; } = null!;
    [Parameter] public DialogService        DialogService   { get; set; } = null!;
    [Parameter] public NotificationService  NotificationService { get; set; } = null!;

    private SyncJobType? _selectedType = SyncJobType.Sync;
    private DateTime?    _from = DateTime.Today.AddDays(-7);
    private DateTime?    _to   = DateTime.Today;
    private bool         _isBusy;
    private string?      _errorMessage;

    private void SelectType(SyncJobType t)
    {
        _selectedType = t;
        _errorMessage = null;
    }

    private string CardStyle(SyncJobType t)
    {
        var selected = _selectedType == t;
        return selected
            ? "border: 2px solid var(--rz-primary); background: var(--rz-primary-lighter); cursor: pointer;"
            : "border: 2px solid transparent; cursor: pointer;";
    }

    private async Task SubmitAsync()
    {
        _errorMessage = null;

        if (_selectedType == SyncJobType.Sync)
        {
            if (!_from.HasValue || !_to.HasValue)
            {
                _errorMessage = "Выберите даты начала и окончания периода.";
                return;
            }

            var from = _from.Value.Date;
            var to   = _to.Value.Date.AddDays(1).AddTicks(-1);

            if (from > to)
            {
                _errorMessage = "Дата начала не может быть позже даты окончания.";
                return;
            }

            if ((to - from).TotalDays > 30)
            {
                _errorMessage = "Максимальная длина периода — 30 дней.";
                return;
            }

            _isBusy = true;
            try
            {
                await JobService.EnqueueSyncAsync(from, to);
                DialogService.Close(true);
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
            }
            finally
            {
                _isBusy = false;
            }
        }
        else if (_selectedType == SyncJobType.Update)
        {
            _isBusy = true;
            try
            {
                await JobService.EnqueueUpdateAsync();
                DialogService.Close(true);
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
            }
            finally
            {
                _isBusy = false;
            }
        }
        else if (_selectedType == SyncJobType.Returns)
        {
            if (!_from.HasValue || !_to.HasValue)
            {
                _errorMessage = "Выберите даты начала и окончания периода.";
                return;
            }

            var from = _from.Value.Date;
            var to   = _to.Value.Date.AddDays(1).AddTicks(-1);

            if (from > to)
            {
                _errorMessage = "Дата начала не может быть позже даты окончания.";
                return;
            }

            if ((to - from).TotalDays > 30)
            {
                _errorMessage = "Максимальная длина периода — 30 дней.";
                return;
            }

            _isBusy = true;
            try
            {
                await JobService.EnqueueReturnsSyncAsync(from, to);
                DialogService.Close(true);
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
            }
            finally
            {
                _isBusy = false;
            }
        }
    }
}

