@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Domain.Constants
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore

@inject ICommunicationTaskService TaskService
@inject ICommunicationTaskSyncService SyncService
@inject IOzonChatService ChatService
@inject IOzonQuestionsService QuestionsService
@inject IOzonReviewsService ReviewsService
@inject IMarketplaceClientService MarketplaceClientService
@inject ITenantProvider TenantProvider
@inject ICurrentUserProvider CurrentUser
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject TaskBoardStateService BoardState
@inject UserContext UserContext

@implements IAsyncDisposable

<link rel="stylesheet" href="css/taskboard.css" />
<link rel="stylesheet" href="css/questions.css" />
<link rel="stylesheet" href="css/chats/chatMessages.css" />
<link rel="stylesheet" href="css/chats/chatComposer.css" />
<script src="js/taskboard.js"></script>

<div class="taskboard-root" @onclick="@(() => { _clientDropdownOpen = false; _dateDropdownOpen = false; })">


    <div class="taskboard-filters">
        <div class="taskboard-filters-row">
            @{ var allActive = _filterType is null; }
            <span class="q-pill type-all @(allActive ? "active" : "")"
                  style="background:@(allActive ? "var(--rz-primary)" : "var(--rz-base-200)"); color:@(allActive ? "#fff" : "var(--rz-text-color)");"
                  @onclick="@(() => SetFilter(null))">
                Все
                <span class="q-pill-count">@(_board.NewTasks.Count + _board.InProgressTasks.Count + _board.DoneTotalCount)</span>
            </span>
            <span class="q-pill type-chat @(_filterType == CommunicationTaskType.Chat ? "active" : "")"
                  @onclick="@(() => SetFilter(CommunicationTaskType.Chat))">
                Чаты
                <span class="q-pill-count">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Chat))</span>
            </span>
            <span class="q-pill type-question @(_filterType == CommunicationTaskType.Question ? "active" : "")"
                  @onclick="@(() => SetFilter(CommunicationTaskType.Question))">
                Вопросы
                <span class="q-pill-count">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Question))</span>
            </span>
            <span class="q-pill type-review @(_filterType == CommunicationTaskType.Review ? "active" : "")"
                  @onclick="@(() => SetFilter(CommunicationTaskType.Review))">
                Отзывы
                <span class="q-pill-count">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Review))</span>
            </span>

            <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 4px;"></span>

            <div style="position:relative;" @onclick:stopPropagation="true">
                @{ var dateActive = _filterFrom.HasValue || _filterTo.HasValue; }
                <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px 3px 8px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;white-space:nowrap;
                             background:@(dateActive ? "var(--rz-primary)" : "var(--rz-base-200)");
                             color:@(dateActive ? "#fff" : "var(--rz-text-color)");
                             border:2px solid @(dateActive ? "var(--rz-primary)" : "transparent");"
                      @onclick="@(() => _dateDropdownOpen = !_dateDropdownOpen)">
                    <span class="rzi" style="font-size:1.1rem;line-height:1;">date_range</span>
                    @if (dateActive)
                    {
                        <span>@(_filterFrom.HasValue ? _filterFrom.Value.ToString("dd.MM") : "...") — @(_filterTo.HasValue ? _filterTo.Value.ToString("dd.MM") : "...")</span>
                    }
                    <span class="rzi" style="font-size:1rem;line-height:1;">@(_dateDropdownOpen ? "expand_less" : "expand_more")</span>
                </span>
                @if (_dateDropdownOpen)
                {
                    <div style="position:absolute;top:calc(100% + 4px);left:0;z-index:500;
                                background:var(--rz-base-background-color);border:1px solid var(--rz-base-300);
                                border-radius:12px;box-shadow:0 4px 16px rgba(0,0,0,0.14);
                                padding:12px;display:flex;flex-direction:column;gap:0.6rem;min-width:220px;"
                         @onclick:stopPropagation="true">
                        <div style="display:flex;flex-direction:column;gap:4px;">
                            <span style="font-size:0.75rem;font-weight:600;color:var(--rz-text-secondary-color);">С</span>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_filterFrom"
                                              DateFormat="dd.MM.yyyy" ShowCalendarWeek="false"
                                              Placeholder="дд.мм.гггг" Style="width:100%;" />
                        </div>
                        <div style="display:flex;flex-direction:column;gap:4px;">
                            <span style="font-size:0.75rem;font-weight:600;color:var(--rz-text-secondary-color);">По</span>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_filterTo"
                                              DateFormat="dd.MM.yyyy" ShowCalendarWeek="false"
                                              Placeholder="дд.мм.гггг" Style="width:100%;" />
                        </div>
                        <div style="display:flex;gap:0.4rem;">
                            <RadzenButton Text="Применить" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Style="flex:1;"
                                          Click="@(async () => { _dateDropdownOpen = false; await LoadBoardAsync(); })" />
                            @if (dateActive)
                            {
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                              title="Сбросить"
                                              Click="@(async () => { _filterFrom = null; _filterTo = null; _dateDropdownOpen = false; await LoadBoardAsync(); })" />
                            }
                        </div>
                    </div>
                }
            </div>

            <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 4px;"></span>

            <div style="position:relative;" @onclick:stopPropagation="true">
                <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px 3px 12px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;white-space:nowrap;
                             background:@(_filterClientId != null ? "var(--rz-primary)" : "var(--rz-base-200)");
                             color:@(_filterClientId != null ? "#fff" : "var(--rz-text-color)");
                             border:2px solid @(_filterClientId != null ? "var(--rz-primary)" : "transparent");"
                      @onclick="@(() => _clientDropdownOpen = !_clientDropdownOpen)">
                    @(_clientOptions.FirstOrDefault(c => c.Id == _filterClientId)?.Name ?? "Все кабинеты")
                    <span class="rzi" style="font-size:1rem;line-height:1;">@(_clientDropdownOpen ? "expand_less" : "expand_more")</span>
                </span>
                @if (_clientDropdownOpen)
                {
                    <div style="position:absolute;top:calc(100% + 4px);left:0;z-index:500;
                                background:var(--rz-base-background-color);border:1px solid var(--rz-base-300);
                                border-radius:12px;box-shadow:0 4px 16px rgba(0,0,0,0.14);
                                display:flex;flex-direction:column;gap:0.25rem;
                                padding:6px;min-width:160px;max-height:370px;overflow-y:auto;"
                         @onclick:stopPropagation="true">
                        <span style="display:inline-flex;align-items:center;padding:4px 12px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;white-space:nowrap;
                                     background:@(_filterClientId == null ? "var(--rz-primary)" : "var(--rz-base-200)");
                                     color:@(_filterClientId == null ? "#fff" : "var(--rz-text-color)");"
                              @onclick="@(async () => { _clientDropdownOpen = false; await SetClientFilter(null); })">Все</span>
                        @foreach (var c in _clientOptions)
                        {
                            var cCopy = c;
                            <span style="display:inline-flex;align-items:center;padding:4px 12px;border-radius:20px;cursor:pointer;font-size:0.82rem;font-weight:500;white-space:nowrap;
                                         background:@(_filterClientId == cCopy.Id ? "var(--rz-primary)" : "var(--rz-base-200)");
                                         color:@(_filterClientId == cCopy.Id ? "#fff" : "var(--rz-text-color)");"
                                  @onclick="@(async () => { _clientDropdownOpen = false; await SetClientFilter(cCopy.Id); })">@cCopy.Name</span>
                        }
                    </div>
                }
            </div>

            <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 4px;"></span>

            <RadzenButton Icon="cloud_sync" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.ExtraSmall" Click="@FullSyncAndReloadAsync"
                          IsBusy="@_syncing" title="Полная синхронизация" />
            <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Light"
                          Size="ButtonSize.ExtraSmall" Click="@QuickSyncAndReloadAsync" IsBusy="@_loading"
                          title="Обновить" />
            <span style="display:inline-block;width:1px;height:18px;background:var(--rz-base-300);margin:0 4px;"></span>
            <RadzenButton Icon="bar_chart" ButtonStyle="ButtonStyle.Secondary" Shade="Shade.Light"
                          Size="ButtonSize.ExtraSmall" Click="@(() => Navigation.NavigateTo("/task-board-report"))"
                          title="Отчёт по оплате" />
            <RadzenButton Icon="settings" ButtonStyle="ButtonStyle.Secondary" Shade="Shade.Light"
                          Size="ButtonSize.ExtraSmall" Click="@(() => Navigation.NavigateTo("/task-board-settings"))"
                          title="Настройки тарифов" />
        </div>
    </div>

    <div class="taskboard-columns">

        @if (_loading || _syncing)
        {
            @for (var col = 0; col < 3; col++)
            {
                <div class="taskboard-column">
                    <div class="taskboard-column-header" style="opacity:0.5;">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line short"></div>
                    </div>
                    <div class="taskboard-column-body">
                        @for (var i = 0; i < 4; i++)
                        {
                            <div class="skeleton-card">
                                <div style="display:flex;gap:0.5rem;align-items:center;">
                                    <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                    <div class="skeleton-line title"></div>
                                </div>
                                <div class="skeleton-line long"></div>
                                <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                    <div class="skeleton-line short"></div>
                                    <div class="skeleton-line short" style="width:30%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {

        <!-- NEW -->
        <div class="taskboard-column col-new">
            <div class="taskboard-column-header">
                <span>Новые</span>
                <span class="taskboard-column-count">@FilteredNew.Count</span>
                @if (_loadingNew)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                              Size="ProgressBarCircularSize.ExtraSmall"
                                              Style="margin-left:auto;" />
                }
            </div>
            <div class="taskboard-column-body">
                @if (_loadingNew && FilteredNew.Count == 0)
                {
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="skeleton-card">
                            <div style="display:flex;gap:0.5rem;align-items:center;">
                                <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                <div class="skeleton-line title"></div>
                            </div>
                            <div class="skeleton-line long"></div>
                            <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                <div class="skeleton-line short"></div>
                                <div class="skeleton-line short" style="width:30%;"></div>
                            </div>
                        </div>
                    }
                }
                else if (FilteredNew.Count == 0)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="inbox" /><span>Задач нет</span></div>
                }
                else
                {
                    @foreach (var task in FilteredNew)
                    {
                        <div class="task-card" @onclick="@(() => OnCardClick(task))">
                            <div class="task-card-header">
                                <span class="task-type-badge @GetTypeClass(task.TaskType)">@GetTypeLabel(task.TaskType)</span>
                                <span class="task-card-title" title="@task.Title">@task.Title</span>
                                @if (task.TaskType == CommunicationTaskType.Chat && task.UnreadCount > 0)
                                {
                                    <span class="task-unread-badge" title="Непрочитанных сообщений">@task.UnreadCount</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.PreviewText))
                            {
                                <div class="task-card-preview">@task.PreviewText</div>
                            }
                            <div class="task-card-footer">
                                <span class="task-card-time">
                                    <RadzenIcon Icon="schedule" Style="font-size:0.85rem;" />
                                    @FormatTimeAgo(task.CreatedAt)
                                </span>
                                @if (!string.IsNullOrEmpty(task.ExternalStatus))
                                {
                                    <span class="task-external-status">@task.ExternalStatus</span>
                                }
                                @if (_board.PaymentEstimates.TryGetValue(task.TaskType, out var cardEst) && cardEst > 0)
                                {
                                    <span class="task-estimate-badge" title="Потенциальный заработок за задачу">~@cardEst.ToString("F0") ₽</span>
                                }
                                else if (_board.HourlyEstimates.TryGetValue(task.TaskType, out var cardHr) && cardHr > 0)
                                {
                                    <span class="task-estimate-badge" title="Ставка за час">@cardHr.ToString("F0") ₽/ч</span>
                                }
                            </div>
                            <div class="task-card-actions">
                                <RadzenButton Text="Взять" Icon="play_arrow"
                                              ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall"
                                              Click="@(async () => await ClaimAsync(task))"
                                              @onclick:stopPropagation="true" />
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- IN PROGRESS -->
        <div class="taskboard-column col-inprogress">
            <div class="taskboard-column-header">
                <span>В работе</span>
                <span class="taskboard-column-count">@FilteredInProgress.Count</span>
            </div>
            <div class="taskboard-column-body">
                @if (FilteredInProgress.Count == 0)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="hourglass_empty" /><span>Нет задач в работе</span></div>
                }
                else
                {
                    @foreach (var task in FilteredInProgress)
                    {
                        <div class="task-card" @onclick="@(() => OnCardClick(task))">
                            <div class="task-card-header">
                                <span class="task-type-badge @GetTypeClass(task.TaskType)">@GetTypeLabel(task.TaskType)</span>
                                <span class="task-card-title" title="@task.Title">@task.Title</span>
                                @if (task.TaskType == CommunicationTaskType.Chat && task.UnreadCount > 0)
                                {
                                    <span class="task-unread-badge" title="Непрочитанных сообщений">@task.UnreadCount</span>
                                }
                                @if (task.TaskType == CommunicationTaskType.Chat && task.LastMessageFromCustomer)
                                {
                                    <span class="task-last-from-customer-badge" title="Есть новое сообщение от покупателя">есть новое сообщение</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.PreviewText))
                            {
                                <div class="task-card-preview">@task.PreviewText</div>
                            }
                            @if (task.HasActiveTimer)
                            {
                                <div class="task-timer-active">
                                    <span class="timer-dot"></span>
                                    <span class="live-timer" data-started="@task.StartedAt?.ToString("o")">@FormatDuration(task.StartedAt)</span>
                                </div>
                            }
                            <div class="task-card-footer">
                                @if (task.AssignedToUserName is not null)
                                {
                                    <span class="task-card-assignee">
                                        <RadzenIcon Icon="person" Style="font-size:0.85rem;" />
                                        @task.AssignedToUserName
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(task.ExternalStatus))
                                {
                                    <span class="task-external-status">@task.ExternalStatus</span>
                                }
                                @{ var inProgressEst = ComputeEstimate(task); }
                                @if (inProgressEst > 0)
                                {
                                    <span class="task-estimate-badge" title="Ожидаемая оплата по текущим тарифам">~@inProgressEst.ToString("F0") ₽</span>
                                }
                            </div>
                            @if (task.AssignedToUserId == CurrentUser.UserId)
                            {
                                <div class="task-card-actions">
                                    @if (task.HasActiveTimer)
                                    {
                                        <RadzenButton Text="Пауза" Icon="pause"
                                                      ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.ExtraSmall"
                                                      Click="@(async () => await PauseAsync(task))"
                                                      @onclick:stopPropagation="true" />
                                    }
                                    else
                                    {
                                        <RadzenButton Text="Продолжить" Icon="play_arrow"
                                                      ButtonStyle="ButtonStyle.Info" Size="ButtonSize.ExtraSmall"
                                                      Click="@(async () => await ResumeAsync(task))"
                                                      @onclick:stopPropagation="true" />
                                    }
                                    <RadzenButton Text="Готово" Icon="check"
                                                  ButtonStyle="ButtonStyle.Success" Size="ButtonSize.ExtraSmall"
                                                  Click="@(async () => await CompleteAsync(task))"
                                                  @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                                  Click="@(async () => await ReleaseAsync(task))"
                                                  @onclick:stopPropagation="true"
                                                  title="Снять с себя" />
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <!-- DONE -->
        <div class="taskboard-column col-done">
            <div class="taskboard-column-header">
                <span>Выполненные</span>
                <span class="taskboard-column-count">@_board.DoneTotalCount</span>
            </div>
            <div class="taskboard-column-body">
                @if (FilteredDone.Count == 0 && !_loadingMore)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="check_circle_outline" /><span>Пока нет выполненных</span></div>
                }
                else
                {
                    @foreach (var task in FilteredDone)
                    {
                        <div class="task-card" @onclick="@(() => OnCardClick(task))">
                            <div class="task-card-header">
                                <span class="task-type-badge @GetTypeClass(task.TaskType)">@GetTypeLabel(task.TaskType)</span>
                                <span class="task-card-title" title="@task.Title">@task.Title</span>
                                @if (task.TaskType == CommunicationTaskType.Chat && task.LastMessageFromCustomer)
                                {
                                    <span class="task-last-from-customer-badge" title="Есть новое сообщение от покупателя">есть новое сообщение</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.PreviewText))
                            {
                                <div class="task-card-preview">@task.PreviewText</div>
                            }
                            <div class="task-card-footer">
                                @if (task.AssignedToUserName is not null)
                                {
                                    <span class="task-card-assignee">
                                        <RadzenIcon Icon="person" Style="font-size:0.85rem;" />
                                        @task.AssignedToUserName
                                    </span>
                                }
                                @if (task.PaymentAmount.HasValue && task.PaymentAmount > 0)
                                {
                                    <span class="task-payment-badge">+@task.PaymentAmount.Value.ToString("F0") ₽</span>
                                }
                                <span class="task-card-time">
                                    @if (task.TotalTimeSpentTicks > 0)
                                    {
                                        @FormatTimeSpan(TimeSpan.FromTicks(task.TotalTimeSpentTicks))
                                    }
                                </span>
                            </div>
                        </div>
                    }

                    @if (_loadingMore)
                    {
                        <div style="display:flex;justify-content:center;padding:0.75rem;gap:0.4rem;color:var(--rz-text-secondary-color);font-size:0.82rem;">
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" />
                            Загрузка...
                        </div>
                    }
                    else if (_board.DoneTasks.Count < _board.DoneTotalCount)
                    {
                        <div @ref="_doneSentinel" style="height:1px;"></div>
                    }
                }
            </div>
        </div>

        } @* end else !_loading *@
    </div>
</div>

@* ──────────────────── Preview overlay ──────────────────── *@
@if (_previewTask is not null)
{
    <div class="task-detail-backdrop" @onclick="ClosePreview"></div>
    <div class="task-detail-overlay">
        <div class="task-detail-header">
            <RadzenStack Gap="0.3rem">
                <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin:0;font-weight:600;">@_previewTask.Title</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
                    <span class="task-type-badge @GetTypeClass(_previewTask.TaskType)">@GetTypeLabel(_previewTask.TaskType)</span>
                    @if (!string.IsNullOrEmpty(_previewTask.ExternalStatus))
                    {
                        <span class="task-external-status">@_previewTask.ExternalStatus</span>
                    }
                    @if (_previewTask.TaskType == CommunicationTaskType.Chat && _previewTask.UnreadCount > 0)
                    {
                        <span class="task-unread-badge">@_previewTask.UnreadCount непрочит.</span>
                    }
                    @if (_previewTask.TaskType == CommunicationTaskType.Chat && _previewTask.LastMessageFromCustomer
                         && (_previewTask.Status == CommunicationTaskStatus.InProgress || _previewTask.Status == CommunicationTaskStatus.Done))
                    {
                        <span class="task-last-from-customer-badge" title="Есть новое сообщение от покупателя">есть новое сообщение</span>
                    }
                    @if (_previewTask.TaskType == CommunicationTaskType.Chat && _previewTask.ChatType == "BUYER_SELLER" && !string.IsNullOrEmpty(_previewTask.ExternalId))
                    {
                        <span style="font-size:0.72rem;color:var(--rz-text-secondary-color);font-family:monospace;">ID: @_previewTask.ExternalId</span>
                    }
                    @if (_previewTask.Status != CommunicationTaskStatus.Done)
                    {
                        @if (_board.PaymentEstimates.TryGetValue(_previewTask.TaskType, out var hdrEst) && hdrEst > 0)
                        {
                            <span class="task-estimate-badge">~@hdrEst.ToString("F0") ₽</span>
                        }
                        else if (_board.HourlyEstimates.TryGetValue(_previewTask.TaskType, out var hdrHr) && hdrHr > 0)
                        {
                            <span class="task-estimate-badge">@hdrHr.ToString("F0") ₽/ч</span>
                        }
                    }
                </RadzenStack>
            </RadzenStack>
            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click="ClosePreview" />
        </div>
        <div class="task-detail-body @(_previewTask.TaskType == CommunicationTaskType.Question ? "task-detail-body-question" : null)"
             style="@(_previewTask.TaskType == CommunicationTaskType.Chat || _previewTask.TaskType == CommunicationTaskType.Question ? "overflow:hidden;" : "overflow-y:auto;")">

            @if (_previewLoading)
            {
                <div style="display:flex;align-items:center;justify-content:center;padding:3rem;gap:0.5rem;">
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                    <span style="color:var(--rz-text-secondary-color);">Загрузка...</span>
                </div>
            }
            else
            {
                @* ── Potential earnings (New / InProgress tasks) ── *@
                @if (_previewTask.Status != CommunicationTaskStatus.Done)
                {

                    var hasPerTaskEst = _board.PaymentEstimates.TryGetValue(_previewTask.TaskType, out var bodyEst) && bodyEst > 0;
                    var hasHourlyEst = _board.HourlyEstimates.TryGetValue(_previewTask.TaskType, out var bodyHr) && bodyHr > 0;
                    if (hasPerTaskEst || hasHourlyEst)
                    {
                        <div style="margin-bottom:0.75rem;padding:0.65rem 0.9rem;background:rgba(139,92,246,0.06);border-radius:8px;border:1px dashed rgba(139,92,246,0.3);">
                            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.4rem;">
                                <span style="font-size:0.82rem;color:#5b21b6;font-weight:600;">
                                    <RadzenIcon Icon="payments" Style="font-size:0.9rem;vertical-align:middle;margin-right:3px;" />
                                    Потенциальный заработок
                                </span>
                                <span style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                                    @if (hasPerTaskEst)
                                    {
                                        <span class="task-estimate-badge" style="font-size:0.8rem;padding:2px 10px;">~@bodyEst.ToString("F0") ₽ за задачу</span>
                                    }
                                    @if (hasHourlyEst)
                                    {
                                        <span class="task-estimate-badge" style="font-size:0.8rem;padding:2px 10px;">@bodyHr.ToString("F0") ₽/ч</span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                }

                @* ── Time & Payment breakdown (shown when detail loaded) ── *@
                @if (_taskDetail is not null && (_taskDetail.TimeEntries.Count > 0 || (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)))
                {
                    <div style="margin-bottom:0.75rem;padding:0.6rem 0.85rem;background:var(--rz-base-50);border-radius:8px;border:1px solid var(--rz-base-200);">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.4rem;">
                            <span style="font-size:0.8rem;font-weight:600;color:var(--rz-text-color);">
                                <RadzenIcon Icon="schedule" Style="font-size:0.9rem;vertical-align:middle;margin-right:3px;" />
                                Время и оплата
                            </span>
                            @if (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)
                            {
                                <span class="task-payment-badge" style="font-size:0.82rem;padding:2px 10px;">
                                    +@_previewTask.PaymentAmount.Value.ToString("F0") ₽
                                </span>
                            }
                            else if (_previewTask.TotalTimeSpentTicks > 0)
                            {
                                <span style="font-size:0.8rem;font-weight:600;color:var(--rz-text-secondary-color);">
                                    @FormatTimeSpan(TimeSpan.FromTicks(_previewTask.TotalTimeSpentTicks))
                                </span>
                            }
                        </div>
                        @if (_taskDetail.TimeEntries.Count > 0)
                        {
                            <table style="width:100%;font-size:0.75rem;border-collapse:collapse;">
                                <thead>
                                    <tr style="color:var(--rz-text-secondary-color);">
                                        <th style="text-align:left;padding:2px 4px;font-weight:500;">Начало</th>
                                        <th style="text-align:left;padding:2px 4px;font-weight:500;">Конец</th>
                                        <th style="text-align:right;padding:2px 4px;font-weight:500;">Длит.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in _taskDetail.TimeEntries.OrderBy(x => x.StartedAt))
                                    {
                                        <tr style="border-top:1px solid var(--rz-base-200);">
                                            <td style="padding:3px 4px;">@e.StartedAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                            <td style="padding:3px 4px;">@(e.EndedAt.HasValue ? e.EndedAt.Value.ToLocalTime().ToString("dd.MM HH:mm") : "⏱ в процессе")</td>
                                            <td style="padding:3px 4px;text-align:right;font-variant-numeric:tabular-nums;">
                                                @if (e.DurationMinutes >= 60)
                                                {
                                                    @($"{(int)(e.DurationMinutes / 60)}ч {(int)(e.DurationMinutes % 60)}м")
                                                }
                                                else
                                                {
                                                    @($"{(int)e.DurationMinutes}м")
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (_taskDetail.TimeEntries.Count > 1)
                            {
                                var totalMin = _taskDetail.TimeEntries
                                    .Where(e => e.EndedAt.HasValue)
                                    .Sum(e => e.DurationMinutes);
                                <div style="text-align:right;font-size:0.75rem;color:var(--rz-text-secondary-color);margin-top:3px;padding-right:4px;">
                                    Итого:
                                    @if (totalMin >= 60)
                                    {
                                        @($"{(int)(totalMin / 60)}ч {(int)(totalMin % 60)}м")
                                    }
                                    else
                                    {
                                        @($"{(int)totalMin}м")
                                    }
                                    @if (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)
                                    {
                                        <span style="margin-left:8px;font-weight:700;color:#065f46;">= +@_previewTask.PaymentAmount.Value.ToString("F0") ₽</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                }

                @* ── Chat preview ── *@
                @if (_previewTask.TaskType == CommunicationTaskType.Chat)
                {
                    @if (_chatFallbackUrl is not null)
                    {
                        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;text-align:center;">
                            <span class="rzi" style="font-size:2.5rem;color:var(--rz-warning)">lock</span>
                            <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-secondary-color);">
                                История чата недоступна через API для этого клиента.<br />
                                Откройте чат напрямую на сайте Ozon Seller.
                            </RadzenText>
                            <RadzenButton Text="Открыть в Ozon Seller"
                                          Icon="open_in_new"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Medium"
                                          Click="@(_ => JS.InvokeVoidAsync("open", _chatFallbackUrl, "_blank"))" />
                        </div>
                    }
                    else
                    {
                        <div style="flex:1;min-height:0;display:flex;flex-direction:column;margin:-1rem;">
                            <ChatMessages Messages="_chatMessages"
                                          SelectedChat="_previewChatVm"
                                          EagerImages="true"
                                          OpenGallery="OnOpenGallery"
                                          LoadingHistory="false" />
                            @if (_previewTask.Status == CommunicationTaskStatus.InProgress)
                            {
                                <div style="border-top:1px solid var(--rz-base-300);padding:0.5rem 1rem 0.75rem;background:var(--rz-base-background-color);flex-shrink:0;">
                                    <ChatComposer
                                        QuickReplies="TaskBoardChatQuickReplies"
                                        OnSendWithFile="OverlaySendChatMessageAsync"
                                        PlaceHolder="Написать сообщение..."
                                        EnableAttachments="true" />
                                </div>
                            }
                            else
                            {
                                <div style="border-top:1px solid var(--rz-base-300);padding:0.75rem 1.25rem;background:var(--rz-base-50);flex-shrink:0;
                                           display:flex;align-items:center;gap:0.6rem;color:var(--rz-text-secondary-color);">
                                    <span class="rzi" style="font-size:1.2rem;opacity:0.5;">lock</span>
                                    <span style="font-size:0.82rem;">Чтобы отправлять сообщения, нажмите «Взять задачу»</span>
                                </div>
                            }
                        </div>
                    }
                }

                @* ── Question preview (как чат: скролл контента + ChatComposer снизу) ── *@
                @if (_previewTask.TaskType == CommunicationTaskType.Question && _questionDetail is not null)
                {
                    <div class="task-question-overlay-root">
                        <div class="task-question-scroll">
                            <div class="task-question-thread">
                                <div class="task-question-bubble task-question-bubble-buyer">
                                    <div class="task-question-bubble-meta">
                                        <span class="task-question-author">@_questionDetail.Question.AuthorName</span>
                                        <span class="task-question-sku">SKU @_questionDetail.Question.Sku</span>
                                        <span class="task-question-when">@_questionDetail.Question.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                    <div class="task-question-bubble-text">@_questionDetail.Question.Text</div>
                                </div>

                                @if (_questionDetail.Product is not null)
                                {
                                    <div class="task-question-product-card">
                                        @if (!string.IsNullOrWhiteSpace(_questionDetail.Product.PrimaryImage))
                                        {
                                            <img src="@_questionDetail.Product.PrimaryImage"
                                                 alt=""
                                                 class="task-question-product-thumb"
                                                 width="56"
                                                 height="56"
                                                 loading="lazy"
                                                 @onclick="@(() => OpenOverlayGallery(new List<string> { _questionDetail.Product!.PrimaryImage }, 0))" />
                                        }
                                        <div class="task-question-product-text">
                                            <div class="task-question-product-name" title="@_questionDetail.Product.Name">@_questionDetail.Product.Name</div>
                                            <div class="task-question-product-props">
                                                <span>SKU @_questionDetail.Product.Sku</span>
                                                @if (!string.IsNullOrWhiteSpace(_questionDetail.Product.OfferId))
                                                {
                                                    <span>· @_questionDetail.Product.OfferId</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (_questionDetail.Answers.Count > 0)
                                {
                                    <div class="task-question-answers-label">Ответы (@_questionDetail.Answers.Count)</div>
                                    @foreach (var ans in _questionDetail.Answers)
                                    {
                                        <div class="task-question-bubble task-question-bubble-seller">
                                            <div class="task-question-bubble-meta">
                                                <span class="task-question-author">@ans.AuthorName</span>
                                                <span class="task-question-when">@ans.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Shade="Shade.Lighter"
                                                              Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                                              Style="margin-left:auto;padding:0 4px;min-width:auto;" Title="Удалить ответ"
                                                              IsBusy="@(_overlayDeletingAnswerId == ans.Id)"
                                                              Click="@(() => DeleteOverlayAnswerAsync(ans))" />
                                            </div>
                                            <div class="task-question-bubble-text">@ans.Text</div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        @if (_previewTask.Status == CommunicationTaskStatus.InProgress)
                        {
                            <div class="task-question-composer-wrap">
                                <ChatComposer QuickReplies="TaskBoardChatQuickReplies"
                                              OnSendTextOnly="SendOverlayAnswerTextAsync"
                                              EnableAttachments="false"
                                              MaxLength="3000"
                                              PlaceHolder="Написать ответ…" />
                            </div>
                        }
                        else
                        {
                            <div class="task-question-locked-bar">
                                <span class="rzi" style="font-size:1.2rem;opacity:0.5;">lock</span>
                                <span style="font-size:0.82rem;">Чтобы ответить, нажмите «Взять задачу»</span>
                            </div>
                        }
                    </div>
                }

                @* ── Review preview ── *@
                @if (_previewTask.TaskType == CommunicationTaskType.Review && _reviewDetail is not null)
                {
                    @* Stars + status *@
                    <div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.5rem;">
                        <div class="review-stars" style="font-size:1.1rem;">
                            @for (var i = 1; i <= 5; i++)
                            {
                                var starIdx = i;
                                var starCls = starIdx <= _reviewDetail.Review.Rating ? "star-filled" : "star-empty";
                                <span class="@starCls">★</span>
                            }
                        </div>
                        <RadzenBadge Text="@(_reviewDetail.Review.Status == "PROCESSED" ? "Обработан" : "Не обработан")"
                                     BadgeStyle="@(_reviewDetail.Review.Status == "PROCESSED" ? BadgeStyle.Success : BadgeStyle.Warning)" />
                    </div>

                    @* Meta stats *@
                    @if (_reviewDetail.LikesAmount > 0 || _reviewDetail.DislikesAmount > 0 || _reviewDetail.Review.IsRatingParticipant)
                    {
                        <div class="review-meta-row" style="margin-bottom:0.5rem;">
                            @if (_reviewDetail.LikesAmount > 0) { <span><strong>👍</strong> @_reviewDetail.LikesAmount</span> }
                            @if (_reviewDetail.DislikesAmount > 0) { <span><strong>👎</strong> @_reviewDetail.DislikesAmount</span> }
                            @if (_reviewDetail.Review.IsRatingParticipant) { <span style="color:#10b981;"><strong>✓</strong> Учитывается в рейтинге</span> }
                        </div>
                    }

                    @* Product card *@
                    @if (_reviewDetail.Product is not null)
                    {
                        <div class="question-product-card">
                            <RadzenText TextStyle="TextStyle.Subtitle2"
                                        Style="font-weight:600;margin-bottom:0.5rem;color:var(--rz-text-secondary-color);">Товар</RadzenText>
                            <div class="question-product-layout">
                                @if (!string.IsNullOrWhiteSpace(_reviewDetail.Product.PrimaryImage))
                                {
                                    <img src="@_reviewDetail.Product.PrimaryImage"
                                         alt="@_reviewDetail.Product.Name"
                                         class="question-product-image"
                                         @onclick="@(() => OpenOverlayGallery(new List<string> { _reviewDetail.Product.PrimaryImage }, 0))"
                                         title="Нажмите для просмотра" />
                                }
                                <div class="question-product-info">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;margin:0;">@_reviewDetail.Product.Name</RadzenText>
                                    <div class="question-product-props">
                                        <span><strong>SKU:</strong> @_reviewDetail.Product.Sku</span>
                                        @if (!string.IsNullOrWhiteSpace(_reviewDetail.Product.OfferId))
                                        {
                                            <span><strong>Артикул:</strong> @_reviewDetail.Product.OfferId</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Chat-bubble display *@
                    <div class="chat-messages-area">
                        @if (!string.IsNullOrWhiteSpace(_reviewDetail.Review.Text))
                        {
                            <div class="chat-message-row from-customer">
                                <div class="chat-avatar customer" title="Покупатель">К</div>
                                <div class="chat-bubble-wrap">
                                    <div class="chat-message-sender">Покупатель</div>
                                    <div class="chat-message-bubble from-customer">@_reviewDetail.Review.Text</div>
                                    <div class="chat-message-meta">
                                        <span class="chat-message-time">@_reviewDetail.Review.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (_reviewDetail.Photos.Count > 0)
                        {
                            <div class="chat-message-row from-customer">
                                <div class="chat-avatar customer" title="Покупатель">К</div>
                                <div class="chat-bubble-wrap">
                                    <div class="chat-message-sender">Покупатель</div>
                                    <div class="chat-message-bubble from-customer review-photos-grid">
                                        @foreach (var item in _reviewDetail.Photos.Select((p, i) => new { Photo = p, Index = i }))
                                        {
                                            <img src="@item.Photo.Url"
                                                 alt="Фото отзыва"
                                                 class="review-photo-thumb"
                                                 loading="lazy"
                                                 @onclick="@(() => OpenOverlayGallery(_reviewDetail.Photos.Select(x => x.Url).ToList(), item.Index))"
                                                 title="Нажмите для просмотра" />
                                        }
                                    </div>
                                    <div class="chat-message-meta">
                                        <span class="chat-message-time">@_reviewDetail.Review.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (_reviewDetail.Videos.Count > 0)
                        {
                            <div class="chat-message-row from-customer">
                                <div class="chat-avatar customer" title="Покупатель">К</div>
                                <div class="chat-bubble-wrap">
                                    <div class="chat-message-sender">Покупатель</div>
                                    <div class="chat-message-bubble from-customer review-videos-grid">
                                        @foreach (var item in _reviewDetail.Videos.Select((v, i) => new { Video = v, Index = i }))
                                        {
                                            <div class="review-video-thumb"
                                                 @onclick="@(() => OpenOverlayGallery(_reviewDetail.Videos.Select(v => v.Url).ToList(), item.Index, isVideo: true))"
                                                 title="Нажмите для просмотра">
                                                @if (!string.IsNullOrWhiteSpace(item.Video.PreviewUrl))
                                                {
                                                    <img src="@item.Video.PreviewUrl" alt="Видео" loading="lazy" />
                                                }
                                                else
                                                {
                                                    <div style="width:100%;height:100%;background:#1a1a2e;"></div>
                                                }
                                                <div class="review-video-play"><RadzenIcon Icon="play_circle_filled" /></div>
                                            </div>
                                        }
                                    </div>
                                    <div class="chat-message-meta">
                                        <span class="chat-message-time">@_reviewDetail.Review.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }

                        @foreach (var comment in _reviewDetail.Comments)
                        {
                            <div class="chat-message-row from-seller">
                                <div class="chat-avatar seller" title="Продавец">П</div>
                                <div class="chat-bubble-wrap">
                                    <div class="chat-message-sender">Продавец</div>
                                    <div class="chat-message-bubble from-seller">@comment.Text</div>
                                    <div class="chat-message-meta" style="display:flex;align-items:center;gap:0.5rem;">
                                        @if (comment.IsOwner || comment.IsOfficial)
                                        {
                                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Shade="Shade.Lighter"
                                                          Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                                          Style="margin-left:auto;padding:0 2px;" Title="Удалить комментарий"
                                                          IsBusy="@(_overlayDeletingCommentId == comment.Id)"
                                                          Click="@(() => DeleteOverlayCommentAsync(comment))" />
                                        }
                                        <span>@comment.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @* Comment composer or locked placeholder *@
                    @if (_previewTask.Status == CommunicationTaskStatus.InProgress)
                    {
                        <ChatComposer
                            QuickReplies="TaskBoardReviewQuickReplies"
                            OnSendTextOnly="SendOverlayCommentAsync"
                            EnableAttachments="false"
                            PlaceHolder="Написать комментарий к отзыву..."
                            MaxLength="3000" />
                    }
                    else
                    {
                        <div style="padding:0.6rem 0.9rem;border-radius:8px;
                                   background:var(--rz-base-100);border:1px dashed var(--rz-base-300);
                                   display:flex;align-items:center;gap:0.6rem;color:var(--rz-text-secondary-color);">
                            <span class="rzi" style="font-size:1.15rem;opacity:0.45;">edit_off</span>
                            <span style="font-size:0.82rem;">Чтобы оставить комментарий, нажмите «Взять задачу»</span>
                        </div>
                    }
                }

                @if (!_previewLoading &&
                     _previewTask.TaskType != CommunicationTaskType.Chat &&
                     _questionDetail is null && _reviewDetail is null)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
                        Не удалось загрузить предпросмотр
                    </RadzenAlert>
                }
            }
        </div>

        @* Action bar at bottom *@
        <div style="padding:0.5rem 1rem;border-top:1px solid var(--rz-base-300);display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;min-height:3rem;">
            @if (_previewTask.Status == CommunicationTaskStatus.New)
            {
                <RadzenButton Text="Взять задачу" Icon="play_arrow" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Click="OverlayClaimAsync" IsBusy="@_overlayBusy" Style="margin-left:auto;" />
            }
            else if (_previewTask.Status == CommunicationTaskStatus.InProgress)
            {
                @if (_previewTask.AssignedToUserId == CurrentUser.UserId)
                {
                    <div class="task-timer-active" style="display:inline-flex;align-items:center;gap:0.3rem;margin-right:auto;">
                        @if (_previewTask.HasActiveTimer)
                        {
                            <span class="timer-dot"></span>
                        }
                        <span style="font-size:0.85rem;font-variant-numeric:tabular-nums;min-width:5rem;">
                            @FormatOverlayDuration(_previewTask)
                        </span>
                    </div>
                    @if (_previewTask.HasActiveTimer)
                    {
                        <RadzenButton Text="Пауза" Icon="pause" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small"
                                      Click="OverlayPauseAsync" IsBusy="@_overlayBusy" />
                    }
                    else
                    {
                        <RadzenButton Text="Продолжить" Icon="play_arrow" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small"
                                      Click="OverlayResumeAsync" IsBusy="@_overlayBusy" />
                    }
                    <RadzenButton Text="Готово" Icon="check" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                  Click="OverlayCompleteAsync" IsBusy="@_overlayBusy" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  title="Снять с себя" Click="OverlayReleaseAsync" IsBusy="@_overlayBusy" />
                }
                else
                {
                    <span style="font-size:0.85rem;color:var(--rz-text-secondary-color);display:inline-flex;align-items:center;gap:0.3rem;">
                        <RadzenIcon Icon="person" Style="font-size:0.9rem;" />
                        Занято: @(_previewTask.AssignedToUserName ?? "другой пользователь")
                    </span>
                }
            }
            else if (_previewTask.Status == CommunicationTaskStatus.Done)
            {
                @if (_previewTask.AssignedToUserId == CurrentUser.UserId)
                {
                    <RadzenButton Text="Вернуть в работу" Icon="replay" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                  Click="OverlayReopenAsync" IsBusy="@_overlayBusy" Style="margin-left:auto;" />
                }
            }
        </div>
    </div>
}

@if (_galleryCurrentIndex >= 0 && _galleryItems.Any())
{
    <div class="lightbox-overlay" tabindex="0" @ref="_galleryDiv" @onkeydown="GalleryNavigate"
         @onclick="GalleryClose">

        @if (_galleryItems.Count > 1)
        {
            <RadzenButton Icon="chevron_left" ButtonStyle="ButtonStyle.Light"
                          @onclick:stopPropagation="true"
                          class="lightbox-arrow left"
                          Click="GalleryPrev"/>
        }

        @if (_galleryIsVideo)
        {
            <video class="lightbox-image"
                   src="@_galleryItems[_galleryCurrentIndex]"
                   controls autoplay
                   @onclick:stopPropagation="true" />
        }
        else
        {
            <img class="lightbox-image"
                 src="@_galleryItems[_galleryCurrentIndex]"
                 alt="изображение"
                 @onclick:stopPropagation="true"/>
        }

        @if (_galleryItems.Count > 1)
        {
            <RadzenButton Icon="chevron_right" ButtonStyle="ButtonStyle.Primary"
                          @onclick:stopPropagation="true"
                          class="lightbox-arrow right"
                          Click="GalleryNext"/>
        }

        <button class="lightbox-close" @onclick:stopPropagation="true" @onclick="GalleryClose"
                title="Закрыть (Esc)">
            <RadzenIcon Icon="close"/>
        </button>
    </div>
}

@code {
    private TaskBoardDto _board = new();
    private CommunicationTaskType? _filterType;
    private DateTime? _filterFrom = DateTime.Today.AddDays(-30);
    private DateTime? _filterTo;
    private Guid? _filterClientId;
    private List<ClientOptionDto> _clientOptions = new();
    private bool _clientDropdownOpen;
    private bool _dateDropdownOpen;
    private bool _loading;
    private bool _loadingNew;
    private bool _syncing;
    private bool _loadingMore;

    private const int DonePageSize = 25;

    private static readonly string[] TaskBoardChatQuickReplies =
    [
        "Здравствуйте!",
        "Здравствуйте, для проверки необходим VIN номер Вашего авто",
        "Заявка на рассмотрении, ожидайте",
        "Оформите возврат"
    ];

    private static readonly string[] TaskBoardReviewQuickReplies =
    [
        "Здравствуйте!",
        "Здравствуйте! Спасибо за ваш отзыв.",
        "Здравствуйте! Приносим извинения за доставленные неудобства.",
