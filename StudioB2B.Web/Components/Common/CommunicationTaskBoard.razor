    }

    private static string Plural(int n, string one, string few, string many)
    {
        var mod10 = n % 10;
        var mod100 = n % 100;
        if (mod100 is >= 11 and <= 19) return many;
        return mod10 switch { 1 => one, >= 2 and <= 4 => few, _ => many };
    }
