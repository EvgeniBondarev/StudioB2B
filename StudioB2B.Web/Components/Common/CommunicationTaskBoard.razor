@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Web.Components.Common.TaskBoard

@inject ICommunicationTaskService TaskService
@inject ICommunicationTaskSyncService SyncService
@inject IOzonChatService ChatService
@inject IOzonQuestionsService QuestionsService
@inject IOzonReviewsService ReviewsService
@inject IMarketplaceClientService MarketplaceClientService
@inject IUserService UserService
@inject ITenantProvider TenantProvider
@inject ICurrentUserProvider CurrentUser
@inject NotificationService NotificationService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject TaskBoardStateService BoardState
@inject UserContext UserContext

@implements IAsyncDisposable

<link rel="stylesheet" href="css/taskboard.css?v=1775729400" />
<link rel="stylesheet" href="css/chats/chatMessages.css" />
<link rel="stylesheet" href="css/chats/chatComposer.css" />
<script src="js/taskboard.js?v=1775729247"></script>

<div class="taskboard-root">

    <TaskBoardSidebar
        IsOpen="_sidebarOpen"
        IsOpenChanged="@(v => { _sidebarOpen = v; })"
        FilterTypes="_filterTypes"
        FilterFrom="_filterFrom"
        FilterFromChanged="@(v => { _filterFrom = v; })"
        FilterTo="_filterTo"
        FilterToChanged="@(v => { _filterTo = v; })"
        FilterClientIds="_filterClientIds"
        FilterUserIds="_filterUserIds"
        ClientOptions="_clientOptions"
        UserOptions="_userOptions"
        TypeCounts="_board.TypeCounts"
        Loading="_loading"
        Syncing="_syncing"
        OnRefresh="QuickSyncAndReloadAsync"
        OnFullSync="FullSyncAndReloadAsync"
        OnToggleType="ToggleTypeFilter"
        OnToggleClient="ToggleClientFilter"
        OnToggleUser="ToggleUserFilter"
        OnClearTypes="@(async () => { _filterTypes.Clear(); await LoadBoardAsync(); })"
        OnClearClients="@(async () => { _filterClientIds.Clear(); await LoadBoardAsync(); })"
        OnClearUsers="@(async () => { _filterUserIds.Clear(); await ReloadDbAndKeepNewAsync(); })"
        OnClearDate="@(async () => { _filterFrom = null; _filterTo = null; await LoadBoardAsync(); })"
        OnApplyDate="LoadBoardAsync" />

    <div class="taskboard-main @(_previewTask != null ? "has-preview" : "")">
    <div class="taskboard-columns">

        @if (_loading || _syncing)
        {
            @for (var col = 0; col < 3; col++)
            {
                <div class="taskboard-column">
                    <div class="taskboard-column-header" style="opacity:0.5;">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line short"></div>
                    </div>
                    <div class="taskboard-column-body">
                        @for (var i = 0; i < 4; i++)
                        {
                            <div class="skeleton-card">
                                <div style="display:flex;gap:0.5rem;align-items:center;">
                                    <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                    <div class="skeleton-line title"></div>
                                </div>
                                <div class="skeleton-line long"></div>
                                <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                    <div class="skeleton-line short"></div>
                                    <div class="skeleton-line short" style="width:30%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {

        <!-- NEW -->
        <div class="taskboard-column col-new">
            <div class="taskboard-column-header">
                <span>Новые</span>
                <span class="taskboard-column-count">@FilteredNew.Count</span>
                @if (_loadingNew)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                              Size="ProgressBarCircularSize.ExtraSmall"
                                              Style="margin-left:auto;" />
                }
            </div>
            <div class="taskboard-column-body">
                @if (_loadingNew && FilteredNew.Count == 0)
                {
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="skeleton-card">
                            <div style="display:flex;gap:0.5rem;align-items:center;">
                                <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                <div class="skeleton-line title"></div>
                            </div>
                            <div class="skeleton-line long"></div>
                            <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                <div class="skeleton-line short"></div>
                                <div class="skeleton-line short" style="width:30%;"></div>
                            </div>
                        </div>
                    }
                }
                else if (FilteredNew.Count == 0)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="inbox" /><span>Задач нет</span></div>
                }
                else
                {
                    @foreach (var task in FilteredNew)
                    {
                        var t = task;
                        <TaskCard Task="t" Board="_board"
                                  CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                                  ShowNewButtons="true"
                                  OnClick="@(() => OnCardClick(t))"
                                  OnClaim="@(() => ClaimAsync(t))" />
                    }
                }
            </div>
        </div>

        <!-- IN PROGRESS -->
        <div class="taskboard-column col-inprogress">
            <div class="taskboard-column-header">
                <span>В работе</span>
                <span class="taskboard-column-count">@FilteredInProgress.Count</span>
            </div>

            @if (_previewTask is not null && _previewTask.Status == CommunicationTaskStatus.InProgress)
            {
                var inpToShow = FilteredInProgress;
                <div class="taskboard-column-body col-inprogress-cards-above">
                    @foreach (var task in inpToShow)
                    {
                        var t = task;
                        <TaskCard Task="t" Board="_board"
                                  CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                                  IsSelected="@(_previewTask?.Id == t.Id)"
                                  ShowInProgressButtons="true"
                                  OnClick="@(() => OnCardClick(t))"
                                  OnPause="@(() => PauseAsync(t))"
                                  OnResume="@(() => ResumeAsync(t))"
                                  OnComplete="@(() => CompleteAsync(t))"
                                  OnRelease="@(() => ReleaseAsync(t))" />
                    }
                </div>

                <div class="task-detail-overlay @TaskBoardHelpers.GetPreviewTypeClass(_previewTask!.TaskType)">
                    <TaskDetailOverlayContent
                        Task="_previewTask"
                        TaskDetail="_taskDetail"
                        PreviewLoading="_previewLoading"
                        Board="_board"
                        CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                        ChatMessages="_chatMessages"
                        ChatVm="_previewChatVm"
                        ChatFallbackUrl="@_chatFallbackUrl"
                        QuestionDetail="_questionDetail"
                        ReviewDetail="_reviewDetail"
                        ChatAuthors="_chatMessageAuthors"
                        QuestionAuthors="_questionAuthors"
                        SendingAnswer="_overlaySendingAnswer"
                        OverlayBusy="_overlayBusy"
                        DeletingAnswerId="_overlayDeletingAnswerId"
                        DeletingCommentId="_overlayDeletingCommentId"
                        ChatQuickReplies="ChatQuickReplies"
                        QuestionQuickReplies="QuestionQuickReplies"
                        ReviewQuickReplies="ReviewQuickReplies"
                        OnClose="ClosePreview"
                        OnClaim="OverlayClaimAsync"
                        OnPause="OverlayPauseAsync"
                        OnResume="OverlayResumeAsync"
                        OnComplete="OverlayCompleteAsync"
                        OnRelease="OverlayReleaseAsync"
                        OnReopen="OverlayReopenAsync"
                        OnOpenExternalUrl="@(url => Js.InvokeVoidAsync("open", url, "_blank"))"
                        OnSendChatMessage="OverlaySendChatMessageAsync"
                        OnSendAnswer="OverlaySendAnswerAsync"
                        OnSendComment="OverlaySendCommentAsync"
                        OnGenerateAiReply="GenerateAiReplyAsync"
                        OnDeleteAnswer="@(ans => OverlayDeleteAnswerAsync(ans))"
                        OnDeleteComment="@(c => OverlayDeleteCommentAsync(c))"
                        OnOpenGallery="OpenOverlayGallery" />
                </div>
            }
            else
            {
                <div class="taskboard-column-body">
                    @if (FilteredInProgress.Count == 0)
                    {
                        <div class="taskboard-empty"><RadzenIcon Icon="hourglass_empty" /><span>Нет задач в работе</span></div>
                    }
                    else
                    {
                        @foreach (var task in FilteredInProgress)
                        {
                            var t = task;
                            <TaskCard Task="t" Board="_board"
                                      CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                                      IsSelected="@(_previewTask?.Id == t.Id)"
                                      ShowInProgressButtons="true"
                                      OnClick="@(() => OnCardClick(t))"
                                      OnPause="@(() => PauseAsync(t))"
                                      OnResume="@(() => ResumeAsync(t))"
                                      OnComplete="@(() => CompleteAsync(t))"
                                      OnRelease="@(() => ReleaseAsync(t))" />
                        }
                    }
                </div>
            }
        </div>

        <!-- DONE -->
        <div class="taskboard-column col-done">
            <div class="taskboard-column-header">
                <span>Выполненные</span>
                <span class="taskboard-column-count">@_board.DoneTotalCount</span>
            </div>
            <div class="taskboard-column-body">
                @if (FilteredDone.Count == 0 && !_loadingMore)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="check_circle_outline" /><span>Пока нет выполненных</span></div>
                }
                else
                {
                    @foreach (var task in FilteredDone)
                    {
                        var t = task;
                        <TaskCard Task="t" Board="_board"
                                  CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                                  ShowDoneButtons="true"
                                  OnClick="@(() => OnCardClick(t))"
                                  OnReopen="@(() => CardReopenAsync(t))" />
                    }

                    @if (_loadingMore)
                    {
                        <div style="display:flex;justify-content:center;padding:0.75rem;gap:0.4rem;color:var(--rz-text-secondary-color);font-size:0.82rem;">
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.ExtraSmall" />
                            Загрузка...
                        </div>
                    }
                    else if (_board.DoneTasks.Count < _board.DoneTotalCount)
                    {
                        <div @ref="_doneSentinel" style="height:1px;"></div>
                    }
                }
            </div>
        </div>

        } @* end else !_loading *@
    </div>

    @* New / Done side modal *@
    @if (_previewTask is not null && _previewTask.Status != CommunicationTaskStatus.InProgress)
    {
        <div class="task-side-modal-backdrop" @onclick="ClosePreview">
        <div class="task-detail-overlay @TaskBoardHelpers.GetPreviewTypeClass(_previewTask.TaskType) @(_previewTask.Status == CommunicationTaskStatus.New ? "overlay-col-new" : "overlay-col-done")"
             @onclick:stopPropagation="true">
            <TaskDetailOverlayContent
                Task="_previewTask"
                TaskDetail="_taskDetail"
                PreviewLoading="_previewLoading"
                IsModalScrollBody="true"
                Board="_board"
                CurrentUserId="@(_myTenantId ?? CurrentUser.UserId)"
                ChatMessages="_chatMessages"
                ChatVm="_previewChatVm"
                ChatFallbackUrl="@_chatFallbackUrl"
                QuestionDetail="_questionDetail"
                ReviewDetail="_reviewDetail"
                ChatAuthors="_chatMessageAuthors"
                QuestionAuthors="_questionAuthors"
                SendingAnswer="_overlaySendingAnswer"
                OverlayBusy="_overlayBusy"
                DeletingAnswerId="_overlayDeletingAnswerId"
                DeletingCommentId="_overlayDeletingCommentId"
                ChatQuickReplies="ChatQuickReplies"
                QuestionQuickReplies="QuestionQuickReplies"
                ReviewQuickReplies="ReviewQuickReplies"
                OnClose="ClosePreview"
                OnClaim="OverlayClaimAsync"
                OnPause="OverlayPauseAsync"
                OnResume="OverlayResumeAsync"
                OnComplete="OverlayCompleteAsync"
                OnRelease="OverlayReleaseAsync"
                OnReopen="OverlayReopenAsync"
                OnOpenExternalUrl="@(url => Js.InvokeVoidAsync("open", url, "_blank"))"
                OnSendChatMessage="OverlaySendChatMessageAsync"
                OnSendAnswer="OverlaySendAnswerAsync"
                OnSendComment="OverlaySendCommentAsync"
                OnGenerateAiReply="GenerateAiReplyAsync"
                OnDeleteAnswer="@(ans => OverlayDeleteAnswerAsync(ans))"
                OnDeleteComment="@(c => OverlayDeleteCommentAsync(c))"
                OnOpenGallery="OpenOverlayGallery" />
        </div>
        </div>
    }

    </div>
</div>

<TaskBoardGallery @ref="_gallery" />
