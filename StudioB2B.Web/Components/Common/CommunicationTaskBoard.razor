    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        _ = LoadClientOptionsAsync();

        if (BoardState.HasData)
        {
            // Restore from cache instantly — no skeleton, no delay
            _board = BoardState.Board!;
            await StartSignalRAsync();
            _timerTick = new Timer(_ => InvokeAsync(StateHasChanged), null,
                TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

            // Silently refresh in background if data is stale
            if (BoardState.IsStale)
                _ = SilentReloadAsync();
        }
        else
        {
            // First visit: sync + load with skeleton
            await QuickSyncAndReloadAsync();
            await StartSignalRAsync();
            _timerTick = new Timer(_ => InvokeAsync(StateHasChanged), null,
                TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        }

        // Restore active preview if user navigated away and back
        if (BoardState.ActivePreviewExternalId is not null)
        {
            var savedTask = FindTaskInBoard(BoardState.ActivePreviewExternalId, BoardState.ActivePreviewClientId);
            if (savedTask is not null)
                await ShowPreviewAsync(savedTask);
            else
                BoardState.ClearActivePreview();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_board.DoneTasks.Count < _board.DoneTotalCount && !_loadingMore)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("taskBoardInfiniteScroll.init", _doneSentinel, _dotNetRef); }
            catch { /* JS not ready on first render */ }
        }
    }


    private async Task QuickSyncAndReloadAsync()
    {
        // GetBoardAsync fetches live New tasks directly from Ozon — no separate sync step needed.
        await LoadBoardAsync();
    }

    private async Task FullSyncAndReloadAsync()
    {
        // Show skeleton immediately — don't wait for SyncAsync to complete before rendering.
        await LoadBoardAsync();

        // Run full sync in background; silently refresh board once done.
        _syncing = true;
        StateHasChanged();
        try
        {
            await SyncService.SyncAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Синхронизация", "Полная синхронизация завершена", 3000);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Warning, "Синхронизация", ex.Message, 4000); }
        finally { _syncing = false; }

        await SilentReloadAsync();
    }

    private async Task LoadBoardAsync()
    {
        _loading = true;
        _loadingNew = false;
        StateHasChanged();
        try
        {
            var filter = new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            };

            // Phase 1: fast DB load — show InProgress + Done immediately
            _board = await TaskService.GetDbBoardAsync(filter);
            _loading = false;
            _loadingNew = true;
            StateHasChanged();

            // Phase 2: stream live Ozon new tasks — each batch (chats, questions, reviews) renders immediately
            await foreach (var batch in TaskService.StreamNewTasksAsync(filter))
            {
                _board.NewTasks.AddRange(batch);
                foreach (var t in batch)
                    _board.TypeCounts[t.TaskType] = _board.TypeCounts.GetValueOrDefault(t.TaskType) + 1;
                await InvokeAsync(StateHasChanged);
            }
            BoardState.Set(_board);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        finally { _loading = false; _loadingNew = false; StateHasChanged(); }
    }

    /// <summary>Background refresh that doesn't show skeleton — used on re-navigation when cache is stale.</summary>
    private async Task SilentReloadAsync()
    {
        try
        {
            var filter = new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            };

            // Load DB part first, then Ozon new tasks silently
            var dbBoard = await TaskService.GetDbBoardAsync(filter);
            _board = dbBoard;
            await InvokeAsync(StateHasChanged);

            await foreach (var batch in TaskService.StreamNewTasksAsync(filter))
            {
                _board.NewTasks.AddRange(batch);
                foreach (var t in batch)
                    _board.TypeCounts[t.TaskType] = _board.TypeCounts.GetValueOrDefault(t.TaskType) + 1;
                await InvokeAsync(StateHasChanged);
            }
            BoardState.Set(_board);
            await InvokeAsync(StateHasChanged);
        }
        catch { /* silent — don't disturb the user */ }
    }

    [JSInvokable]
    public async Task LoadMoreDoneAsync()
    {
        if (_loadingMore || _board.DoneTasks.Count >= _board.DoneTotalCount) return;

        _loadingMore = true;
        StateHasChanged();
        try
        {
            var filter = new CommunicationTaskFilter { TaskType = _filterType, From = _filterFrom, To = _filterTo, MarketplaceClientId = _filterClientId };
            var (items, total) = await TaskService.GetDoneTasksPageAsync(filter, _board.DoneTasks.Count, DonePageSize);
            _board.DoneTasks.AddRange(items);
            _board.DoneTotalCount = total;
            BoardState.AppendDone(items, total);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        finally { _loadingMore = false; StateHasChanged(); }
    }

    /// <summary>Refreshes board data from the server without triggering skeleton loading.</summary>
    private async Task RefreshBoardSilentAsync()
    {
        try
        {
            var board = await TaskService.GetBoardAsync(new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            });
            _board = board;
            BoardState.Set(board);
            StateHasChanged();
        }
        catch { /* silent */ }
    }

    private async Task StartSignalRAsync()
    {
        try
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            _hubConnection = new HubConnectionBuilder()
                .WithUrl($"{baseUri}/hubs/taskboard")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<object>("TaskClaimed", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("TaskReleased", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("TaskCompleted", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("BoardUpdated", async _ => await InvokeAsync(RefreshBoardSilentAsync));

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinTenantGroup", TenantProvider.TenantId.ToString());
        }
        catch { NotificationService.Notify(NotificationSeverity.Warning, "SignalR", "Не удалось подключиться", 3000); }
    }


    private async Task SetFilter(CommunicationTaskType? type)
    {
        _filterType = _filterType == type ? null : type;
        _board.DoneTasks.Clear();
        _board.DoneTotalCount = 0;
        StateHasChanged();
        try
        {
            var filter = new CommunicationTaskFilter { TaskType = _filterType, From = _filterFrom, To = _filterTo, MarketplaceClientId = _filterClientId };
            var (items, total) = await TaskService.GetDoneTasksPageAsync(filter, 0, DonePageSize);
            _board.DoneTasks.AddRange(items);
            _board.DoneTotalCount = total;
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        StateHasChanged();
    }

