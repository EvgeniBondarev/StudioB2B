                            <span class="question-answer-date">@_questionDetail.Question.PublishedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="question-answer-text">@_questionDetail.Question.Text</div>
                    </div>

                    @* Product card *@
                    @if (_questionDetail.Product is not null)
                    {
                        <div class="question-product-card">
                            <RadzenText TextStyle="TextStyle.Subtitle2"
