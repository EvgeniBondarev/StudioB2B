}

@code {
    private TaskBoardDto _board = new();
    private CommunicationTaskType? _filterType;
    private DateTime? _filterFrom = DateTime.Today.AddDays(-30);
    private DateTime? _filterTo;
    private Guid? _filterClientId;
    private List<ClientOptionDto> _clientOptions = new();
    private bool _loading;
    private bool _syncing;
    private bool _loadingMore;

    private const int DonePageSize = 25;
    private ElementReference _doneSentinel;
    private DotNetObjectReference<CommunicationTaskBoard>? _dotNetRef;

    private HubConnection? _hubConnection;
    private Timer? _timerTick;

    // Preview state
    private CommunicationTaskDto? _previewTask;
    private bool _previewLoading;
    private CommunicationTaskDetailDto? _taskDetail;
    private List<OzonChatMessageDto> _chatMessages = new();
    private OzonChatViewModelDto? _previewChatVm;
    private OzonQuestionDetailDto? _questionDetail;
    private OzonReviewDetailDto? _reviewDetail;

    // Gallery / lightbox state
    private List<string> _galleryItems = new();
    private int _galleryCurrentIndex = -1;
    private ElementReference _galleryDiv;

    private List<CommunicationTaskDto> FilteredNew => ApplyTypeFilter(_board.NewTasks);
    private List<CommunicationTaskDto> FilteredInProgress => ApplyTypeFilter(_board.InProgressTasks);
    private List<CommunicationTaskDto> FilteredDone => ApplyTypeFilter(_board.DoneTasks);

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantProvider.IsResolved) return;

        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        _ = LoadClientOptionsAsync();

        if (BoardState.HasData)
        {
            // Restore from cache instantly — no skeleton, no delay
            _board = BoardState.Board!;
            await StartSignalRAsync();
            _timerTick = new Timer(_ => InvokeAsync(StateHasChanged), null,
                TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));

            // Silently refresh in background if data is stale
            if (BoardState.IsStale)
                _ = SilentReloadAsync();
        }
        else
        {
            // First visit: sync + load with skeleton
            await QuickSyncAndReloadAsync();
            await StartSignalRAsync();
            _timerTick = new Timer(_ => InvokeAsync(StateHasChanged), null,
                TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_board.DoneTasks.Count < _board.DoneTotalCount && !_loadingMore)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("taskBoardInfiniteScroll.init", _doneSentinel, _dotNetRef); }
            catch { /* JS not ready on first render */ }
        }
    }


    private async Task QuickSyncAndReloadAsync()
    {
        // GetBoardAsync fetches live New tasks directly from Ozon — no separate sync step needed.
        await LoadBoardAsync();
    }

    private async Task FullSyncAndReloadAsync()
    {
        // Show skeleton immediately — don't wait for SyncAsync to complete before rendering.
        await LoadBoardAsync();

        // Run full sync in background; silently refresh board once done.
        _syncing = true;
        StateHasChanged();
        try
        {
            await SyncService.SyncAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Синхронизация", "Полная синхронизация завершена", 3000);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Warning, "Синхронизация", ex.Message, 4000); }
        finally { _syncing = false; }

        await SilentReloadAsync();
    }

    private async Task LoadBoardAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var board = await TaskService.GetBoardAsync(new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            });
            _board = board;
            BoardState.Set(board);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        finally { _loading = false; StateHasChanged(); }
    }

    /// <summary>Background refresh that doesn't show skeleton — used on re-navigation when cache is stale.</summary>
    private async Task SilentReloadAsync()
    {
        try
        {
            var board = await TaskService.GetBoardAsync(new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            });
            _board = board;
            BoardState.Set(board);
            await InvokeAsync(StateHasChanged);
        }
        catch { /* silent — don't disturb the user */ }
    }

    [JSInvokable]
    public async Task LoadMoreDoneAsync()
    {
        if (_loadingMore || _board.DoneTasks.Count >= _board.DoneTotalCount) return;

        _loadingMore = true;
        StateHasChanged();
        try
        {
            var filter = new CommunicationTaskFilter { TaskType = _filterType, From = _filterFrom, To = _filterTo, MarketplaceClientId = _filterClientId };
            var (items, total) = await TaskService.GetDoneTasksPageAsync(filter, _board.DoneTasks.Count, DonePageSize);
            _board.DoneTasks.AddRange(items);
            _board.DoneTotalCount = total;
            BoardState.AppendDone(items, total);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        finally { _loadingMore = false; StateHasChanged(); }
    }

    /// <summary>Refreshes board data from the server without triggering skeleton loading.</summary>
    private async Task RefreshBoardSilentAsync()
    {
        try
        {
            var board = await TaskService.GetBoardAsync(new CommunicationTaskFilter
            {
                DoneTake = DonePageSize,
                From = _filterFrom,
                To = _filterTo,
                TaskType = _filterType,
                MarketplaceClientId = _filterClientId
            });
            _board = board;
            BoardState.Set(board);
            StateHasChanged();
        }
        catch { /* silent */ }
    }

    private async Task StartSignalRAsync()
    {
        try
        {
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            _hubConnection = new HubConnectionBuilder()
                .WithUrl($"{baseUri}/hubs/taskboard")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<object>("TaskClaimed", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("TaskReleased", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("TaskCompleted", async _ => await InvokeAsync(RefreshBoardSilentAsync));
            _hubConnection.On<object>("BoardUpdated", async _ => await InvokeAsync(RefreshBoardSilentAsync));

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinTenantGroup", TenantProvider.TenantId.ToString());
        }
        catch { NotificationService.Notify(NotificationSeverity.Warning, "SignalR", "Не удалось подключиться", 3000); }
    }


    private async Task SetFilter(CommunicationTaskType? type)
    {
        _filterType = _filterType == type ? null : type;
        _board.DoneTasks.Clear();
        _board.DoneTotalCount = 0;
        StateHasChanged();
        try
        {
            var filter = new CommunicationTaskFilter { TaskType = _filterType, From = _filterFrom, To = _filterTo, MarketplaceClientId = _filterClientId };
            var (items, total) = await TaskService.GetDoneTasksPageAsync(filter, 0, DonePageSize);
            _board.DoneTasks.AddRange(items);
            _board.DoneTotalCount = total;
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }
        StateHasChanged();
    }

    private async Task OnDateFilterChange(DateTime? _) => await LoadBoardAsync();

    private async Task OnClientFilterChange(object value)
    {
        _filterClientId = value is Guid g ? g : (Guid?)null;
        await LoadBoardAsync();
    }

    private async Task LoadClientOptionsAsync()
    {
        try { _clientOptions = await MarketplaceClientService.GetClientOptionsAsync(); StateHasChanged(); }
        catch { /* non-critical */ }
    }

    private List<CommunicationTaskDto> ApplyTypeFilter(List<CommunicationTaskDto> source)
    {
        if (_filterType is null) return source;
        return source.Where(t => t.TaskType == _filterType.Value).ToList();
    }


    private async Task OnCardClick(CommunicationTaskDto task)
    {
        if (task.Status == CommunicationTaskStatus.InProgress)
        {
            var tabIndex = task.TaskType switch
            {
                CommunicationTaskType.Chat => 1,
                CommunicationTaskType.Review => 2,
                CommunicationTaskType.Question => 3,
                _ => 0
            };
            var encodedId = Uri.EscapeDataString(task.ExternalId);
            Navigation.NavigateTo(
                $"/communication?tab={tabIndex}&id={encodedId}&clientId={task.MarketplaceClientId}",
                forceLoad: false);
            return;
        }

        await ShowPreviewAsync(task);
    }

    private async Task ShowPreviewAsync(CommunicationTaskDto task)
    {
        _previewTask = task;
        _previewLoading = true;
        _taskDetail = null;
        _chatMessages.Clear();
        _previewChatVm = null;
        _questionDetail = null;
        _reviewDetail = null;
        StateHasChanged();

        try
        {
            switch (task.TaskType)
            {
                case CommunicationTaskType.Chat:
                    _previewChatVm = new OzonChatViewModelDto
                    {
                        MarketplaceClientId = task.MarketplaceClientId,
                        MarketplaceClientName = task.MarketplaceClientName,
                        ChatId = task.ExternalId
                    };
                    var history = await ChatService.GetChatHistoryAsync(
                        task.MarketplaceClientId, task.ExternalId, "Backward", limit: 50);
                    if (history is not null)
                        _chatMessages = history.Messages.OrderBy(m => m.CreatedAt).ToList();
                    break;

                case CommunicationTaskType.Question:
                {
                    var creds = await GetClientCredsAsync(task.MarketplaceClientId);
                    var qVm = new OzonQuestionViewModelDto
                    {
                        Id = task.ExternalId,
                        MarketplaceClientId = task.MarketplaceClientId,
                        MarketplaceClientName = task.MarketplaceClientName,
                        ApiId = creds.apiId,
                        ApiKey = creds.apiKey
                    };
                    _questionDetail = await QuestionsService.GetQuestionDetailAsync(qVm);
                    break;
                }

                case CommunicationTaskType.Review:
                {
                    var creds = await GetClientCredsAsync(task.MarketplaceClientId);
                    var rVm = new OzonReviewViewModelDto
                    {
                        Id = task.ExternalId,
                        MarketplaceClientId = task.MarketplaceClientId,
                        MarketplaceClientName = task.MarketplaceClientName,
                        ApiId = creds.apiId,
                        ApiKey = creds.apiKey
                    };
                    _reviewDetail = await ReviewsService.GetReviewDetailAsync(rVm);
                    break;
                }
            }

            // Load time entries / payment detail — only if the task already exists in DB.
            if (task.Id != Guid.Empty)
                _taskDetail = await TaskService.GetTaskDetailAsync(task.Id);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка предпросмотра", ex.Message, 5000);
        }
        finally
        {
            _previewLoading = false;
            StateHasChanged();
        }
    }

    private void ClosePreview()
    {
        _previewTask = null;
        _taskDetail = null;
        _chatMessages.Clear();
        _previewChatVm = null;
        _questionDetail = null;
        _reviewDetail = null;
        GalleryClose();
        StateHasChanged();
    }

    private void OnOpenGallery((List<string> Items, int Index) args)
    {
        _galleryItems = args.Items;
        _galleryCurrentIndex = args.Index;
        _ = InvokeAsync(async () =>
        {
            await Task.Yield();
            await _galleryDiv.FocusAsync();
        });
    }

    private void GalleryNext()
    {
        if (_galleryItems.Count == 0) return;
        _galleryCurrentIndex = (_galleryCurrentIndex + 1) % _galleryItems.Count;
    }

    private void GalleryPrev()
    {
        if (_galleryItems.Count == 0) return;
        _galleryCurrentIndex = (_galleryCurrentIndex - 1 + _galleryItems.Count) % _galleryItems.Count;
    }

    private void GalleryClose()
    {
        _galleryCurrentIndex = -1;
    }

    private void GalleryNavigate(KeyboardEventArgs e)
    {
        if (_galleryCurrentIndex < 0) return;
        switch (e.Key)
        {
            case "ArrowLeft": GalleryPrev(); break;
            case "ArrowRight": GalleryNext(); break;
            case "Escape": GalleryClose(); break;
        }
        StateHasChanged();
    }


    /// <summary>
    /// Returns the current user's ID, re-syncing UserContext from the cascading AuthState
    /// if it is temporarily null (can happen due to an auth-state refresh race).
    /// Returns null and shows an error notification if the user cannot be resolved.
    /// </summary>
    private async Task<Guid?> GetUserIdAsync()
    {
        if (CurrentUser.UserId is not null)
            return CurrentUser.UserId.Value;

        // Re-sync from the cascading principal and retry once
        var authState = await AuthState;
        UserContext.SetUser(authState.User);

        if (CurrentUser.UserId is not null)
            return CurrentUser.UserId.Value;

        NotificationService.Notify(NotificationSeverity.Error, "Ошибка",
            "Не удалось определить текущего пользователя. Обновите страницу.", 5000);
        return null;
    }

    private async Task ClaimAsync(CommunicationTaskDto task)
    {
        var userId = await GetUserIdAsync();
        if (userId is null) return;

        // Optimistic: move card New → InProgress immediately.
        // Live New tasks have Id==Guid.Empty, so match by ExternalId+Type+Client.
        _board.NewTasks.RemoveAll(t =>
            t.TaskType == task.TaskType &&
            t.ExternalId == task.ExternalId &&
            t.MarketplaceClientId == task.MarketplaceClientId);
        task.Status = CommunicationTaskStatus.InProgress;
        task.AssignedToUserId = userId;
        task.HasActiveTimer = true;
        task.StartedAt = DateTime.UtcNow;
        _board.InProgressTasks.Insert(0, task);
        StateHasChanged();

        try
        {
            if (task.Id == Guid.Empty)
            {
                var newId = await TaskService.CreateAndClaimAsync(task, userId.Value);
                if (newId is null)
                    NotificationService.Notify(NotificationSeverity.Warning, "Задача уже занята", "Кто-то успел взять раньше", 3000);
                else
                    task.Id = newId.Value;
            }
            else
            {
                var ok = await TaskService.ClaimTaskAsync(task.Id, userId.Value);
                if (!ok)
                    NotificationService.Notify(NotificationSeverity.Warning, "Задача уже занята", "Кто-то успел взять раньше", 3000);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.InnerException?.Message ?? ex.Message, 8000);
        }

        // Silent refresh to get accurate server state (assignee name, timer start, etc.)
        await RefreshBoardSilentAsync();
    }

    private async Task PauseAsync(CommunicationTaskDto task)
    {
        var userId = await GetUserIdAsync();
        if (userId is null) return;

        // Optimistic: stop timer indicator immediately
        var local = _board.InProgressTasks.FirstOrDefault(t => t.Id == task.Id);
        if (local is not null) { local.HasActiveTimer = false; StateHasChanged(); }

        try { await TaskService.PauseTaskAsync(task.Id, userId.Value); }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }

        await RefreshBoardSilentAsync();
    }

    private async Task ResumeAsync(CommunicationTaskDto task)
    {
        var userId = await GetUserIdAsync();
        if (userId is null) return;

        // Optimistic: start timer indicator immediately
        var local = _board.InProgressTasks.FirstOrDefault(t => t.Id == task.Id);
        if (local is not null) { local.HasActiveTimer = true; local.StartedAt = DateTime.UtcNow; StateHasChanged(); }

        try { await TaskService.ResumeTaskAsync(task.Id, userId.Value); }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }

        await RefreshBoardSilentAsync();
    }

    private async Task CompleteAsync(CommunicationTaskDto task)
    {
        var userId = await GetUserIdAsync();
        if (userId is null) return;

        // Optimistic: move card InProgress → Done immediately
        _board.InProgressTasks.RemoveAll(t => t.Id == task.Id);
        task.Status = CommunicationTaskStatus.Done;
        task.HasActiveTimer = false;
        task.CompletedAt = DateTime.UtcNow;
        _board.DoneTasks.Insert(0, task);
        _board.DoneTotalCount++;
        StateHasChanged();

        try
        {
            var ok = await TaskService.CompleteTaskAsync(task.Id, userId.Value);
            if (ok) NotificationService.Notify(NotificationSeverity.Success, "Задача выполнена", task.Title, 2000);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }

        // Refresh to get server-calculated PaymentAmount
        await RefreshBoardSilentAsync();
    }

    private async Task ReleaseAsync(CommunicationTaskDto task)
    {
        var userId = await GetUserIdAsync();
        if (userId is null) return;

        // Optimistic: remove from InProgress. Task will reappear in New via live Ozon feed on next board refresh.
        _board.InProgressTasks.RemoveAll(t => t.Id == task.Id);
        StateHasChanged();

        try { await TaskService.ReleaseTaskAsync(task.Id, userId.Value); }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Ошибка", ex.Message, 5000); }

        await RefreshBoardSilentAsync();
    }

    private async Task<(string apiId, string apiKey)> GetClientCredsAsync(Guid marketplaceClientId)
    {
        var creds = await MarketplaceClientService.GetClientCredentialsAsync(marketplaceClientId);
        return creds is not null ? (creds.Value.ApiId, creds.Value.Key) : ("", "");
    }


    private static string GetTypeClass(CommunicationTaskType type) => type switch
    {
        CommunicationTaskType.Chat => "task-type-chat",
        CommunicationTaskType.Question => "task-type-question",
        CommunicationTaskType.Review => "task-type-review",
        _ => ""
    };

    private static string GetTypeLabel(CommunicationTaskType type) => type switch
    {
        CommunicationTaskType.Chat => "Чат",
        CommunicationTaskType.Question => "Вопрос",
        CommunicationTaskType.Review => "Отзыв",
        _ => "—"
    };

    private decimal ComputeEstimate(CommunicationTaskDto task)
    {
        if (_board.ActiveRates.Count == 0) return 0m;

        var liveTicks = task.TotalTimeSpentTicks;
        if (task.HasActiveTimer && task.StartedAt.HasValue)
            liveTicks += (DateTime.UtcNow - task.StartedAt.Value).Ticks;

        var totalMinutes = (decimal)TimeSpan.FromTicks(liveTicks).TotalMinutes;
        var total = 0m;

        foreach (var rate in _board.ActiveRates)
        {
            if (rate.TaskType.HasValue && rate.TaskType != task.TaskType) continue;
            if (rate.UserId.HasValue && rate.UserId != task.AssignedToUserId) continue;
            if (rate.MinDurationMinutes.HasValue && totalMinutes < rate.MinDurationMinutes.Value) continue;
            if (rate.MaxDurationMinutes.HasValue && totalMinutes > rate.MaxDurationMinutes.Value) continue;

            total += rate.PaymentMode switch
            {
                PaymentMode.PerTask => rate.Rate,
                PaymentMode.Hourly => rate.Rate * (totalMinutes / 60m),
                _ => 0m
            };
        }

        return Math.Round(total, 2);
    }

    private static string GetStatusLabel(CommunicationTaskStatus status) => status switch
    {
        CommunicationTaskStatus.New => "Новая",
        CommunicationTaskStatus.InProgress => "В работе",
        CommunicationTaskStatus.Done => "Выполнена",
        CommunicationTaskStatus.Cancelled => "Отменена",
        _ => "—"
    };

    private static string FormatTimeAgo(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalSeconds < 60) return "только что";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} мин";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч";
        if (diff.TotalDays < 2) return "вчера";
        return utcTime.ToLocalTime().ToString("dd.MM");
    }

    private static string FormatDuration(DateTime? startedAt)
    {
        if (startedAt is null) return "—";
        var diff = DateTime.UtcNow - startedAt.Value;
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}ч {diff.Minutes:D2}м {diff.Seconds:D2}с";
        if (diff.TotalMinutes >= 1) return $"{(int)diff.TotalMinutes}м {diff.Seconds:D2}с";
        return $"{(int)diff.TotalSeconds}с";
    }

    private static string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}ч {ts.Minutes}м";
        return $"{(int)ts.TotalMinutes}м";
    }

    public async ValueTask DisposeAsync()
    {
        _timerTick?.Dispose();
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("taskBoardInfiniteScroll.dispose"); }
        catch { /* ignore */ }
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
