                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600;margin:0;">@_questionDetail.Product.Name</RadzenText>
                                    <div class="question-product-props">
                                        <span><strong>SKU:</strong> @_questionDetail.Product.Sku</span>
                                        @if (!string.IsNullOrWhiteSpace(_questionDetail.Product.OfferId))
                                        {
                                            <span><strong>Артикул:</strong> @_questionDetail.Product.OfferId</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Answers *@
                    @if (_questionDetail.Answers.Count > 0)
                    {
                        <div class="question-answers-section">
                            <RadzenText TextStyle="TextStyle.Subtitle2"
