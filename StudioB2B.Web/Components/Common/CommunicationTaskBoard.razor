                                              IsBusy="@_overlaySendingAnswer"
                                              Disabled="@(string.IsNullOrWhiteSpace(_overlayAnswerText) || (_overlayAnswerText?.Length ?? 0) < 2 || (_overlayAnswerText?.Length ?? 0) > 3000)"
                                              Click="SendOverlayAnswerAsync" Title="Ответить" />
