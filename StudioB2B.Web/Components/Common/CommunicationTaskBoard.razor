@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Services
@using StudioB2B.Domain.Constants
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.EntityFrameworkCore

@inject ICommunicationTaskService TaskService
@inject ICommunicationTaskSyncService SyncService
@inject IOzonChatService ChatService
@inject IOzonQuestionsService QuestionsService
@inject IOzonReviewsService ReviewsService
@inject IMarketplaceClientService MarketplaceClientService
@inject IUserService UserService
@inject ITenantProvider TenantProvider
@inject ICurrentUserProvider CurrentUser
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject TaskBoardStateService BoardState
@inject UserContext UserContext

@implements IAsyncDisposable

<link rel="stylesheet" href="css/taskboard.css?v=1775729250" />
<link rel="stylesheet" href="css/chats/chatMessages.css" />
<link rel="stylesheet" href="css/chats/chatComposer.css" />
<script src="js/taskboard.js?v=1775729247"></script>

<div class="taskboard-root">


    <div class="taskboard-sidebar @(_sidebarOpen ? "open" : "")">

        <div class="tb-sidebar-handle" @onclick="@(() => _sidebarOpen = !_sidebarOpen)" title="Фильтры">
            <span class="rzi" style="font-size:1.2rem;">@(_sidebarOpen ? "close" : "tune")</span>
        </div>

        @if (_sidebarOpen)
        {
            <div class="tb-sidebar-card">
                <div class="tb-sidebar-actions">
                    <RadzenButton Text="Обновить" Icon="refresh" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Light"
                                  Size="ButtonSize.Small" Click="@QuickSyncAndReloadAsync" IsBusy="@_loading"
                                  Style="flex:1;" />
                    <RadzenButton Icon="cloud_sync" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" Click="@FullSyncAndReloadAsync"
                                  IsBusy="@_syncing" title="Полная синхронизация" />
                </div>
            </div>

                <div class="tb-sidebar-card">
                <div class="tb-sidebar-card-header">
                    <span>Тип задачи</span>
                    @if (_filterTypes.Count > 0)
                    {
                        <span class="tb-sidebar-clear" @onclick="@(async () => { _filterTypes.Clear(); await LoadBoardAsync(); })" title="Сбросить">
                            <span class="rzi">close</span>
                        </span>
                    }
                </div>
                <div class="tb-sidebar-card-body">
                    <label class="tb-check-item type-chat">
                        <input type="checkbox" checked="@_filterTypes.Contains(CommunicationTaskType.Chat)"
                               @onchange="@(async e => await ToggleTypeFilter(CommunicationTaskType.Chat, (bool)e.Value!))" />
                        <span class="tb-sidebar-dot"></span>
                        Чаты
                        <span class="tb-sidebar-count" style="margin-left:auto;">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Chat))</span>
                    </label>
                    <label class="tb-check-item type-question">
                        <input type="checkbox" checked="@_filterTypes.Contains(CommunicationTaskType.Question)"
                               @onchange="@(async e => await ToggleTypeFilter(CommunicationTaskType.Question, (bool)e.Value!))" />
                        <span class="tb-sidebar-dot"></span>
                        Вопросы
                        <span class="tb-sidebar-count" style="margin-left:auto;">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Question))</span>
                    </label>
                    <label class="tb-check-item type-review">
                        <input type="checkbox" checked="@_filterTypes.Contains(CommunicationTaskType.Review)"
                               @onchange="@(async e => await ToggleTypeFilter(CommunicationTaskType.Review, (bool)e.Value!))" />
                        <span class="tb-sidebar-dot"></span>
                        Отзывы
                        <span class="tb-sidebar-count" style="margin-left:auto;">@(_board.TypeCounts.GetValueOrDefault(CommunicationTaskType.Review))</span>
                    </label>
                </div>
            </div>

            <div class="tb-sidebar-card">
                @{ var dateActive = _filterFrom.HasValue || _filterTo.HasValue; }
                <div class="tb-sidebar-card-header">
                    <span>Дата</span>
                    @if (dateActive)
                    {
                        <span class="tb-sidebar-clear"
                              @onclick="@(async () => { _filterFrom = null; _filterTo = null; await LoadBoardAsync(); })"
                              title="Сбросить">
                            <span class="rzi">close</span>
                        </span>
                    }
                </div>
                <div class="tb-sidebar-card-body" style="padding:0.5rem 0.6rem 0.6rem;">
                    <div class="tb-sidebar-field-label">С</div>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="_filterFrom"
                                      DateFormat="dd.MM.yyyy" ShowCalendarWeek="false"
                                      Placeholder="дд.мм.гггг" Style="width:100%;margin-bottom:0.4rem;" />
                    <div class="tb-sidebar-field-label">По</div>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="_filterTo"
                                      DateFormat="dd.MM.yyyy" ShowCalendarWeek="false"
                                      Placeholder="дд.мм.гггг" Style="width:100%;margin-bottom:0.5rem;" />
                    <RadzenButton Text="Применить" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Style="width:100%;"
                                  Click="@(async () => await LoadBoardAsync())" />
                </div>
            </div>

            @if (_clientOptions.Count > 0)
            {
                <div class="tb-sidebar-card">
                    <div class="tb-sidebar-card-header">
                        <span>Кабинет</span>
                        @if (_filterClientIds.Count > 0)
                        {
                            <span class="tb-sidebar-clear" @onclick="@(async () => { _filterClientIds.Clear(); await LoadBoardAsync(); })" title="Сбросить">
                                <span class="rzi">close</span>
                            </span>
                        }
                    </div>
                    <div class="tb-sidebar-card-body">
                        @foreach (var c in _clientOptions)
                        {
                            var cCopy = c;
                            <label class="tb-check-item">
                                <input type="checkbox" checked="@_filterClientIds.Contains(cCopy.Id)"
                                       @onchange="@(async e => await ToggleClientFilter(cCopy.Id, (bool)e.Value!))" />
                                <span class="tb-sidebar-dot"></span>
                                @cCopy.Name
                            </label>
                        }
                    </div>
                </div>
            }

            @if (_userOptions.Count > 0)
            {
                <div class="tb-sidebar-card">
                    <div class="tb-sidebar-card-header">
                        <span>Сотрудник</span>
                        @if (_filterUserIds.Count > 0)
                        {
                            <span class="tb-sidebar-clear" @onclick="@(async () => { _filterUserIds.Clear(); await ReloadDbAndKeepNewAsync(); })" title="Сбросить">
                                <span class="rzi">close</span>
                            </span>
                        }
                    </div>
                    <div class="tb-sidebar-card-body">
                        @foreach (var u in _userOptions)
                        {
                            var uCopy = u;
                            var uName = $"{uCopy.FirstName} {uCopy.LastName}".Trim();
                            <label class="tb-check-item">
                                <input type="checkbox" checked="@_filterUserIds.Contains(uCopy.Id)"
                                       @onchange="@(async e => await ToggleUserFilter(uCopy.Id, (bool)e.Value!))" />
                                <span class="tb-sidebar-dot"></span>
                                @uName
                            </label>
                        }
                    </div>
                </div>
            }

            <div class="tb-sidebar-card">
                <div class="tb-sidebar-card-body tb-sidebar-links" style="padding:0.4rem 0.45rem;">
                    <span class="tb-sidebar-link" @onclick="@(() => Navigation.NavigateTo("/task-board-report"))">
                        <span class="rzi" style="font-size:1rem;">bar_chart</span>
                        Отчёт по оплате
                    </span>
                    <span class="tb-sidebar-link" @onclick="@(() => Navigation.NavigateTo("/task-board-settings"))">
                        <span class="rzi" style="font-size:1rem;">settings</span>
                        Настройки тарифов
                    </span>
                </div>
            </div>
        }

    </div>

    <div class="taskboard-main @(_previewTask != null ? "has-preview" : "")">
    <div class="taskboard-columns">

        @if (_loading || _syncing)
        {
            @for (var col = 0; col < 3; col++)
            {
                <div class="taskboard-column">
                    <div class="taskboard-column-header" style="opacity:0.5;">
                        <div class="skeleton-line title"></div>
                        <div class="skeleton-line short"></div>
                    </div>
                    <div class="taskboard-column-body">
                        @for (var i = 0; i < 4; i++)
                        {
                            <div class="skeleton-card">
                                <div style="display:flex;gap:0.5rem;align-items:center;">
                                    <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                    <div class="skeleton-line title"></div>
                                </div>
                                <div class="skeleton-line long"></div>
                                <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                    <div class="skeleton-line short"></div>
                                    <div class="skeleton-line short" style="width:30%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {

        <!-- NEW -->
        <div class="taskboard-column col-new">
            <div class="taskboard-column-header">
                <span>Новые</span>
                <span class="taskboard-column-count">@FilteredNew.Count</span>
                @if (_loadingNew)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                              Size="ProgressBarCircularSize.ExtraSmall"
                                              Style="margin-left:auto;" />
                }
            </div>
            <div class="taskboard-column-body">
                @if (_loadingNew && FilteredNew.Count == 0)
                {
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="skeleton-card">
                            <div style="display:flex;gap:0.5rem;align-items:center;">
                                <div class="skeleton-line short" style="width:48px;height:18px;border-radius:10px;"></div>
                                <div class="skeleton-line title"></div>
                            </div>
                            <div class="skeleton-line long"></div>
                            <div style="display:flex;justify-content:space-between;margin-top:0.1rem;">
                                <div class="skeleton-line short"></div>
                                <div class="skeleton-line short" style="width:30%;"></div>
                            </div>
                        </div>
                    }
                }
                else if (FilteredNew.Count == 0)
                {
                    <div class="taskboard-empty"><RadzenIcon Icon="inbox" /><span>Задач нет</span></div>
                }
                else
                {
                    @foreach (var task in FilteredNew)
                    {
                        <div class="task-card @(task.WasPreviouslyCompleted ? "task-card--reopened" : "")" @onclick="@(() => OnCardClick(task))">
                            <div class="task-card-header">
                                <span class="task-type-badge @GetTypeClass(task.TaskType)">@GetTypeLabel(task.TaskType)</span>
                                <span class="task-card-title" title="@task.Title">@task.Title</span>
                                @if (task.TaskType == CommunicationTaskType.Chat && task.UnreadCount > 0)
                                {
                                    <span class="task-unread-badge" title="Непрочитанных сообщений">@task.UnreadCount</span>
                                }
                                @if (task.WasPreviouslyCompleted)
                                {
                                    <span class="task-was-completed-badge" title="Покупатель написал снова после завершения">Повтор</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.PreviewText))
                            {
                                <div class="task-card-preview">@task.PreviewText</div>
                            }
                            <div class="task-card-footer">
                                <span class="task-card-time">
                                    <RadzenIcon Icon="schedule" Style="font-size:0.85rem;" />
                                    @FormatTimeAgo(task.CreatedAt)
                                </span>
                                @if (!string.IsNullOrEmpty(task.ExternalStatus))
                                {
                                    <span class="task-external-status">@task.ExternalStatus</span>
                                }
                                @if (_board.PaymentEstimates.TryGetValue(task.TaskType, out var cardEst) && cardEst > 0)
                                {
                                    <span class="task-estimate-badge" title="Потенциальный заработок за задачу">~@cardEst.ToString("F0") ₽</span>
                                }
                                else if (_board.HourlyEstimates.TryGetValue(task.TaskType, out var cardHr) && cardHr > 0)
                                {
                                    <span class="task-estimate-badge" title="Ставка за час">@cardHr.ToString("F0") ₽/ч</span>
                                }
                            </div>
                            <div class="task-card-actions">
                                <RadzenButton Text="Взять" Icon="play_arrow"
                                              ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall"
                                              Click="@(async () => await ClaimAsync(task))"
                                              @onclick:stopPropagation="true" />
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- IN PROGRESS -->
        <div class="taskboard-column col-inprogress">
            <div class="taskboard-column-header">
                <span>В работе</span>
                <span class="taskboard-column-count">@FilteredInProgress.Count</span>
            </div>
            @if (_previewTask is not null && _previewTask.Status == CommunicationTaskStatus.InProgress)
            {
                var _inpToShow = FilteredInProgress;
                if (_inpToShow.Count > 0)
                {
                    <div class="taskboard-pinned-card">
                    @foreach (var task in _inpToShow.Take(1))
                    {
                        <div class="task-card @(_previewTask?.Id == task.Id ? "selected" : "")" @onclick="@(() => OnCardClick(task))">
                            <div class="task-card-header">
                                <span class="task-type-badge @GetTypeClass(task.TaskType)">@GetTypeLabel(task.TaskType)</span>
                                <span class="task-card-title" title="@task.Title">@task.Title</span>
                                @if (task.TaskType == CommunicationTaskType.Chat && task.UnreadCount > 0)
                                {
                                    <span class="task-unread-badge" title="Непрочитанных сообщений">@task.UnreadCount</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.PreviewText))
                            {
                                <div class="task-card-preview">@task.PreviewText</div>
                            }
                            @if (task.HasActiveTimer)
                            {
                                <div class="task-timer-active">
                                    <span class="timer-dot"></span>
                                    <span class="live-timer" data-started="@task.StartedAt?.ToString("o")" data-accumulated="@task.TotalTimeSpentTicks">@FormatDuration(task.StartedAt, task.TotalTimeSpentTicks)</span>
                                </div>
                            }
                            <div class="task-card-footer">
                                <span class="task-card-time">
                                    <RadzenIcon Icon="schedule" Style="font-size:0.85rem;" />
                                    @FormatTimeAgo(task.UpdatedAt)
                                </span>
                                @if (task.AssignedToUserName is not null)
                                {
                                    <span class="task-card-assignee">
                                        <RadzenIcon Icon="person" Style="font-size:0.85rem;" />
                                        @task.AssignedToUserName
                                    </span>
                                }
                                @{ var inProgressEst = ComputeEstimate(task); }
                                @if (inProgressEst > 0)
                                {
                                    <span class="task-estimate-badge" title="Ожидаемая оплата по текущим тарифам">~@inProgressEst.ToString("F0") ₽</span>
                                }
                                else if (_board.PaymentEstimates.TryGetValue(task.TaskType, out var inpBrdEst) && inpBrdEst > 0)
                                {
                                    <span class="task-estimate-badge" title="Потенциальный заработок за задачу">~@inpBrdEst.ToString("F0") ₽</span>
                                }
                                else if (_board.HourlyEstimates.TryGetValue(task.TaskType, out var inpBrdHr) && inpBrdHr > 0)
                                {
                                    <span class="task-estimate-badge" title="Ставка за час">@inpBrdHr.ToString("F0") ₽/ч</span>
                                }
                            </div>
                            @if (task.AssignedToUserId == (_myTenantId ?? CurrentUser.UserId))
                            {
                                <div class="task-card-actions">
                                    @if (task.HasActiveTimer)
                                    {
                                        <RadzenButton Text="Пауза" Icon="pause"
                                                      ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.ExtraSmall"
                                                      Click="@(async () => await PauseAsync(task))"
                                                      @onclick:stopPropagation="true" />
                                    }
                                    else
                                    {
                                        <RadzenButton Text="Продолжить" Icon="play_arrow"
                                                      ButtonStyle="ButtonStyle.Info" Size="ButtonSize.ExtraSmall"
                                                      Click="@(async () => await ResumeAsync(task))"
                                                      @onclick:stopPropagation="true" />
                                    }
                                    <RadzenButton Text="Готово" Icon="check"
                                                  ButtonStyle="ButtonStyle.Success" Size="ButtonSize.ExtraSmall"
                                                  Click="@(async () => await CompleteAsync(task))"
                                                  @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="replay" ButtonStyle="ButtonStyle.Danger" Shade="Shade.Lighter" Size="ButtonSize.ExtraSmall"
                                                  Click="@(async () => await ReleaseAsync(task))"
                                                  @onclick:stopPropagation="true"
                                                  title="Снять с себя" />
                                </div>
                            }
                        </div>
                    }
                    </div>
                }
                        <div class="task-detail-overlay @GetPreviewTypeClass(_previewTask!.TaskType)">
        <div class="task-detail-header">
            <div style="display:flex;align-items:center;gap:0.4rem;flex:1;min-width:0;flex-wrap:wrap;overflow:hidden;">
                <span style="font-weight:600;font-size:0.95rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:1;min-width:0;">@_previewTask.Title</span>
                <span class="task-type-badge @GetTypeClass(_previewTask.TaskType)">@GetTypeLabel(_previewTask.TaskType)</span>
                    @if (!string.IsNullOrEmpty(_previewTask.ExternalStatus) && _previewTask.TaskType != CommunicationTaskType.Chat)
                    {
                        <span class="task-external-status">@_previewTask.ExternalStatus</span>
                    }
                    @if (_previewTask.TaskType == CommunicationTaskType.Chat && _previewTask.UnreadCount > 0)
                    {
                        <span class="task-unread-badge">@_previewTask.UnreadCount непрочит.</span>
                    }
                    @if (_previewTask.Status != CommunicationTaskStatus.Done)
                    {
                        var hasHdrEst = _board.PaymentEstimates.TryGetValue(_previewTask.TaskType, out var hdrEst) && hdrEst > 0;
                        var hasHdrHr = _board.HourlyEstimates.TryGetValue(_previewTask.TaskType, out var hdrHr) && hdrHr > 0;
                        if (hasHdrEst || hasHdrHr)
                        {
                            <div class="earnings-popup-wrap">
                                <span class="task-estimate-badge earnings-trigger">
                                    @if (hasHdrEst) { @($"~{hdrEst:F0} ₽") } else { @($"{hdrHr:F0} ₽/ч") }
                                </span>
                                <div class="earnings-popup">
                                    <div style="font-size:0.78rem;font-weight:600;margin-bottom:0.4rem;display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                                        <span style="display:flex;align-items:center;gap:0.3rem;"><span class="rzi" style="font-size:0.9rem;">payments</span> Потенциальный заработок</span>
                                        <span style="display:flex;gap:0.3rem;flex-wrap:wrap;">
                                            @if (hasHdrEst) { <span style="font-weight:700;color:#5b21b6;">~@hdrEst.ToString("F0") ₽ за задачу</span> }
                                            @if (hasHdrHr) { <span style="font-weight:700;color:#5b21b6;">@hdrHr.ToString("F0") ₽/ч</span> }
                                        </span>
                                    </div>
                                    @if (_taskDetail is not null && (_taskDetail.TimeEntries.Count > 0 || (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)))
                                    {
                                        <div style="border-top:1px solid var(--rz-base-200);padding-top:0.4rem;">
                                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.3rem;">
                                                <span style="font-size:0.73rem;font-weight:600;color:var(--rz-text-secondary-color);display:flex;align-items:center;gap:0.25rem;"><span class="rzi" style="font-size:0.85rem;">schedule</span> Время и оплата</span>
                                                @if (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)
                                                {
                                                    <span class="task-payment-badge" style="font-size:0.73rem;">+@_previewTask.PaymentAmount.Value.ToString("F0") ₽</span>
                                                }
                                                else if (_previewTask.TotalTimeSpentTicks > 0)
                                                {
                                                    <span style="font-size:0.73rem;font-weight:600;color:var(--rz-text-secondary-color);">@FormatTimeSpan(TimeSpan.FromTicks(_previewTask.TotalTimeSpentTicks))</span>
                                                }
                                            </div>
                                            @if (_taskDetail.TimeEntries.Count > 0)
                                            {
                                                <table style="width:100%;font-size:0.72rem;border-collapse:collapse;">
                                                    <thead>
                                                        <tr style="color:var(--rz-text-secondary-color);">
                                                            <th style="text-align:left;padding:2px 4px;font-weight:500;">Начало</th>
                                                            <th style="text-align:left;padding:2px 4px;font-weight:500;">Конец</th>
                                                            <th style="text-align:right;padding:2px 4px;font-weight:500;">Длит.</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var e in _taskDetail.TimeEntries.OrderBy(x => x.StartedAt))
                                                        {
                                                            <tr style="border-top:1px solid var(--rz-base-200);">
                                                                <td style="padding:3px 4px;">@e.StartedAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                                                <td style="padding:3px 4px;">@(e.EndedAt.HasValue ? e.EndedAt.Value.ToLocalTime().ToString("dd.MM HH:mm") : "⏱ в процессе")</td>
                                                                <td style="padding:3px 4px;text-align:right;font-variant-numeric:tabular-nums;">
                                                                    @if (e.DurationMinutes >= 60)
                                                                    { @($"{(int)(e.DurationMinutes / 60)}ч {(int)(e.DurationMinutes % 60)}м") }
                                                                    else
                                                                    { @($"{(int)e.DurationMinutes}м") }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                                @if (_taskDetail.TimeEntries.Count > 1)
                                                {
                                                    var totalMin = _taskDetail.TimeEntries.Where(e => e.EndedAt.HasValue).Sum(e => e.DurationMinutes);
                                                    <div style="text-align:right;font-size:0.72rem;color:var(--rz-text-secondary-color);margin-top:3px;padding-right:4px;">
                                                        Итого: @(totalMin >= 60 ? $"{(int)(totalMin / 60)}ч {(int)(totalMin % 60)}м" : $"{(int)totalMin}м")
                                                        @if (_previewTask.PaymentAmount.HasValue && _previewTask.PaymentAmount > 0)
                                                        {
                                                            <span style="margin-left:8px;font-weight:700;color:#065f46;">= +@_previewTask.PaymentAmount.Value.ToString("F0") ₽</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
            </div>
            <div style="display:flex;align-items:center;gap:0.25rem;flex-shrink:0;">
                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="ClosePreview" />
            </div>
        </div>
        <div class="task-detail-body" style="@(_previewTask.TaskType == CommunicationTaskType.Chat ? "overflow:hidden;" : "overflow-y:auto;")">
            @if (_previewLoading)
            {
                <div style="display:flex;align-items:center;justify-content:center;padding:3rem;gap:0.5rem;">
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                    <span style="color:var(--rz-text-secondary-color);">Загрузка...</span>
                </div>
            }
            else
            {
                @* ── Chat preview ── *@
                @if (_previewTask.TaskType == CommunicationTaskType.Chat)
                {
                    @if (_chatFallbackUrl is not null)
                    {
                        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;text-align:center;">
                            <span class="rzi" style="font-size:2.5rem;color:var(--rz-warning)">lock</span>
                            <RadzenText TextStyle="TextStyle.Body1" Style="color:var(--rz-text-secondary-color);">
                                История чата недоступна через API для этого клиента.<br />
                                Откройте чат напрямую на сайте Ozon Seller.
                            </RadzenText>
                            <RadzenButton Text="Открыть в Ozon Seller"
                                          Icon="open_in_new"
                                          ButtonStyle="ButtonStyle.Primary"
