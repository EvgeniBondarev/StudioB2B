@using System.Text.Json
@using StudioB2B.Domain.Entities

@if (_summary is not null)
{
    <RadzenStack Gap="1rem">
        @if (History.Status == SyncJobStatusEnum.Succeeded)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">
                Обновление завершено успешно.
            </RadzenAlert>
        }
        else if (History.Status == SyncJobStatusEnum.Failed)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
                Ошибка: @History.ErrorMessage
            </RadzenAlert>
        }
        else if (History.Status == SyncJobStatusEnum.Cancelled)
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
                Задача была отменена.
            </RadzenAlert>
        }

        @if (_summary.PerClient.Count > 0)
        {
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Итог по клиентам</RadzenText>
            <RadzenDataGrid TItem="ClientSyncResultItemDto" Data="@_summary.PerClient"
                            Density="Density.Compact" AllowSorting="true">
                <Columns>
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ClientName" Title="Клиент" />
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="Mode" Title="Режим" Width="80px" />
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ShipmentsUpdated" Title="Отправлений обновлено" Width="140px" />
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersSelectedForUpdate" Title="Заказов выбрано для обновления" Width="200px" />
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersSkipped" Title="Заказов пропущено" Width="140px" />
                    <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Title="Изменённые поля">
                        <Template Context="c">@c.UpdatedFieldsSummary</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap">
                <RadzenText TextStyle="TextStyle.Body2">
                    <strong>Заказов выбрано для обновления:</strong> @_summary.Total.OrdersSelectedForUpdate
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">
                    <strong>Заказов пропущено (конечный статус):</strong> @_summary.Total.OrdersSkipped
                </RadzenText>
            </RadzenStack>
        }

        @if (_summary.UpdatedShipments.Count > 0)
        {
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Детализация изменений статусов</RadzenText>
            <RadzenDataGrid TItem="ShipmentUpdateItemDto" Data="@_summary.UpdatedShipments"
                            Density="Density.Compact" AllowSorting="true"
                            AllowPaging="true" PageSize="15">
                <Columns>
                    <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="PostingNumber" Title="Номер отправления" />
                    <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="ClientName" Title="Клиент" />
                    <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="OldStatusName" Title="Было" />
                    <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="NewStatusName" Title="Стало" />
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenStack>
}
else if (History.Status is SyncJobStatusEnum.Failed)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">
        Ошибка: @History.ErrorMessage
    </RadzenAlert>
}
else if (History.Status is SyncJobStatusEnum.Cancelled)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Задача была отменена.
    </RadzenAlert>
}

@code {
    [Parameter, EditorRequired] public SyncJobHistory History { get; set; } = null!;

    private OrderSyncSummaryDto? _summary;

    protected override void OnParametersSet()
    {
        _summary = string.IsNullOrEmpty(History.ResultJson)
            ? null
            : JsonSerializer.Deserialize<OrderSyncSummaryDto>(History.ResultJson);
    }
}

