@if (!string.IsNullOrWhiteSpace(Error))
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin-bottom: 1rem;">
        @Error
    </RadzenAlert>
}

<form method="post" action="/api/auth/login">
    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

    <RadzenStack Gap="1rem">

        <RadzenFormField Text="Email" Style="width: 100%;">
            <RadzenTextBox Name="email" Style="width: 100%;" autocomplete="username" />
        </RadzenFormField>

        <RadzenFormField Text="Пароль" Style="width: 100%;">
            <RadzenPassword Name="password" Style="width: 100%;" autocomplete="current-password" />
        </RadzenFormField>

        <RadzenButton ButtonType="ButtonType.Submit"
                      Text="Войти"
                      ButtonStyle="ButtonStyle.Primary"
                      Style="width: 100%; justify-content: center;" />
    </RadzenStack>
</form>

@code {
    [Parameter] public string ReturnUrl { get; set; } = "/";
    [Parameter] public string? Error { get; set; }
}

