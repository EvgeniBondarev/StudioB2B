@using StudioB2B.Domain.Entities.Orders
@using System.Text.Json
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces
@using SyncJobType = StudioB2B.Domain.Constants.SyncJobTypeEnum

<RadzenStack Gap="1.25rem">

    <!-- Тип задачи -->
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Тип задачи</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem">
            <RadzenCard Style="@CardStyle(SyncJobType.Sync)" @onclick="@(() => _jobType = SyncJobType.Sync)" class="rz-cursor-pointer">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width:140px; padding:0.5rem 0.25rem;">
                    <RadzenIcon Icon="cloud_sync" Style="font-size:2rem; color:var(--rz-primary);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Загрузка заказов</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard Style="@CardStyle(SyncJobType.Update)" @onclick="@(() => _jobType = SyncJobType.Update)" class="rz-cursor-pointer">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width:140px; padding:0.5rem 0.25rem;">
                    <RadzenIcon Icon="sync" Style="font-size:2rem; color:var(--rz-secondary);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Обновление статусов</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard Style="@CardStyle(SyncJobType.Returns)" @onclick="@(() => _jobType = SyncJobType.Returns)" class="rz-cursor-pointer">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center" Style="min-width:140px; padding:0.5rem 0.25rem;">
                    <RadzenIcon Icon="assignment_return" Style="font-size:2rem; color:var(--rz-info);" />
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Загрузка возвратов</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>
    </RadzenStack>

    <!-- Тип расписания -->
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Тип расписания</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem">
            @foreach (var opt in _scheduleTypeOptions)
            {
                <RadzenButton Text="@opt.Label"
                              ButtonStyle="@(_scheduleType == opt.Value ? ButtonStyle.Primary : ButtonStyle.Light)"
                              Size="ButtonSize.Small"
                              Click="@(() => _scheduleType = opt.Value)" />
            }
        </RadzenStack>
    </RadzenStack>

    <!-- Параметры расписания -->
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Параметры расписания</RadzenText>

        @if (_scheduleType == ScheduleUiType.EveryNMinutes)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                <RadzenText TextStyle="TextStyle.Body2">Каждые</RadzenText>
                <RadzenNumeric TValue="int" @bind-Value="_intervalMinutes" Min="1" Max="1440" Style="width:90px;" />
                <RadzenText TextStyle="TextStyle.Body2">минут</RadzenText>
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.EveryNHours)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                <RadzenText TextStyle="TextStyle.Body2">Каждые</RadzenText>
                <RadzenNumeric TValue="int" @bind-Value="_intervalHours" Min="1" Max="23" Style="width:80px;" />
                <RadzenText TextStyle="TextStyle.Body2">часов</RadzenText>
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.EveryNDays)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem" Wrap="FlexWrap.Wrap">
                <RadzenText TextStyle="TextStyle.Body2">Каждые</RadzenText>
                <RadzenNumeric TValue="int" @bind-Value="_intervalDays" Min="1" Max="30" Style="width:80px;" />
                <RadzenText TextStyle="TextStyle.Body2">дней в</RadzenText>
                <RadzenDatePicker TValue="DateTime" @bind-Value="_timeValue" ShowTime="true" TimeOnly="true"
                                  DateFormat="HH:mm" Style="width:110px;" />
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.DailyAt)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                <RadzenText TextStyle="TextStyle.Body2">Ежедневно в</RadzenText>
                <RadzenDatePicker TValue="DateTime" @bind-Value="_timeValue" ShowTime="true" TimeOnly="true"
                                  DateFormat="HH:mm" Style="width:110px;" />
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.WeeklyAt)
        {
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Body2">Дни недели:</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.35rem" Wrap="FlexWrap.Wrap">
                    @foreach (var d in _weekDays)
                    {
                        var selected = _selectedDays.Contains(d.Value);
                        <RadzenButton Text="@d.Label"
                                      Size="ButtonSize.ExtraSmall"
                                      ButtonStyle="@(selected ? ButtonStyle.Primary : ButtonStyle.Light)"
                                      Click="@(() => ToggleDay(d.Value))" />
                    }
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem" Style="margin-top:0.25rem;">
                    <RadzenText TextStyle="TextStyle.Body2">В</RadzenText>
                    <RadzenDatePicker TValue="DateTime" @bind-Value="_timeValue" ShowTime="true" TimeOnly="true"
                                      DateFormat="HH:mm" Style="width:110px;" />
                </RadzenStack>
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.MonthlyAt)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem" Wrap="FlexWrap.Wrap">
                <RadzenText TextStyle="TextStyle.Body2">Числа</RadzenText>
                <RadzenNumeric TValue="int" @bind-Value="_dayOfMonth" Min="1" Max="28" Style="width:70px;" />
                <RadzenText TextStyle="TextStyle.Body2">в</RadzenText>
                <RadzenDatePicker TValue="DateTime" @bind-Value="_timeValue" ShowTime="true" TimeOnly="true"
                                  DateFormat="HH:mm" Style="width:110px;" />
            </RadzenStack>
        }
        else if (_scheduleType == ScheduleUiType.CustomCron)
        {
            <RadzenStack Gap="0.35rem">
                <RadzenTextBox @bind-Value="_cronExpression" Placeholder="* * * * *" Style="font-family:monospace; width:100%;" />
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                    Формат: мин час день_мес месяц день_нед. Например: <b>0 9 * * 1-5</b> — каждый будний день в 09:00.
                    <a href="https://crontab.guru" target="_blank">Справка</a>
                </RadzenText>
            </RadzenStack>
        }

        <!-- Превью cron -->
        @{
            var previewCron = BuildCron();
        }
        @if (!string.IsNullOrEmpty(previewCron) && _scheduleType != ScheduleUiType.CustomCron)
        {
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color); font-family:monospace;">
                Cron: <b>@previewCron</b>
            </RadzenText>
        }
    </RadzenStack>

    <!-- Параметры задачи (SyncParams) -->
    @if (_jobType == SyncJobType.Sync || _jobType == SyncJobType.Update || _jobType == SyncJobType.Returns)
    {
        <RadzenStack Gap="0.35rem">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight:600;">Параметры синхронизации</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.6rem">
                <RadzenText TextStyle="TextStyle.Body2">Глубина периода:</RadzenText>
                <RadzenNumeric TValue="int" @bind-Value="_syncDaysBack" Min="1" Max="90" Style="width:80px;" />
                <RadzenText TextStyle="TextStyle.Body2">дней назад</RadzenText>
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color);">
                Период: от (сегодня − N дней) до сегодня.
            </RadzenText>
        </RadzenStack>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false" Style="margin:0;">
            @_errorMessage
        </RadzenAlert>
    }

    <!-- Кнопки -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Отмена"    ButtonStyle="ButtonStyle.Light"   Click="@(() => DialogService.Close(false))" />
        <RadzenButton Text="@SaveText" ButtonStyle="ButtonStyle.Primary" Icon="save"
                      IsBusy="@_isBusy" Disabled="@_isBusy" Click="@SubmitAsync" />
    </RadzenStack>

</RadzenStack>

@code {
    [Parameter] public IOrderSyncJobService JobService    { get; set; } = null!;
    [Parameter] public DialogService        DialogService { get; set; } = null!;
    [Parameter] public SyncJobSchedule?     EditSchedule  { get; set; }

    // ── Состояние UI ──────────────────────────────────────────────────────────

    private SyncJobType    _jobType         = SyncJobType.Sync;
    private ScheduleUiType _scheduleType    = ScheduleUiType.DailyAt;

    private int          _intervalMinutes   = 15;
    private int          _intervalHours     = 1;
    private int          _intervalDays      = 3;
    private int          _dayOfMonth        = 1;
    private DateTime     _timeValue         = DateTime.Today.AddHours(9);
    private string       _cronExpression    = "0 9 * * *";
    private HashSet<int> _selectedDays      = new() { 1, 2, 3, 4, 5 }; // пн–пт
    private int          _syncDaysBack      = 7;

    private bool     _isBusy;
    private string?  _errorMessage;

    private bool   IsEdit   => EditSchedule is not null;
    private string SaveText => IsEdit ? "Сохранить" : "Создать";

    // ── Внутренний enum для UI (не хранится в БД) ─────────────────────────────

    private enum ScheduleUiType
    {
        EveryNMinutes,
        EveryNHours,
        EveryNDays,
        DailyAt,
        WeeklyAt,
        MonthlyAt,
        CustomCron,
    }

    private record ScheduleTypeOption(string Label, ScheduleUiType Value);
    private record WeekDayOption(string Label, int Value);

    private readonly List<ScheduleTypeOption> _scheduleTypeOptions = new()
    {
        new("Каждые N мин.",  ScheduleUiType.EveryNMinutes),
        new("Каждые N ч.",    ScheduleUiType.EveryNHours),
        new("Каждые N дней",  ScheduleUiType.EveryNDays),
        new("Ежедневно",      ScheduleUiType.DailyAt),
        new("По дням недели", ScheduleUiType.WeeklyAt),
        new("Раз в месяц",    ScheduleUiType.MonthlyAt),
        new("Свой cron",      ScheduleUiType.CustomCron),
    };

    private readonly List<WeekDayOption> _weekDays = new()
    {
        new("Пн", 1), new("Вт", 2), new("Ср", 3),
        new("Чт", 4), new("Пт", 5), new("Сб", 6), new("Вс", 0),
    };

    // ── Инициализация из EditSchedule ─────────────────────────────────────────

    protected override void OnInitialized()
    {
        if (EditSchedule is null) return;

        _jobType = EditSchedule.JobType;

        // Читаем SyncParams
        if (!string.IsNullOrEmpty(EditSchedule.SyncParams))
        {
            try
            {
                var p = JsonSerializer.Deserialize<JsonElement>(EditSchedule.SyncParams);
                if (p.TryGetProperty("DaysBack", out var db) && db.TryGetInt32(out var d))
                    _syncDaysBack = d;
            }
            catch { /* используем дефолт */ }
        }

        // Восстанавливаем UI-тип и параметры из cron
        RestoreFromCron(EditSchedule.CronExpression);
    }

    /// <summary>
    /// Пытается распознать cron-выражение и выставить соответствующий UI-тип и параметры.
    /// Если не удаётся — ставит CustomCron.
    /// </summary>
    private void RestoreFromCron(string? cron)
    {
        if (string.IsNullOrWhiteSpace(cron))
        {
            _scheduleType   = ScheduleUiType.DailyAt;
            _cronExpression = "0 9 * * *";
            return;
        }

        var parts = cron.Trim().Split(' ');
        if (parts.Length != 5) { SetCustomCron(cron); return; }

        var (min, hour, dom, month, dow) = (parts[0], parts[1], parts[2], parts[3], parts[4]);

        // */N * * * *  → EveryNMinutes
        if (min.StartsWith("*/") && hour == "*" && dom == "*" && month == "*" && dow == "*"
            && int.TryParse(min[2..], out var nm))
        {
            _scheduleType    = ScheduleUiType.EveryNMinutes;
            _intervalMinutes = nm;
            return;
        }

        // * */N * * *  → EveryNHours
        if (hour.StartsWith("*/") && dom == "*" && month == "*" && dow == "*"
            && int.TryParse(hour[2..], out var nh))
        {
            _scheduleType   = ScheduleUiType.EveryNHours;
            _intervalHours  = nh;
            return;
        }

        // M H */N * *  → EveryNDays
        if (dom.StartsWith("*/") && month == "*" && dow == "*"
            && int.TryParse(dom[2..], out var nd)
            && int.TryParse(hour, out var h2) && int.TryParse(min, out var m2))
        {
            _scheduleType  = ScheduleUiType.EveryNDays;
            _intervalDays  = nd;
            _timeValue     = DateTime.Today.AddHours(h2).AddMinutes(m2);
            return;
        }

        // M H * * *  → DailyAt
        if (dom == "*" && month == "*" && dow == "*"
            && int.TryParse(hour, out var h3) && int.TryParse(min, out var m3))
        {
            _scheduleType = ScheduleUiType.DailyAt;
            _timeValue    = DateTime.Today.AddHours(h3).AddMinutes(m3);
            return;
        }

        // M H D * *  → MonthlyAt
        if (month == "*" && dow == "*"
            && int.TryParse(dom, out var day)
            && int.TryParse(hour, out var h4) && int.TryParse(min, out var m4))
        {
            _scheduleType = ScheduleUiType.MonthlyAt;
            _dayOfMonth   = day;
            _timeValue    = DateTime.Today.AddHours(h4).AddMinutes(m4);
            return;
        }

        // M H * * dow  → WeeklyAt
        if (dom == "*" && month == "*" && dow != "*"
            && int.TryParse(hour, out var h5) && int.TryParse(min, out var m5))
        {
            _scheduleType = ScheduleUiType.WeeklyAt;
            _timeValue    = DateTime.Today.AddHours(h5).AddMinutes(m5);
            _selectedDays = dow.Split(',')
                .Select(p => int.TryParse(p.Trim(), out var dd) ? dd : -1)
                .Where(dd => dd >= 0)
                .ToHashSet();
            return;
        }

        SetCustomCron(cron);
    }

    private void SetCustomCron(string cron)
    {
        _scheduleType   = ScheduleUiType.CustomCron;
        _cronExpression = cron;
    }

    // ── Построение cron из UI ─────────────────────────────────────────────────

    private string BuildCron() => _scheduleType switch
    {
        ScheduleUiType.EveryNMinutes => $"*/{_intervalMinutes} * * * *",
        ScheduleUiType.EveryNHours   => $"0 */{_intervalHours} * * *",
        ScheduleUiType.EveryNDays    => $"{_timeValue.Minute} {_timeValue.Hour} */{_intervalDays} * *",
        ScheduleUiType.DailyAt       => $"{_timeValue.Minute} {_timeValue.Hour} * * *",
        ScheduleUiType.WeeklyAt      => BuildWeeklyCron(),
        ScheduleUiType.MonthlyAt     => $"{_timeValue.Minute} {_timeValue.Hour} {_dayOfMonth} * *",
        ScheduleUiType.CustomCron    => _cronExpression.Trim(),
        _                            => "0 9 * * *"
    };

    private string BuildWeeklyCron()
    {
        var dow = string.Join(",", _selectedDays.OrderBy(d => d));
        return $"{_timeValue.Minute} {_timeValue.Hour} * * {dow}";
    }

    private void ToggleDay(int day)
    {
        if (!_selectedDays.Remove(day))
            _selectedDays.Add(day);
    }

    private string CardStyle(SyncJobType t) =>
        _jobType == t
            ? "border:2px solid var(--rz-primary); background:var(--rz-primary-lighter); cursor:pointer;"
            : "border:2px solid transparent; cursor:pointer;";

    // ── Валидация и сохранение ────────────────────────────────────────────────

    private async Task SubmitAsync()
    {
        _errorMessage = null;

        // Валидация
        switch (_scheduleType)
        {
            case ScheduleUiType.EveryNMinutes when _intervalMinutes < 1:
                _errorMessage = "Интервал должен быть не менее 1 минуты."; return;
            case ScheduleUiType.EveryNHours when _intervalHours < 1:
                _errorMessage = "Интервал должен быть не менее 1 часа."; return;
            case ScheduleUiType.EveryNDays when _intervalDays < 1:
                _errorMessage = "Интервал должен быть не менее 1 дня."; return;
            case ScheduleUiType.WeeklyAt when _selectedDays.Count == 0:
                _errorMessage = "Выберите хотя бы один день недели."; return;
            case ScheduleUiType.MonthlyAt when _dayOfMonth is < 1 or > 28:
                _errorMessage = "День месяца: от 1 до 28."; return;
            case ScheduleUiType.CustomCron when string.IsNullOrWhiteSpace(_cronExpression):
                _errorMessage = "Введите cron-выражение."; return;
        }

        var cron = BuildCron();

        // Строим SyncParams JSON
        string? syncParams = null;
        if (_jobType is SyncJobType.Sync or SyncJobType.Update or SyncJobType.Returns)
            syncParams = JsonSerializer.Serialize(new { DaysBack = _syncDaysBack });

        var schedule = new SyncJobSchedule
        {
            Id                     = EditSchedule?.Id ?? Guid.NewGuid(),
            JobType                = _jobType,
            IsEnabled              = EditSchedule?.IsEnabled ?? true,
            CronExpression         = cron,
            SyncParams             = syncParams,
            HangfireRecurringJobId = EditSchedule?.HangfireRecurringJobId,
        };

        _isBusy = true;
        try
        {
            if (IsEdit)
                await JobService.UpdateScheduleAsync(schedule);
            else
                await JobService.CreateScheduleAsync(schedule);

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}
