@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Interfaces

@inject IAuditLogService AuditLogService
@inject DialogService DialogService


<div style="min-width: min(760px, 90vw);">

    @if (_loading)
    {
        <div class="dlg-loading"><div class="dlg-spinner"></div></div>
    }
    else if (_totalCount == 0)
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 140px; gap: 0.5rem;">
            <RadzenIcon Icon="history" Style="font-size: 2rem; color: var(--rz-text-disabled-color);" />
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                История изменений отсутствует
            </RadzenText>
        </RadzenStack>
    }
    else if (Subjects.Count == 1)
    {
        <AuditSubjectPanel Subject="@Subjects[0]" Logs="@GetLogs(Subjects[0])" ValueResolver="@_resolver" />
    }
    else
    {
        <RadzenTabs>
            <Tabs>
                @foreach (var subject in Subjects)
                {
                    var s = subject;
                    var logs = GetLogs(s);
                    <RadzenTabsItem>
                        <Template>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                                <span>@s.Label</span>
                                @if (logs.Count > 0)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Info"
                                                 Text="@logs.Count.ToString()"
                                                 Style="font-size: 0.7rem; padding: 0.1rem 0.4rem; min-width: 20px;" />
                                }
                            </RadzenStack>
                        </Template>
                        <ChildContent>
                            <div style="padding-top: 0.75rem;">
                                <AuditSubjectPanel Subject="@s" Logs="@logs" ValueResolver="@_resolver" />
                            </div>
                        </ChildContent>
                    </RadzenTabsItem>
                }
            </Tabs>
        </RadzenTabs>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End"
                 Style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--rz-border-color);">
        <RadzenButton Text="Закрыть" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close())" />
    </RadzenStack>

</div>

@code {
    [Parameter] public IReadOnlyList<AuditSubject> Subjects { get; set; } = [];

    private bool _loading = true;
    private int _totalCount = 0;

    private readonly Dictionary<string, List<FieldAuditLog>> _logsByKey = new();
    private IReadOnlyDictionary<string, string> _resolver = new Dictionary<string, string>();

    protected override async Task OnInitializedAsync()
    {
        if (Subjects.Count == 0)
        {
            _loading = false;
            return;
        }

        var allLogs = await AuditLogService.GetBySubjectsAsync(Subjects);

        foreach (var subject in Subjects)
        {
            _logsByKey[SubjectKey(subject)] = allLogs
                .Where(x => x.EntityName == subject.EntityName && x.EntityId == subject.EntityId)
                .ToList();
        }

        _totalCount = allLogs.Count;
        _resolver = await AuditLogService.BuildValueResolverAsync(allLogs);
        _loading = false;
    }

    private List<FieldAuditLog> GetLogs(AuditSubject subject) =>
        _logsByKey.GetValueOrDefault(SubjectKey(subject)) ?? [];

    private static string SubjectKey(AuditSubject s) => $"{s.EntityName}|{s.EntityId}";
}
