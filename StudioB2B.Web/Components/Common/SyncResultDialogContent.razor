@if (ReturnsSummary is not null)
{
    <RadzenStack Gap="1rem">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Итог загрузки возвратов</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap">
            <RadzenText TextStyle="TextStyle.Body2"><strong>Создано:</strong> @ReturnsSummary.Created</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2"><strong>Обновлено:</strong> @ReturnsSummary.Updated</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2"><strong>Заказов с возвратом:</strong> @ReturnsSummary.Linked</RadzenText>
        </RadzenStack>
    </RadzenStack>
}
else if (Summary is not null)
{
    <RadzenStack Gap="1rem">
        @if (JobType == SyncJobTypeEnum.Sync)
        {
            @if (Summary.PerClient.Count > 0)
            {
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Итог по клиентам</RadzenText>
                <RadzenDataGrid TItem="ClientSyncResultItemDto" Data="@Summary.PerClient"
                                Density="Density.Compact" AllowSorting="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ClientName" Title="Клиент" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="Mode" Title="Режим" Width="80px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ShipmentsCreated" Title="Отправлений создано" Width="130px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ShipmentsUpdated" Title="Обновлено" Width="100px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersCreated" Title="Заказов создано" Width="120px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersUpdated" Title="Обновлено" Width="100px" />
                    </Columns>
                </RadzenDataGrid>

                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap">
                    <RadzenText TextStyle="TextStyle.Body2">
                        <strong>Всего отправлений:</strong> создано @Summary.Total.ShipmentsCreated, обновлено @Summary.Total.ShipmentsUpdated
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">
                        <strong>Всего заказов:</strong> создано @Summary.Total.OrdersCreated, обновлено @Summary.Total.OrdersUpdated
                    </RadzenText>
                </RadzenStack>
            }
        }
        else
        {
            @if (Summary.PerClient.Count > 0)
            {
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Итог по клиентам</RadzenText>
                <RadzenDataGrid TItem="ClientSyncResultItemDto" Data="@Summary.PerClient"
                                Density="Density.Compact" AllowSorting="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ClientName" Title="Клиент" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="Mode" Title="Режим" Width="80px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="ShipmentsUpdated" Title="Отправлений обновлено" Width="150px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersSelectedForUpdate" Title="Заказов выбрано для обновления" Width="200px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Property="OrdersSkipped" Title="Заказов пропущено" Width="140px" />
                        <RadzenDataGridColumn TItem="ClientSyncResultItemDto" Title="Изменённые поля">
                            <Template Context="c">@c.UpdatedFieldsSummary</Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap">
                    <RadzenText TextStyle="TextStyle.Body2">
                        <strong>Заказов выбрано для обновления:</strong> @Summary.Total.OrdersSelectedForUpdate
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">
                        <strong>Заказов пропущено (конечный статус):</strong> @Summary.Total.OrdersSkipped
                    </RadzenText>
                </RadzenStack>
            }

            @if (Summary.UpdatedShipments.Count > 0)
            {
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">Детализация изменений статусов</RadzenText>
                <RadzenDataGrid TItem="ShipmentUpdateItemDto" Data="@Summary.UpdatedShipments"
                                Density="Density.Compact" AllowSorting="true"
                                AllowPaging="true" PageSize="15">
                    <Columns>
                        <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="PostingNumber" Title="Номер отправления" />
                        <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="ClientName" Title="Клиент" />
                        <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="OldStatusName" Title="Было" />
                        <RadzenDataGridColumn TItem="ShipmentUpdateItemDto" Property="NewStatusName" Title="Стало" />
                    </Columns>
                </RadzenDataGrid>
            }
        }
    </RadzenStack>
}

@code {
    [Parameter] public OrderSyncSummaryDto? Summary { get; set; }
    [Parameter] public ReturnsSyncResultDto? ReturnsSummary { get; set; }
    [Parameter, EditorRequired] public SyncJobTypeEnum JobType { get; set; }
}

