@using Microsoft.EntityFrameworkCore
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services
@using System.Text.RegularExpressions
@using StudioB2B.Domain.Entities
@using StudioB2B.Infrastructure.Features
@using StudioB2B.Infrastructure.Interfaces

@inject ITenantDbContextFactory Factory
@inject DialogService DialogService

@implements IDisposable

@if (_order == null)
{
    <div class="dlg-loading"><div class="dlg-spinner"></div></div>
}
else
{
    <RadzenTabs Style="height: 630px;" @bind-SelectedIndex="_selectedTabIndex">
        <Tabs>

            <RadzenTabsItem Text="Товар">
                @{
                    var product = _order.ProductInfo?.Product;
                }
                <RadzenStack Gap="1.25rem" Style="padding: 1rem 0;">
                    @if (product != null)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1.5rem" AlignItems="AlignItems.Start">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl"
                                     style="width: 120px; height: 120px; object-fit: contain; border: 1px solid var(--rz-border-color); border-radius: 8px; flex-shrink: 0;"
                                     alt="@product.Name" />
                            }
                            else
                            {
                                <div style="width: 120px; height: 120px; background: var(--rz-base-200); border-radius: 8px;
                                            display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <RadzenIcon Icon="image_not_supported" Style="color: var(--rz-text-disabled-color); font-size: 2rem;" />
                                </div>
                            }
                            <RadzenStack Gap="0.5rem" Style="flex: 1; min-width: 0;">
                                <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0;">
                                    @product.Name
                                </RadzenText>
                                <RadzenStack Gap="0.25rem">
                                    @DetailRow("Артикул", product.Article, mono: true)
                                    @DetailRow("SKU (Ozon)", product.Sku?.ToString(), mono: true)
                                    @DetailRow("Штрихкод", product.Barcode, mono: true)
                                    @DetailRow("Производитель", product.Manufacturer?.Name)
                                    @DetailRow("Категория", product.Category?.Name)
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenStack>

                        @if (product.Attributes.Count > 0)
                        {
                            <div>
                                <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-bottom: 0.5rem;">
                                    Характеристики
                                </RadzenText>
                                <RadzenDataGrid TItem="ProductAttributeValue"
                                                Data="@product.Attributes"
                                                Density="Density.Compact"
                                                AllowSorting="true"
                                                AllowFiltering="false"
                                                AllowPaging="@(product.Attributes.Count > 15)"
                                                PageSize="15"
                                                Style="max-height: 320px; overflow-y: auto;"
                                                PageSizeText="@RadzenRuStrings.PageSizeText"
                                                PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                                                EmptyText="@RadzenRuStrings.EmptyText">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="ProductAttributeValue"
                                                              Title="Характеристика"
                                                              Width="220px"
                                                              Filterable="false" Sortable="false">
                                            <Template Context="attr">
                                                @(attr.Attribute?.Name ?? attr.Attribute?.Code ?? "—")
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="ProductAttributeValue"
                                                              Property="Value"
                                                              Title="Значение" />
                                    </Columns>
                                </RadzenDataGrid>
                            </div>
                        }
                        else
                        {
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                                Характеристики не загружены.
                            </RadzenText>
                        }
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                            Информация о товаре отсутствует.
                        </RadzenText>
                    }
                </RadzenStack>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Цены">
                <RadzenStack Gap="1rem" Style="padding: 1rem 0;">
                    @if (_order.Prices.Count > 0)
                    {
                        <RadzenDataGrid TItem="OrderPrice"
                                        Data="@_order.Prices.OrderBy(p => p.PriceType?.Name).ToList()"
                                        Density="Density.Compact"
                                        AllowSorting="true"
                                        AllowFiltering="false"
                                        AllowPaging="false"
                                        EmptyText="@RadzenRuStrings.EmptyText">
                            <Columns>
                                <RadzenDataGridColumn TItem="OrderPrice"
                                                      Property="PriceType.Name"
                                                      Title="Тип цены"
                                                      Width="280px" />
                                <RadzenDataGridColumn TItem="OrderPrice"
                                                      Title="Значение"
                                                      Width="140px"
                                                      TextAlign="TextAlign.Right">
                                    <Template Context="p">
                                        <span style="@GetPriceColor(p.Value)">@p.Value.ToString("N2")</span>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="OrderPrice"
                                                      Property="Currency.Code"
                                                      Title="Валюта"
                                                      Width="80px" />
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                            Цены не загружены.
                        </RadzenText>
                    }
                </RadzenStack>
            </RadzenTabsItem>

            @if (_calcRules.Count > 0)
            {
                <RadzenTabsItem Text="Расчёты">
                    <RadzenStack Gap="0.75rem" Style="padding: 1rem 0;">
                        <RadzenDataGrid TItem="CalculationResultRow"
                                        Data="@_calcResults"
                                        Density="Density.Compact"
                                        AllowSorting="false"
                                        AllowFiltering="false"
                                        AllowPaging="false"
                                        EmptyText="@RadzenRuStrings.EmptyText">
                            <Columns>
                                <RadzenDataGridColumn TItem="CalculationResultRow" Title="Название" Width="180px">
                                    <Template Context="row">
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.3rem">
                                            <RadzenIcon Icon="calculate" Style="font-size: 1rem; color: var(--rz-primary);" />
                                            <span>@row.Name</span>
                                        </RadzenStack>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="CalculationResultRow" Title="Формула" Width="260px">
                                    <Template Context="row">
                                        <RadzenStack Gap="0.15rem">
                                            <span style="font-family: monospace; font-size: 0.8rem; color: var(--rz-text-secondary-color);"
                                                  title="@row.Formula">@row.Formula</span>
                                            @if (!string.IsNullOrWhiteSpace(row.RenderedFormula) &&
                                                 !string.Equals(row.RenderedFormula, row.Formula, StringComparison.Ordinal))
                                            {
                                                <RadzenText TextStyle="TextStyle.Caption"
                                                            Style="color: var(--rz-text-secondary-color);">
                                                    Подстановка:
                                                    <code>@row.RenderedFormula</code>
                                                </RadzenText>
                                            }
                                        </RadzenStack>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="CalculationResultRow" Title="Результат" Width="140px" TextAlign="TextAlign.Right">
                                    <Template Context="row">
                                        @if (row.Result == decimal.MinValue)
                                        {
                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.End">
                                                <RadzenIcon Icon="warning" Style="font-size: 1rem; color: var(--rz-warning);"
                                                            title="@row.ErrorMessage" />
                                                <span style="color: var(--rz-danger); font-size: 0.78rem;" title="@row.ErrorMessage">Ошибка</span>
                                            </RadzenStack>
                                        }
                                        else
                                        {
                                            var breakdown = $"Формула: {row.Formula}\nПодстановка: {row.RenderedFormula} = {row.Result:N2}";
                                            <strong style="@($"cursor: help; {GetPriceColor(row.Result)}")" title="@breakdown">@row.Result.ToString("N2")</strong>
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenStack>
                </RadzenTabsItem>
            }

            <RadzenTabsItem Text="Получатель">
                <RadzenStack Gap="0.75rem" Style="padding: 1rem 0;">
                    @if (_order.Recipient != null)
                    {
                        @DetailRow("Имя", _order.Recipient.Name)
                        @DetailRow("Телефон", _order.Recipient.Phone, mono: true)
                        @DetailRow("Email", _order.Recipient.Email, mono: true)
                        @if (_order.Recipient.Address != null)
                        {
                            var a = _order.Recipient.Address;
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-top: 0.5rem;">
                                Адрес доставки
                            </RadzenText>
                            @DetailRow("Индекс", a.PostalCode)
                            @DetailRow("Регион", a.Region)
                            @DetailRow("Город", a.City)
                            @DetailRow("Улица", a.Street)
                            @if (!string.IsNullOrEmpty(a.Comment))
                            {
                                @DetailRow("Комментарий", a.Comment)
                            }
                        }
                    }
                    else
                    {
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                            Информация о получателе отсутствует.
                        </RadzenText>
                    }
                </RadzenStack>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Отправление">
                <RadzenStack Gap="1rem" Style="padding: 1rem 0;">
                    @{
                        var s = _order.Shipment;
                    }
                    @if (s != null)
                    {
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-bottom: 0.25rem;">
                            Номер отправления и доставка
                        </RadzenText>
                        @DetailRow("Номер отправления", s.PostingNumber, mono: true)
                        @DetailRow("Номер заказа", s.OrderNumber, mono: true)
                        @DetailRow("Трек-номер", s.TrackingNumber, mono: true)
                        @DetailRow("Статус отправления", s.Status?.Name)
                        @DetailRow("Способ доставки", s.DeliveryMethod?.Name)
                        @if (s.InProcessAt.HasValue)
                        {
                            <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Дата принятия</span>
                                <span style="font-size: 0.9rem;" title="@FormatDateTooltip(s.InProcessAt)">@FormatDateDisplay(s.InProcessAt)</span>
                            </div>
                        }
                        @if (s.ShipmentDate.HasValue)
                        {
                            <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Дата отгрузки</span>
                                <span style="font-size: 0.9rem;" title="@FormatDateTooltip(s.ShipmentDate)">@FormatDateDisplay(s.ShipmentDate)</span>
                            </div>
                        }
                        {
                            var term = _order.DeliveryTerm;
                            if (term is not null)
                            {
                                var status = _order.ShipmentStatus;
                                var shipDate = s.ShipmentDate!.Value;
                                var accepted = s.InProcessAt!.Value;
                                var termDays = (int)term.Value.TotalDays;
                                var termHours = term.Value.Hours;
                                var termText = termDays > 0 ? $"{termDays} дн. {termHours} ч." : $"{termHours} ч.";

                                <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                    <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Срок доставки</span>
                                    <span style="font-size: 0.9rem;">@termText</span>
                                </div>

                                if (status.IsBeforeShipment())
                                {
                                    var remaining = shipDate - DateTime.Now;
                                    if (remaining.TotalMinutes <= 0)
                                    {
                                        var overdue = DateTime.Now - shipDate;
                                        var ovDays = (int)overdue.TotalDays;
                                        var ovHours = overdue.Hours;
                                        var ovMin = overdue.Minutes;
                                        var ovText = ovDays > 0 ? $"{ovDays} дн. {ovHours} ч. {ovMin} мин." : $"{ovHours} ч. {ovMin} мин.";
                                        <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                            <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Статус отгрузки</span>
                                            <span style="font-size: 0.9rem; color: var(--rz-danger); font-weight: 600;">Просрочено на @ovText</span>
                                        </div>
                                    }
                                    else
                                    {
                                        var remDays = (int)remaining.TotalDays;
                                        var remHours = remaining.Hours;
                                        var remMin = remaining.Minutes;
                                        var remText = remDays > 0 ? $"{remDays} дн. {remHours} ч. {remMin} мин." : $"{remHours} ч. {remMin} мин.";
                                        var remStyle = remaining.TotalHours < 12 ? "color: var(--rz-danger); font-weight: 600;"
                                                     : remaining.TotalHours < 24 ? "color: var(--rz-warning-dark);"
                                                     : "";
                                        <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                            <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Осталось до отгрузки</span>
                                            <span style="font-size: 0.9rem; @remStyle">@remText</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div style="display: flex; gap: 0.75rem; align-items: baseline;">
                                        <span style="min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;">Статус отгрузки</span>
                                        <span style="font-size: 0.9rem; color: var(--rz-text-secondary-color);">Отгружено</span>
                                    </div>
                                }
                            }
                        }

                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-top: 0.75rem; margin-bottom: 0.25rem;">
                            Клиент маркетплейса
                        </RadzenText>
                        @DetailRow("Клиент", s.MarketplaceClient?.Name)
                        @DetailRow("Компания", s.MarketplaceClient?.Company)
                        @DetailRow("Склад отправки", _order.WarehouseInfo?.SenderWarehouse?.Name)

                        @if (_shipmentOrders.Count > 0)
                        {
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; margin-top: 0.75rem; margin-bottom: 0.5rem;">
                                Позиции в отправлении (@_shipmentOrders.Count)
                            </RadzenText>
                            <RadzenDataGrid TItem="OrderEntity"
                                            Data="@_shipmentOrders"
                                            Density="Density.Compact"
                                            AllowSorting="false"
                                            AllowFiltering="false"
                                            AllowPaging="@(_shipmentOrders.Count > 10)"
                                            PageSize="10"
                                            Style="max-height: 280px; overflow-y: auto;"
                                            PageSizeText="@RadzenRuStrings.PageSizeText"
                                            PagingSummaryFormat="@RadzenRuStrings.PagingSummaryFormat"
                                            EmptyText="@RadzenRuStrings.EmptyText">
                                <Columns>
                                    <RadzenDataGridColumn TItem="OrderEntity" Title="Товар" Width="240px">
                                        <Template Context="o">
                                            @(o.ProductInfo?.Product?.Name ?? "—")
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="OrderEntity" Title="Артикул" Width="120px">
                                        <Template Context="o">
                                            <span style="font-family: monospace; font-size: 0.8rem;">@(o.ProductInfo?.Product?.Article ?? "—")</span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="OrderEntity" Property="Quantity" Title="Кол-во" Width="80px" TextAlign="TextAlign.Center" />
                                    <RadzenDataGridColumn TItem="OrderEntity" Title="Статус" Width="160px">
                                        <Template Context="o">
                                            @o.Status?.Name
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    }
                </RadzenStack>
            </RadzenTabsItem>

            @if (_order.Shipment.Returns.Count > 0)
            {
                <RadzenTabsItem Text="Возврат">
                    <RadzenStack Gap="1rem" Style="padding: 1rem 0; overflow-y: auto; max-height: 500px;">
                        @foreach (var r in _order.Shipment.Returns)
                        {
                            <RadzenCard Style="padding: 1rem;">
                                @DetailRow("Номер отправления", r.PostingNumber, mono: true)
                                @DetailRow("Номер заказа", r.OrderNumber, mono: true)
                                @DetailRow("Товар", r.ProductName)
                                @DetailRow("Артикул", r.OfferId, mono: true)
                                @DetailRow("Кол-во", r.ProductQuantity.ToString())
                                @DetailRow("Цена", r.ProductPrice.HasValue ? $"{r.ProductPrice:N2} {r.ProductPriceCurrencyCode}" : null)
                                @DetailRow("Статус возврата", r.VisualStatusDisplayName)
                                @DetailRow("Статус компенсации", r.CompensationStatusDisplayName)
                                @DetailRow("Тип", GetReturnTypeDisplayName(r.Type))
                                @DetailRow("Схема", r.Schema)
                                @DetailRow("Причина", r.ReturnReasonName)
                                @DetailRow("Дата изменения", r.VisualStatusChangeMoment?.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
                                @DetailRow("Склад", r.PlaceName)
                                @DetailRow("Хранение (дней)", r.StorageDays?.ToString())
                                @DetailRow("Сумма хранения", r.StorageSum.HasValue ? $"{r.StorageSum:N2} {r.StorageCurrencyCode}" : null)
                                @DetailRow("Штрихкод", r.LogisticBarcode, mono: true)
                            </RadzenCard>
                        }
                    </RadzenStack>
                </RadzenTabsItem>
            }

        </Tabs>
    </RadzenTabs>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                 Style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--rz-border-color);">
        <RadzenButton Icon="history" Text="История изменений" Shade="Shade.Light" ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Small"
                      Click="@OpenAuditHistory" />
        <RadzenButton Text="Закрыть" ButtonStyle="ButtonStyle.Primary" Shade="Shade.Light" Click="@(() => DialogService.Close())" />
    </RadzenStack>
}

@code {
    [Parameter] public Guid OrderId { get; set; }
    [Parameter] public bool OpenReturnTab { get; set; }

    private TenantDbContext? _db;
    private OrderEntity? _order;
    private List<OrderEntity> _shipmentOrders = new();
    private int _selectedTabIndex;

    private List<CalculationRule> _calcRules = new();
    private List<CalculationResultRow> _calcResults = new();

    private sealed record CalculationResultRow(string Name, string Formula, string RenderedFormula, decimal Result, string? ErrorMessage = null);

    protected override async Task OnInitializedAsync()
    {
        _db = Factory.CreateDbContext();

        _order = await _db.Orders
            .IncludeForDetail()
            .AsSplitQuery()
            .AsNoTracking()
            .FirstOrDefaultAsync(o => o.Id == OrderId);

        _calcRules = await _db.GetActiveRulesAsync();
        if (_order != null && _calcRules.Count > 0)
        {
            var engine = new CalculationEngine();
            var computed = engine.Calculate(_order, _calcRules);
            var context = CalculationEngine.GetContextSnapshot(_order);

            _calcResults = _calcRules
                .Where(r => computed.ContainsKey(r.ResultKey))
                .Select(r =>
                {
                    var rendered = RenderFormulaWithValues(r.Formula, context);
                    engine.LastErrors.TryGetValue(r.ResultKey, out var errorMsg);
                    return new CalculationResultRow(r.Name, r.Formula, rendered, computed[r.ResultKey], errorMsg);
                })
                .ToList();
        }

        if (_order?.ShipmentId != null)
        {
            _shipmentOrders = await _db.Orders
                .IncludeForShipmentList()
                .AsNoTracking()
                .Where(o => o.ShipmentId == _order.ShipmentId)
                .OrderByDescending(o => o.Shipment.InProcessAt)
                .ThenBy(o => o.ProductInfo == null ? "" : (o.ProductInfo.Product == null ? "" : (o.ProductInfo.Product.Article ?? "")))
                .ToListAsync();
        }

        if (OpenReturnTab && _order?.Shipment.Returns.Count > 0)
        {
            // Tabs: Товар(0), Цены(1), [Расчёты(2)], Получатель, Отправление, Возврат
            _selectedTabIndex = (_calcRules.Count > 0 ? 1 : 0) + 4;
        }
    }

    public void Dispose() => _db?.Dispose();

    private static string? GetReturnTypeDisplayName(string? type) => type switch
    {
        "Cancellation" => "Отмена",
        "FullReturn" => "Полный возврат",
        "PartialReturn" => "Частичный возврат",
        "ClientReturn" => "Клиентский возврат",
        _ => type
    };

    private static string GetPriceColor(decimal value) =>
        value < 0 ? "color: var(--rz-danger);" : "";

    private async Task OpenAuditHistory()
    {
        var subjects = new List<AuditSubject>
        {
            new("OrderEntity", OrderId.ToString(), "Заказ"),
            new("Shipment", _order!.ShipmentId.ToString(), "Отправление"),
        };
        if (_order.ProductInfo is { } pi)
            subjects.Add(new("OrderProductInfo", pi.Id.ToString(), "Товар в заказе"));
        if (_order.RecipientId is { } rid)
            subjects.Add(new("Recipient", rid.ToString(), "Получатель"));
        if (_order.Recipient?.Address?.Id is { } aid)
            subjects.Add(new("Address", aid.ToString(), "Адрес"));

        await DialogService.OpenAsync<AuditHistoryDialog>(
            "История изменений заказа",
            new Dictionary<string, object?> { [nameof(AuditHistoryDialog.Subjects)] = (IReadOnlyList<AuditSubject>)subjects },
            new DialogOptions { Width = "min(960px, 95vw)", Resizable = true, Draggable = true });
    }

    private static string FormatDateDisplay(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy");
    }

    private static string FormatDateTooltip(DateTime? d)
    {
        if (!d.HasValue) return "";
        return d.Value.Date == DateTime.Today ? d.Value.ToString("HH:mm") : d.Value.ToString("dd.MM.yyyy HH:mm");
    }

    private static string RenderFormulaWithValues(string formula, IReadOnlyDictionary<string, decimal> context)
    {
        if (string.IsNullOrWhiteSpace(formula) || context.Count == 0)
            return formula;

        var rendered = formula;

        foreach (var kv in context)
        {
            if (string.IsNullOrWhiteSpace(kv.Key))
                continue;

            var pattern = $@"\b{Regex.Escape(kv.Key)}\b";
            rendered = Regex.Replace(
                rendered,
                pattern,
                kv.Value.ToString("N2"));
        }

        return rendered;
    }

    // Small helper render fragment for label+value rows
    private RenderFragment DetailRow(string label, string? value, bool mono = false) => __builder =>
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "style", "display: flex; gap: 0.75rem; align-items: baseline;");
        __builder.OpenElement(2, "span");
        __builder.AddAttribute(3, "style", "min-width: 160px; color: var(--rz-text-secondary-color); font-size: 0.85rem; flex-shrink: 0;");
        __builder.AddContent(4, label);
        __builder.CloseElement();
        __builder.OpenElement(5, "span");
        if (mono)
        {
            __builder.OpenComponent<CopyableText>(6);
            __builder.AddAttribute(7, "Text", value);
            __builder.AddAttribute(8, "Style", "font-family: monospace; font-size: 0.85rem; word-break: break-all;");
            __builder.AddAttribute(9, "Tooltip", "Нажмите, чтобы скопировать");
            __builder.AddAttribute(10, "ChildContent", (RenderFragment)(__builder2 =>
            {
                __builder2.AddContent(11, value);
            }));
            __builder.CloseComponent();
        }
        else
        {
            __builder.AddAttribute(12, "style", "font-size: 0.9rem;");
            __builder.AddContent(13, value);
        }
        __builder.CloseElement();
        __builder.CloseElement();
    };
}
