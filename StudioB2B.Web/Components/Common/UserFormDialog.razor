<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@Model">
            <DataAnnotationsValidator />

            <MudTextField T="string" Label="Email" @bind-Value="Model.Email"
                          For="@(() => Model.Email)"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                          FullWidth="true" InputType="InputType.Email"
                          Disabled="@IsEdit" />

            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" sm="4">
                    <MudTextField T="string" Label="Фамилия" @bind-Value="Model.LastName"
                                  For="@(() => Model.LastName)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField T="string" Label="Имя" @bind-Value="Model.FirstName"
                                  For="@(() => Model.FirstName)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField T="string" Label="Отчество" @bind-Value="Model.MiddleName"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
            </MudGrid>

            @if (!IsEdit)
            {
                <MudTextField T="string" Label="Пароль" @bind-Value="Model.Password"
                              For="@(() => Model.Password)"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                              FullWidth="true" InputType="InputType.Password"
                              HelperText="Минимум 6 символов" />
            }

            @if (IsEdit)
            {
                <MudCheckBox T="bool" @bind-Value="Model.IsActive" Label="Активен" Class="mb-2" />
            }

            @if (AvailableRoles.Count > 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1 mb-1">Роли</MudText>
                <MudPaper Outlined="true" Class="pa-2">
                    @foreach (var role in AvailableRoles)
                    {
                        var r = role;
                        <MudCheckBox T="bool"
                                     Value="@Model.SelectedRoles.Contains(r)"
                                     ValueChanged="@(v => ToggleRole(r, v))"
                                     Label="@r" Dense="true" />
                    }
                </MudPaper>
            }
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = "Пользователь";
    [Parameter] public UserFormModel Model { get; set; } = new();
    [Parameter] public List<string> AvailableRoles { get; set; } = [];
    [Parameter] public bool IsEdit { get; set; }

    private void ToggleRole(string role, bool selected)
    {
        if (selected) { if (!Model.SelectedRoles.Contains(role)) Model.SelectedRoles.Add(role); }
        else Model.SelectedRoles.Remove(role);
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Model.LastName) || string.IsNullOrWhiteSpace(Model.FirstName))
            return;
        if (!IsEdit && string.IsNullOrWhiteSpace(Model.Password))
            return;
        MudDialog.Close(DialogResult.Ok(Model));
    }
}

