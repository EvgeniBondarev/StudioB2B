@using StudioB2B.Infrastructure.Features

@inject CreateUser CreateUserService
@inject UpdateUser UpdateUserService
@inject GetAvailableRoles GetAvailableRolesService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject JwtAuthenticationStateProvider AuthStateProvider

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 180px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else
{
    <RadzenTemplateForm TItem="UserFormModel" Data="_model" Submit="@HandleSubmit">
        <RadzenStack Gap="1rem" Style="padding: 0.25rem 0;">

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Фамилия" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.LastName" Name="LastName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="LastName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Имя" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.FirstName" Name="FirstName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="FirstName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Отчество" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_model.MiddleName" Name="MiddleName" Style="width: 100%;" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            @if (UserId == Guid.Empty)
            {
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <ChildContent>
                                <RadzenTextBox @bind-Value="_model.Email" Name="Email" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Email" Text="Обязательное поле" />
                                <RadzenEmailValidator Component="Email" Text="Некорректный email" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <ChildContent>
                                <RadzenPassword @bind-Value="_model.Password" Name="Password" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Password" Text="Обязательное поле" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            }

            <RadzenFormField Text="Роли" Style="width: 100%;">
                <RadzenDropDown Data="@_availableRoles"
                                @bind-Value="_model.Roles"
                                Multiple="true"
                                AllowClear="true"
                                TextProperty="Label"
                                ValueProperty="Value"
                                Placeholder="Выберите роли..."
                                Style="width: 100%;" />
            </RadzenFormField>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="_model.IsActive" Name="IsActive" />
                <RadzenLabel Text="Активен" Component="IsActive" />
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End"
                         Style="margin-top: 0.5rem; border-top: 1px solid var(--rz-border-color); padding-top: 1rem;">
                <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                              Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="@(UserId == Guid.Empty ? "Создать" : "Сохранить")"
                              ButtonStyle="ButtonStyle.Primary"
                              Icon="@(UserId == Guid.Empty ? "person_add" : "save")"
                              IsBusy="@_saving" />
            </RadzenStack>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid UserId { get; set; }
    [Parameter] public string Email { get; set; } = "";
    [Parameter] public string FirstName { get; set; } = "";
    [Parameter] public string LastName { get; set; } = "";
    [Parameter] public string? MiddleName { get; set; }
    [Parameter] public bool IsActive { get; set; } = true;
    [Parameter] public List<string> Roles { get; set; } = [];

    private List<LabelValueDto> _availableRoles = [];
    private UserFormModel _model = new();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _availableRoles = await GetAvailableRolesService.HandleAsync();

        _model = new UserFormModel
        {
            Email = Email,
            FirstName = FirstName,
            LastName = LastName,
            MiddleName = MiddleName,
            IsActive = IsActive,
            Roles = Roles.ToList()
        };

        _loading = false;
    }

    private async Task HandleSubmit(UserFormModel model)
    {
        _saving = true;
        try
        {
            if (UserId == Guid.Empty)
            {
                var (ok, error) = await CreateUserService.HandleAsync(
                    new CreateUserDto(model.Email, model.FirstName, model.LastName,
                                      model.MiddleName, model.Password ?? "P@ssw0rd", model.Roles));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь создан");
                    DialogService.Close(true);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка создания");
                }
            }
            else
            {
                var (ok, error) = await UpdateUserService.HandleAsync(UserId,
                    new UpdateUserDto(model.FirstName, model.LastName, model.MiddleName,
                                      model.IsActive, model.Roles));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь обновлён");
                    DialogService.Close(true);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка обновления");
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private class UserFormModel
    {
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? MiddleName { get; set; }
        public string? Password { get; set; }
        public bool IsActive { get; set; } = true;
        public List<string> Roles { get; set; } = [];
    }
}

