@using StudioB2B.Infrastructure.Features

@inject CreateUser CreateUserService
@inject UpdateUser UpdateUserService
@inject GetUserById GetUserByIdService
@inject GetAvailablePermissions GetAvailablePermissionsService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject JwtAuthenticationStateProvider AuthStateProvider

@if (_loading)
{
    <div class="dlg-loading"><div class="dlg-spinner"></div></div>
}
else
{
    <RadzenTemplateForm TItem="UserFormModel" Data="_model" Submit="@HandleSubmit">
        <RadzenStack Gap="1rem" Style="padding: 0.25rem 0;">

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Фамилия" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.LastName" Name="LastName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="LastName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Имя" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.FirstName" Name="FirstName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="FirstName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Отчество" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_model.MiddleName" Name="MiddleName" Style="width: 100%;" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            @if (UserId == Guid.Empty)
            {
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <ChildContent>
                                <RadzenTextBox @bind-Value="_model.Email" Name="Email" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Email" Text="Обязательное поле" />
                                <RadzenEmailValidator Component="Email" Text="Некорректный email" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <ChildContent>
                                <RadzenPassword @bind-Value="_model.Password" Name="Password" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Password" Text="Обязательное поле" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            }

            <!-- ── Permission picker ──────────────────────────────────── -->
            <div>
                <div style="font-size: 0.8rem; color: var(--rz-text-secondary-color); margin-bottom: 0.5rem; font-weight: 500;">
                    Права доступа
                </div>

                @if (_availablePermissions.Count == 0)
                {
                    <div style="padding: 0.75rem; color: var(--rz-text-secondary-color); font-size: 0.85rem;
                                border: 1px solid var(--rz-border-color); border-radius: 4px; text-align: center;">
                        Права доступа не созданы. Сначала создайте права на странице «Права доступа».
                    </div>
                }
                else
                {
                    <div style="border: 1px solid var(--rz-border-color); border-radius: 4px; max-height: 240px; overflow-y: auto;">
                        @foreach (var perm in _availablePermissions)
                        {
                            var permId = Guid.Parse(perm.Value);
                            var selected = _model.Permissions.Contains(permId);
                            <div @onclick="@(() => TogglePermission(permId))"
                                 style="display: flex; align-items: center; gap: 8px; padding: 6px 12px;
                                        cursor: pointer; user-select: none;
                                        @(selected ? "background: color-mix(in srgb,var(--rz-primary) 8%,transparent);" : "")">
                                <i class="rzi" style="font-size: 1.1rem; flex-shrink: 0;
                                                      color: @(selected ? "var(--rz-primary)" : "var(--rz-base-400)");">
                                    @(selected ? "check_box" : "check_box_outline_blank")
                                </i>
                                <span style="font-size: 0.85rem;">@perm.Label</span>
                            </div>
                        }
                    </div>
                    <div style="font-size: 0.74rem; color: var(--rz-text-secondary-color); margin-top: 0.25rem;">
                        Выбрано: <b>@_model.Permissions.Count</b> из @_availablePermissions.Count
                    </div>
                }
            </div>
            <!-- ── / Permission picker ────────────────────────────────── -->

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="_model.IsActive" Name="IsActive" />
                <RadzenLabel Text="Активен" Component="IsActive" />
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End"
                         Style="margin-top: 0.5rem; border-top: 1px solid var(--rz-border-color); padding-top: 1rem;">
                <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                              Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="@(UserId == Guid.Empty ? "Создать" : "Сохранить")"
                              ButtonStyle="ButtonStyle.Primary"
                              Icon="@(UserId == Guid.Empty ? "person_add" : "save")"
                              IsBusy="@_saving" />
            </RadzenStack>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    private List<LabelValueDto> _availablePermissions = [];
    private UserFormModel _model = new();
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _availablePermissions = await GetAvailablePermissionsService.HandleAsync();

        if (UserId != Guid.Empty)
        {
            var fresh = await GetUserByIdService.HandleAsync(UserId);
            if (fresh is not null)
            {
                // Map permission names back to IDs
                var nameToId = _availablePermissions
                    .ToDictionary(p => p.Label, p => Guid.Parse(p.Value));

                _model = new UserFormModel
                {
                    Email = fresh.Email,
                    FirstName = fresh.FirstName,
                    LastName = fresh.LastName,
                    MiddleName = fresh.MiddleName,
                    IsActive = fresh.IsActive,
                    Permissions = fresh.Permissions
                        .Where(name => nameToId.ContainsKey(name))
                        .Select(name => nameToId[name])
                        .ToList()
                };
            }
        }

        _loading = false;
    }

    private void TogglePermission(Guid id)
    {
        if (_model.Permissions.Contains(id))
            _model.Permissions.Remove(id);
        else
            _model.Permissions.Add(id);
    }

    private async Task HandleSubmit(UserFormModel model)
    {
        _saving = true;
        try
        {
            if (UserId == Guid.Empty)
            {
                var (ok, error) = await CreateUserService.HandleAsync(
                    new CreateUserDto(model.Email, model.FirstName, model.LastName,
                                      model.MiddleName, model.Password ?? "P@ssw0rd", model.Permissions));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь создан");
                    DialogService.Close(true);
                }
                else
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка создания");
            }
            else
            {
                var (ok, error) = await UpdateUserService.HandleAsync(UserId,
                    new UpdateUserDto(model.FirstName, model.LastName, model.MiddleName,
                                      model.IsActive, model.Permissions));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь обновлён");
                    DialogService.Close(true);
                }
                else
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка обновления");
            }
        }
        finally { _saving = false; }
    }

    private class UserFormModel
    {
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? MiddleName { get; set; }
        public string? Password { get; set; }
        public bool IsActive { get; set; } = true;
        public List<Guid> Permissions { get; set; } = [];
    }
}

