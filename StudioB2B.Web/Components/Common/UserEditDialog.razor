@using StudioB2B.Infrastructure.Features

@inject CreateUser CreateUserService
@inject UpdateUser UpdateUserService
@inject GetUserById GetUserByIdService
@inject GetAvailableRoles GetAvailableRolesService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject JwtAuthenticationStateProvider AuthStateProvider

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 180px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else
{
    <RadzenTemplateForm TItem="UserFormModel" Data="_model" Submit="@HandleSubmit">
        <RadzenStack Gap="1rem" Style="padding: 0.25rem 0;">

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Фамилия" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.LastName" Name="LastName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="LastName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Имя" Style="width: 100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="_model.FirstName" Name="FirstName" Style="width: 100%;" />
                        </ChildContent>
                        <Helper>
                            <RadzenRequiredValidator Component="FirstName" Text="Обязательное поле" />
                        </Helper>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Отчество" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="_model.MiddleName" Name="MiddleName" Style="width: 100%;" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            @if (UserId == Guid.Empty)
            {
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Email" Style="width: 100%;">
                            <ChildContent>
                                <RadzenTextBox @bind-Value="_model.Email" Name="Email" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Email" Text="Обязательное поле" />
                                <RadzenEmailValidator Component="Email" Text="Некорректный email" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="Пароль" Style="width: 100%;">
                            <ChildContent>
                                <RadzenPassword @bind-Value="_model.Password" Name="Password" Style="width: 100%;" />
                            </ChildContent>
                            <Helper>
                                <RadzenRequiredValidator Component="Password" Text="Обязательное поле" />
                            </Helper>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>
            }

            <!-- ── Role picker ─────────────────────────────────────────── -->
            <div>
                <div style="font-size: 0.8rem; color: var(--rz-text-secondary-color); margin-bottom: 0.4rem; font-weight: 500;">Роли</div>

                <!-- Search + Select all / Clear all -->
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                             Gap="0.4rem" Style="margin-bottom: 0.4rem;">
                    <div style="position:relative;flex:1;">
                        <i class="rzi" style="position:absolute;left:8px;top:50%;transform:translateY(-50%);
                                              color:var(--rz-text-secondary-color);font-size:1rem;pointer-events:none;">search</i>
                        <input type="text"
                               value="@_roleSearch"
                               @oninput="@(e => _roleSearch = e.Value?.ToString() ?? "")"
                               placeholder="Поиск роли..."
                               style="width:100%;padding:5px 8px 5px 30px;
                                      border:1px solid var(--rz-border-color);border-radius:4px;
                                      outline:none;background:var(--rz-base-background-color);
                                      color:var(--rz-text-color);font-size:0.85rem;box-sizing:border-box;" />
                    </div>
                    <RadzenButton Text="Все" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light"
                                  Click="@SelectAllRoles" Title="Выбрать все роли" />
                    <RadzenButton Text="Снять" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light"
                                  Click="@ClearAllRoles" Title="Снять все роли" />
                </RadzenStack>

                <!-- Selected chips (hidden when searching) -->
                @if (_model.Roles.Count > 0 && string.IsNullOrEmpty(_roleSearch))
                {
                    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:0.4rem;
                                max-height:68px;overflow-y:auto;padding:4px;
                                background:var(--rz-base-100);border-radius:4px;">
                        @foreach (var rv in _model.Roles)
                        {
                            var chip = _availableRoles.FirstOrDefault(x => x.Value == rv)?.Label ?? rv;
                            <span style="display:inline-flex;align-items:center;gap:3px;
                                         padding:2px 5px 2px 8px;border-radius:10px;
                                         background:var(--rz-primary-lighter);color:var(--rz-primary-dark);
                                         font-size:0.72rem;max-width:210px;">
                                <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                      title="@chip">@GetRoleShortLabel(chip)</span>
                                <span @onclick="@(() => RemoveRole(rv))" @onclick:stopPropagation="true"
                                      style="cursor:pointer;opacity:0.55;padding:0 2px;flex-shrink:0;font-size:0.65rem;">✕</span>
                            </span>
                        }
                    </div>
                }

                <!-- Grouped list -->
                <div style="border:1px solid var(--rz-border-color);border-radius:4px;
                             max-height:280px;overflow-y:auto;">
                    @{
                        var groups = GetFilteredGroups(_roleSearch.Trim());
                    }
                    @if (!groups.Any())
                    {
                        <div style="padding:1rem;text-align:center;
                                    color:var(--rz-text-secondary-color);font-size:0.82rem;">
                            Ничего не найдено
                        </div>
                    }
                    @foreach (var g in groups)
                    {
                        var groupSelected = g.Roles.Count(r => _model.Roles.Contains(r.Value));
                        <div style="padding:3px 10px;background:var(--rz-base-200);font-weight:600;
                                    font-size:0.75rem;color:var(--rz-text-secondary-color);
                                    position:sticky;top:0;z-index:1;
                                    border-bottom:1px solid var(--rz-border-color);
                                    display:flex;justify-content:space-between;align-items:center;">
                            <span>@g.Name</span>
                            <span style="font-weight:400;opacity:0.7;">@groupSelected / @g.Roles.Count</span>
                        </div>
                        @foreach (var role in g.Roles)
                        {
                            var sel = _model.Roles.Contains(role.Value);
                            <div @onclick="@(() => ToggleRole(role.Value))"
                                 style="display:flex;align-items:center;gap:8px;padding:4px 10px;
                                        cursor:pointer;user-select:none;
                                        @(sel ? "background:color-mix(in srgb,var(--rz-primary) 8%,transparent);" : "")">
                                <i class="rzi" style="font-size:1.1rem;flex-shrink:0;
                                                      color:@(sel ? "var(--rz-primary)" : "var(--rz-base-400)");">
                                    @(sel ? "check_box" : "check_box_outline_blank")
                                </i>
                                <span style="font-size:0.82rem;line-height:1.3;">@GetRoleShortLabel(role.Label)</span>
                            </div>
                        }
                    }
                </div>

                <div style="font-size:0.74rem;color:var(--rz-text-secondary-color);margin-top:0.25rem;">
                    Выбрано: <b>@_model.Roles.Count</b> из @_availableRoles.Count
                </div>
            </div>
            <!-- ── / Role picker ───────────────────────────────────────── -->

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="_model.IsActive" Name="IsActive" />
                <RadzenLabel Text="Активен" Component="IsActive" />
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End"
                         Style="margin-top: 0.5rem; border-top: 1px solid var(--rz-border-color); padding-top: 1rem;">
                <RadzenButton Text="Отмена" ButtonStyle="ButtonStyle.Light"
                              Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="@(UserId == Guid.Empty ? "Создать" : "Сохранить")"
                              ButtonStyle="ButtonStyle.Primary"
                              Icon="@(UserId == Guid.Empty ? "person_add" : "save")"
                              IsBusy="@_saving" />
            </RadzenStack>

        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    [Parameter] public Guid UserId { get; set; }
    [Parameter] public string Email { get; set; } = "";
    [Parameter] public string FirstName { get; set; } = "";
    [Parameter] public string LastName { get; set; } = "";
    [Parameter] public string? MiddleName { get; set; }
    [Parameter] public bool IsActive { get; set; } = true;
    [Parameter] public List<string> Roles { get; set; } = [];

    private List<LabelValueDto> _availableRoles = [];
    private List<RoleGroup> _groupedRoles = [];
    private string _roleSearch = "";
    private UserFormModel _model = new();
    private bool _loading = true;
    private bool _saving;

    private record RoleGroup(string Name, List<LabelValueDto> Roles);

    protected override async Task OnInitializedAsync()
    {
        _availableRoles = await GetAvailableRolesService.HandleAsync();

        // Build grouped structure once
        _groupedRoles = _availableRoles
            .GroupBy(r => GetGroupName(r.Label))
            .Select(g => new RoleGroup(g.Key, g.ToList()))
            .OrderBy(g => g.Name == "Общее" ? 0 : 1)
            .ThenBy(g => g.Name)
            .ToList();

        if (UserId != Guid.Empty)
        {
            // Always load fresh data from the DB — never rely on parameters
            // which may be stale due to Blazor async event handler suspension points
            var fresh = await GetUserByIdService.HandleAsync(UserId);
            _model = new UserFormModel
            {
                Email = fresh?.Email ?? Email,
                FirstName = fresh?.FirstName ?? FirstName,
                LastName = fresh?.LastName ?? LastName,
                MiddleName = fresh?.MiddleName ?? MiddleName,
                IsActive = fresh?.IsActive ?? IsActive,
                Roles = fresh?.Roles.ToList() ?? Roles.ToList()
            };
        }
        else
        {
            _model = new UserFormModel
            {
                Email = Email,
                FirstName = FirstName,
                LastName = LastName,
                MiddleName = MiddleName,
                IsActive = IsActive,
                Roles = Roles.ToList()
            };
        }

        _loading = false;
    }

    // ── Role picker helpers ────────────────────────────────────────────────

    private static string GetGroupName(string label)
    {
        if (!label.Contains(':')) return "Общее";
        var prefix = label.Split(':')[0].Trim();
        return prefix switch
        {
            "Клиенты маркетплейсов" => "Маркетплейс",
            "Статусы заказов" => "Статусы",
            "Правила расчёта" => "Расчёты",
            "Журнал аудита" => "Аудит",
            "Документы заказов" => "Документы",
            "История проведений" => "История",
            _ => prefix
        };
    }

    private static string GetRoleShortLabel(string label)
    {
        var idx = label.IndexOf(':');
        return idx < 0 ? label : label[(idx + 1)..].Trim();
    }

    private IReadOnlyList<RoleGroup> GetFilteredGroups(string search)
    {
        if (string.IsNullOrEmpty(search)) return _groupedRoles;

        return _groupedRoles
            .Select(g => new RoleGroup(g.Name,
                g.Roles.Where(r =>
                    r.Label.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    r.Value.Contains(search, StringComparison.OrdinalIgnoreCase))
                .ToList()))
            .Where(g => g.Roles.Count > 0)
            .ToList();
    }

    private void ToggleRole(string value)
    {
        if (_model.Roles.Contains(value))
            _model.Roles.Remove(value);
        else
            _model.Roles.Add(value);
    }

    private void RemoveRole(string value) => _model.Roles.Remove(value);

    private void SelectAllRoles() =>
        _model.Roles = _availableRoles.Select(r => r.Value).ToList();

    private void ClearAllRoles() => _model.Roles.Clear();

    // ── Form submit ────────────────────────────────────────────────────────

    private async Task HandleSubmit(UserFormModel model)
    {
        _saving = true;
        try
        {
            if (UserId == Guid.Empty)
            {
                var (ok, error) = await CreateUserService.HandleAsync(
                    new CreateUserDto(model.Email, model.FirstName, model.LastName,
                                      model.MiddleName, model.Password ?? "P@ssw0rd", model.Roles));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь создан");
                    DialogService.Close(true);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка создания");
                }
            }
            else
            {
                var (ok, error) = await UpdateUserService.HandleAsync(UserId,
                    new UpdateUserDto(model.FirstName, model.LastName, model.MiddleName,
                                      model.IsActive, model.Roles));
                if (ok)
                {
                    await AuthStateProvider.RefreshAsync();
                    NotificationService.Notify(NotificationSeverity.Success, "Пользователь обновлён");
                    DialogService.Close(true);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Ошибка", error ?? "Ошибка обновления");
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private class UserFormModel
    {
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? MiddleName { get; set; }
        public string? Password { get; set; }
        public bool IsActive { get; set; } = true;
        public List<string> Roles { get; set; } = [];
    }
}

