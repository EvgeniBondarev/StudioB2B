@if (Task.AssignedToUserName is not null || Task.AssignedAt.HasValue || Task.CompletedAt.HasValue)
{
    <div class="payment-breakdown-card done" style="margin-top:0.5rem;">
        <div class="payment-breakdown-header">
            <span class="rzi" style="font-size:0.85rem;">manage_accounts</span>
            Обработка
        </div>
        @if (Task.AssignedToUserName is not null)
        {
            <div class="payment-breakdown-row">
                <span class="payment-breakdown-label">Сотрудник</span>
                <span class="payment-breakdown-amount" style="color:var(--rz-text-color);font-weight:500;">@Task.AssignedToUserName</span>
            </div>
        }
        @if (Task.AssignedAt.HasValue)
        {
            <div class="payment-breakdown-row">
                <span class="payment-breakdown-label">Взят в работу</span>
                <span class="payment-breakdown-amount" style="color:var(--rz-text-color);">@Task.AssignedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        }
        @if (Task.CompletedAt.HasValue)
        {
            <div class="payment-breakdown-row">
                <span class="payment-breakdown-label">Завершён</span>
                <span class="payment-breakdown-amount" style="color:var(--rz-text-color);">@Task.CompletedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public CommunicationTaskDto Task { get; set; } = null!;
}

