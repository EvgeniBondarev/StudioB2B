@using Microsoft.EntityFrameworkCore
@using StudioB2B.Domain.Entities.Orders
@using StudioB2B.Domain.Entities.Products
@using StudioB2B.Domain.Entities.Warehouses
@using StudioB2B.Infrastructure.Interfaces
@using StudioB2B.Infrastructure.Persistence.Tenant
@using StudioB2B.Infrastructure.Services

@inject ITenantDbContextFactory Factory
@inject IOrderTransactionService TransactionService
@inject NotificationService NotificationService
@inject DialogService DialogService

@implements IDisposable

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 150px;">
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </RadzenStack>
}
else if (_preview != null)
{
    @* Шаг 2: ввод значений и применение *@
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;">
            @_preview.TransactionName → @_preview.ToStatusName
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">
            Укажите значения для пользовательских цен и полей (если требуется) и нажмите «Применить».
        </RadzenText>
        <RadzenStack Gap="0.75rem">
            @foreach (var rule in _preview.Rules)
            {
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" Style="flex-wrap: wrap;">
                    <RadzenText TextStyle="TextStyle.Body2" Style="min-width: 140px;">
                        @rule.PriceTypeName@(rule.IsRequired ? " *" : "")
                        @if (rule.ProductName != null)
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);"> (@rule.ProductName)</RadzenText>
                        }
                    </RadzenText>
                    @if (rule.RequiresUserInput)
                    {
                        <RadzenNumeric @bind-Value="_userValues[rule.RuleId]"
                                       Style="@($"width: 140px; {GetPriceColor(_userValues.GetValueOrDefault(rule.RuleId))}")" Min="0" Format="N2"
                                       Placeholder="Введите значение" />
                    }
                    else
                    {
                        var cv = rule.ComputedValue;
                        var breakdown = rule.FormulaBreakdown ?? rule.Formula ?? "";
                        <RadzenText TextStyle="TextStyle.Body2" Style="@($"cursor: help; {GetPriceColor(cv)}")" title="@breakdown">
                            @(cv?.ToString("N2") ?? "—")
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-base-500);">(по формуле)</RadzenText>
                    }
                </RadzenStack>
            }
            @foreach (var fr in _preview.FieldRules.Where(x => x.RequiresUserInput))
            {
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" Style="flex-wrap: wrap;">
                    <RadzenText TextStyle="TextStyle.Body2" Style="min-width: 180px;">
                        @fr.DisplayName@(fr.IsRequired ? " *" : "")
                    </RadzenText>
                    @RenderFieldControl(fr)
                </RadzenStack>
            }
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" Style="margin-top: 0.5rem;">
            <RadzenButton Text="Назад" ButtonStyle="ButtonStyle.Light" Click="@BackToSelect" />
            <RadzenButton Text="Применить" ButtonStyle="ButtonStyle.Primary" Click="@ApplyAsync"
                          Disabled="@(_preview != null && GetValidationErrors().Count > 0)" />
        </RadzenStack>
    </RadzenStack>
}
else if (_transactions.Count == 0)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">
        Нет доступных документов для текущего статуса заказа (@(_currentStatusName ?? "—")). Создайте документ на странице «Документы».
    </RadzenAlert>
}
else
{
    @* Шаг 1: выбор документа *@
    <RadzenStack Gap="1rem" Style="padding: 0.5rem 0;">
        <RadzenText TextStyle="TextStyle.Body2">
            Выберите документ для проведения по заказу @OrderId:
        </RadzenText>
        <RadzenDataGrid TItem="OrderTransaction"
                        Data="@_transactions"
                        Density="Density.Compact"
                        AllowSorting="false"
                        AllowFiltering="false"
                        AllowPaging="false"
                        RowClick="@OnRowClick"
                        Style="cursor: pointer;"
                        EmptyText="@RadzenRuStrings.EmptyText">
            <Columns>
                <RadzenDataGridColumn TItem="OrderTransaction" Property="Name" Title="Документ" Width="220px" />
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Целевой статус" Width="180px">
                    <Template Context="t">
                        @t.ToSystemStatus?.Name
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Правил цен" Width="90px" TextAlign="TextAlign.Center">
                    <Template Context="t">
                        @(t.Rules?.Count ?? 0)
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="OrderTransaction" Title="Правил полей" Width="100px" TextAlign="TextAlign.Center">
                    <Template Context="t">
                        @(t.FieldRules?.Count ?? 0)
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenStack>
}

@code {
    [Parameter] public Guid OrderId { get; set; }
    [Parameter] public Guid? CurrentSystemStatusId { get; set; }

    private TenantDbContext? _db;
    private bool _loading = true;
    private List<OrderTransaction> _transactions = [];
    private string? _currentStatusName;
    private TransactionApplyPreview? _preview;
    private Guid? _selectedTransactionId;
    private Dictionary<Guid, decimal> _userValues = [];
    private Dictionary<Guid, string> _fieldUserValues = [];
    private List<OrderStatus> _orderStatuses = [];
    private List<Product> _products = [];
    private List<Supplier> _suppliers = [];
    private List<Warehouse> _warehouses = [];
    private List<DeliveryMethod> _deliveryMethods = [];
    private List<Recipient> _recipients = [];
    private List<Address> _addresses = [];
    private List<WarehouseInfo> _warehouseInfos = [];
    private List<OrderProductInfo> _orderProductInfos = [];

    protected override async Task OnInitializedAsync()
    {
        _db = Factory.CreateDbContext();

        if (CurrentSystemStatusId.HasValue)
        {
            var status = await _db.OrderStatuses
                .AsNoTracking()
                .FirstOrDefaultAsync(s => s.Id == CurrentSystemStatusId.Value);
            _currentStatusName = status?.Name;

            _transactions = await _db.OrderTransactions
                .Include(t => t.FromSystemStatus)
                .Include(t => t.ToSystemStatus)
                .Include(t => t.Rules)
                .Include(t => t.FieldRules)
                .Where(t => !t.IsDeleted && t.IsEnabled && t.FromSystemStatusId == CurrentSystemStatusId.Value)
                .OrderBy(t => t.Name)
                .AsNoTracking()
                .ToListAsync();
        }

        _loading = false;
    }

    private async Task OnRowClick(DataGridRowMouseEventArgs<OrderTransaction> args)
    {
        var t = args.Data;
        if (t == null) return;

        _loading = true;
        StateHasChanged();

        _preview = await TransactionService.GetApplyPreviewAsync(OrderId, t.Id);
        _selectedTransactionId = t.Id;

        if (_preview != null)
        {
            _userValues = _preview.Rules
                .Where(r => r.RequiresUserInput)
                .ToDictionary(r => r.RuleId, _ => 0m);
            _fieldUserValues = _preview.FieldRules
                .Where(r => r.RequiresUserInput)
                .ToDictionary(r => r.RuleId, _ => string.Empty);
            await LoadReferenceDataAsync(_preview.FieldRules.Where(r => r.RequiresUserInput));
        }

        _loading = false;
        StateHasChanged();
    }

    private async Task LoadReferenceDataAsync(IEnumerable<TransactionApplyFieldRulePreview> fieldRules)
    {
        if (_db == null) return;
        var refTypes = fieldRules.Select(f => f.ReferenceType).Distinct().ToList();
        if (refTypes.Contains(FieldReferenceType.OrderStatus))
            _orderStatuses = await _db.OrderStatuses.Where(s => !s.IsDeleted).OrderBy(s => s.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.Product))
            _products = await _db.Products.Where(p => !p.IsDeleted).OrderBy(p => p.Article).Take(1000).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.Supplier))
            _suppliers = await _db.Suppliers.Where(s => !s.IsDeleted).OrderBy(s => s.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.Warehouse))
            _warehouses = await _db.Warehouses.Where(w => !w.IsDeleted).OrderBy(w => w.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.DeliveryMethod))
            _deliveryMethods = await _db.DeliveryMethods.Where(d => !d.IsDeleted).OrderBy(d => d.Name).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.Recipient))
            _recipients = await _db.Recipients.OrderBy(r => r.Name).Take(500).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.Address))
            _addresses = await _db.Addresses.Take(500).AsNoTracking().ToListAsync();
        if (refTypes.Contains(FieldReferenceType.WarehouseInfo))
            _warehouseInfos = await _db.WarehouseInfos
                .Include(wi => wi.RecipientWarehouse)
                .Include(wi => wi.SenderWarehouse)
                .OrderBy(wi => wi.Id)
                .Take(500)
                .AsNoTracking()
                .ToListAsync();
        if (refTypes.Contains(FieldReferenceType.OrderProductInfo))
            _orderProductInfos = await _db.OrderProductInfos
                .Include(opi => opi.Product)
                .Where(opi => !opi.IsDeleted)
                .OrderBy(opi => opi.Product != null ? opi.Product.Article : "")
                .Take(500)
                .AsNoTracking()
                .ToListAsync();
    }

    private RenderFragment RenderFieldControl(TransactionApplyFieldRulePreview fr) => builder =>
    {
        var value = _fieldUserValues.GetValueOrDefault(fr.RuleId) ?? "";
        if (fr.ReferenceType != FieldReferenceType.None && fr.ValueType == TransactionFieldValueType.Guid)
        {
            var items = GetReferenceItems(fr.ReferenceType);
            var currentGuid = Guid.TryParse(value, out var g) ? g : (Guid?)null;
            builder.OpenComponent<RadzenDropDown<Guid?>>(0);
            builder.AddAttribute(1, "Data", items);
            builder.AddAttribute(2, "ValueProperty", "Id");
            builder.AddAttribute(3, "TextProperty", GetReferenceTextProperty(fr.ReferenceType));
            builder.AddAttribute(4, "Value", currentGuid);
            builder.AddAttribute(5, "ValueChanged", EventCallback.Factory.Create<Guid?>(this, v => SetFieldValue(fr.RuleId, v?.ToString() ?? "")));
            builder.AddAttribute(6, "Style", "width: 240px;");
            builder.AddAttribute(7, "Placeholder", "Выберите...");
            builder.AddAttribute(8, "AllowClear", true);
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueType.DateTime)
        {
            var dt = DateTime.TryParse(value, out var d) ? d : (DateTime?)null;
            builder.OpenComponent<RadzenDatePicker<DateTime?>>(0);
            builder.AddAttribute(1, "Value", dt);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<DateTime?>(this, v => SetFieldValue(fr.RuleId, v?.ToString("yyyy-MM-dd") ?? "")));
            builder.AddAttribute(3, "Style", "width: 180px;");
            builder.AddAttribute(4, "Placeholder", "гггг-мм-дд");
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueType.Int)
        {
            var n = int.TryParse(value, out var v) ? v : (int?)null;
            builder.OpenComponent<RadzenNumeric<int?>>(0);
            builder.AddAttribute(1, "Value", n);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<int?>(this, v => SetFieldValue(fr.RuleId, v?.ToString() ?? "")));
            builder.AddAttribute(3, "Style", "width: 120px;");
            builder.AddAttribute(4, "Format", "D0");
            builder.AddAttribute(5, "Placeholder", "Число");
            builder.CloseComponent();
        }
        else if (fr.ValueType == TransactionFieldValueType.Decimal)
        {
            var n = decimal.TryParse(value, out var v) ? v : (decimal?)null;
            builder.OpenComponent<RadzenNumeric<decimal?>>(0);
            builder.AddAttribute(1, "Value", n);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<decimal?>(this, v => SetFieldValue(fr.RuleId, v?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")));
            builder.AddAttribute(3, "Style", "width: 120px;");
            builder.AddAttribute(4, "Format", "N2");
            builder.AddAttribute(5, "Placeholder", "Число");
            builder.CloseComponent();
        }
        else
        {
            builder.OpenComponent<RadzenTextBox>(0);
            builder.AddAttribute(1, "Value", value);
            builder.AddAttribute(2, "ValueChanged", EventCallback.Factory.Create<string>(this, v => SetFieldValue(fr.RuleId, v ?? "")));
            builder.AddAttribute(3, "Style", "width: 200px;");
            builder.AddAttribute(4, "Placeholder", "Значение");
            builder.CloseComponent();
        }
    };

    private void SetFieldValue(Guid ruleId, string value)
    {
        _fieldUserValues[ruleId] = value;
        StateHasChanged();
    }

    private object GetReferenceItems(FieldReferenceType refType) => refType switch
    {
        FieldReferenceType.OrderStatus => _orderStatuses.Select(s => new { s.Id, Name = s.Name ?? "" }).ToList(),
        FieldReferenceType.Product => _products.Select(p => new { p.Id, Name = $"{p.Article} — {p.Name}" }).ToList(),
        FieldReferenceType.Supplier => _suppliers.Select(s => new { s.Id, Name = s.Name ?? "" }).ToList(),
        FieldReferenceType.Warehouse => _warehouses.Select(w => new { w.Id, Name = w.Name ?? "" }).ToList(),
        FieldReferenceType.WarehouseInfo => _warehouseInfos.Select(wi => new { wi.Id, Name = $"{wi.SenderWarehouse?.Name ?? "—"} → {wi.RecipientWarehouse?.Name ?? "—"}" }).ToList(),
        FieldReferenceType.DeliveryMethod => _deliveryMethods.Select(d => new { d.Id, Name = d.Name ?? "" }).ToList(),
        FieldReferenceType.OrderProductInfo => _orderProductInfos.Select(opi => new { opi.Id, Name = $"{opi.Product?.Article ?? "—"} — {opi.Product?.Name ?? ""}" }).ToList(),
        FieldReferenceType.Recipient => _recipients.Select(r => new { r.Id, Name = r.Name ?? "" }).ToList(),
        FieldReferenceType.Address => _addresses.Select(a => new { a.Id, Name = $"{a.City} {a.Street}".Trim() }).ToList(),
        _ => Array.Empty<object>()
    };

    private static string GetReferenceTextProperty(FieldReferenceType refType) => "Name";

    private void BackToSelect()
    {
        _preview = null;
        _selectedTransactionId = null;
        _userValues = [];
        _fieldUserValues = [];
    }

    private List<string> GetValidationErrors()
    {
        if (_preview == null) return [];
        var errors = new List<string>();
        foreach (var rule in _preview.Rules.Where(r => r.RequiresUserInput && r.IsRequired))
        {
            if (!_userValues.ContainsKey(rule.RuleId))
                errors.Add(rule.PriceTypeName);
        }
        foreach (var fr in _preview.FieldRules.Where(r => r.RequiresUserInput && r.IsRequired))
        {
            var value = _fieldUserValues.GetValueOrDefault(fr.RuleId) ?? "";
            if (IsFieldValueEmpty(value, fr.ValueType))
                errors.Add(fr.DisplayName);
        }
        return errors;
    }

    private static bool IsFieldValueEmpty(string value, TransactionFieldValueType valueType)
    {
        if (string.IsNullOrWhiteSpace(value)) return true;
        return valueType switch
        {
            TransactionFieldValueType.Guid => !Guid.TryParse(value.Trim(), out var g) || g == Guid.Empty,
            TransactionFieldValueType.DateTime => !DateTime.TryParse(value, out _),
            TransactionFieldValueType.Int => !int.TryParse(value, out _),
            TransactionFieldValueType.Decimal => !decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out _),
            _ => false
        };
    }

    private async Task ApplyAsync()
    {
        if (!_selectedTransactionId.HasValue) return;

        var validationErrors = GetValidationErrors();
        if (validationErrors.Count > 0)
        {
            await DialogService.OpenAsync<TransactionErrorDialog>(
                "Ошибка валидации",
                new Dictionary<string, object?>
                {
                    [nameof(TransactionErrorDialog.Title)] = "Ошибка валидации",
                    [nameof(TransactionErrorDialog.Message)] = "Не заполнены обязательные поля. Заполните все поля, отмеченные звёздочкой (*).",
                    [nameof(TransactionErrorDialog.ValidationErrors)] = validationErrors
                });
            return;
        }

        var result = await TransactionService.ApplyAsync(OrderId, _selectedTransactionId.Value, _userValues, _fieldUserValues);
        if (result.Success)
        {
            var msg = result.PricesUpdated > 0 || result.FieldsUpdated > 0
                ? $"Обновлено цен: {result.PricesUpdated}, полей: {result.FieldsUpdated}"
                : "Статус изменён";
            NotificationService.Notify(NotificationSeverity.Success, "Документ проведён", msg);
            DialogService.Close(true);
        }
        else
        {
            await DialogService.OpenAsync<TransactionErrorDialog>(
                "Ошибка проведения документа",
                new Dictionary<string, object?>
                {
                    [nameof(TransactionErrorDialog.Title)] = "Ошибка проведения документа",
                    [nameof(TransactionErrorDialog.Message)] = result.ErrorMessage ?? "Не удалось провести документ",
                    [nameof(TransactionErrorDialog.ValidationErrors)] = result.ValidationErrors
                });
        }
    }

    public void Dispose() => _db?.Dispose();

    private static string GetPriceColor(decimal? value) =>
        value is null || value < 0 ? "color: var(--rz-danger);" : "";
}
