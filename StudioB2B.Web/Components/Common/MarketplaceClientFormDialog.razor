<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@Model">
            <DataAnnotationsValidator />

            <MudTextField T="string" Label="Название" @bind-Value="Model.Name"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                          FullWidth="true" />

            <MudTextField T="string" Label="API Id" @bind-Value="Model.ApiId"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                          FullWidth="true" />

            <MudTextField T="string" Label="Key" @bind-Value="Model.Key"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3"
                          FullWidth="true" />

            <MudSelect T="Guid?" Label="Тип клиента" @bind-Value="Model.ClientTypeId" Class="mb-3"
                       Dense="true" DisableUnderLine="true">
                <MudSelectItem T="Guid?" Value="@(null as Guid?)">— не задан</MudSelectItem>
                @foreach (var t in ClientTypes)
                {
                    <MudSelectItem T="Guid?" Value="t.Id">@t.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="Guid?" Label="Режим" @bind-Value="Model.ModeId" Class="mb-3"
                       Dense="true" DisableUnderLine="true">
                <MudSelectItem T="Guid?" Value="@(null as Guid?)">— не задан</MudSelectItem>
                @foreach (var m in Modes)
                {
                    <MudSelectItem T="Guid?" Value="m.Id">@m.Name</MudSelectItem>
                }
            </MudSelect>

            <!-- additional fields could be added here -->
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = "Клиент";
    [Parameter] public MarketplaceClientFormModel Model { get; set; } = new();
    [Parameter] public List<MarketplaceClientTypeDto> ClientTypes { get; set; } = new();
    [Parameter] public List<MarketplaceClientModeDto> Modes { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
            return;
        MudDialog.Close(DialogResult.Ok(Model));
    }
}